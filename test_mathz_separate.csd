yeet "mathz"
yeet "vibez"

slay test_abs() {
    sus x drip = -5.5
    sus result drip = mathz.abs_normie(x)
    vibez.spill("Abs test completed")
}

slay test_max() {
    sus a drip = 10.0
    sus b drip = 20.0
    sus result drip = mathz.max_normie(a, b)
    vibez.spill("Max test completed")
}

slay main_character() {
    test_abs()
    test_max()
    vibez.spill("All tests completed")
}
