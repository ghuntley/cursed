yeet "vibez"

slay fibonacci(n normie) -> normie {
    bestie (n <= 1) {
        damn n
    }
    damn fibonacci(n - 1) + fibonacci(n - 2)
}

slay main() {
    vibez.spill("=== Syntax Test ===")
    
    sus result := fibonacci(5)
    vibez.spill("Fibonacci(5): " + result)
    
    vibez.spill("=== Test Complete ===")
}
