vibe test

slay main() {
    fr fr Test traditional if statement
    lowkey 5 > 0 {
        vibez.spill("traditional if works")
    }

    fr fr Test new if statement with prefix
    lowkey x := 42; x > 0 {
        vibez.spill("if with prefix works")
        vibez.spill(x)
    }

    fr fr Test more complex prefix
    lowkey y := 10 * 2; y > 15 {
        vibez.spill("complex prefix works")
        vibez.spill(y)
    }
}
