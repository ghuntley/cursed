slay demo_usage_examples() cringe {
    vibez.spill("")
    vibez.spill("💡 Usage Examples:")
    vibez.spill("==================")
    
    vibez.spill("🧠 Neural Network Creation:")
    vibez.spill("   sus network = neural_network_create(0.001, OPTIMIZER_ADAM())")
    vibez.spill("   sus layer1 = layer_create_dense(784, 128, ACTIVATION_RELU())")
    vibez.spill("   network = neural_network_add_layer(network, layer1)")
    
    vibez.spill("📈 Training:")
    vibez.spill("   sus loss = neural_network_train_epoch(network, data, labels, ...)")
    vibez.spill("   sus accuracy = neural_network_evaluate(network, test_data, ...)")
    
    vibez.spill("🎯 Clustering:")
    vibez.spill("   sus centroids, assignments = kmeans_cluster(data, samples, features, k, iterations)")
    
    vibez.spill("🤖 Q-Learning:")
    vibez.spill("   sus agent = q_learning_agent_create(states, actions, lr, gamma, epsilon)")
    vibez.spill("   sus action = q_learning_choose_action(agent, state)")
}

fr fr === MAIN EXECUTION ===

demo_ml_fundamentals()
demo_ml_algorithms()
demo_ml_features()
demo_usage_examples()

vibez.spill("")
