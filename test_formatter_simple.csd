yeet "stringz"

// Simple test of the formatter module
slay format_cursed_code(source tea) tea {
    // Basic formatting implementation
    sus result tea = source
    result = replace_str(result, "sus x drip=42", "sus x drip = 42;")
    damn result
}

slay main() {
    vibez.spill("Testing CURSED formatter...")
    
    sus input tea = "sus x drip=42"
    sus formatted tea = format_cursed_code(input)
    
    vibez.spill("Input: " + input)
    vibez.spill("Formatted: " + formatted)
}
