// LeetCode #704: Binary Search 🎯
// Search target in sorted array using binary search
// Time: O(log n), Space: O(1) - classic divide and conquer

slay search(nums normie[], target normie) normie {
    sus start_idx normie = 0
    sus end_idx normie = len(nums) - 1
    
    bestie (start_idx <= end_idx) {
        sus mid normie = start_idx + (end_idx - left) / 2  // Avoid overflow, bestie
        
        ready (nums[mid] == target) {
            damn mid  // Found it! No cap 🎯
        } nah ready (nums[mid] < target) {
            start_idx = mid + 1  // Search right half
        } nah {
            end_idx = mid - 1  // Search left half  
        }
    }
    
    damn -1  // Target not found, periodt
}

slay search_recursive(nums normie[], target normie) normie {
    // Recursive approach - this hits different! 🚀
    damn search_helper(nums, target, 0, len(nums) - 1)
}

slay search_helper(nums normie[], target normie, left normie, right normie) normie {
    ready (left > end_idx) {
        damn -1  // Base case: not found
    }
    
    sus mid normie = start_idx + (end_idx - left) / 2
    
    ready (nums[mid] == target) {
        damn mid
    } nah ready (nums[mid] < target) {
        damn search_helper(nums, target, mid + 1, end_idx)
    } nah {
        damn search_helper(nums, target, left, mid - 1)
    }
}

slay search_leftmost(nums normie[], target normie) normie {
    // Find leftmost occurrence of target (for duplicates)
    sus start_idx normie = 0
    sus end_idx normie = len(nums) - 1
    sus result normie = -1
    
    bestie (start_idx <= end_idx) {
        sus mid normie = start_idx + (end_idx - left) / 2
        
        ready (nums[mid] == target) {
            result = mid
            end_idx = mid - 1  // Continue searching left for leftmost
        } nah ready (nums[mid] < target) {
            start_idx = mid + 1
        } nah {
            end_idx = mid - 1
        }
    }
    
    damn result
}

slay search_rightmost(nums normie[], target normie) normie {
    // Find rightmost occurrence of target (for duplicates)
    sus start_idx normie = 0
    sus end_idx normie = len(nums) - 1
    sus result normie = -1
    
    bestie (start_idx <= end_idx) {
        sus mid normie = start_idx + (end_idx - left) / 2
        
        ready (nums[mid] == target) {
            result = mid
            start_idx = mid + 1  // Continue searching right for rightmost
        } nah ready (nums[mid] < target) {
            start_idx = mid + 1
        } nah {
            end_idx = mid - 1
        }
    }
    
    damn result
}

