fr fr Simple stdlib runtime test
yeet "testz"
yeet "vibez"
yeet "mathz"

test_start("Basic stdlib runtime functionality")

fr fr Test vibez module
vibez.spill("Testing CURSED stdlib runtime execution")
assert_true(based)

fr fr Test mathz module
sus result drip = mathz.math_add(21, 21)
assert_eq_int(result, 42)

fr fr Test mathematical operations
sus sqrt_result meal = mathz.sqrt_meal(16.0)
assert_eq_float(sqrt_result, 4.0)

print_test_summary()
