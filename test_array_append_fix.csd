vibe main
yeet "vibez"
yeet "mathz"

slay main_character() {
    vibez.spill("Starting array test")
    sus big_array []normie = []normie{}
    vibez.spill("Initial array created")
    big_array = append(big_array, 100)
    vibez.spill("Added first element")
    big_array = append(big_array, 200)  
    vibez.spill("Added second element")
    big_array = append(big_array, 300)
    vibez.spill("Added third element")
    
    vibez.spill("arr_len:", len(big_array))
}

slay main() {
    main_character()
}
