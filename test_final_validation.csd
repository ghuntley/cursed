yeet "mathz"
yeet "stringz"
yeet "arrayz"

# Test module function calls work correctly
sus abs_value drip = mathz.abs_normie(-42)
vibez.spill("Absolute value of -42:", abs_value)

sus max_value drip = mathz.max_normie(15, 25)  
vibez.spill("Max of 15 and 25:", max_value)

sus concat_value tea = stringz.concat_strings("Hello", "World")
vibez.spill("Concatenated string:", concat_value)

# Test that direct calls still work
mathz.abs_normie(-100)
stringz.concat_strings("Direct", "Call")

vibez.spill("All tests completed successfully!")
