vibe main
yeet "vibez"

slay main_character() {
    vibez.spill("Starting array test")
    sus arr []normie = []normie{}
    vibez.spill("Initial length:", len(arr))
    
    arr = append(arr, 42)
    vibez.spill("After 1 append:", len(arr))
    
    arr = append(arr, 100)
    vibez.spill("After 2 appends:", len(arr))
    
    arr = append(arr, 200)
    vibez.spill("After 3 appends:", len(arr))
}
