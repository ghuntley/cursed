fr fr Basic test for Pure CURSED Standard Library Migration

yeet "mathz"
yeet "stringz" 
yeet "arrayz"

vibez.spill("=== Pure CURSED Standard Library Test ===")

fr fr Test basic math functions
vibez.spill("Math: abs_normie(-42) =", abs_normie(-42))
vibez.spill("Math: max_normie(10, 20) =", max_normie(10, 20))
vibez.spill("Math: add_two(15, 25) =", add_two(15, 25))

fr fr Test string functions
vibez.spill("String: concat_strings works =", concat_strings("hello", "world"))
vibez.spill("String: to_uppercase works =", to_uppercase("cursed"))

fr fr Test array functions
sus numbers []drip = [1, 2, 3]
vibez.spill("Array: sum_array([1,2,3]) =", sum_array(numbers))
vibez.spill("Array: find_max([1,2,3]) =", find_max(numbers))

vibez.spill("✅ Pure CURSED stdlib migration successful!")
