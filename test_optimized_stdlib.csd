# Test optimized stdlib modules
yeet "vibez"
yeet "mathz"
yeet "arrayz"

# Test basic functionality to ensure optimizations work
vibez.spill("🚀 Testing CURSED Stdlib Optimizations")

# Test mathematical operations
sus fib_result drip = mathz.math_fibonacci(10)
vibez.spillf("Fibonacci(10): {}", fib_result)

sus fact_result drip = mathz.math_factorial(5)
vibez.spillf("Factorial(5): {}", fact_result)

sus prime_result lit = mathz.math_is_prime(17)
vibez.spillf("Is 17 prime: {}", prime_result)

# Test array operations
sus test_array []drip = [3, 1, 4, 1, 5, 9]
vibez.spillf("Original array: {}", test_array)

sus sorted_array []drip = arrayz.sort_array(test_array)
vibez.spillf("Sorted array: {}", sorted_array)

# Test string operations
sus greeting tea = "Hello"
sus world tea = "World"
sus combined tea = greeting + " " + world
vibez.spillf("Combined string: {}", combined)

vibez.spill("✅ All stdlib optimization tests completed successfully!")
