<T> MyTrait for T {\n    fn get(&self) -> usize { 0 }\n}\n\nstruct Foo;\n\nfn main() {\n    let f = Foo;\n\n    f.get(); // the trait is implemented so we can use it\n}\n```\n"},"level":"error","message":"conflicting implementations of trait `std::fmt::Display` for type `performance::CompilationPhase`","spans":[{"byte_end":74920,"byte_start":74877,"column_end":44,"column_start":1,"expansion":null,"file_name":"src/optimization/real_compilation_profiler.rs","is_primary":false,"label":"first implementation here","line_end":2284,"line_start":2284,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":44,"highlight_start":1,"text":"impl std::fmt::Display for CompilationPhase {"}]},{"byte_end":742,"byte_start":709,"column_end":34,"column_start":1,"expansion":null,"file_name":"src/profiling/performance.rs","is_primary":true,"label":"conflicting implementation for `performance::CompilationPhase`","line_end":27,"line_start":27,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":34,"highlight_start":1,"text":"impl Display for CompilationPhase {"}]}]}}
