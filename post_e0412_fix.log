se `Rc` and `RefCell`:\n\n```\nuse std::cell::RefCell;\nuse std::rc::Rc;\n\nstruct MyStruct { s: u32 }\n\nfn main() {\n    let mut x = Rc::new(RefCell::new(MyStruct{ s: 5u32 }));\n    let y = x.clone();\n    x.borrow_mut().s = 6;\n    println!(\"{}\", x.borrow().s);\n}\n```\n\nWith this approach, x and y share ownership of the data via the `Rc` (reference\ncount type). `RefCell` essentially performs runtime borrow checking: ensuring\nthat at most one writer or multiple readers can access the data at any one time.\n\nIf you wish to learn more about ownership in Rust, start with the\n[Understanding Ownership][understanding-ownership] chapter in the Book.\n\n[understanding-ownership]: https://doc.rust-lang.org/book/ch04-00-understanding-ownership.html\n"},"level":"error","message":"borrow of partially moved value: `ir_gen_result`","spans":[{"byte_end":18377,"byte_start":18352,"column_end":51,"column_start":26,"expansion":null,"file_name":"src/optimization/real_performance_analyzer.rs","is_primary":false,"label":"value partially moved here","line_end":586,"line_start":586,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":51,"highlight_start":26,"text":"            bottlenecks: ir_gen_result.bottlenecks,"}]},{"byte_end":18455,"byte_start":18441,"column_end":77,"column_start":63,"expansion":null,"file_name":"src/optimization/real_performance_analyzer.rs","is_primary":true,"label":"value borrowed here after partial move","line_end":587,"line_start":587,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":77,"highlight_start":63,"text":"            efficiency_score: self.calculate_efficiency_score(&ir_gen_result),"}]}]}}
