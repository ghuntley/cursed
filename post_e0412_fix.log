utDebug;\n    // some_func(WithoutDebug);\n}\n```\n\nRust only looks at the signature of the called function, as such it must\nalready specify all requirements that will be used for every type parameter.\n"},"level":"error","message":"`P` cannot be sent between threads safely","spans":[{"byte_end":12617,"byte_start":12509,"column_end":14,"column_start":31,"expansion":null,"file_name":"src/stdlib/async/io.rs","is_primary":true,"label":"`P` cannot be sent between threads safely","line_end":458,"line_start":455,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":40,"highlight_start":31,"text":"            spawn_blocking_io(move || {"},{"highlight_end":46,"highlight_start":1,"text":"                let file = File::open(path)?;"},{"highlight_end":39,"highlight_start":1,"text":"                Ok(AsyncFile { file })"},{"highlight_end":14,"highlight_start":1,"text":"            }).await"}]},{"byte_end":12516,"byte_start":12509,"column_end":38,"column_start":31,"expansion":null,"file_name":"src/stdlib/async/io.rs","is_primary":false,"label":"within this `{closure@src/stdlib/async/io.rs:455:31: 455:38}`","line_end":455,"line_start":455,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":38,"highlight_start":31,"text":"            spawn_blocking_io(move || {"}]},{"byte_end":12508,"byte_start":12491,"column_end":30,"column_start":13,"expansion":null,"file_name":"src/stdlib/async/io.rs","is_primary":false,"label":"required by a bound introduced by this call","line_end":455,"line_start":455,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":30,"highlight_start":13,"text":"            spawn_blocking_io(move || {"}]}]}}
