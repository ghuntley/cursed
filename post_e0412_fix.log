_func(WithoutDebug);\n}\n```\n\nRust only looks at the signature of the called function, as such it must\nalready specify all requirements that will be used for every type parameter.\n"},"level":"error","message":"`P` cannot be sent between threads safely","spans":[{"byte_end":13274,"byte_start":13164,"column_end":14,"column_start":31,"expansion":null,"file_name":"src/stdlib/async/io.rs","is_primary":true,"label":"`P` cannot be sent between threads safely","line_end":478,"line_start":475,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":40,"highlight_start":31,"text":"            spawn_blocking_io(move || {"},{"highlight_end":48,"highlight_start":1,"text":"                let file = options.open(path)?;"},{"highlight_end":39,"highlight_start":1,"text":"                Ok(AsyncFile { file })"},{"highlight_end":14,"highlight_start":1,"text":"            }).await"}]},{"byte_end":13171,"byte_start":13164,"column_end":38,"column_start":31,"expansion":null,"file_name":"src/stdlib/async/io.rs","is_primary":false,"label":"within this `{closure@src/stdlib/async/io.rs:475:31: 475:38}`","line_end":475,"line_start":475,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":38,"highlight_start":31,"text":"            spawn_blocking_io(move || {"}]},{"byte_end":13163,"byte_start":13146,"column_end":30,"column_start":13,"expansion":null,"file_name":"src/stdlib/async/io.rs","is_primary":false,"label":"required by a bound introduced by this call","line_end":475,"line_start":475,"suggested_replacement":null,"suggestion_applicability":null,"text":[{"highlight_end":30,"highlight_start":13,"text":"            spawn_blocking_io(move || {"}]}]}}
