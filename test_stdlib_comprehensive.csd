yeet "vibez"
yeet "mathz" 
yeet "stringz"

slay main() {
    vibez.spill("=== CURSED Standard Library Comprehensive Test ===")
    
    // Test vibez module
    vibez.spill("Testing vibez module...")
    vibez.spill("Output test: ", "success!")
    
    // Test mathz module  
    vibez.spill("Testing mathz module...")
    sus pi_value drip = mathz.PI
    sus sqrt_val drip = mathz.sqrt(16)
    vibez.spill("PI value:", pi_value, "sqrt(16):", sqrt_val)
    
    // Test stringz module
    vibez.spill("Testing stringz module...")
    sus text tea = "Hello World"
    sus length drip = stringz.len_string(text)
    vibez.spill("String:", text, "Length:", length)
    
    vibez.spill("=== All stdlib modules tested successfully! ===")
}
