// Array module import and operations
yeet "arrayz"

sus numbers []drip = [5, 2, 8, 1, 9]
sus length drip = len(numbers)
sus sorted []drip = sort_drip(numbers)
sus reversed []drip = reverse_drip(numbers)
sus sum drip = sum_drip(numbers)
sus contains lit = contains_drip(numbers, 8)

vibez.spill("length:", length)
vibez.spill("sum:", sum)
vibez.spill("contains 8:", contains)
