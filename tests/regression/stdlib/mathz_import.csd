// Math module import and basic functions
yeet "mathz"

sus result1 drip = abs_normie(-42)
sus result2 drip = max_drip(10, 20)
sus result3 drip = min_drip(5, 15)
sus result4 normie = sqrt_normie(16.0)
sus result5 drip = pow_drip(2, 8)

vibez.spill("abs(-42):", result1)
vibez.spill("max(10,20):", result2)
vibez.spill("min(5,15):", result3)
vibez.spill("sqrt(16):", result4)
vibez.spill("pow(2,8):", result5)
