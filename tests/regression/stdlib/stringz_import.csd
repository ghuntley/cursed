// String module import and operations
yeet "stringz"

sus text tea = "Hello World"
sus length drip = len_str(text)
sus upper tea = to_upper(text)
sus lower tea = to_lower(text)
sus trimmed tea = trim_str("  spaced  ")
sus contains lit = contains_str(text, "World")

vibez.spill("length:", length)
vibez.spill("upper:", upper)
vibez.spill("lower:", lower)
vibez.spill("trimmed:", trimmed)
vibez.spill("contains World:", contains)
