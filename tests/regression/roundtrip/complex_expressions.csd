// Complex expressions for round-trip parsing
sus complex_calc drip = ((5 + 3) * 2 - 1) / (10 % 3) + abs_normie(-7)

sus boolean_logic lit = (x > 5 && y < 10) || (z == 15 && w != 20)

sus nested_calls drip = max_drip(
    min_drip(a, b) + c,
    pow_drip(d, 2) - sqrt_normie(e)
)

sus array_expr []drip = [
    1 + 2,
    3 * 4,
    5 - 6,
    7 / 8
]

sus conditional drip = ready (condition) ? value_if_true : value_if_false

sus string_interpolation tea = "Result: " + to_str_drip(complex_calc) + " (completed)"
