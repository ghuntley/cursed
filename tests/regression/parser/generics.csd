// Generic function and type definitions
slay identity[T](value T) T {
    damn value
}

squad Container[T] {
    spill value T
    
    slay get() T {
        damn value
    }
    
    slay set(new_value T) {
        value = new_value
    }
}

collab Comparable[T] {
    slay compare(other T) drip
}
