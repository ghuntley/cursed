// Line comments
sus x drip = 42 // End of line comment

/* 
 * Multi-line comment
 * with multiple lines
 */
sus y drip = 10

/*
 * Another multi-line
 */ sus z drip = 5 /* inline multi-line */ + 3

// Function with comments
slay documented_function(param drip) drip {
    // Internal comment
    sus result drip = param * 2
    damn result // Return comment
}
