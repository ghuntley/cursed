fr fr Simple test file for basic types in CURSED

fr fr Boolean type (lit)
sus bool_val = based;

fr fr Integer type (normie)
sus int_val = 42;

fr fr Float type (snack)
sus float_val = 3.14;

fr fr String type (tea)
sus str_val = "Hello, CURSED!";

fr fr Character type (sip)
sus char_val = 'C';

fr fr Print all values to verify
puts("Boolean:")
puts(bool_val)

puts("Integer:")
puts(int_val)

puts("Float:")
puts(float_val)

puts("String:")
puts(str_val)

puts("Character:")
puts(char_val)