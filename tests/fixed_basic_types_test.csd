fr fr Demonstrating all basic types for JIT testing

sus normie_val = 42;  fr fr Integer
sus thicc_val = 100000000000;  fr fr Int64
sus meal_val = 3.14;  fr fr Float64
sus literal_val = "Hello, CURSED!";  fr fr String
sus sip_val = 'C';  fr fr Character
sus is_true = based;  fr fr Boolean true

slay main() {
    puts(is_true);  fr fr Should be true (1)
    puts(normie_val);  fr fr Should be 42
    puts(meal_val);  fr fr Should be 3.14
    puts(literal_val);  fr fr Should be "Hello, CURSED!"
    puts(sip_val);  fr fr Should be 'C'
    yolo 0;
}