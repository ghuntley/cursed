vibe main

yeet "vibez"

slay test_vibez_spill() {
    // Test basic string output
    vibez.spill("This is a test message");
    
    // Test multiple calls
    vibez.spill("First message");
    vibez.spill("Second message");
    
    // Test with special characters
    vibez.spill("Special chars: !@#$%^&*()");
    
