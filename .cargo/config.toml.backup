# Linux-specific configuration - Force ld linker instead of mold and fix library paths
[target.x86_64-unknown-linux-gnu]
linker = "gcc"
rustflags = [
    "-C", "linker=gcc",
    "-C", "link-arg=-fuse-ld=ld",
    "-C", "link-arg=-Wl,--disable-new-dtags",
    "-C", "link-arg=-Wl,-Bdynamic",
    "-C", "link-arg=-L/nix/store/6pak77li0iw9x0b3yhmbjvp846w3p6bx-libffi-3.4.6/lib",
    "-C", "link-arg=-Wl,-rpath,/nix/store/6pak77li0iw9x0b3yhmbjvp846w3p6bx-libffi-3.4.6/lib",
    "-C", "link-arg=-L/nix/store/k3a7dzrqphj9ksbb43i24vy6inz8ys51-ncurses-6.4.20221231/lib",
    "-C", "link-arg=-Wl,-rpath,/nix/store/k3a7dzrqphj9ksbb43i24vy6inz8ys51-ncurses-6.4.20221231/lib",
    "-C", "link-arg=-L/nix/store/0z4hrksbdrwv9xb8ycjk3rq9ppmw0350-libxml2-2.13.5/lib",
    "-C", "link-arg=-Wl,-rpath,/nix/store/0z4hrksbdrwv9xb8ycjk3rq9ppmw0350-libxml2-2.13.5/lib",
    "-C", "link-arg=-lffi",
    "-C", "link-arg=-ltinfo",
    "-C", "link-arg=-lxml2",
]

[build]
rustflags = [
    "-C", "linker=gcc",
    "-C", "link-arg=-fuse-ld=ld",
    "-C", "link-arg=-Wl,--disable-new-dtags",
    "-C", "link-arg=-Wl,-Bdynamic",
    "-C", "link-arg=-L/nix/store/6pak77li0iw9x0b3yhmbjvp846w3p6bx-libffi-3.4.6/lib",
    "-C", "link-arg=-Wl,-rpath,/nix/store/6pak77li0iw9x0b3yhmbjvp846w3p6bx-libffi-3.4.6/lib",
    "-C", "link-arg=-L/nix/store/k3a7dzrqphj9ksbb43i24vy6inz8ys51-ncurses-6.4.20221231/lib",
    "-C", "link-arg=-Wl,-rpath,/nix/store/k3a7dzrqphj9ksbb43i24vy6inz8ys51-ncurses-6.4.20221231/lib",
    "-C", "link-arg=-L/nix/store/0z4hrksbdrwv9xb8ycjk3rq9ppmw0350-libxml2-2.13.5/lib",
    "-C", "link-arg=-Wl,-rpath,/nix/store/0z4hrksbdrwv9xb8ycjk3rq9ppmw0350-libxml2-2.13.5/lib",
    "-C", "link-arg=-lffi",
    "-C", "link-arg=-ltinfo", 
    "-C", "link-arg=-lxml2",
]

# macOS-specific configuration  
[target.aarch64-apple-darwin]
rustflags = []

[target.x86_64-apple-darwin]
rustflags = []

# Environment variables for cross-platform builds
[env]
CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER = "gcc"
# Library paths will be provided by devenv.nix or system package managers
