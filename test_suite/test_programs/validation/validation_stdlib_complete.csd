vibe main

yeet "vibez"

fr fr Comprehensive stdlib validation test covering vibez output functionality
fr fr Tests vibez output functions with various data types
fr fr Validates consistent behavior across interpreter and compiled modes

slay main_character() {
    vibez.spill("=== Comprehensive Stdlib Validation ===")
    
    fr fr Test vibez module extensively with different types
    vibez.spill("Testing vibez.spill function")
    
    fr fr Test integer output
    vibez.spill("Integer test:")
    vibez.spill(42)
    vibez.spill(-17)
    vibez.spill(0)
    
    fr fr Test float output
    vibez.spill("Float test:")
    vibez.spill(3.14159)
    vibez.spill(-2.71828)
    vibez.spill(0.0)
    
    fr fr Test boolean output
    vibez.spill("Boolean test:")
    vibez.spill(based)
    vibez.spill(cringe)
    
    fr fr Test tea output
    vibez.spill("String test:")
    vibez.spill("Simple tea")
    vibez.spill("Complex tea with numbers: 123")
    vibez.spill("String with symbols: !@#$%")
    vibez.spill("")
    
    fr fr Test large numbers
    vibez.spill("Large number test:")
    vibez.spill(999999999)
    vibez.spill(-123456789)
    
    fr fr Test precision numbers
    vibez.spill("Precision test:")
    vibez.spill(123.456789)
    vibez.spill(0.000001)
    
    fr fr Test mathematical expressions output
    vibez.spill("Expression test:")
    sus calc_result normie = 10 + 20 * 3
    vibez.spill(calc_result)
    
    sus div_result meal = 22.0 / 7.0
    vibez.spill(div_result)
    
    vibez.spill("=== Stdlib Validation Complete ===")
    damn
}
