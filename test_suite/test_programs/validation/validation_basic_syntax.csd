vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== Basic Syntax Test ===")
    
    sus age drip = 25
    vibez.spill(age)
    
    sus name drip = "CURSED"
    vibez.spill(name)
    
    sus is_cool lit = based
    vibez.spill(is_cool)
    
    vibez.spill("=== Test Complete ===")
}
