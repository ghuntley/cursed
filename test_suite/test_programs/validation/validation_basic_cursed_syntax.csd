vibe main

yeet "vibez"

fr fr Basic CURSED Syntax Validation Test
fr fr Tests: Core language syntax elements and variable declarations
fr fr Expected: Demonstrates proper CURSED program structure

slay main_character() {
    vibez.spill("=== CURSED Syntax Validation ===")
    
    fr fr Test variable declarations with all types
    sus integer_var normie = 42
    sus float_var drip = 3.14
    sus string_var tea = "Hello CURSED"
    sus boolean_var lit = based
    
    vibez.spill("Integer variable:")
    vibez.spill(integer_var)
    
    vibez.spill("Float variable:")
    vibez.spill(float_var)
    
    vibez.spill("String variable:")
    vibez.spill(string_var)
    
    vibez.spill("Boolean variable (based):")
    vibez.spill(boolean_var)
    
    fr fr Test basic control flow
    ready (integer_var > 40) {
        vibez.spill("Conditional test passed")
    }
    
    vibez.spill("=== Syntax Test Complete ===")
}
