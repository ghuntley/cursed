vibe main_character

yeet "vibez"
yeet "mathz"
yeet "stringz"

fr fr Comprehensive CURSED Syntax Validation Test
fr fr Tests: All major language features with proper syntax
fr fr Expected: Identical behavior in interpreter and compiled modes

slay main_character() {
    vibez.spill("=== Comprehensive CURSED Syntax Test ===")
    
    fr fr Variable declarations with proper syntax
    sus number normie = 42
    sus text tea = "Hello, CURSED!"
    sus result normie = mathz.add_two(10, 15)
    
    vibez.spill("Number:")
    vibez.spill(number)
    vibez.spill("Text:")
    vibez.spill(text)
    vibez.spill("Math result:")
    vibez.spill(result)
    
    fr fr String operations
    sus greeting tea = stringz.concat("Welcome to ", "CURSED Language")
    sus length normie = stringz.length(greeting)
    
    vibez.spill("Greeting:")
    vibez.spill(greeting)
    vibez.spill("Length:")
    vibez.spill(length)
    
    fr fr Arithmetic expressions
    sus a normie = 5
    sus b normie = 3
    sus addition normie = a + b
    sus multiplication normie = a * b
    sus complex_expr normie = (a + b) * 2 - 1
    
    vibez.spill("Addition result:")
    vibez.spill(addition)
    vibez.spill("Multiplication result:")
    vibez.spill(multiplication)
    vibez.spill("Complex expression:")
    vibez.spill(complex_expr)
    
    fr fr Control flow
    ready number > 30 {
        vibez.spill("Number is greater than 30")
        sus doubled normie = number * 2
        vibez.spill("Doubled:")
        vibez.spill(doubled)
    } otherwise {
        vibez.spill("Number is 30 or less")
    }
    
    vibez.spill("=== Test Complete ===")
}
