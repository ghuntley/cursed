vibe main

fr fr Test: Basic arithmetic operations
fr fr Purpose: Test all arithmetic operators work correctly
fr fr Expected: All arithmetic should compute properly

slay main_character() {
    fr fr Integer arithmetic
    sus a drip = 10
    sus b drip = 3
    
    sus addition drip = a + b
    sus subtraction drip = a - b  
    sus multiplication drip = a * b
    sus division drip = a / b
    sus modulo drip = a % b
    
    fr fr Verify some known results
    sus result1 drip = 2 * 5 + 3
    sus result2 drip = (4 + 6) * 2
    sus result3 drip = 15 - 8 + 2
    
    fr fr Negative numbers
    sus negative drip = -42
    sus positive drip = 42
    sus sum drip = negative + positive
    
    damn 0
}
