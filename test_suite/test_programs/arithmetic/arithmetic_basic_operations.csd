vibe main;

yeet "vibez";

fr fr Test: Basic arithmetic operations
fr fr Purpose: Test all arithmetic operators work correctly
fr fr Expected: All arithmetic should compute properly

slay main_character() {
    fr fr Integer arithmetic
    sus a normie = 10;
    sus b normie = 3;
    
    sus addition normie = a + b;
    sus subtraction normie = a - b;
    sus multiplication normie = a * b;
    sus division normie = a / b;
    sus modulo normie = a % b;
    
    fr fr Verify some known results
    sus result1 normie = 2 * 5 + 3;
    sus result2 normie = (4 + 6) * 2;
    sus result3 normie = 15 - 8 + 2;
    
    fr fr Negative numbers
    sus negative normie = -42;
    sus positive normie = 42;
    sus sum normie = negative + positive;
    
    vibez.spill("All arithmetic operations completed successfully");
    
    damn;
}
