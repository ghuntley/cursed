vibe main

yeet "vibez"

fr fr Arithmetic Operations Feature Test
fr fr Tests: Complete arithmetic operations with proper precedence
fr fr Expected: Mathematical operations produce identical results

slay main_character() {
    vibez.spill("=== Arithmetic Operations Test ===")
    
    fr fr Basic arithmetic operations
    sus a normie = 10
    sus b normie = 3
    
    vibez.spill("Addition (10 + 3):")
    vibez.spill(a + b)
    
    vibez.spill("Subtraction (10 - 3):")
    vibez.spill(a - b)
    
    vibez.spill("Multiplication (10 * 3):")
    vibez.spill(a * b)
    
    vibez.spill("Division (10 / 3):")
    vibez.spill(a / b)
    
    fr fr Test operator precedence
    sus result1 normie = 2 + 3 * 4
    vibez.spill("Precedence test (2 + 3 * 4):")
    vibez.spill(result1)
    
    sus result2 normie = (2 + 3) * 4
    vibez.spill("Parentheses test ((2 + 3) * 4):")
    vibez.spill(result2)
    
    fr fr Complex expression
    sus complex normie = 15 - 2 * 3 + 8 / 4
    vibez.spill("Complex expression (15 - 2 * 3 + 8 / 4):")
    vibez.spill(complex)
    
    vibez.spill("=== Arithmetic Test Complete ===")
}
