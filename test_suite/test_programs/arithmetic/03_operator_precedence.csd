vibe main

yeet "vibez"

fr fr Operator Precedence Test
fr fr Tests: Mathematical operator precedence
fr fr Expected: Operations follow standard precedence rules

slay main_character() {
    vibez.spill("=== Operator Precedence Test ===")
    
    vibez.spill("2 + 3 * 4 should be 14:")
    vibez.spill(2 + 3 * 4)
    
    vibez.spill("(2 + 3) * 4 should be 20:")
    vibez.spill((2 + 3) * 4)
    
    vibez.spill("10 - 3 + 2 should be 9:")
    vibez.spill(10 - 3 + 2)
    
    vibez.spill("8 / 2 * 3 should be 12:")
    vibez.spill(8 / 2 * 3)
    
    vibez.spill("=== Test Complete ===")
}
