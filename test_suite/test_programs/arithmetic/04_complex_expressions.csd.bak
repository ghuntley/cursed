// Complex Expressions Test  
// Tests: Deeply nested arithmetic expressions
// Expected: Complex expressions evaluate correctly

fn main() {
    yap("=== Complex Expressions Test ===")
    
    let a = 2
    let b = 3
    let c = 4
    let d = 5
    
    yap("Complex expression 1:")
    yap(((a + b) * c) - ((d - a) / b))
    
    yap("Complex expression 2:")  
    yap(a * b + c / d - (a - b) * (c + d))
    
    yap("Complex expression 3:")
    yap((a + b * c) / (d - a) + b * (c - d))
    
    yap("=== Test Complete ===")
}
