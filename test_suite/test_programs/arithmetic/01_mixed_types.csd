vibe main_character

yeet "vibez"

fr fr Mixed Type Arithmetic Test
fr fr Tests: Integer and float arithmetic operations
fr fr Expected: Type handling should be consistent

slay main_character() {
    vibez.spill("=== Mixed Type Arithmetic Test ===")
    
    sus int_val normie = 10
    sus float_val meal = 3.5
    
    vibez.spill("Integer value:")
    vibez.spill(int_val)
    
    vibez.spill("Float value:")
    vibez.spill(float_val)
    
    vibez.spill("Integer + Integer:")
    vibez.spill(int_val + 5)
    
    vibez.spill("Float + Float:")
    vibez.spill(float_val + 2.5)
    
fr fr Test mixed operations if supported
    vibez.spill("Integer * 2:")
    vibez.spill(int_val * 2)
    
    vibez.spill("Float / 2:")
    vibez.spill(float_val / 2)
    
    vibez.spill("=== Test Complete ===")
}
