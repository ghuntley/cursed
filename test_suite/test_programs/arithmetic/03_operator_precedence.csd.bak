// Operator Precedence Test
// Tests: Mathematical operator precedence
// Expected: Operations follow standard precedence rules

fn main() {
    yap("=== Operator Precedence Test ===")
    
    yap("2 + 3 * 4 should be 14:")
    yap(2 + 3 * 4)
    
    yap("(2 + 3) * 4 should be 20:")
    yap((2 + 3) * 4)
    
    yap("10 - 3 + 2 should be 9:")
    yap(10 - 3 + 2)
    
    yap("8 / 2 * 3 should be 12:")
    yap(8 / 2 * 3)
    
    yap("=== Test Complete ===")
}
