vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== Complex Expressions Test ===")
    
    sus a drip = 2
    sus b drip = 3
    sus c drip = 4
    sus d drip = 5
    
    vibez.spill("Complex expression 1:")
    vibez.spill(((a + b) * c) - ((d - a) / b))
    
    vibez.spill("Complex expression 2:")  
    vibez.spill(a * b + c / d - (a - b) * (c + d))
    
    vibez.spill("Complex expression 3:")
    vibez.spill((a + b * c) / (d - a) + b * (c - d))
    
    vibez.spill("=== Test Complete ===")
}
