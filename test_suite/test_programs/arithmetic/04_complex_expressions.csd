vibe main_character

yeet "vibez"

slay main_character() {
    vibez.spill("=== Complex Expressions Test ===")
    
    sus a normie = 2
    sus b normie = 3
    sus c normie = 4
    sus d normie = 5
    
    vibez.spill("Complex expression 1:")
    sus expr1 meal = ((a + b) * c) - ((d - a) / b)
    vibez.spill(expr1)
    
    vibez.spill("Complex expression 2:")  
    sus expr2 meal = a * b + c / d - (a - b) * (c + d)
    vibez.spill(expr2)
    
    vibez.spill("Complex expression 3:")
    sus expr3 normie = (a + b * c) + (d - a) * b
    vibez.spill(expr3)
    
    vibez.spill("=== Test Complete ===")
}
