vibe main

yeet "vibez"

slay deep_recursion(n normie) {
    ready (n <= 0) {
        damn 0
    }
    damn 1 + deep_recursion(n - 1)
}

slay main_character() {
    vibez.spill("=== Recursive Depth Test ===")
    
    vibez.spill("Shallow recursion:")
    vibez.spill(deep_recursion(5))
    
    vibez.spill("Medium recursion:")
    vibez.spill(deep_recursion(10))
    
    vibez.spill("Deeper recursion:")
    vibez.spill(deep_recursion(50))
    
    vibez.spill("=== Test Complete ===")
}
