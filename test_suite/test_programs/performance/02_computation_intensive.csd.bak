// Computation Intensive Test
// Tests: Performance-heavy calculations
// Expected: Both modes produce same results (timing may differ)

fn fibonacci(n) {
    if (n <= 1) {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

fn sum_range(start, end) {
    let sum = 0
    let i = start
    while (i <= end) {
        sum = sum + i
        i = i + 1
    }
    return sum
}

fn main() {
    yap("=== Computation Intensive Test ===")
    
    yap("Fibonacci sequence:")
    yap(fibonacci(8))
    yap(fibonacci(10))
    
    yap("Sum of range:")
    yap(sum_range(1, 100))
    
    yap("=== Test Complete ===")
}
