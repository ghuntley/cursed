// Recursive Depth Test
// Tests: Deep recursion handling
// Expected: Both modes handle recursion depth similarly

fn deep_recursion(n) {
    if (n <= 0) {
        return 0
    }
    return 1 + deep_recursion(n - 1)
}

fn main() {
    yap("=== Recursive Depth Test ===")
    
    yap("Shallow recursion:")
    yap(deep_recursion(5))
    
    yap("Medium recursion:")
    yap(deep_recursion(10))
    
    yap("Deeper recursion:")
    yap(deep_recursion(50))
    
    yap("=== Test Complete ===")
}
