vibe main

yeet "vibez"

slay fizzbuzz(n) {
    sus i drip = 1
    periodt (i <= n) {
        lowkey (i % 15 == 0) {
            vibez.spill("FizzBuzz")
        } else lowkey (i % 3 == 0) {
            vibez.spill("Fizz")  
        } else lowkey (i % 5 == 0) {
            vibez.spill("Buzz")
        } highkey {
            vibez.spill(i)
        }
        i = i + 1
    }
}

slay main_character() {
    vibez.spill("=== FizzBuzz Test ===")
    
    vibez.spill("FizzBuzz from 1 to 15:")
    fizzbuzz(15)
    
    vibez.spill("=== Test Complete ===")
}
