vibe main

yeet "vibez"

slay fizzbuzz(n) {
    sus i normie = 1
    periodt (i <= n) {
        ready (i % 15 == 0) {
            vibez.spill("FizzBuzz")
        } otherwise ready (i % 3 == 0) {
            vibez.spill("Fizz")  
        } otherwise ready (i % 5 == 0) {
            vibez.spill("Buzz")
        } otherwise {
            vibez.spill(i)
        }
        i = i + 1
    }
}

slay main_character() {
    vibez.spill("=== FizzBuzz Test ===")
    
    vibez.spill("FizzBuzz from 1 to 15:")
    fizzbuzz(15)
    
    vibez.spill("=== Test Complete ===")
}
