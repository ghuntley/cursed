vibe main

yeet "vibez"

slay calculate_complex(a, b, c) {
    damn (a + b) * c - (a - b) / 2
}

slay main_character() {
    vibez.spill("=== Nested Operations Test ===")
    
    vibez.spill("Complex arithmetic:")
    sus result1 drip = (5 + 3) * 2 - 1
    vibez.spill(result1)
    
    vibez.spill("Nested function calls:")
    sus result2 drip = calculate_complex(10, 4, 3)
    vibez.spill(result2)
    
    vibez.spill("Nested conditionals:")
    sus x drip = 15
    lowkey (x > 10) {
        lowkey (x < 20) {
            vibez.spill("x is between 10 and 20")
        } highkey {
            vibez.spill("x is 20 or greater")
        }
    } highkey {
        vibez.spill("x is 10 or less")
    }
    
    vibez.spill("Multiple operations:")
    sus a drip = 2
    sus b drip = 3
    sus c drip = 4
    sus final drip = (a * b) + (b * c) - (a + c)
    vibez.spill(final)
    
    vibez.spill("=== Test Complete ===")
}
