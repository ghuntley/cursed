vibe main

yeet "vibez"

slay calculate_complex(a, b, c normie) normie {
    damn (a + b) * c - (a - b) / 2
}

slay main_character() {
    vibez.spill("=== Nested Operations Test ===")
    
    vibez.spill("Complex arithmetic:")
    sus result1 normie = (5 + 3) * 2 - 1
    vibez.spill(result1)
    
    vibez.spill("Nested function calls:")
    sus result2 normie = calculate_complex(10, 4, 3)
    vibez.spill(result2)
    
    vibez.spill("Nested conditionals:")
    sus x normie = 15
    ready (x > 10) {
        ready (x < 20) {
            vibez.spill("x is between 10 and 20")
        } otherwise {
            vibez.spill("x is 20 or greater")
        }
    } otherwise {
        vibez.spill("x is 10 or less")
    }
    
    vibez.spill("Multiple operations:")
    sus a normie = 2
    sus b normie = 3
    sus c normie = 4
    sus final normie = (a * b) + (b * c) - (a + c)
    vibez.spill(final)
    
    vibez.spill("=== Test Complete ===")
    damn
}
