vibe main_character

yeet "vibez"

fr fr Simple Arithmetic Test
fr fr Tests: Basic integer arithmetic operations
fr fr Expected: Identical results in both modes

slay main_character() {
    vibez.spill("=== Simple Arithmetic Test ===")
    
    sus a normie = 10
    sus b normie = 5
    
    vibez.spill("Addition:")
    vibez.spill(a + b)
    
    vibez.spill("Subtraction:")
    vibez.spill(a - b)
    
    vibez.spill("Multiplication:")
    vibez.spill(a * b)
    
    vibez.spill("Division:")
    vibez.spill(a / b)
    
    vibez.spill("=== Test Complete ===")
}
