vibe main_character

yeet "vibez"

fr fr Variable Assignment Test
fr fr Tests: Variable declarations and assignments
fr fr Expected: Identical behavior in both modes

slay main_character() {
    vibez.spill("=== Variable Assignment Test ===")
    
    sus x normie = 42
    vibez.spill("x =")
    vibez.spill(x)
    
    sus y normie = x + 8
    vibez.spill("y = x + 8 =")
    vibez.spill(y)
    
    sus name tea = "CURSED"
    vibez.spill("name =")
    vibez.spill(name)
    
    vibez.spill("=== Test Complete ===")
}
