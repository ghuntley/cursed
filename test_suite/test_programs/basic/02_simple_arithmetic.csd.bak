// Simple Arithmetic Test
// Tests: Basic integer arithmetic operations
// Expected: Identical results in both modes

fn main() {
    yap("=== Simple Arithmetic Test ===")
    
    let a = 10
    let b = 5
    
    yap("Addition:")
    yap(a + b)
    
    yap("Subtraction:")
    yap(a - b)
    
    yap("Multiplication:")
    yap(a * b)
    
    yap("Division:")
    yap(a / b)
    
    yap("=== Test Complete ===")
}
