vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== If Statement Test ===")
    
    sus x normie = 10
    sus y normie = 5
    
    vibez.spill("x = 10, y = 5")
    
    lowkey (x > y) {
        vibez.spill("x is greater than y")
    }
    
    lowkey (y > x) {
        vibez.spill("y is greater than x")
    } highkey {
        vibez.spill("x is not less than y")
    }
    
    sus score normie = 85
    vibez.spill("Score evaluation:")
    
    lowkey (score >= 90) {
        vibez.spill("Grade A")
    } else lowkey (score >= 80) {
        vibez.spill("Grade B")
    } else lowkey (score >= 70) {
        vibez.spill("Grade C")
    } highkey {
        vibez.spill("Grade F")
    }
    
    vibez.spill("=== Test Complete ===")
}
