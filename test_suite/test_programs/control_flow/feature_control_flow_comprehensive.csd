vibe main

yeet "vibez"
yeet "mathz"

fr fr Comprehensive Control Flow Test
fr fr Tests: All control flow structures work correctly
fr fr Expected: Conditionals, loops, and returns function properly

slay main_character() {
    vibez.spill("=== Control Flow Test ===")
    
    fr fr Test basic conditional
    sus value normie = 15
    lowkey (value > 10) {
        vibez.spill("Value is greater than 10")
    }
    
    fr fr Test if-else structure
    sus check normie = 5
    lowkey (check > 7) {
        vibez.spill("Check is greater than 7")
    } highkey {
        vibez.spill("Check is not greater than 7")
    }
    
    fr fr Test while loop
    sus counter normie = 0
    vibez.spill("Starting loop count:")
    bestie (counter < 3) {
        vibez.spill(counter)
        counter = counter + 1
    }
    
    fr fr Test nested conditions
    sus a normie = 8
    sus b normie = 12
    lowkey (a < 10) {
        lowkey (b > 10) {
            vibez.spill("Both conditions met")
        }
    }
    
    fr fr Test boolean logic
    sus flag lit = based
    lowkey (flag) {
        vibez.spill("Boolean test passed")
    }
    
    vibez.spill("=== Control Flow Test Complete ===")
}
