vibe main_character
yeet "vibez"

fr fr Test automatic semicolon insertion
slay main_character() {
    fr fr Package declarations should work without semicolons
    fr fr Import statements should work without semicolons  
    fr fr Regular statements should work without semicolons
    
    sus x normie = 42
    sus y normie = 100
    sus z normie = x + y
    
    fr fr Method calls should work without semicolons
    vibez.spill("Package and import parsing works")
    vibez.spill("Variable declarations work")
    vibez.spill("Arithmetic works")
    vibez.spill(z)
    
    fr fr Return statements should work without semicolons
    damn z
}

fr fr Additional function to test multiple function declarations
slay helper_function() {
    sus value normie = 999
    damn value
}
