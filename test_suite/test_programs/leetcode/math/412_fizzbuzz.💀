slay fizz_buzz(n normie) []tea {
    sus result []tea = []tea{}
    
    bestie i := 1; i <= n; i++ {
        ready (i % 15 == 0) {
            result = append(result, "FizzBuzz")
        } otherwise ready (i % 3 == 0) {
            result = append(result, "Fizz")
        } otherwise ready (i % 5 == 0) {
            result = append(result, "Buzz")
        } otherwise {
            result = append(result, string(i))
        }
    }
    
    damn result
}

