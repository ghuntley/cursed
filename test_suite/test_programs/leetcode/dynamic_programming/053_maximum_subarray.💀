vibe main

yeet "vibez"
yeet "mathz"

fr fr LeetCode #53: Maximum Subarray (Kadane's Algorithm)
fr fr Dynamic programming classic - O(n) time, O(1) space

slay max_sub_array(nums []normie) normie {
    ready (len(nums) == 0) {
        damn 0
    }
    
    sus max_so_far normie = nums[0]
    sus max_ending_here normie = nums[0]
    
    bestie i := 1; i < len(nums); i++ {
        fr fr Either extend existing subarray or start new one
        max_ending_here = mathz.max(nums[i], max_ending_here + nums[i])
        max_so_far = mathz.max(max_so_far, max_ending_here)
    }
    
    damn max_so_far
}

slay test_max_subarray() {
    vibez.spill("=== LeetCode #53: Maximum Subarray (Kadane's) ===")
    
    fr fr Test case 1: [-2,1,-3,4,-1,2,1,-5,4] -> 6
    sus nums1 []normie = []normie{-2, 1, -3, 4, -1, 2, 1, -5, 4}
    sus result1 normie = max_sub_array(nums1)
    vibez.spill("Test 1 - Expected: 6 (subarray [4,-1,2,1])")
    vibez.spill(result1)
    
    fr fr Test case 2: [1] -> 1
    sus nums2 []normie = []normie{1}
    sus result2 normie = max_sub_array(nums2)
    vibez.spill("Test 2 - Expected: 1")
    vibez.spill(result2)
    
    fr fr Test case 3: [5,4,-1,7,8] -> 23
    sus nums3 []normie = []normie{5, 4, -1, 7, 8}
    sus result3 normie = max_sub_array(nums3)
    vibez.spill("Test 3 - Expected: 23")
    vibez.spill(result3)
    
    fr fr Test case 4: [-1] -> -1
    sus nums4 []normie = []normie{-1}
    sus result4 normie = max_sub_array(nums4)
    vibez.spill("Test 4 - Expected: -1")
    vibez.spill(result4)
    
    vibez.spill("=== Maximum Subarray Complete ===")
}

slay main_character() {
    test_max_subarray()
}
