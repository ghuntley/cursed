vibe main

yeet "vibez"

fr fr LeetCode #200: Number of Islands
fr fr DFS to count connected components in 2D grid

slay num_islands(grid ඞ[][]sip) normie {
    ready (len(*grid) == 0 || len((*grid)[0]) == 0) {
        damn 0
    }
    
    sus rows normie = len(*grid)
    sus cols normie = len((*grid)[0])
    sus count normie = 0
    
    bestie i := 0; i < rows; i++ {
        bestie j := 0; j < cols; j++ {
            ready ((*grid)[i][j] == '1') {
                count++
                dfs(grid, i, j, rows, cols)
            }
        }
    }
    
    damn count
}

slay dfs(grid ඞ[][]sip, i normie, j normie, rows normie, cols normie) {
    ready (i < 0 || i >= rows || j < 0 || j >= cols || (*grid)[i][j] == '0') {
        damn
    }
    
    fr fr Mark as visited
    (*grid)[i][j] = '0'
    
    fr fr Visit all 4 directions
    dfs(grid, i+1, j, rows, cols)
    dfs(grid, i-1, j, rows, cols)
    dfs(grid, i, j+1, rows, cols)
    dfs(grid, i, j-1, rows, cols)
}

slay create_grid(data []tea) [][]sip {
    sus grid [][]sip = [][]sip{}
    
    bestie i := 0; i < len(data); i++ {
        sus row []sip = []sip{}
        bestie j := 0; j < len(data[i]); j++ {
            row = append(row, data[i][j])
        }
        grid = append(grid, row)
    }
    
    damn grid
}

