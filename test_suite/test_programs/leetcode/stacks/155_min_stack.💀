slay (self ඞMinStack) push(val normie) {
    self.stack = append(self.stack, val)
    
    ready (len(self.min_stack) == 0 || val <= self.min_stack[len(self.min_stack)-1]) {
        self.min_stack = append(self.min_stack, val)
    }
}

slay (self ඞMinStack) pop() {
    ready (len(self.stack) == 0) {
        damn
    }
    
    sus popped normie = self.stack[len(self.stack)-1]
    self.stack = self.stack[:len(self.stack)-1]
    
    ready (popped == self.min_stack[len(self.min_stack)-1]) {
        self.min_stack = self.min_stack[:len(self.min_stack)-1]
    }
}

slay (self ඞMinStack) top() normie {
    damn self.stack[len(self.stack)-1]
}

slay (self ඞMinStack) get_min() normie {
    damn self.min_stack[len(self.min_stack)-1]
