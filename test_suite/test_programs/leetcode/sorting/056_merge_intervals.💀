vibe main

yeet "vibez"
yeet "mathz"

fr fr LeetCode #56: Merge Intervals
fr fr Sort intervals then merge overlapping ones

be_like Interval squad {
    start normie
    end normie
}

slay merge_intervals(intervals []Interval) []Interval {
    ready (len(intervals) <= 1) {
        damn intervals
    }
    
    fr fr Sort intervals by start time (simple bubble sort)
    bestie i := 0; i < len(intervals); i++ {
        bestie j := 0; j < len(intervals)-1-i; j++ {
            ready (intervals[j].start > intervals[j+1].start) {
                sus temp Interval = intervals[j]
                intervals[j] = intervals[j+1]
                intervals[j+1] = temp
            }
        }
    }
    
    sus merged []Interval = []Interval{intervals[0]}
    
    bestie i := 1; i < len(intervals); i++ {
        sus last_idx normie = len(merged) - 1
        
        ready (merged[last_idx].end >= intervals[i].start) {
            fr fr Merge overlapping intervals
            merged[last_idx].end = mathz.max(merged[last_idx].end, intervals[i].end)
        } otherwise {
            fr fr No overlap, add new interval
            merged = append(merged, intervals[i])
        }
    }
    
    damn merged
}

slay print_intervals(intervals []Interval) {
    bestie i := 0; i < len(intervals); i++ {
        vibez.spill("Interval: [" + string(intervals[i].start) + "," + string(intervals[i].end) + "]")
    }
}

slay test_merge_intervals() {
    vibez.spill("=== LeetCode #56: Merge Intervals ===")
    
    fr fr Test case 1: [[1,3],[2,6],[8,10],[15,18]] -> [[1,6],[8,10],[15,18]]
    sus intervals1 []Interval = []Interval{
        Interval{start: 1, end: 3},
        Interval{start: 2, end: 6},
        Interval{start: 8, end: 10},
        Interval{start: 15, end: 18}
    }
    
    sus merged1 []Interval = merge_intervals(intervals1)
    vibez.spill("Test 1 - Expected: [[1,6],[8,10],[15,18]]")
    print_intervals(merged1)
    
    fr fr Test case 2: [[1,4],[4,5]] -> [[1,5]]
    sus intervals2 []Interval = []Interval{
        Interval{start: 1, end: 4},
        Interval{start: 4, end: 5}
    }
    
    sus merged2 []Interval = merge_intervals(intervals2)
    vibez.spill("Test 2 - Expected: [[1,5]]")
    print_intervals(merged2)
    
    vibez.spill("=== Merge Intervals Complete ===")
}

slay main_character() {
    test_merge_intervals()
}
