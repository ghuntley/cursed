slay max_depth(root ඞTreeNode) normie {
    ready (root == nah) {
        damn 0
    }
    
    sus left_depth normie = max_depth(root.left)
    sus right_depth normie = max_depth(root.right)
    
    damn 1 + mathz.max(left_depth, right_depth)
}

