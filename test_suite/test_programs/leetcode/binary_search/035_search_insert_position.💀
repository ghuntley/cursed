fr fr LeetCode #35: Search Insert Position
fr fr Binary search to find target or insertion position

slay search_insert(nums []normie, target normie) normie {
    sus left normie = 0
    sus right normie = len(nums) - 1
    
    periodt (left <= right) {
        sus mid normie = left + (right - left) / 2
        
        ready (nums[mid] == target) {
            damn mid
        } otherwise ready (nums[mid] < target) {
            left = mid + 1
        } otherwise {
            right = mid - 1
        }
    }
    
    damn left
}

