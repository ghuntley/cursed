vibe main_character;

yeet "mathz";
yeet "vibez";

slay main_character() {
    vibez.spill("=== Advanced Mathz Test ===")
    
    vibez.spill("Power function:")
    vibez.spill(mathz.pow(2, 3))
    vibez.spill(mathz.pow(5, 2))
    
    vibez.spill("Square root:")
    vibez.spill(mathz.sqrt(16))
    vibez.spill(mathz.sqrt(25))
    
    vibez.spill("Modulo operation:")
    vibez.spill(mathz.mod(10, 3))
    vibez.spill(mathz.mod(15, 4))
    
    vibez.spill("Multiple operations:")
    vibez.spill(mathz.add_two(mathz.abs(-5), mathz.max(3, 7)))
    
    vibez.spill("=== Test Complete ===")
};
