// Basic Mathz Stdlib Test
// Tests: mathz module functions
// Expected: Stdlib functions work identically

import mathz

fn main() {
    yap("=== Mathz Stdlib Test ===")
    
    yap("Testing mathz.add_two:")
    let result1 = mathz.add_two(5, 3)
    yap(result1)
    
    yap("Testing mathz.abs:")
    let result2 = mathz.abs(-7)
    yap(result2)
    
    yap("Testing mathz.max:")
    let result3 = mathz.max(10, 15)
    yap(result3)
    
    yap("Testing mathz.min:")
    let result4 = mathz.min(8, 12)
    yap(result4)
    
    yap("=== Test Complete ===")
}
