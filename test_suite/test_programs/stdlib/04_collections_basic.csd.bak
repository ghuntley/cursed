// Basic Collections Test
// Tests: Basic array/collection operations
// Expected: Collections work the same in both modes

import collections

fn main() {
    yap("=== Basic Collections Test ===")
    
    yap("Creating array:")
    let arr = collections.new_array()
    
    yap("Adding elements:")
    collections.push(arr, 1)
    collections.push(arr, 2)
    collections.push(arr, 3)
    
    yap("Array length:")
    yap(collections.length(arr))
    
    yap("Getting elements:")
    yap(collections.get(arr, 0))
    yap(collections.get(arr, 1))
    yap(collections.get(arr, 2))
    
    yap("=== Test Complete ===")
}
