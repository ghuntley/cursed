// Basic Stringz Stdlib Test
// Tests: stringz module functions
// Expected: String operations work identically

import stringz

fn main() {
    yap("=== Stringz Stdlib Test ===")
    
    yap("Testing stringz.concat:")
    let result1 = stringz.concat("Hello", " World")
    yap(result1)
    
    yap("Testing stringz.length:")
    let result2 = stringz.length("CURSED")
    yap(result2)
    
    yap("Testing stringz.upper:")
    let result3 = stringz.upper("cursed")
    yap(result3)
    
    yap("Testing stringz.lower:")
    let result4 = stringz.lower("PROGRAMMING")
    yap(result4)
    
    yap("=== Test Complete ===")
}
