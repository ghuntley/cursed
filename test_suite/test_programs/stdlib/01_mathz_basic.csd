vibe main

yeet "mathz"
yeet "vibez"

fr fr Basic Mathz Stdlib Test
fr fr Tests: mathz module functions
fr fr Expected: Stdlib functions work identically

slay main_character() {
    vibez.spill("=== Mathz Stdlib Test ===")
    
    vibez.spill("Testing mathz.add_two:")
    sus result1 normie = mathz.add_two(5, 3)
    vibez.spill(result1)
    
    vibez.spill("Testing mathz.abs:")
    sus result2 normie = mathz.abs(-7)
    vibez.spill(result2)
    
    vibez.spill("Testing mathz.max:")
    sus result3 normie = mathz.max(10, 15)
    vibez.spill(result3)
    
    vibez.spill("Testing mathz.min:")
    sus result4 normie = mathz.min(8, 12)
    vibez.spill(result4)
    
    vibez.spill("=== Test Complete ===")
}
