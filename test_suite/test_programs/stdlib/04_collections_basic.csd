vibe main

yeet "collections"
yeet "vibez"

slay main_character() {
    vibez.spill("=== Basic Collections Test ===")
    
    vibez.spill("Creating array:")
    sus arr normie = collections.new_array()
    
    vibez.spill("Adding elements:")
    collections.push(arr, 1)
    collections.push(arr, 2)
    collections.push(arr, 3)
    
    vibez.spill("Array length:")
    vibez.spill(collections.length(arr))
    
    vibez.spill("Getting elements:")
    vibez.spill(collections.get(arr, 0))
    vibez.spill(collections.get(arr, 1))
    vibez.spill(collections.get(arr, 2))
    
    vibez.spill("=== Test Complete ===")
}
