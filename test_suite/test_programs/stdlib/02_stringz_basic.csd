vibe main

yeet "stringz"
yeet "vibez"

slay main_character() {
    vibez.spill("=== Stringz Stdlib Test ===")
    
    vibez.spill("Testing stringz.concat:")
    sus result1 drip = stringz.concat("Hello", " World")
    vibez.spill(result1)
    
    vibez.spill("Testing stringz.length:")
    sus result2 drip = stringz.length("CURSED")
    vibez.spill(result2)
    
    vibez.spill("Testing stringz.upper:")
    sus result3 drip = stringz.upper("cursed")
    vibez.spill(result3)
    
    vibez.spill("Testing stringz.lower:")
    sus result4 drip = stringz.lower("PROGRAMMING")
    vibez.spill(result4)
    
    vibez.spill("=== Test Complete ===")
}
