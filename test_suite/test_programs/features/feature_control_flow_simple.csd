vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== Control Flow Test ===")
    
    sus x drip = 10
    ready x > 5 {
        vibez.spill("x is greater than 5")
    }
    
    sus grade drip = 85
    ready grade >= 90 {
        vibez.spill("Grade: A")
    } otherwise {
        vibez.spill("Grade: B or below")
    }
    
    vibez.spill("=== Test Complete ===")
}
