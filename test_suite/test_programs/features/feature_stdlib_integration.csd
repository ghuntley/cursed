vibe main_character

yeet "mathz"
yeet "vibez"

slay main_character() {
    vibez.spill("=== Stdlib Test ===")
    
    sus num normie = -42
    vibez.spill("abs(-42):")
    vibez.spill(mathz.abs(num))
    
    sus a normie = 3
    sus b normie = 4
    vibez.spill("add(3, 4):")
    vibez.spill(mathz.add(a, b))
    
    vibez.spill("=== Test Complete ===")
}
