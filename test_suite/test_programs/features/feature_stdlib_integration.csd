vibe main

yeet "mathz"
yeet "vibez"

slay main_character() {
    vibez.spill("=== Stdlib Test ===")
    
    sus num drip = -42
    vibez.spill("abs(-42):")
    vibez.spill(mathz.abs(num))
    
    sus a drip = 3
    sus b drip = 4
    vibez.spill("add(3, 4):")
    vibez.spill(mathz.add(a, b))
    
    vibez.spill("=== Test Complete ===")
}
