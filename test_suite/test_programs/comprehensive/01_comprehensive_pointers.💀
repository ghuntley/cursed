    sus p2 ඞඞnormie = ඞp1
    sus p3 ඞඞඞnormie = ඞp2
    
    ***p3 = 777
    vibez.spill(val)
    
    fr fr 5. Function pointer parameters
    vibez.spill("5. Function Parameters:")
    sus a normie = 100
    sus b normie = 200
    swap_values(ඞa, ඞb)
    vibez.spill(a)
    vibez.spill(b)
    
    vibez.spill("=== Comprehensive Test Complete ===")
