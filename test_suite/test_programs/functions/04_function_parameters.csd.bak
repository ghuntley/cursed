// Function Parameters Test
// Tests: Various parameter scenarios
// Expected: Parameter passing works consistently

fn no_params() {
    return 42
}

fn one_param(x) {
    return x * 2
}

fn multiple_params(a, b, c) {
    return a + b + c
}

fn main() {
    yap("=== Function Parameters Test ===")
    
    yap("No parameters:")
    yap(no_params())
    
    yap("One parameter:")
    yap(one_param(10))
    
    yap("Multiple parameters:")
    yap(multiple_params(1, 2, 3))
    
    yap("Parameters with expressions:")
    yap(multiple_params(5 + 1, 3 * 2, 10 - 2))
    
    yap("=== Test Complete ===")
}
