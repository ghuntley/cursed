// Nested Function Calls Test
// Tests: Functions calling other functions
// Expected: Nested calls work identically

fn double_value(x) {
    return x * 2
}

fn add_one(x) {
    return x + 1
}

fn complex_calc(x) {
    return double_value(add_one(x))
}

fn main() {
    yap("=== Nested Function Calls Test ===")
    
    yap("double_value(5):")
    yap(double_value(5))
    
    yap("add_one(7):")
    yap(add_one(7))
    
    yap("complex_calc(3) = double_value(add_one(3)):")
    yap(complex_calc(3))
    
    yap("Nested in expression:")
    yap(double_value(add_one(2)) + 1)
    
    yap("=== Test Complete ===")
}
