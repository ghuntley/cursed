vibe main_character

yeet "vibez"
yeet "mathz"

fr fr Function Call Feature Test
fr fr Tests: Function definitions and calls with parameters
fr fr Expected: Functions execute with correct parameter passing

slay calculate_sum(x normie, y normie) normie {
    damn x + y
}

slay print_message(msg tea) {
    vibez.spill(msg)
}

slay is_positive(num normie) lit {
    ready (num > 0) {
        damn based
    } otherwise {
        damn cringe
    }
}

slay main_character() {
    vibez.spill("=== Function Call Test ===")
    
    fr fr Test function with return value
    sus sum_result normie = calculate_sum(7, 13)
    vibez.spill("Sum of 7 and 13:")
    vibez.spill(sum_result)
    
    fr fr Test void function
    print_message("Function call successful")
    
    fr fr Test boolean return function
    sus positive_check lit = is_positive(25)
    vibez.spill("Is 25 positive?")
    vibez.spill(positive_check)
    
    sus negative_check lit = is_positive(-5)
    vibez.spill("Is -5 positive?")
    vibez.spill(negative_check)
    
    fr fr Test function call in expression
    sus complex_expr normie = calculate_sum(3, 4) * 2
    vibez.spill("Function result in expression:")
    vibez.spill(complex_expr)
    
    fr fr Test stdlib and custom function mixing
    sus mixed_result normie = mathz.abs(calculate_sum(-10, 5))
    vibez.spill("Mixed function calls result:")
    vibez.spill(mixed_result)
    
    vibez.spill("=== Function Test Complete ===")
}
