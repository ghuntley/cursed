// Recursive Function Test  
// Tests: Basic recursion functionality
// Expected: Recursion works the same in both modes

fn factorial(n) {
    if (n <= 1) {
        return 1
    }
    return n * factorial(n - 1)
}

fn countdown(n) {
    if (n > 0) {
        yap(n)
        countdown(n - 1)
    }
}

fn main() {
    yap("=== Recursive Function Test ===")
    
    yap("Factorial of 5:")
    let fact = factorial(5)
    yap(fact)
    
    yap("Countdown from 3:")
    countdown(3)
    yap("Done!")
    
    yap("=== Test Complete ===")
}
