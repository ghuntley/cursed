vibe main

yeet "vibez"

slay factorial(n) {
    lowkey (n <= 1) {
        damn 1
    }
    damn n * factorial(n - 1)
}

slay countdown(n) {
    lowkey (n > 0) {
        vibez.spill(n)
        countdown(n - 1)
    }
}

slay main_character() {
    vibez.spill("=== Recursive Function Test ===")
    
    vibez.spill("Factorial of 5:")
    sus fact drip = factorial(5)
    vibez.spill(fact)
    
    vibez.spill("Countdown from 3:")
    countdown(3)
    vibez.spill("Done!")
    
    vibez.spill("=== Test Complete ===")
}
