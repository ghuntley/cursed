vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== String Operations Test ===")
    
    sus greeting drip = "Hello"
    sus target drip = "World"
    
    vibez.spill("Individual strings:")
    vibez.spill(greeting)
    vibez.spill(target)
    
    vibez.spill("String with numbers:")
    sus mixed drip = "Value: 42"
    vibez.spill(mixed)
    
    vibez.spill("Empty string:")
    sus empty drip = ""
    vibez.spill(empty)
    vibez.spill("After empty string")
    
    vibez.spill("Special characters:")
    sus special drip = "Hello\nWorld"
    vibez.spill(special)
    
    vibez.spill("=== Test Complete ===")
}
