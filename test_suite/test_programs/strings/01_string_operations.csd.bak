// String Operations Test
// Tests: String handling and manipulation
// Expected: String operations work consistently

fn main() {
    yap("=== String Operations Test ===")
    
    let greeting = "Hello"
    let target = "World"
    
    yap("Individual strings:")
    yap(greeting)
    yap(target)
    
    yap("String with numbers:")
    let mixed = "Value: 42"
    yap(mixed)
    
    yap("Empty string:")
    let empty = ""
    yap(empty)
    yap("After empty string")
    
    yap("Special characters:")
    let special = "Hello\nWorld"
    yap(special)
    
    yap("=== Test Complete ===")
}
