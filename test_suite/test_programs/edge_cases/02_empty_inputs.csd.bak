// Empty Inputs Test
// Tests: Handling of empty or null-like inputs
// Expected: Empty inputs handled consistently

fn handle_empty(x) {
    if (x == 0) {
        return "zero"
    }
    return "non-zero"
}

fn main() {
    yap("=== Empty Inputs Test ===")
    
    yap("Empty string:")
    let empty_str = ""
    yap(empty_str)
    yap("After empty string")
    
    yap("Zero value:")
    yap(handle_empty(0))
    
    yap("Non-zero value:")
    yap(handle_empty(5))
    
    yap("=== Test Complete ===")
}
