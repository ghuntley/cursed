vibe main_character

yeet "vibez"
yeet "mathz"

fr fr Test: Complex expression parsing edge cases
fr fr Purpose: Test parser handles deeply nested and complex expressions
fr fr Expected: All complex expressions should parse and evaluate correctly

slay main_character() {
    fr fr Deeply nested arithmetic expressions
    sus complex1 normie = ((10 + 5) * (8 - 3)) / (2 + 1)
    vibez.spill(complex1)
    
    fr fr Mixed operations with precedence
    sus complex2 normie = 2 + 3 * 4 - 1 * (5 + 2) / 7
    vibez.spill(complex2)
    
    fr fr Boolean expressions with multiple operators
    sus a normie = 10
    sus b normie = 20
    sus c normie = 15
    
    sus complex_bool lit = (a < b) && (b > c) || (a + c == b + 5)
    vibez.spill(complex_bool)
    
    fr fr Nested function calls
    sus nested_result normie = mathz.abs(mathz.max(-5, mathz.min(10, -3)))
    vibez.spill(nested_result)
    
    fr fr Complex conditional with nested expressions
    ready ((a * 2) > (b - 5)) && (mathz.abs(c - 10) < 6) {
        vibez.spill("Complex condition passed")
    } otherwise {
        vibez.spill("Complex condition failed")
    }
    
    fr fr Expression with multiple mathematical operations
    sus x snack = 2.5
    sus y snack = 1.5
    sus complex_float snack = (x + y) * (x - y) + (x * y) / (x + 1.0)
    vibez.spill(complex_float)
    
    fr fr Chain of comparisons
    sus chain_result lit = a < b && b < (c + 10) && (c + 10) < 30
    vibez.spill(chain_result)
    
    damn 0
}
