vibe main
yeet "vibez"
yeet "mathz"
yeet "stringz"

fr fr Corrected Boundary Test - Basic Edge Cases
fr fr Tests: Simple boundary conditions with correct syntax
fr fr Expected: Proper handling of edge values

slay main() {
    vibez.spill("=== Corrected Boundary Test ===")
    
    vibez.spill("Testing zero values...")
    sus zero = 0
    vibez.spill("Zero:", zero)
    vibez.spill("Zero abs:", mathz.abs_normie(zero))
    
    vibez.spill("Testing negative values...")
    sus negative = -100
    vibez.spill("Negative:", negative)  
    vibez.spill("Negative abs:", mathz.abs_normie(negative))
    
    vibez.spill("Testing large values...")
    sus large = 999999
    vibez.spill("Large:", large)
    vibez.spill("Large abs:", mathz.abs_normie(large))
    
    vibez.spill("Testing empty strings...")
    sus empty_str = ""
    vibez.spill("Empty string length:", stringz.length(empty_str))
    
    vibez.spill("Testing single characters...")
    sus single = "x"
    vibez.spill("Single char:", single)
    vibez.spill("Single length:", stringz.length(single))
    
    vibez.spill("Testing edge arithmetic...")
    vibez.spill("Zero + 1 =", zero + 1)
    vibez.spill("Zero * 999 =", zero * 999)
    vibez.spill("1 - 1 =", 1 - 1)
    
    vibez.spill("Testing boundary loops...")
    sus count = 0
    periodt (count < 3) {
        vibez.spill("Boundary loop iteration:", count)
        count = count + 1
    }
    
    vibez.spill("Testing boundary conditions...")
    ready (zero == 0) {
        vibez.spill("Zero boundary detected")
    }
    
    ready (negative < 0) {
        vibez.spill("Negative boundary detected")
    }
    
    ready (large > 100000) {
        vibez.spill("Large value boundary detected")
    }
    
    vibez.spill("Corrected boundary test completed")
    damn
}
