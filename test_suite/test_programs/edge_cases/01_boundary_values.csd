vibe main_character

yeet "vibez"

slay main_character() {
    vibez.spill("=== Boundary Values Test ===")
    
    vibez.spill("Small numbers:")
    vibez.spill(1)
    vibez.spill(0)
    vibez.spill(-1)
    
    vibez.spill("Large numbers:")
    vibez.spill(999999)
    vibez.spill(1000000)
    vibez.spill(-999999)
    
    vibez.spill("Decimal boundaries:")
    vibez.spill(0.1)
    vibez.spill(0.0)
    vibez.spill(-0.1)
    
    vibez.spill("=== Test Complete ===")
}
