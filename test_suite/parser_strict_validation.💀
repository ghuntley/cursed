vibe main
yeet "vibez"

# ===================================================================
# ORACLE PRIORITY 1: Parser Strict Validation Tests
# Tests designed to pass with -Zparser-strict flag
# ===================================================================

slay main_character() {
    # Basic arithmetic validation
    sus a normie = 5
    sus b normie = 10
    sus result1 normie = a + b * 2    # Should parse as: a + (b * 2)
    
    # Member access validation
    sus obj = TestObject{field: 42}
    sus deep normie = obj.field
    
    # Logical operators validation
    sus condition lit = based && cringe
    sus filter lit = based || cringe
    
    # Comparison operators validation
    sus compare_result lit = (a > b) && (result1 >= 20)
    
    # Conditional expression validation
    ready condition {
        vibez.spill("Condition is true")
    } otherwise {
        vibez.spill("Condition is false")
    }
    
    # Simple loop validation
    bestie i := 0; i < 5; i++ {
        vibez.spill("Loop iteration: " + string(i))
    }
    
    # Simple function call validation
    sus final_result normie = add_numbers(a, b)
    
    # Success message
    vibez.spill("All parser strict validation tests completed!")
}

slay add_numbers(x, y normie) normie {
    damn x + y
}

squad TestObject {
    field normie
}
