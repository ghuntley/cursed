vibe main
yeet "vibez"
yeet "mathz"

slay main() {
    vibez.spill("Testing abs function:")
    sus test_val = 42
    vibez.spill("Input:", test_val)
    
    sus result = mathz.abs_normie(test_val)
    vibez.spill("Result:", result)
    
    sus negative_val = -42
    vibez.spill("Negative input:", negative_val)
    
    sus negative_result = mathz.abs_normie(negative_val)
    vibez.spill("Negative result:", negative_result)
    
    vibez.spill("Test complete")
}
