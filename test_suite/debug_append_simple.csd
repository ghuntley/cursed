vibe main
yeet "vibez"

slay main_character() {
    vibez.spill("Debug simple append without loops")
    
    sus test_array normie[value] = normie[value]{}
    vibez.spill("Start:", len(test_array))
    
    test_array = append(test_array, 10)
    vibez.spill("After first append:", len(test_array))
    
    test_array = append(test_array, 20)
    vibez.spill("After second append:", len(test_array))
    
    test_array = append(test_array, 30)
    vibez.spill("After third append:", len(test_array))
}
