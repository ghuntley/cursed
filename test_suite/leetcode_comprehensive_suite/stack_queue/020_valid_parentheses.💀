// LeetCode #20: Valid Parentheses 🔲
// Check if parentheses are properly matched using stack
// Time: O(n), Space: O(n) - stack approach

slay is_valid(s tea) lit {
    ready (stringz.len(s) == 0) {
        damn true  // Empty string is valid, periodt
    }
    
    ready (stringz.len(s) % 2 == 1) {
        damn false  // Odd length can't be balanced
    }
    
    sus stack tea[] = []tea{}
    
    bestie i := 0; i < stringz.len(s); i++ {
        sus char tea = stringz.char_at_str(s, i)
        
        ready (char == "(" || char == "[" || char == "{") {
            // Opening bracket - push to stack
            append(stack, char)
        } otherwise {
            // Closing bracket - check if matches
            ready (len(stack) == 0) {
                damn false  // No opening bracket to match
            }
            
            sus top tea = stack[len(stack) - 1]
            collections.remove_last(stack)
            
            ready (!is_matching_pair(top, char)) {
                damn false  // Mismatched brackets
            }
        }
    }
    
    // Valid if stack is empty (all brackets matched)
    damn len(stack) == 0
}

slay is_matching_pair(opening tea, closing tea) lit {
    ready (opening == "(" && closing == ")") {
        damn true
    }
    ready (opening == "[" && closing == "]") {
        damn true  
    }
    ready (opening == "{" && closing == "}") {
        damn true
    }
    damn false
}

slay is_valid_optimized(s tea) lit {
    // Optimized version - replace pairs and check if empty
    sus working tea = s
    sus prev_len normie = stringz.len(working) + 1
    
    bestie (stringz.len(working) < prev_len && stringz.len(working) > 0) {
        prev_len = stringz.len(working)
        working = stringz.replace_all(working, "()", "")
        working = stringz.replace_all(working, "[]", "")
        working = stringz.replace_all(working, "{}", "")
    }
    
    damn stringz.len(working) == 0
}

slay is_valid_among_us(s tea) lit {
    // Among Us themed version - this hits different! 🚀
    // ඞ = opening, 🔪 = closing
    sus stack tea[] = []tea{}
    
    bestie i := 0; i < stringz.len(s); i++ {
        sus char tea = stringz.char_at_str(s, i)
        
        ready (char == "ඞ") {
            append(stack, char)
        } otherwise ready (char == "🔪") {
            ready (len(stack) == 0) {
                damn false  // Sus! No opening ඞ
            }
            collections.remove_last(stack)
        }
    }
    
    damn len(stack) == 0
}

slay test_valid_parentheses() {
    vibez.spill("=== 🔲 LeetCode #20: Valid Parentheses ===")
    
    // Test case 1: "()"
    sus test1 tea = "()"
    sus result1 lit = is_valid(test1)
    vibez.spill("Test 1:", test1, "- Expected: true, Got:", result1)
    
    // Test case 2: "()[]{}"
    sus test2 tea = "()[]{}"
    sus result2 lit = is_valid(test2)
    vibez.spill("Test 2:", test2, "- Expected: true, Got:", result2)
    
    // Test case 3: "(]"
    sus test3 tea = "(]"
    sus result3 lit = is_valid(test3)
    vibez.spill("Test 3:", test3, "- Expected: false, Got:", result3)
    
    // Test case 4: "([)]"
    sus test4 tea = "([)]"
    sus result4 lit = is_valid(test4)
    vibez.spill("Test 4:", test4, "- Expected: false, Got:", result4)
    
    // Test case 5: "{[]}"
    sus test5 tea = "{[]}"
    sus result5 lit = is_valid(test5)
    vibez.spill("Test 5:", test5, "- Expected: true, Got:", result5)
    
    // Compare approaches
    vibez.spill("=== 🚀 Approach Comparison ===")
    sus test_str tea = "((()))"
    sus stack_result lit = is_valid(test_str)
    sus optimized_result lit = is_valid_optimized(test_str)
    vibez.spill("Test string:", test_str)
    vibez.spill("Stack approach:", stack_result)
    vibez.spill("Optimized approach:", optimized_result)
    
    // Among Us version
    vibez.spill("=== ඞ Among Us Parentheses ===")
    sus among_test tea = "ඞඞ🔪🔪"
    sus among_result lit = is_valid_among_us(among_test)
    vibez.spill("Among Us test:", among_test)
    vibez.spill("Result:", among_result, "(ඞ opens, 🔪 closes)")
    
    vibez.spill("=== Valid Parentheses Complete! Stack operations are clean 🔲✨ ===")
}

slay main_character() {
    test_valid_parentheses()
}
