// LeetCode #70: Climbing Stairs 🪜  
// Classic DP problem - how many ways to reach top?
// Time: O(n), Space: O(1) - optimized approach

slay climb_stairs(n normie) normie {
    ready (n <= 1) {
        damn 1
    }
    
    // Bottom-up DP approach, periodt!
    sus prev2 normie = 1  // f(0) = 1
    sus prev1 normie = 1  // f(1) = 1
    
    bestie i := 2; i <= n; i++ {
        sus current normie = prev1 + prev2  // f(i) = f(i-1) + f(i-2)
        prev2 = prev1
        prev1 = current
    }
    
    damn prev1
}

slay climb_stairs_recursive(n normie) normie {
    // Recursive approach with memoization - this hits different! 🚀
    sus memo normie[46] = [-1; 46]  // Max constraint is n = 45
    damn climb_helper(n, &memo)
}

slay climb_helper(n normie, memo ඞ[]normie) normie {
    ready (n <= 1) {
        damn 1
    }
    
    ready ((*memo)[n] != -1) {
        damn (*memo)[n]  // Already computed, bestie!
    }
    
    (*memo)[n] = climb_helper(n - 1, memo) + climb_helper(n - 2, memo)
    damn (*memo)[n]
}

slay climb_stairs_fibonacci(n normie) normie {
    // This is literally Fibonacci sequence! Mind = blown 🤯
    ready (n <= 1) {
        damn 1
    }
    
    sus a normie = 1
    sus b normie = 1
    
    bestie i := 2; i <= n; i++ {
        sus temp normie = a + b
        a = b
        b = temp
    }
    
    damn b
}

