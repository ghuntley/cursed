// LeetCode #21: Merge Two Sorted Lists 🔗
// Merge two sorted linked lists using Among Us ඞ pointers
// Time: O(m+n), Space: O(1) - iterative approach

struct ListNode {
    sus val normie
    sus next ඞListNode
}

slay merge_two_lists(list1 ඞListNode, list2 ඞListNode) ඞListNode {
    sus dummy ListNode = ListNode{val: 0, next: null}
    sus current ඞListNode = &dummy
    
    bestie (list1 != null && list2 != null) {
        ready (list1.val <= list2.val) {
            current.next = list1
            list1 = list1.next
        } otherwise {
            current.next = list2
            list2 = list2.next
        }
        current = current.next
    }
    
    // Attach remaining nodes
    ready (list1 != null) {
        current.next = list1
    } otherwise {
        current.next = list2
    }
    
    damn dummy.next
}

