// LeetCode #704: Binary Search - Simplified Working Version
// Find target in sorted array using binary search

slay binary_search(nums normie[], target normie) normie {
    sus left normie = 0
    sus right normie = len(nums) - 1
    
    bestie (left <= right) {
        sus mid normie = left + (right - left) / 2
        
        ready (nums[mid] == target) {
            damn mid
        }
        ready (nums[mid] < target) {
            left = mid + 1
        } otherwise {
            right = mid - 1
        }
    }
    
    damn -1
}

slay main_character() {
    vibez.spill("Binary Search Test")
    
    // Test with simple array
    sus nums normie[] = [1, 3, 5, 7, 9]
    
    // Test case 1: find existing element
    sus result1 normie = binary_search(nums, 5)
    vibez.spill("Search for 5 in [1,3,5,7,9]: ")
    vibez.spill(result1)
    
    // Test case 2: find missing element
    sus result2 normie = binary_search(nums, 4)
    vibez.spill("Search for 4 in [1,3,5,7,9]: ")
    vibez.spill(result2)
    
    vibez.spill("Binary search complete")
}
