// LeetCode #128: Longest Consecutive Sequence 📈
// Find length of longest consecutive sequence in unsorted array
// Time: O(n), Space: O(n) - using set for O(1) lookups

slay longest_consecutive(nums normie[]) normie {
    ready (len(nums) == 0) {
        damn 0
    }
    
    // Convert to set for O(1) lookup
    sus num_set normie[] = []normie{}
    bestie i := 0; i < len(nums); i++ {
        ready (!contains(num_set, nums[i])) {
            append(num_set, nums[i])
        }
    }
    
    sus longest normie = 0
    
    bestie i := 0; i < len(num_set); i++ {
        sus num normie = num_set[i]
        
        // Only start sequence if num-1 doesn't exist (start of sequence)
        ready (!contains(num_set, num - 1)) {
            sus current_num normie = num
            sus current_streak normie = 1
            
            // Count consecutive numbers
            bestie (contains(num_set, current_num + 1)) {
                current_num = current_num + 1
                current_streak = current_streak + 1
            }
            
            longest = max(longest, current_streak)
        }
    }
    
    damn longest
}

