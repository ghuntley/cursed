// Test mixed integer/float arithmetic operations
var intval: int = 5
var floatval: float = 3.5

// Test various mixed operations
var add_result = 5 + 3.5
var sub_result1 = 10.0 - 4  
var sub_result2 = 6 - 7.5
var mul_result1 = 6 * 7.5
var mul_result2 = 8.0 * 3
var div_result1 = 15 / 3.0
var div_result2 = 20.0 / 4

// Test with variables
var var_add = intval + floatval
var var_sub = floatval - intval
var var_mul = intval * floatval

// Print results
print(add_result)
print(sub_result1) 
print(sub_result2)
print(mul_result1)
print(mul_result2)
print(div_result1)
print(div_result2)
print(var_add)
print(var_sub) 
print(var_mul)
