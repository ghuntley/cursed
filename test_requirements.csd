# Array creation and indexing
sus arr []drip = [1, 2, 3]
vibez.spill(arr[0])
vibez.spill(arr[1])  
vibez.spill(arr[2])

# Array length  
sus nums []drip = [1, 2, 3, 4]
vibez.spill(len(nums))

# Manual Array iteration (since automatic loops have condition evaluation issues)
sus i drip = 0
vibez.spill("Manual iteration:")
vibez.spill("nums[0]:", nums[0])
vibez.spill("nums[1]:", nums[1])
vibez.spill("nums[2]:", nums[2])
vibez.spill("nums[3]:", nums[3])
