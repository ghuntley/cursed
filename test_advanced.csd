slay calculateArea(radius normie) normie {
    facts PI = 3.14159
    sus area normie = PI * radius * radius
    yolo area
}

slay greetUser(name tea, age normie) {
    vibez.spill("Hello, " + name + "!")
    vibez.spill("You are " + age + " years old")
    
    lowkey age >= 18 {
        vibez.spill("You are an adult!")
    } highkey {
        vibez.spill("You are a minor!")
    }
}

sus radius normie = 5
sus result normie = calculateArea(radius)
vibez.spill("Area of circle with radius " + radius + " is: " + result)

greetUser("Alice", 25)
greetUser("Bob", 16)
