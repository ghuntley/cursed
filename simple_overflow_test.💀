vibe main
yeet "vibez"

slay main_character() {
    vibez.spill("Testing integer overflow fixes...")
    
    // Test large integer operations that could overflow
    sus a drip = 9223372036854775800;  // Near max i64
    sus b drip = 5;
    
    // This should use overflow-safe arithmetic
    sus sum drip = a + b;
    vibez.spill("Large addition passed")
    
    // Test subtraction
    sus diff drip = a - b;
    vibez.spill("Large subtraction passed")
    
    // Test multiplication with smaller numbers
    sus c drip = 1000000;
    sus d drip = 2000;
    sus prod drip = c * d;
    vibez.spill("Multiplication passed")
    
    // Test string concatenation
    sus str1 drip = "Hello ";
    sus str2 drip = "World!";
    sus concat drip = str1 + str2;
    vibez.spill(concat)
    
    vibez.spill("All overflow tests passed!")
}
