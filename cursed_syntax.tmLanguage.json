{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CURSED",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#stdlib"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cursed",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.cursed",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cursed",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.cursed",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cursed",
          "match": "\\b(ready|otherwise|bestie|stan|vibe|sick|when|go|select)\\b"
        },
        {
          "name": "keyword.declaration.cursed",
          "match": "\\b(sus|damn|slay|facts|squad|collab)\\b"
        },
        {
          "name": "keyword.import.cursed",
          "match": "\\b(yeet|as)\\b"
        },
        {
          "name": "keyword.error.cursed",
          "match": "\\b(yikes|shook|fam)\\b"
        },
        {
          "name": "constant.language.boolean.cursed",
          "match": "\\b(based|cap)\\b"
        },
        {
          "name": "constant.language.null.cursed",
          "match": "\\b(cringe)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.cursed",
          "match": "\\b(lit|tea|drip|normie|smol|thicc|byte|rune|mid|snack|meal|extra|sip)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.cursed",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.cursed",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.cursed",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.cursed",
          "match": "="
        },
        {
          "name": "keyword.operator.channel.cursed",
          "match": "(<-)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cursed",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "stdlib": {
      "patterns": [
        {
          "name": "support.function.stdlib.cursed",
          "match": "\\b(vibez|mathz|stringz|arrayz|testz|jsonz|cryptz|filez|httpz|timez|concurrenz)\\.[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "support.module.stdlib.cursed",
          "match": "\\b(vibez|mathz|stringz|arrayz|testz|jsonz|cryptz|filez|httpz|timez|concurrenz)\\b"
        }
      ]
    }
  },
  "scopeName": "source.cursed"
}
