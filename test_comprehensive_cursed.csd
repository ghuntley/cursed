yeet "vibez"

slay greet(name tea) {
    vibez.spill("Hello", name, "!")
}

slay add(a drip, b drip) drip {
    damn a + b
}

slay main() {
    vibez.spill("=== CURSED Comprehensive Test ===")
    
    // Test variables and types
    sus name tea = "CURSED Developer"
    sus age drip = 25
    sus active lit = based
    
    vibez.spill("Name:", name, "Age:", age, "Active:", active)
    
    // Test function calls
    greet(name)
    
    sus result drip = add(10, 15)
    vibez.spill("10 + 15 =", result)
    
    // Test control flow
    ready (result > 20) {
        vibez.spill("Result is greater than 20!")
    } otherwise {
        vibez.spill("Result is not greater than 20")
    }
    
    // Test loops
    sus i drip = 0
    bestie (i < 3) {
        vibez.spill("Loop iteration:", i)
        i = i + 1
    }
    
    vibez.spill("=== Test completed successfully! ===")
}
