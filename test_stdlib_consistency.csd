vibe main
yeet "vibez"
yeet "stringz" 
yeet "collections"

slay main_character() {
    fr fr Test stringz module
    sus str_result tea = stringz.concat("Hello", " World")
    vibez.spill(str_result)
    
    sus len_result normie = stringz.length("test string")
    vibez.spill(len_result)
    
    fr fr Test collections module with simple array literal
    sus arr normie[value] = normie[value]{100, 400, 900}
    sus arr_len normie = collections.length(arr)
    vibez.spill(arr_len)
}
