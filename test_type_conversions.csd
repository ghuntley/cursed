// Test type conversions and arithmetic operations
slay main_character() {
    // Basic types
    sus x drip = 42
    sus y meal = 3.14
    sus flag lit = based
    
    // Type cast test (simplified syntax)
    sus float_val meal = 42.0
    sus int_val drip = 100
    
    // Arithmetic operations
    sus sum drip = 10 + 5
    sus product drip = 6 * 7
    sus division meal = 15.0 / 3.0
    
    // Boolean operations
    sus comparison lit = x > 30
    
    vibez.spill("Enhanced type system working!")
    vibez.spill("Integer sum: %d", sum)
    vibez.spill("Product: %d", product)
    vibez.spill("Division: %f", division)
    
    damn 0
}
