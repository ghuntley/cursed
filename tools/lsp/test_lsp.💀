slay test_syntax_diagnostics() {
    test_start("Syntax error diagnostics")
    
    sus content tea = "sus x drip = 42\nslay test() { damn x }"  // Missing semicolons
    sus diagnostics []Diagnostic = check_cursed_syntax(content)
    
    assert_true(len(diagnostics) > 0)
    assert_eq_string(diagnostics[0].code, "missing-semicolon")
}

slay test_document_tracking() {
    test_start("Document state tracking")
    
    sus server LSPServer = init_lsp_server()
    
    // Simulate opening a document
    sus params tea = json_object()
    sus text_document tea = json_object()
    text_document = json_set(text_document, "uri", json_string("file:///test.💀"))
    text_document = json_set(text_document, "languageId", json_string("cursed"))
    text_document = json_set(text_document, "version", json_number(1))
    text_document = json_set(text_document, "text", json_string("sus x drip = 42;"))
    params = json_set(params, "textDocument", text_document)
    
    handle_text_document_open(server, params)
    
    assert_eq_int(len(server.documents), 1)
    assert_eq_string(server.documents[0].uri, "file:///test.💀")
    assert_eq_string(server.documents[0].content, "sus x drip = 42;")
}

slay test_document_changes() {
    test_start("Document change handling")
    
    sus server LSPServer = init_lsp_server()
    
    // Add initial document
    sus doc DocumentInfo = DocumentInfo{
        uri: "file:///test.💀",
        version: 1,
        content: "sus x drip = 42;",
        language_id: "cursed"
    }
    push(server.documents, doc)
    
    // Simulate document change
    sus params tea = json_object()
    sus text_document tea = json_object()
    text_document = json_set(text_document, "uri", json_string("file:///test.💀"))
    text_document = json_set(text_document, "version", json_number(2))
    params = json_set(params, "textDocument", text_document)
    
    sus changes tea = json_array([])
    sus change tea = json_object()
    change = json_set(change, "text", json_string("sus y drip = 24;"))
    changes = json_array_push(changes, change)
    params = json_set(params, "contentChanges", changes)
    
    handle_text_document_change(server, params)
    
    assert_eq_string(server.documents[0].content, "sus y drip = 24;")
    assert_eq_int(server.documents[0].version, 2)
}

