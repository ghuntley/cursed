{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CURSED",
  "scopeName": "source.cursed",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cursed",
          "begin": "//",
          "end": "$",
          "patterns": [
            {
              "name": "constant.language.cursed",
              "match": "\\b(TODO|FIXME|NOTE|HACK|XXX)\\b"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cursed",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\[\"\\\\nrtbf]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.cursed",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cursed",
          "match": "\\b(ready|otherwise|bestie|damn|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.cursed",
          "match": "\\b(sus|slay|squad|collab|spill)\\b"
        },
        {
          "name": "keyword.other.cursed",
          "match": "\\b(yeet|stan|vibez)\\b"
        },
        {
          "name": "constant.language.boolean.cursed",
          "match": "\\b(based|cringe)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.cursed",
          "match": "\\b(drip|tea|lit|normie)\\b"
        },
        {
          "name": "support.type.collection.cursed",
          "match": "\\[\\](drip|tea|lit|normie)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.cursed",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.cursed",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.cursed",
          "match": "(==|!=|<|>|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.cursed",
          "match": "(&&|\\|\\||!)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cursed",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.cursed",
          "match": "\\b(len|push|pop|concat_str|split_str|trim_str|contains_str|starts_with|ends_with|index_of|substring|replace_str|to_lower_str|to_upper_str|int_to_str|str_to_int|abs_normie|max_normie|min_normie|pow_normie|sqrt_normie|sin_normie|cos_normie|tan_normie|log_normie|exp_normie|floor_normie|ceil_normie|round_normie)\\b"
        },
        {
          "name": "support.function.vibez.cursed",
          "match": "\\bvibez\\.(spill|get|readline)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.cursed",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.cursed",
          "match": ";"
        },
        {
          "name": "punctuation.separator.cursed",
          "match": ","
        },
        {
          "name": "punctuation.section.block.begin.cursed",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.cursed",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.cursed",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.cursed",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.cursed",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.cursed",
          "match": "\\]"
        },
        {
          "name": "punctuation.accessor.cursed",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.type.cursed",
          "match": ":"
        }
      ]
    }
  }
}
