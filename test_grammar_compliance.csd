// Testing grammar compliance

// Package declaration
vibe main

// Imports
yeet "fmt"
yeet (
    "strings"
    tea "strings"
)

// Constants
facts (
    PI = 3.14159
    E = 2.71828
)

// Variables
sus name tea = "World"
sus age, height = 25, 180.5

// Types
be_like Person squad {
    name tea
    age normie
}

// Functions
slay add(x, y normie) normie {
    yolo x + y
}

// If statements
lowkey x > 0 {
    yolo x
} highkey lowkey x < 0 {
    yolo -x
} highkey {
    yolo 0
}

// Switch statements
vibe_check day {
    mood "Monday", "Tuesday":
        print("Start of week")
    mood "Friday":
        print("End of week")
    basic:
        print("Mid-week")
}

// For statements
bestie i := 0; i < 10; i++ {
    print(i)
}

bestie _, val := flex items {
    process(val)
}

// While statements
periodt x > 0 {
    x--
}

// Goroutines
stan doSomething()
stan worker(ch, data)

// Channels
sus ch dm<normie>
sus buffered dm<tea>[10]

// Select statements
ready {
    mood ch1 <- value:
        // Send succeeded
    mood result := <-ch2:
        // Receive succeeded
    basic:
        // No operations ready
}

// Defer statements
later file.Close()
