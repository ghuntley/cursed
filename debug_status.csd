yeet "fs"
yeet "io"
yeet "vibez"

slay main_character() {
    vibez.spill("Testing FS module...")
    sus file_content tea = fs.read_file("README.md")
    vibez.spill("FS read_file called")
    
    vibez.spill("Testing IO module...")
    io.println("Hello from IO module")
    vibez.spill("IO println called")
    
    vibez.spill("All modules tested!")
}
