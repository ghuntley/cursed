yeet "mathz"

vibez.spill("Testing mathz module")
vibez.spill("Pi: " + mathz.Pi.(tea))
vibez.spill("E: " + mathz.E.(tea))

sus abs_val meal = mathz.Abs(0.0 - 5.5)
vibez.spill("Abs(-5.5): " + abs_val.(tea))

sus max_val meal = mathz.Max(3.0, 7.0)
vibez.spill("Max(3.0, 7.0): " + max_val.(tea))

sus sqrt_val meal = mathz.Sqrt(16.0)
vibez.spill("Sqrt(16.0): " + sqrt_val.(tea))
