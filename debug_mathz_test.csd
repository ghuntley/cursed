vibe main
yeet "mathz"
yeet "vibez"

slay main_character() {
    vibez.spill("Testing mathz.abs_normie function")
    sus result normie = mathz.abs_normie(-42)
    vibez.spill("Abs result:")
    vibez.spill(result)
    
    vibez.spill("Testing mathz.pow function")
    sus pow_result normie = mathz.pow(2, 3)
    vibez.spill("Pow result:")
    vibez.spill(pow_result)
}
