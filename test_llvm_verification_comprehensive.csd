# Comprehensive LLVM verification test
# Tests various language constructs to ensure proper IR generation

yeet "vibez"
yeet "mathz"
yeet "stringz"

# Test 1: Variables
sus a drip = 42
sus b drip = 24
sus c drip = a + b

# Test 2: String handling
sus message tea = "Hello CURSED!"

# Test 3: Function declarations
slay add_numbers(x drip, y drip) -> drip {
    damn x + y
}

slay print_message(msg tea) {
    vibez.spill(msg)
}

# Test 4: Function calls
sus sum drip = add_numbers(10, 20)
print_message("Testing function calls")

# Test 5: Control flow
ready (sum > 25) {
    vibez.spill("Sum is greater than 25")
} otherwise {
    vibez.spill("Sum is 25 or less")
}

# Test 6: Loop
sus i drip = 0
bestie (i < 3) {
    vibez.spill("Loop iteration:", i)
    i = i + 1
}

# Test output
vibez.spill("Final result:", sum)
