fr fr Simple test without testz dependency
vibez.spill("Testing basic stdlib functionality")

fr fr Test math operations
sus a normie = 10
sus b normie = 20
sus sum normie = a + b
vibez.spill("Math test: 10 + 20 = " + tea(sum))

fr fr Test string operations
sus greeting tea = "Hello "
sus name tea = "CURSED"
sus message tea = greeting + name
vibez.spill("String test: " + message)

fr fr Test boolean operations
sus flag lit = based
vibez.spill("Boolean test: " + tea(flag))

vibez.spill("All basic tests completed successfully")
