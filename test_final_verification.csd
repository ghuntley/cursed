fr fr Test basic CURSED program
sus x drip = 42
sus message tea = "The answer is"
facts(message, x)

fr fr Test vibez.spill
vibez.spill("vibez.spill works:", x)

fr fr Test multiple arguments
facts("Testing", "multiple", "arguments", "with", "facts")

fr fr Test expressions  
facts("Expression test:", 2 + 3, "*", 4, "=", (2 + 3) * 4)

fr fr Test variables in expressions
sus a drip = 10
sus b drip = 5
facts("a + b =", a + b)
facts("a * b =", a * b)
