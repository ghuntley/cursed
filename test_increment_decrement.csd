// Test increment and decrement statements
sus counter drip = 5

vibez.spill("Initial counter:", counter)

counter++
vibez.spill("After increment:", counter)

counter--
vibez.spill("After decrement:", counter)

// Test with floating point
sus float_val normie = 3.14
float_val++
vibez.spill("Float after increment:", float_val)

float_val--
vibez.spill("Float after decrement:", float_val)
