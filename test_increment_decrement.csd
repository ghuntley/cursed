vibe main

fr fr Test increment and decrement operators
slay main() {
    sus count normie = 5
    vibez.spill("Initial count: " + count)
    
    fr fr Test prefix increment
    ++count
    vibez.spill("After ++count: " + count)
    
    fr fr Test postfix increment
    count++
    vibez.spill("After count++: " + count)
    
    fr fr Test prefix decrement
    --count
    vibez.spill("After --count: " + count)
    
    fr fr Test postfix decrement
    count--
    vibez.spill("After count--: " + count)
    
    vibez.spill("Final count: " + count)
}
