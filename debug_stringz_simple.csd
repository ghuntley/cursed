yeet "stringz"

vibez.spill("Testing stringz functions:")

fr Test basic length function
sus test_str tea = "hello"
sus len_result drip = stringz.length(test_str)
vibez.spill("Length of 'hello':", len_result)

fr Test concatenation
sus concat_result tea = stringz.concat("hello", " world")
vibez.spill("Concatenation result:", concat_result)

fr Test contains
sus contains_result lit = stringz.contains("hello world", "world")
vibez.spill("Contains 'world':", contains_result)
