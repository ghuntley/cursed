fr fr Comprehensive CURSED Language Test for LLVM Backend
fr fr Tests all major language constructs to identify LLVM gaps

vibez.spill("🚀 Comprehensive CURSED Language Test")
vibez.spill("=====================================")

fr fr 1. Multiple variable declarations
sus x drip = 10
sus y drip = 5
sus z drip = x + y * 2
vibez.spill("Variables: x =", x, ", y =", y, ", z =", z)

fr fr 2. Arithmetic expressions with proper precedence
sus result1 drip = 2 + 3 * 4
sus result2 drip = (2 + 3) * 4
vibez.spill("2 + 3 * 4 =", result1)
vibez.spill("(2 + 3) * 4 =", result2)

fr fr 3. Function definitions and calls
slay multiply(a drip, b drip) drip {
    damn a * b
}

slay add_three_numbers(x drip, y drip, z drip) drip {
    damn x + y + z
}

sus mult_result drip = multiply(6, 7)
sus add_result drip = add_three_numbers(10, 20, 30)
vibez.spill("multiply(6, 7) =", mult_result)
vibez.spill("add_three_numbers(10, 20, 30) =", add_result)

fr fr 4. Array operations
yeet "arrayz"
sus numbers []drip = [1, 2, 3, 4, 5]
sus array_len drip = len(numbers)
sus first_elem drip = numbers[0]
sus third_elem drip = numbers[2]
vibez.spill("Array length:", array_len)
vibez.spill("First element:", first_elem)
vibez.spill("Third element:", third_elem)

fr fr 5. Control structures - if/else (ready/otherwise)
sus test_value drip = 42
ready (test_value > 40) {
    vibez.spill("Test value is greater than 40")
} otherwise {
    vibez.spill("Test value is 40 or less")
}

fr fr 6. Control structures - while loop (bestie)
sus counter drip = 0
bestie (counter < 3) {
    vibez.spill("Loop iteration:", counter)
    counter = counter + 1
}

fr fr 7. Pattern matching (if supported)
sus pattern_test drip = 5
ready (pattern_test) {
    1 => vibez.spill("Pattern: one")
    2 => vibez.spill("Pattern: two")
    5 => vibez.spill("Pattern: five - matched!")
    _ => vibez.spill("Pattern: other")
}

fr fr 8. Multiple print statements with different types
vibez.spill("String literal test")
vibez.spill("Number test:", 123)
vibez.spill("Mixed test:", "value =", 456)
vibez.spill("Variable test:", x)
vibez.spill("Expression test:", x + y)

fr fr 9. Complex expressions
sus complex_expr drip = (x * 2) + (y * 3) - 1
vibez.spill("Complex expression result:", complex_expr)

fr fr 10. String operations (if supported)
sus greeting tea = "Hello, CURSED!"
vibez.spill("String test:", greeting)

vibez.spill("")
vibez.spill("🎯 Comprehensive test complete!")
vibez.spill("All language constructs tested")
