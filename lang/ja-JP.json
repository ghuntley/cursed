{
  "meta": {
    "locale": "ja-JP",
    "version": "1.0",
    "description": "CURSED パニックメッセージ 日本語版",
    "contributors": ["CURSED開発チーム"],
    "last_updated": "2025-01-10"
  },
  "messages": {
    "panic.yikes": "🚨 CURSED ランタイムエラー: {message}",
    "panic.shook": "💥 CURSED パニック: {message} (コード: {code})",
    "panic.fam": "❌ CURSED 例外: {message}",
    "panic.location": "📍 {function}() 内の {file}:{line}:{column} で",
    "panic.stack_trace": "📚 スタックトレース:",
    "panic.caused_by": "原因:",
    "panic.memory_error": "💾 メモリエラー: {message}",
    "panic.type_error": "🔷 型エラー: {message}",
    "panic.runtime_error": "⚡ ランタイムエラー: {message}",
    "panic.division_by_zero": "🚫 ゼロ除算",
    "panic.index_out_of_bounds": "📊 インデックス {index} が範囲外 (サイズ: {size})",
    "panic.null_pointer": "🎯 ヌルポインタの参照解除",
    "panic.invalid_operation": "❗ 無効な操作: {operation}",
    "panic.unknown_error": "❓ 不明なエラー",
    "panic.file_not_found": "📄 ファイルが見つかりません: {filename}",
    "panic.permission_denied": "🔒 アクセス拒否: {action}",
    "panic.network_error": "🌐 ネットワークエラー: {message}",
    "panic.timeout": "⏰ {seconds}秒後にタイムアウトしました",
    "panic.resource_exhausted": "📈 リソース不足: {resource}",
