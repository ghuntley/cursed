{
  "meta": {
    "locale": "en-US",
    "version": "1.0",
    "description": "CURSED panic messages for English (United States)",
    "contributors": ["CURSED Development Team"],
    "last_updated": "2025-01-10"
  },
  "messages": {
    "panic.yikes": "🚨 CURSED Runtime Error: {message}",
    "panic.shook": "💥 CURSED Panic: {message} (Code: {code})",
    "panic.fam": "❌ CURSED Exception: {message}",
    "panic.location": "📍 At {function}() in {file}:{line}:{column}",
    "panic.stack_trace": "📚 Stack trace:",
    "panic.caused_by": "Caused by:",
    "panic.memory_error": "💾 Memory Error: {message}",
    "panic.type_error": "🔷 Type Error: {message}",
    "panic.runtime_error": "⚡ Runtime Error: {message}",
    "panic.division_by_zero": "🚫 Division by zero",
    "panic.index_out_of_bounds": "📊 Index {index} out of bounds (size: {size})",
    "panic.null_pointer": "🎯 Null pointer dereference",
    "panic.invalid_operation": "❗ Invalid operation: {operation}",
    "panic.unknown_error": "❓ Unknown error occurred",
    "panic.file_not_found": "📄 File not found: {filename}",
    "panic.permission_denied": "🔒 Permission denied: {action}",
    "panic.network_error": "🌐 Network error: {message}",
    "panic.timeout": "⏰ Operation timed out after {seconds} seconds",
    "panic.resource_exhausted": "📈 Resource exhausted: {resource}",
    "panic.assertion_failed": "⚠️ Assertion failed: {condition}",
    "panic.overflow": "🔢 Arithmetic overflow in {operation}",
    "panic.underflow": "🔢 Arithmetic underflow in {operation}",
    "panic.format_error": "📝 Format error: {message}",
    "panic.encoding_error": "🔤 Encoding error: {encoding}",
    "panic.deadlock": "🔄 Deadlock detected in {resource}",
    "panic.race_condition": "🏃 Race condition detected: {details}",
    "panic.invalid_state": "🔧 Invalid state: {state}",
    "panic.not_implemented": "🚧 Feature not implemented: {feature}",
    "panic.deprecated": "⚠️ Deprecated feature used: {feature}",
    "panic.configuration_error": "⚙️ Configuration error: {message}",
    "panic.validation_error": "✅ Validation error: {field}",
    "panic.syntax_error": "📖 Syntax error at {line}:{column}: {message}",
    "panic.parse_error": "🔍 Parse error: {message}",
    "panic.compilation_error": "🔨 Compilation error: {message}",
    "panic.linking_error": "🔗 Linking error: {message}",
    "panic.runtime_version_mismatch": "📦 Runtime version mismatch: expected {expected}, got {actual}",
    "panic.unsupported_platform": "💻 Unsupported platform: {platform}",
    "panic.insufficient_permissions": "🛡️ Insufficient permissions for {action}",
    "panic.quota_exceeded": "📊 Quota exceeded for {resource}: {limit}",
    "panic.service_unavailable": "🚫 Service unavailable: {service}",
    "panic.connection_refused": "🔌 Connection refused to {address}:{port}",
    "panic.authentication_failed": "🔐 Authentication failed for user {user}",
    "panic.authorization_failed": "🚪 Authorization failed for action {action}",
    "panic.data_corruption": "💿 Data corruption detected in {location}",
    "panic.checksum_mismatch": "🔍 Checksum mismatch: expected {expected}, got {actual}",
    "panic.version_conflict": "📚 Version conflict: {package} requires {required}, but {current} is installed"
  },
  "pluralization": {
    "type": "two",
    "rules": {
      "one": "n == 1",
      "other": "n != 1"
    }
  },
  "formatting": {
    "decimal_separator": ".",
    "thousands_separator": ",",
    "currency_symbol": "$",
    "currency_position": "before",
    "date_format": "MM/DD/YYYY",
    "time_format": "hh:mm:ss AM/PM",
    "datetime_format": "MM/DD/YYYY hh:mm:ss AM/PM",
    "rtl": false,
    "text_direction": "ltr"
  },
  "context": {
    "error_severity_levels": {
      "low": "ℹ️",
      "medium": "⚠️",
      "high": "🚨",
      "critical": "💀"
    },
    "component_prefixes": {
      "lexer": "LEX",
      "parser": "PARSE",
      "compiler": "COMP",
      "runtime": "RT",
      "gc": "GC",
      "vm": "VM"
    }
  }
}
