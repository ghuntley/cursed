yeet "mathz"

vibez.spill("Testing mathz.abs_normie(-5):")
sus result1 drip = mathz.abs_normie(-5)
vibez.spill("Result:", result1)

vibez.spill("Testing mathz.abs_normie(10):")
sus result2 drip = mathz.abs_normie(10)
vibez.spill("Result:", result2)

vibez.spill("Testing mathz.max_normie(3, 7):")
sus result3 drip = mathz.max_normie(3, 7)
vibez.spill("Result:", result3)

vibez.spill("Testing mathz.min_normie(3, 7):")
sus result4 drip = mathz.min_normie(3, 7)
vibez.spill("Result:", result4)

vibez.spill("Testing mathz.max_normie(-10, -5):")
sus result5 drip = mathz.max_normie(-10, -5)
vibez.spill("Result:", result5)
