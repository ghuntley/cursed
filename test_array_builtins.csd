vibe main
yeet "vibez"

slay main() {
    // Test len() function with array
    sus arr drip = normie[value]{5, 10, 15}
    vibez.spill("Array:")
    vibez.spill(arr)
    
    sus length drip = len(arr)
    vibez.spill("Length:")
    vibez.spill(length)
    
    // Test len() function with string
    sus text drip = "hello"
    sus text_length drip = len(text)
    vibez.spill("String length:")
    vibez.spill(text_length)
    
    // Test append() function
    sus new_arr drip = append(arr, 20)
    vibez.spill("After append:")
    vibez.spill(new_arr)
    
    sus new_length drip = len(new_arr)
    vibez.spill("New length:")
