fr fr Test typed function parameters and return types
slay add(x normie, y normie) normie {
    yolo x + y;
}

slay greet(name tea) tea {
    yolo "Hello, " + name + "!";
}

slay is_positive(num normie) vibes {
    yolo num > 0;
}

slay main() normie {
    sus result normie = add(5, 3);
    sus greeting tea = greet("CURSED");
    sus positive vibes = is_positive(result);
    
    vibez.spill(greeting);
    lowkey positive {
        vibez.spill("Result is positive!");
    }
    
    yolo result;
}
