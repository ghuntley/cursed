vibe main_character

yeet "vibez"
yeet "mathz"

slay main_character() {
    vibez.spill("=== CURSED Stdlib Demo ===")
    
    fr fr Test mathz module 
    sus negative normie = -42
    sus positive normie = mathz.abs_normie(negative)
    vibez.spill("Absolute value of -42:")
    vibez.spill(positive)
    
    fr fr Test basic arithmetic
    sus sum normie = 10 + 20
    vibez.spill("10 + 20 =")
    vibez.spill(sum)
    
    vibez.spill("=== Demo Complete ===")
}
