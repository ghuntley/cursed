yeet "testz"

# Test variables and arithmetic
sus number normie = 42
sus text tea = "WASM Test"
sus result normie = number + 10

vibez.spill("Number: ", number)
vibez.spill("Text: ", text)
vibez.spill("Result: ", result)

# Test functions
slay add_numbers(a normie, b normie) normie {
    damn a + b
}

sus sum normie = add_numbers(5, 7)
vibez.spill("Sum: ", sum)

# Test conditionals
lowkey sum > 10 {
    vibez.spill("Sum is greater than 10")
} else {
    vibez.spill("Sum is less than or equal to 10")
}

# Test loops
bestie i := 0; i < 3; i++ {
    vibez.spill("Loop iteration: ", i)
}

# Test arrays
sus numbers [3]normie = [1, 2, 3]
vibez.spill("Array element: ", numbers[0])

vibez.spill("WASM advanced test complete!")
