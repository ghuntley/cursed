vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== Simple Loop Test ===")
    
    sus i normie = 1
    vibez.spill("Starting with i =")
    vibez.spill(i)
    
    periodt (i <= 3) {
        vibez.spill("Loop iteration, i =")
        vibez.spill(i)
        i = i + 1
    }
    
    vibez.spill("Loop finished, i =")
    vibez.spill(i)
    vibez.spill("=== Test Complete ===")
}
