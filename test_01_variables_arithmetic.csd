# Test 1: Variable declarations and arithmetic operations
sus x drip = 10
sus y drip = 5
sus z drip = x + y * 2
sus result drip = (x - y) * z / 3
sus name tea = "CURSED"
sus flag lit = based

vibez.spill("Variables test:")
vibez.spill("x =", x)
vibez.spill("y =", y) 
vibez.spill("z = x + y * 2 =", z)
vibez.spill("result = (x - y) * z / 3 =", result)
vibez.spill("name =", name)
vibez.spill("flag =", flag)

# Test complex arithmetic
sus complex drip = ((x + y) * 2 - 5) / (y + 1)
vibez.spill("complex = ((x + y) * 2 - 5) / (y + 1) =", complex)
