yeet "stringz"
yeet "mathz"

sus name tea = "CURSED"
sus length drip = string_length(name)
sus number drip = abs_normie(-100)
sus maximum drip = max_normie(50, 75)

vibez.spill("Language:", name)
vibez.spill("Name length:", length)  
vibez.spill("Absolute value:", number)
vibez.spill("Maximum:", maximum)

slay calculate(x drip, y drip) drip {
    sus sum drip = x + y
    sus product drip = x * y
    damn max_normie(sum, product)
}

sus result drip = calculate(8, 12)
vibez.spill("Calculation result:", result)
