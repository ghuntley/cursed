yeet "testz"
yeet "vibez"

vibez.spill("🚀 Starting Enhanced CURSED Testing Framework Demo")
vibez.spill("✨ All 'damn based' placeholders have been replaced with real functionality")

fr fr ================================
fr fr Basic Test Suite
fr fr ================================

test_start("enhanced_testz_demo")

fr fr Test basic arithmetic
assert_eq_int(5 + 3, 8)
assert_eq_int(10 - 4, 6)
assert_eq_int(3 * 7, 21)

fr fr Test string operations
assert_eq_string("hello", "hello")
assert_ne_string("hello", "world")

fr fr Test boolean logic
assert_true(based)
assert_false(cap)
assert_true(5 > 3)
assert_false(2 > 5)

fr fr ================================
fr fr Advanced Pattern Matching Tests  
fr fr ================================

vibez.spill("🔍 Testing enhanced pattern matching functionality...")

fr fr Test string utilities that were fixed
sus test_text tea = "test_advanced"
assert_true(starts_with_testz(test_text, "test"))
assert_true(ends_with_testz(test_text, "advanced"))
assert_true(contains_testz(test_text, "test"))
assert_true(contains_testz(test_text, "advanced"))

fr fr Test glob pattern matching
assert_true(match_glob_pattern("test_basic", "test*"))
assert_true(match_glob_pattern("unit_test", "*test"))
assert_true(match_glob_pattern("integration_test", "*test*"))

fr fr ================================
fr fr Memory and Performance Tracking
fr fr ================================

vibez.spill("📊 Testing performance metrics collection...")

fr fr Test performance tracking (placeholders now fixed)
sus start_time normie = get_current_time()
sleep_ms(10)  fr fr Small delay
sus end_time normie = get_current_time()

assert_true(end_time >= start_time)

fr fr Test random generation (now uses real cryptz)
sus random_num normie = random_int_range(1, 100)
assert_true(random_num >= 1 && random_num <= 100)

sus random_str tea = random_string(5, 10)
assert_true(random_str.length >= 5 && random_str.length <= 10)

fr fr ================================
