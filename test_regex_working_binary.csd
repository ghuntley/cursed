yeet "vibez"
yeet "regex"

slay main_character() {
    sus text drip = "The number is 123"
    sus pattern drip = "\\d+"
    sus match drip = regex.find(pattern, text)
    sus replaced drip = regex.replace(pattern, text, "XXX")
    sus is_match drip = regex.match(pattern, text)
    vibez.spill("Regex working in binary!")
}
