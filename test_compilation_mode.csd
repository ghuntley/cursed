yeet "vibez"

slay add_numbers(a drip, b drip) drip {
    damn a + b
}

slay greet(name tea) {
    vibez.spill("Hello, ", name, "!")
}

slay main() {
    vibez.spill("Testing compilation mode...")
    
    sus result drip = add_numbers(10, 20)
    vibez.spill("10 + 20 =", result)
    
    greet("CURSED Developer")
    
    vibez.spill("Compilation test completed!")
}
