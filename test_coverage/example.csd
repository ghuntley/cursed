// Example CURSED program for coverage testing

slay calculate_factorial(n normie) normie {
    lowkey (n <= 1) {
        damn 1
    } else {
        damn n * calculate_factorial(n - 1)
    }
}

slay test_conditions(value normie) tea {
    lowkey (value > 0) {
        damn "positive"
    } highkey (value < 0) {
        damn "negative"
    } else {
        damn "zero"
    }
}

slay main_character() {
    sus result1 normie = calculate_factorial(5)
    sus result2 tea = test_conditions(42)
    vibez.spill("Results: " + result1 + " " + result2)
}
