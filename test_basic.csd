# Test 1: Basic functionality - Variables, arithmetic, print statements

# Variables with different types
sus name tea = "World"
sus age drip = 25
sus active lit = based
sus price drip = 99.99

# Arithmetic operations
sus sum drip = 10 + 5
sus diff drip = 20 - 8  
sus product drip = 4 * 6
sus quotient drip = 15 / 3

# Print statements
vibez.spill("Hello", name)
vibez.spill("Age:", age)
vibez.spill("Active:", active)
vibez.spill("Price:", price)
vibez.spill("Sum:", sum)
vibez.spill("Difference:", diff)
vibez.spill("Product:", product)
vibez.spill("Quotient:", quotient)

# Boolean expressions  
sus result lit = (age > 18) and active
vibez.spill("Can access:", result)

# String concatenation
sus greeting tea = "Hello " + name + "!"
vibez.spill(greeting)
