# Unicode strings test
yeet "vibez"
yeet "stringz"

sus emoji_string tea = "🚀 CURSED compiler works! 🎉"
sus unicode_text tea = "Héllo Wörld! 你好世界"
sus mixed_content tea = "ASCII + Unicode: α β γ δ ε"

vibez.spill("Emoji test:", emoji_string)
vibez.spill("Unicode test:", unicode_text)
vibez.spill("Mixed content:", mixed_content)

# Test string length with Unicode
sus length drip = stringz.len(unicode_text)
vibez.spill("Unicode string length:", length)
