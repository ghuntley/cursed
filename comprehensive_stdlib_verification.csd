yeet "testz"

fr fr Comprehensive Standard Library Test
fr fr Testing all major modules: mathz, stringz, fs, time, collections

yeet "mathz"
yeet "stringz" 
yeet "fs"
yeet "time"
yeet "collections"

slay main() cringe {
    ayo("🚀 CURSED Comprehensive Standard Library Test")
    ayo("===============================================")
    
    fr fr Test mathz module
    ayo("\n📊 Testing mathz module...")
    sus result_add normie = add_two(15, 27)
    ayo("add_two(15, 27) =", result_add.(tea))
    
    sus result_abs normie = abs_normie(-42)
    ayo("abs_normie(-42) =", result_abs.(tea))
    
    sus result_max normie = max_normie(100, 200)
    ayo("max_normie(100, 200) =", result_max.(tea))
    
    fr fr Test stringz module
    ayo("\n📝 Testing stringz module...")
    sus test_str tea = "Hello CURSED"
    sus str_len normie = length(test_str)
    ayo("length('Hello CURSED') =", str_len.(tea))
    
    sus concat_result tea = concat("Hello ", "World!")
    ayo("concat('Hello ', 'World!') =", concat_result)
    
    sus substr_result tea = substring(test_str, 0, 5)
    ayo("substring('Hello CURSED', 0, 5) =", substr_result)
    
    fr fr Test time module  
    ayo("\n⏰ Testing time module...")
    sus current_time Time = now()
    ayo("Current time:", current_time.string())
    
    sus unix_ts normie = unix()
    ayo("Unix timestamp:", unix_ts.(tea))
    
    sus custom_time Time = date(2025, 1, 8, 15, 30, 0)
    ayo("Custom date (2025-01-08 15:30:00):", custom_time.format("2006-01-02 15:04:05"))
    
    sus hour_duration Duration = hour()
    ayo("1 hour duration:", hour_duration.string())
    
    fr fr Test collections module
    ayo("\n📦 Testing collections module...")
    sus vec Vec = Vec_new(10)
    ayo("Created vector with capacity:", vec.capacity.(tea))
    
    sus map Map = Map_new(5)
    ayo("Created map with capacity:", map.capacity.(tea))
    
    fr fr Test fs module (basic functionality)
    ayo("\n📁 Testing fs module...")
    sus test_content tea = "CURSED stdlib test content"
    sus write_result lit = write_file("test_output.txt", test_content)
    ayo("File write successful:", write_result.(tea))
    
    sus read_result tea = read_file("test_output.txt")
    ayo("File read result:", read_result)
    
    sus file_exists_result lit = file_exists("test_output.txt")
    ayo("File exists check:", file_exists_result.(tea))
    
    fr fr Advanced time operations
    ayo("\n⚡ Advanced time operations...")
    sus future_time Time = current_time.add(hour_duration)
    ayo("Current + 1 hour:", future_time.string())
    
    sus time_diff Duration = future_time.since(current_time)
    ayo("Time difference:", time_diff.string())
    
    ayo("Weekday:", current_time.weekday_name())
    ayo("Month:", current_time.month_name())
    
    fr fr Summary
    ayo("\n✅ Comprehensive stdlib test completed!")
    ayo("All modules tested successfully:")
    ayo("  ✓ mathz - mathematical operations")
    ayo("  ✓ stringz - string manipulation")
    ayo("  ✓ time - time and duration handling")
    ayo("  ✓ collections - data structures")
    ayo("  ✓ fs - file system operations")
    ayo("\n🎉 CURSED Standard Library is fully functional!")
    
    damn cringe
}
