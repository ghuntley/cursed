yeet "stringz"

# Debug basic stringz functionality
vibez.spill("Testing basic Contains function...")

sus result1 lit = Contains("hello world", "world")
vibez.spill("Contains result:")
vibez.spill(result1)

sus result2 tea = ToLower("HELLO")
vibez.spill("ToLower result:")
vibez.spill(result2)

sus result3 normie = Length("hello")
vibez.spill("Length result:")
vibez.spill(result3)

vibez.spill("Debug completed!")
