fr fr Self-hosting test - CURSED compiler compiling CURSED code

fr fr Import standard library
yeet "vibez"

fr fr Simple factorial function to test recursion and math
slay factorial(n normie) normie {
    lowkey n <= 1 {
        damn 1
    }
    damn n * factorial(n - 1)
}

fr fr Test function with loops and arrays
slay test_loops() {
    sus numbers []normie = []normie{1, 2, 3, 4, 5}
    sus sum normie = 0
    
    bestie i := 0; i < 5; i++ {
        sum = sum + numbers[i]
    }
    
    vibez.spill("Sum of array:", sum)
}

fr fr Test string handling
slay test_strings() {
    sus message tea = "CURSED compiler self-hosting test"
    sus count normie = 42
    sus flag lit = based
    
    vibez.spill("Message:", message)
    vibez.spill("Count:", count)
    vibez.spill("Flag:", flag)
}

fr fr Main function demonstrating CURSED features  
slay main() {
    vibez.spill("🎉 CURSED Self-Hosting Test 🎉")
    vibez.spill("=================================")
    
    fr fr Test factorial
    sus result normie = factorial(5)
    vibez.spill("Factorial of 5:", result)
    
    fr fr Test loops and arrays
    test_loops()
    
    fr fr Test strings
    test_strings()
    
    vibez.spill("Self-hosting test completed successfully! ✅")
}
