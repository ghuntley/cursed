// Test Stage 1: Basic Types
// Testing basic CURSED types as specified in Stage 1

// String type (lit)
sus message: lit = "Hello, CURSED!"

// Integer type (normie) 
sus count: normie = 42

// Float type (tea)
sus price: tea = 3.14

// Boolean type
sus is_valid: lit = "true"  // Using lit for boolean representation

// Character type (if supported)
sus initial: lit = "A"

// Test basic operations
sus sum: normie = count + 10
sus product: tea = price * 2.0
sus greeting: lit = message + " World"

// Print results to test I/O
print(message)
print(count)
print(price)
print(sum)
print(product)
print(greeting)
