{
  "name": "cursed-language-support",
  "displayName": "CURSED Language Support",
  "description": "Language support for CURSED programming language with LSP integration",
  "version": "1.0.0",
  "publisher": "cursed-lang",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "cursed",
    "programming language",
    "lsp",
    "language server"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cursed",
        "aliases": [
          "CURSED",
          "cursed"
        ],
        "extensions": [
          ".csd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cursed",
        "scopeName": "source.cursed",
        "path": "./syntaxes/cursed.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "CURSED Language Server",
      "properties": {
        "cursed.lsp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable CURSED Language Server Protocol support"
        },
        "cursed.lsp.server.path": {
          "type": "string",
          "default": "./zig-out/bin/cursed-zig",
          "description": "Path to CURSED compiler executable"
        },
        "cursed.lsp.server.args": {
          "type": "array",
          "default": [
            "cursed_lsp_server.csd"
          ],
          "description": "Arguments passed to CURSED LSP server"
        },
        "cursed.lsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the CURSED language server"
        },
        "cursed.completion.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable code completion"
        },
        "cursed.hover.enable": {
          "type": "boolean", 
          "default": true,
          "description": "Enable hover information"
        },
        "cursed.formatting.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable document formatting"
        },
        "cursed.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic messages"
        }
      }
    },
    "commands": [
      {
        "command": "cursed.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "CURSED"
      },
      {
        "command": "cursed.showOutputChannel",
        "title": "Show Output Channel",
        "category": "CURSED"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^16.0.0",
    "typescript": "^4.4.0"
  },
  "activationEvents": [
    "onLanguage:cursed"
  ]
}
