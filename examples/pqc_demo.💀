fr fr Demonstrate Falcon Compact Signatures
function demonstrate_falcon_signatures() {
    println("🦅 Falcon Compact Signatures")?
    println("----------------------------")?
    
    // Test both Falcon parameter sets
    sus parameter_sets = [
        (SecurityLevel::Level1, "Falcon-512"),
        (SecurityLevel::Level5, "Falcon-1024")
    ]
    
    lowkey (sus (level, name) in parameter_sets) {
        println(format!("Testing {} ({})", name, level.description()))?
        
        facts (public_key, secret_key) = FalconSignature::keygen(level)?
        println(format!("✓ Generated {} key pair", name))?
        println(format!("  Public key size: {} bytes", public_key.key_data.len()))?
        println(format!("  Secret key size: {} bytes", secret_key.key_data.len()))?
        
        // Test with document signing scenario
        facts document = "CONFIDENTIAL DOCUMENT\n\nThis document contains sensitive information that requires digital signatures for authenticity and non-repudiation. Falcon signatures provide compact post-quantum security.\n\nSigned by: CURSED PQC Demo\nTimestamp: 2024-12-06"
        
        println(format!("Signing document ({} bytes)", document.len()))?
        
        // Sign the document
        facts signature = FalconSignature::sign(&secret_key, document.as_bytes())?
        println(format!("✓ Created compact signature ({} bytes)", signature.len()))?
        println(format!("  Signature size overhead: {:.1}% of document", 
                       (signature.len() as f64 / document.len() as f64) * 100.0))?
        
        // Verify the signature
        facts is_valid = FalconSignature::verify(&public_key, document.as_bytes(), &signature)?
        println(format!("✓ Document signature verification: {}", is_valid))?
    }
    
    println()?
}

fr fr Demonstrate NTRU Encryption
