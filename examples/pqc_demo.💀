fr fr Run performance benchmarks
function run_performance_benchmarks() {
    println("⏱️ Performance Benchmarking")?
    println("---------------------------")?
    
    sus iterations = 10
    println(format!("Running benchmarks with {} iterations...", iterations))?
    println()?
    
    // Benchmark Kyber
    println("Kyber KEM Performance:")?
    lowkey (sus level in [SecurityLevel::Level1, SecurityLevel::Level3, SecurityLevel::Level5]) {
        facts metrics = PqcBenchmark::benchmark_kyber(level, iterations)?
        println(format!("  Kyber-{} ({}):", level.classical_bits(), level.description()))?
        println(format!("    Key generation: {:.2}ms", metrics.keygen_time.as_secs_f64() * 1000.0))?
        println(format!("    Encaps/Decaps: {:.2}ms", metrics.operation_time.as_secs_f64() * 1000.0))?
        println(format!("    Operations/sec: {:.1}", metrics.operations_per_second))?
        println(format!("    Total key size: {} bytes", metrics.key_size))?
        println(format!("    Ciphertext size: {} bytes", metrics.ciphertext_size))?
    }
    
    println()?
    
    // Benchmark Dilithium
    println("Dilithium Signature Performance:")?
    lowkey (sus level in [SecurityLevel::Level1, SecurityLevel::Level3, SecurityLevel::Level5]) {
        facts metrics = PqcBenchmark::benchmark_dilithium(level, iterations)?
        println(format!("  Dilithium-{} ({}):", level.classical_bits(), level.description()))?
        println(format!("    Key generation: {:.2}ms", metrics.keygen_time.as_secs_f64() * 1000.0))?
        println(format!("    Sign/Verify: {:.2}ms", metrics.operation_time.as_secs_f64() * 1000.0))?
        println(format!("    Operations/sec: {:.1}", metrics.operations_per_second))?
        println(format!("    Total key size: {} bytes", metrics.key_size))?
        println(format!("    Signature size: {} bytes", metrics.signature_size.unwrap()))?
    }
    
    println()?
    
    // Compare all algorithms
    println("Algorithm Comparison:")?
    facts all_results = PqcBenchmark::benchmark_all(5)?
    lowkey (sus (name, metrics) in all_results) {
        println(format!("  {}: {:.1} ops/sec, {} bytes keys", 
                       name, metrics.operations_per_second, metrics.key_size))?
    }
    
    println()?
}

