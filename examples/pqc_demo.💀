    // Test different NTRU parameter sets
    sus test_cases = [
        (SecurityLevel::Level1, "NTRU-HPS-2048-509"),
        (SecurityLevel::Level3, "NTRU-HPS-2048-677"),
        (SecurityLevel::Level5, "NTRU-HPS-4096-821")
