fr fr Helper function to create sample binary data
function binary_data_sample() -> Vec<u8> {
    sus data = Vec::new()
    lowkey (sus i = 0; i < 256; i++) {
        data.push((i % 256) as u8)
    }
    data
}

fr fr Helper function to convert hex string to bytes
function bytes_from_hex(hex_string: &str) -> Vec<u8> {
    hex_to_bytes(hex_string).unwrap_or_else(|_| {
        println("Warning: Invalid hex string, using fallback data")?
        vec![0xde, 0xad, 0xbe, 0xef, 0x12, 0x34, 0x56, 0x78]
    })
}

fr fr Demonstrate hybrid classical/post-quantum scenarios
function demonstrate_hybrid_scenarios() {
    println("🔗 Hybrid Classical/Post-Quantum Scenarios")?
    println("------------------------------------------")?
    
    // Scenario 1: Secure key exchange with authentication
    println("Scenario 1: Authenticated Key Exchange")?
    
    // Use Kyber for key exchange
    facts (kyber_pub, kyber_sec) = KyberKem::keygen(SecurityLevel::Level3)?
    facts (ciphertext, shared_secret) = KyberKem::encaps(&kyber_pub)?
    println("✓ Established shared secret using Kyber KEM")?
    
    // Use Dilithium for authentication
    facts (auth_pub, auth_sec) = DilithiumSignature::keygen(SecurityLevel::Level3)?
    facts auth_message = format!("Key exchange session established. Shared secret hash: {}", 
                                bytes_to_hex(&sha256(&shared_secret)))
    facts signature = DilithiumSignature::sign(&auth_sec, auth_message.as_bytes())?
    facts is_authenticated = DilithiumSignature::verify(&auth_pub, auth_message.as_bytes(), &signature)?
    println("✓ Authenticated key exchange using Dilithium signatures")?
    
    // Scenario 2: Document signing with multiple algorithms
    println()?
    println("Scenario 2: Multi-Algorithm Document Signing")?
    
    facts document = "IMPORTANT CONTRACT\n\nThis document requires multiple digital signatures for legal validity in the post-quantum era.\n\nContract ID: PQC-2024-001"
    
    // Sign with Dilithium (primary signature)
    facts dilithium_sig = DilithiumSignature::sign(&auth_sec, document.as_bytes())?
    println("✓ Primary signature created with Dilithium")?
    
    // Sign with Falcon (compact backup signature)
    facts (falcon_pub, falcon_sec) = FalconSignature::keygen(SecurityLevel::Level1)?
    facts falcon_sig = FalconSignature::sign(&falcon_sec, document.as_bytes())?
    println("✓ Backup signature created with Falcon")?
    
    // Verify both signatures
    facts dilithium_valid = DilithiumSignature::verify(&auth_pub, document.as_bytes(), &dilithium_sig)?
    facts falcon_valid = FalconSignature::verify(&falcon_pub, document.as_bytes(), &falcon_sig)?
    println(format!("✓ Multi-signature verification: Dilithium={}, Falcon={}", 
                   dilithium_valid, falcon_valid))?
    
    println("✅ Hybrid scenarios completed successfully")?
    println()?
}

