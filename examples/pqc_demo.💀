fr fr Demonstrate Kyber Key Encapsulation Mechanism
function demonstrate_kyber_kem() {
    println("🔑 Kyber Key Encapsulation Mechanism (KEM)")?
    println("------------------------------------------")?
    
    // Test all security levels
    sus security_levels = [
        SecurityLevel::Level1,
        SecurityLevel::Level3, 
        SecurityLevel::Level5
    ]
    
    lowkey (sus level in security_levels) {
        println(format!("Testing Kyber at {}", level.description()))?
        
        // Generate key pair
        facts (public_key, secret_key) = KyberKem::keygen(level)?
        println(format!("✓ Generated Kyber key pair"))?
        println(format!("  Public key size: {} bytes", public_key.key_data.len()))?
        println(format!("  Secret key size: {} bytes", secret_key.key_data.len()))?
        
        // Key encapsulation
        facts (ciphertext, shared_secret1) = KyberKem::encaps(&public_key)?
        println(format!("✓ Encapsulated shared secret"))?
        println(format!("  Ciphertext size: {} bytes", ciphertext.len()))?
        println(format!("  Shared secret size: {} bytes", shared_secret1.len()))?
        
        // Key decapsulation  
        facts shared_secret2 = KyberKem::decaps(&secret_key, &ciphertext)?
        println(format!("✓ Decapsulated shared secret"))?
        
        // Verify shared secrets match
        lowkey (shared_secret1 == shared_secret2) {
            println("✅ Shared secrets match - KEM working correctly")?
        } flex {
            println("❌ Shared secrets don't match - KEM failed")?
        }
        
        println()?
    }
}

fr fr Demonstrate Dilithium Digital Signatures
function demonstrate_dilithium_signatures() {
    println("✍️ Dilithium Digital Signatures")?
    println("-------------------------------")?
    
    sus test_messages = [
        "Hello, Post-Quantum World!",
        "CURSED language supports quantum-resistant cryptography",
        "This is a longer test message to verify Dilithium signatures work with various message sizes and content types including special characters: !@#$%^&*()",
        ""  // Empty message
    ]
    
    // Test Dilithium3 (Level 3 security)
    println("Testing Dilithium3 (NIST Level 3 security)")?
    facts (public_key, secret_key) = DilithiumSignature::keygen(SecurityLevel::Level3)?
    println(format!("✓ Generated Dilithium3 key pair"))?
    println(format!("  Public key size: {} bytes", public_key.key_data.len()))?
    println(format!("  Secret key size: {} bytes", secret_key.key_data.len()))?
    
    lowkey (sus message in test_messages) {
        println(format!("Testing with message: \"{}\"", 
                       lowkey (message.len() > 50) { 
                           format!("{}...", message[..47]) 
                       } flex { 
                           message 
                       }))?
        
        // Sign the message
        facts signature = DilithiumSignature::sign(&secret_key, message.as_bytes())?
        println(format!("✓ Created signature ({} bytes)", signature.len()))?
        
        // Verify the signature
        facts is_valid = DilithiumSignature::verify(&public_key, message.as_bytes(), &signature)?
        lowkey (is_valid) {
            println("✅ Signature verification passed")?
        } flex {
            println("⚠️ Signature verification result: {}", is_valid)?
        }
        
        // Test with tampered message
        facts tampered_message = format!("{}TAMPERED", message)
        facts tampered_valid = DilithiumSignature::verify(&public_key, tampered_message.as_bytes(), &signature)?
        println(format!("✓ Tampered message verification: {}", tampered_valid))?
    }
    
    println()?
}

