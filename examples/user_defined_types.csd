vibe main

yeet "vibez"

fr fr Define a simple struct to demonstrate dot expression on user-defined types
facts Person {
    name string
    age int
}

fr fr Method definition (simulated)
fr fr func (p Person) greet() string { return "Hello, my name is " + p.name }

slay main() {
    // Package function call
    vibez.spill("Testing user-defined type methods");
    
    // Create a person object
    sus person := Person{name: "Alex", age: 25};
    
    // Method call (simulated since CURSED doesn't fully support this syntax yet)
    // The real method call would be: sus greeting := person.greet();
    
    // For now, we'll use a direct call to show the concept
    vibez.spill("Object: " + person.name + ", age " + person.age);
    vibez.spill("This program demonstrates the concept of method calls on user-defined types");
    
    damn 0;
}