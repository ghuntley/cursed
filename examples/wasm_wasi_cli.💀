    vibez.spill("This demonstrates CURSED language features in WASI environment")
    vibez.spill("")
    
    // Data types demo
    vibez.spill("📝 CURSED Data Types:")
    sus based_value lit = based
    sus cringe_value lit = cringe
    sus vibe_number drip = 1337
    sus chaos_text tea = "Maximum chaos achieved!"
    sus float_magic tea = 3.14159
    
    vibez.spill("  • Boolean (lit): based =", based_value, ", cringe =", cringe_value)
    vibez.spill("  • Integer (drip):", vibe_number)
    vibez.spill("  • String (tea):", chaos_text)
    vibez.spill("  • Float:", float_magic)
    
    // Control flow demo
    vibez.spill("")
    vibez.spill("🔀 Control Flow:")
    ready (based_value) {
        vibez.spill("  • If statement: This code is based!")
    } otherwise {
        vibez.spill("  • If statement: This shouldn't happen")
    }
    
    // Loop demo
    vibez.spill("  • Loop demo:")
    sus count drip = 1
    bestie (count <= 3) {
