// CURSED WASI CLI Application Example
// Demonstrates command-line tool compiled to WASM with WASI
// Can be run with: wasmtime wasm_wasi_cli.wasm

yeet "vibez"      // I/O operations
yeet "filez"      // File operations (WASI)
yeet "argz"       // Command line arguments (WASI)
yeet "stringz"    // String utilities

// WASI entry point
slay _start() {
    // Get command line arguments
    sus args []tea = argz.get_args()
    
    ready (args.len <= 1) {
        show_help()
        damn
    }
    
    sus command tea = args[1]
    
    // Command dispatcher
    ready (command == "hello") {
        hello_command(args)
    } otherwise ready (command == "file") {
        file_command(args)
    } otherwise ready (command == "calc") {
        calc_command(args)
    } otherwise ready (command == "info") {
        info_command(args)
    } otherwise ready (command == "demo") {
        demo_command(args)
    } otherwise {
        vibez.spill("❌ Unknown command:", command)
        show_help()
    }
}

// Show help information
slay show_help() {
    vibez.spill("🚀 CURSED WASI CLI Tool v1.0.0")
    vibez.spill("A command-line utility compiled to WebAssembly with WASI")
    vibez.spill("")
    vibez.spill("Usage:")
    vibez.spill("  wasmtime cursed-cli.wasm <command> [options]")
    vibez.spill("")
    vibez.spill("Commands:")
    vibez.spill("  hello [name]     - Greet someone (or the world)")
    vibez.spill("  file <path>      - Read and analyze a file")
    vibez.spill("  calc <expr>      - Calculate mathematical expressions")
    vibez.spill("  info             - Show system information")
    vibez.spill("  demo             - Run interactive demo")
    vibez.spill("")
    vibez.spill("Examples:")
    vibez.spill("  wasmtime cursed-cli.wasm hello Alice")
    vibez.spill("  wasmtime cursed-cli.wasm file README.md")
    vibez.spill("  wasmtime cursed-cli.wasm calc '42 + 13'")
    vibez.spill("  wasmtime cursed-cli.wasm demo")
}

// Hello command - greet user
slay hello_command(args []tea) {
    sus name tea = ready (args.len > 2) args[2] otherwise "World"
    
    vibez.spill("🌟 Hello from CURSED WASM,", name, "!")
    vibez.spill("This greeting is brought to you by:")
    vibez.spill("  • CURSED Programming Language")
    vibez.spill("  • WebAssembly (WASM)")
    vibez.spill("  • WebAssembly System Interface (WASI)")
    
    // Show some CURSED personality
    ready (name != "World") {
        vibez.spill("")
        vibez.spill("Fun facts about your name '" + name + "':")
        vibez.spill("  • Length:", stringz.length(name), "characters")
        vibez.spill("  • Reversed:", stringz.reverse(name))
        vibez.spill("  • Uppercase:", stringz.to_upper(name))
        vibez.spill("  • Vowel count:", count_vowels(name))
        vibez.spill("  • Cursed rating: " + get_cursed_rating(name) + "/10 🔥")
    }
}

// File command - read and analyze files
slay file_command(args []tea) {
    ready (args.len <= 2) {
        vibez.spill("❌ Error: Please specify a file path")
        vibez.spill("Usage: wasmtime cursed-cli.wasm file <path>")
        damn
    }
    
    sus file_path tea = args[2]
    vibez.spill("📁 Analyzing file:", file_path)
    
    // Read file using WASI file operations
    sus content tea = filez.read_file(file_path) fam {
        when filez.FileNotFound -> {
            vibez.spill("❌ Error: File not found:", file_path)
            damn
        }
        when filez.PermissionDenied -> {
            vibez.spill("❌ Error: Permission denied reading:", file_path)
            damn
        }
        when filez.IOError -> {
            vibez.spill("❌ Error: I/O error reading file:", file_path)
            damn
        }
    }
    
    // Analyze file content
    sus lines []tea = stringz.split_lines(content)
    sus words []tea = stringz.split_words(content)
    sus chars drip = stringz.length(content)
    
    vibez.spill("")
    vibez.spill("📊 File Analysis Results:")
    vibez.spill("  • Size:", chars, "bytes")
    vibez.spill("  • Lines:", lines.len)
    vibez.spill("  • Words:", words.len)
    vibez.spill("  • Characters:", chars)
    vibez.spill("  • Average line length:", chars / lines.len, "chars")
    
    // Content type detection
    sus file_type tea = detect_file_type(file_path, content)
    vibez.spill("  • Detected type:", file_type)
    
    // Show first few lines
    vibez.spill("")
    vibez.spill("📄 First 3 lines:")
    sus max_lines drip = ready (lines.len < 3) lines.len otherwise 3
    sus i drip = 0
    bestie (i < max_lines) {
        vibez.spill("  " + int_to_string(i + 1) + ":", lines[i])
        i = i + 1
    }
    
    ready (lines.len > 3) {
        vibez.spill("  ... (" + int_to_string(lines.len - 3) + " more lines)")
    }
}

// Calculator command - evaluate expressions
slay calc_command(args []tea) {
    ready (args.len <= 2) {
        vibez.spill("❌ Error: Please specify an expression")
        vibez.spill("Usage: wasmtime cursed-cli.wasm calc '<expression>'")
        vibez.spill("Examples: calc '42 + 13', calc '10 * 5 - 3'")
        damn
    }
    
    sus expression tea = args[2]
    vibez.spill("🧮 CURSED Calculator")
    vibez.spill("Expression:", expression)
    
    // Simple expression evaluator
    sus result drip = evaluate_expression(expression) fam {
        when CalculatorError -> {
            vibez.spill("❌ Error: Invalid expression")
            damn
        }
    }
    
    vibez.spill("Result:", result)
    
    // Show additional mathematical properties
    vibez.spill("")
    vibez.spill("✨ Mathematical Properties:")
    vibez.spill("  • Is even:", (result % 2 == 0 ? "Yes" : "No"))
    vibez.spill("  • Is prime:", (is_prime(result) ? "Yes" : "No"))
    vibez.spill("  • Square:", result * result)
    vibez.spill("  • Square root:", sqrt(result))
    vibez.spill("  • Binary:", to_binary(result))
    vibez.spill("  • Hexadecimal:", to_hex(result))
    vibez.spill("  • Factorial:", factorial(result))
}

// Info command - show system information
slay info_command(args []tea) {
    vibez.spill("ℹ️  CURSED WASI System Information")
    vibez.spill("")
    
    // WASI environment information
    vibez.spill("🖥️  Runtime Environment:")
    vibez.spill("  • Platform: WebAssembly System Interface (WASI)")
    vibez.spill("  • Architecture: wasm32")
    vibez.spill("  • Compiled with: CURSED Language v1.0.0")
    vibez.spill("  • Backend: WebAssembly")
    
    // Memory information
    sus memory_pages drip = get_memory_pages()
    vibez.spill("  • Memory pages:", memory_pages)
    vibez.spill("  • Memory size:", memory_pages * 65536, "bytes")
    
    // Environment variables (if available)
    vibez.spill("")
    vibez.spill("🔧 Environment:")
    sus env_vars []tea = get_env_vars()
    ready (env_vars.len > 0) {
        sus i drip = 0
        bestie (i < env_vars.len && i < 5) { // Show first 5
            vibez.spill("  •", env_vars[i])
            i = i + 1
        }
        ready (env_vars.len > 5) {
            vibez.spill("  ... and", env_vars.len - 5, "more")
        }
    } otherwise {
        vibez.spill("  • No environment variables available")
    }
    
    // Current time
    vibez.spill("")
    vibez.spill("⏰ Current time:", get_current_time())
}

