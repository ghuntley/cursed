    }
    
    vibez.spill("  • Safe division result:", risky_result)
    
    vibez.spill("")
    vibez.spill("✅ Demo completed! CURSED WASI is working perfectly.")
}

// Helper functions

slay count_vowels(text tea) drip {
    sus vowels tea = "aeiouAEIOU"
    sus count drip = 0
    sus i drip = 0
    bestie (i < stringz.length(text)) {
        sus char tea = stringz.char_at(text, i)
        ready (stringz.contains(vowels, char)) {
            count = count + 1
        }
        i = i + 1
    }
    damn count
}

slay get_cursed_rating(text tea) tea {
    sus length drip = stringz.length(text)
    sus rating drip = (length % 10) + 1
    damn int_to_string(rating)
}

slay detect_file_type(path tea, content tea) tea {
    ready (stringz.ends_with(path, ".txt")) damn "Text file"
    ready (stringz.ends_with(path, ".md")) damn "Markdown file"
    ready (stringz.ends_with(path, ".json")) damn "JSON file"
    ready (stringz.ends_with(path, ".💀")) damn "CURSED source file"
    ready (stringz.starts_with(content, "<!DOCTYPE")) damn "HTML file"
    ready (stringz.starts_with(content, "{")) damn "JSON-like file"
    damn "Unknown file type"
}

