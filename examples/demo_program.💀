fr fr CURSED Language Demo Program
fr fr Demonstrates core language features

fr fr Variable declarations using 'sus'
sus greeting = "Hello from CURSED!";
sus version = 1.0;
sus is_awesome = based;

fr fr Function definition using 'slay'
slay calculate(x, y) {
    sus result = x + y;
    return result;
}

fr fr Main program logic
slay main_character() {
    // Print greeting
    println(greeting);
    
    // Basic arithmetic
    sus a = 10;
    sus b = 32;
    sus sum = calculate(a, b);
    
    println("Calculation: " + a + " + " + b + " = " + sum);
    
    // Control flow using 'lowkey'/'highkey'
    lowkey (is_awesome) {
        println("✅ CURSED is awesome!");
    } highkey {
        println("❌ Something is wrong");
    }
    
    // Loop example
    sus counter = 0;
    lowkey (counter < 3) {
        println("Count: " + counter);
        counter = counter + 1;
    }
    
    return 0;
}
