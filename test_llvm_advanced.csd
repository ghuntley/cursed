slay add_numbers(a normie, b normie) normie {
    damn a + b
}

slay main_character() {
    sus x normie = 42
    sus y normie = 13
    sus result normie = add_numbers(x, y)
    
    vibez.spill("Sum is:", result)
    
    nah (result > 50) {
        vibez.spill("Result is greater than 50")
    } else {
        vibez.spill("Result is 50 or less")
    }
}
