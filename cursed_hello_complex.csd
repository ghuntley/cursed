# Variable declarations using CURSED syntax
sus name tea = "CURSED"
sus version normie = 1
sus isAwesome lit = based
sus pi meal = 3.14159

# Multiple output statements
vibez.spill("=== Welcome to CURSED Programming Language ===")
vibez.spill("Language name: " + name)
vibez.spill("Version: " + version)
vibez.spill("Is it awesome? " + isAwesome)
vibez.spill("Pi value: " + pi)
vibez.spill("Thanks for using CURSED! 🔥")
