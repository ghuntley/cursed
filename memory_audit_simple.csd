# Simple memory safety test
yeet "vibez"

vibez.spill("Hello, CURSED Memory Test!")

sus x drip = 42
sus y tea = "Memory safety test"
sus arr []drip = [1, 2, 3, 4, 5]

vibez.spill("Testing basic memory operations...")
vibez.spill("x:", x)
vibez.spill("y:", y)
vibez.spill("Array length:", len(arr))

vibez.spill("Memory test completed successfully!")
