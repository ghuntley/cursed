vibe main
yeet "vibez"

slay calculate_complex(a, b, c normie) normie {
    damn (a + b) * c - (a - b) / 2
}

slay main_character() {
    vibez.spill("Testing division operation...")
    
    // Test simple division
    sus result1 normie = 10 / 2
    vibez.spill(result1)
    
    // Test complex expression with division
    sus result2 normie = calculate_complex(10, 4, 3)
    vibez.spill(result2)
}
