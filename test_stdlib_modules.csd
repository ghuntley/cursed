yeet "vibez"
yeet "mathz" 
yeet "stringz"
yeet "collections"
yeet "env"

slay main_character() {
    fr fr Test vibez module
    vibez.spill("Testing CURSED stdlib modules")
    
    fr fr Test mathz module  
    sus result drip = mathz.abs_normie(-42)
    sus sum drip = mathz.add_two(10, 20)
    
    fr fr Test stringz module
    sus str_len drip = stringz.length("hello")
    sus concat_result tea = stringz.concat("hello", "world")
    
    fr fr Test collections module
    sus arr [extra] = collections.Vec_new()
    sus pushed [extra] = collections.Vec_push(arr, 42)
    
    fr fr Test env module
    sus home tea = env.get_env("HOME")
    sus has_path lit = env.has_env("PATH")
    
    vibez.spill("All modules loaded successfully!")
}
