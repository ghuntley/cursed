// Basic CURSED language functionality test

// Variable declarations
sus greeting tea = "Hello, CURSED World!"
sus count drip = 42
sus isReady lit = based

// Function definition
slay greetUser(name tea) normie {
    vibez.spill("Hello, " + name + "!")
    damn 0
}

// Main execution
vibez.spill(greeting)
vibez.spill("Count is: " + count.tea())
