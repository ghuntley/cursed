// Test CURSED file with various lint issues
yeet "stringz"
yeet "vibez"

sus password tea = "secret123"  // Security issue
sus unused_var drip = 42        // Unused variable
sus reallyLongVariableName tea = "this line is too long and exceeds the recommended character limit for readability purposes"

slay divide(a drip, b drip) drip {
    damn a / b  // Division by zero risk
}

slay my_function() {
    sus x drip = 0
    bestie (x < 100000) {
        bestie (x < 50000) {
            bestie (x < 25000) {
                bestie (x < 12500) {
                    bestie (x < 6250) {  // Excessive nesting
                        vibez.spill("Too deep!")
                    }
                }
            }
        }
        x = x + 1
    }
}

slay unused_function() {  // Unused function
    vibez.spill("Never called")
}

slay main() {
    sus result drip = divide(10, 2)
    vibez.spill("Result: " + int_to_str(result))
}
