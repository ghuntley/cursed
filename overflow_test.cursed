vibe main
yeet "vibez"
yeet "mathz"

slay main_character() {
    vibez.spill("Testing overflow fixes...")
    
    // Test large integer operations
    sus big drip = 9223372036854775807;  // Max i64
    sus result drip = mathz.abs_normie(big);
    vibez.spill("Max i64 abs test passed")
    
    // Test large array creation (but reasonable size)
    sus size drip = 1000;
    sus arr drip = collections.make_vec(size);
    vibez.spill("Large array creation passed")
    
    // Test string concatenation with moderate strings
    sus str1 drip = "Hello ";
    sus str2 drip = "World!";
    sus concat drip = str1 + str2;
    vibez.spill(concat)
}
