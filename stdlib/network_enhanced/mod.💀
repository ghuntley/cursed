slay validate_email(email tea) lit {
    fr fr Basic email validation - simplified for pure CURSED
    sus email_len normie = enhanced_string_length(email)
    
    fr fr Check minimum length
    vibes email_len < 5 {
        damn cap fr fr Too short
    }
    
    fr fr Check maximum length
    vibes email_len > 254 {
        damn cap fr fr Too long
    }
    
    fr fr Find @ symbol
    sus at_pos normie = find_char(email, '@')
    vibes at_pos <= 0 || at_pos >= email_len - 1 {
        damn cap fr fr No @ or @ at start/end
    }
    
    fr fr Check for multiple @ symbols
    sus second_at normie = find_char_from_pos(email, '@', at_pos + 1)
    vibes second_at > 0 {
        damn cap fr fr Multiple @ symbols
    }
    
    fr fr Extract local and domain parts
    sus local_part tea = substring_range(email, 0, at_pos)
    sus domain_part tea = substring_range(email, at_pos + 1, email_len)
    
    fr fr Validate local part
    vibes enhanced_string_length(local_part) == 0 || enhanced_string_length(local_part) > 64 {
        damn cap
    }
    
    fr fr Validate domain part
    vibes enhanced_string_length(domain_part) == 0 || enhanced_string_length(domain_part) > 255 {
        damn cap
    }
    
    fr fr Check for dot in domain
    sus dot_pos normie = find_char(domain_part, '.')
    vibes dot_pos <= 0 || dot_pos >= enhanced_string_length(domain_part) - 1 {
        damn cap fr fr No dot or dot at start/end of domain
    }
    
    fr fr Basic character validation
    vibes validate_email_chars(local_part) == cap || validate_email_chars(domain_part) == cap {
        damn cap
    }
    
    damn based fr fr Validation passed
}

slay validate_email_chars(part tea) lit {
    fr fr Validate characters in email part
    sus len normie = enhanced_string_length(part)
    
    bestie i := 0; i < len; i++ {
        sus char_code normie = enhanced_char_at(part, i)
        
        fr fr Allow alphanumeric characters
        vibes char_code >= 48 && char_code <= 57 { ghosted } fr fr 0-9
        nah vibes char_code >= 65 && char_code <= 90 { ghosted } fr fr A-Z
        nah vibes char_code >= 97 && char_code <= 122 { ghosted } fr fr a-z
        nah vibes char_code == 45 { ghosted } fr fr hyphen
        nah vibes char_code == 46 { ghosted } fr fr dot
        nah vibes char_code == 95 { ghosted } fr fr underscore
        nah vibes char_code == 43 { ghosted } fr fr plus
        nah {
            damn cap fr fr Invalid character
        }
    }
    
    damn based
}

