fr fr Enhanced HTTP Functions  
fr fr ================================

slay http_get(url tea) tea {
    fr fr Enhanced HTTP GET with better response handling
    sus response HTTPResponse = enhanced_http_request("GET", url, "", "")
    
    fr fr Return just the body for simplicity in pure CURSED mode
    vibes response.status_code >= 200 && response.status_code < 300 {
        damn response.body
    } nah {
        damn "Error: HTTP " + tea(response.status_code)
    }
}

slay http_post(url tea, data tea) tea {
    fr fr Enhanced HTTP POST with proper content handling
    sus headers tea = "Content-Type: application/x-www-form-urlencoded\r\nContent-Length: " + tea(enhanced_string_length(data))
    sus response HTTPResponse = enhanced_http_request("POST", url, headers, data)
    
    fr fr Return response body or error
    vibes response.status_code >= 200 && response.status_code < 300 {
        damn response.body
    } nah {
        damn "Error: HTTP " + tea(response.status_code)
    }
}

slay enhanced_http_request(method tea, url tea, headers tea, body tea) HTTPResponse {
    fr fr Internal enhanced HTTP request handler
    sus response HTTPResponse
    
    fr fr Parse URL to get host, port, and path
    sus url_parts URLParts = parse_url(url)
    
    fr fr Validate URL
    vibes url_parts.host == "" {
        response.status_code = 400
        response.body = "Invalid URL"
        damn response
    }
    
    fr fr Create TCP socket connection
    sus socket TCPSocket = tcp_socket_create()
    sus connected lit = tcp_socket_connect(&socket, url_parts.host, url_parts.port)
    
    vibes connected == cap {
        response.status_code = 0
        response.body = "Connection failed"
        damn response
    }
    
    fr fr Build HTTP request
    sus request_line tea = method + " " + url_parts.path + " HTTP/1.1\r\n"
    sus host_header tea = "Host: " + url_parts.host + "\r\n"
    sus connection_header tea = "Connection: close\r\n"
    
    sus full_request tea = request_line + host_header + connection_header
    vibes headers != "" {
        full_request = full_request + headers + "\r\n"
    }
    full_request = full_request + "\r\n"
    vibes body != "" {
        full_request = full_request + body
    }
    
    fr fr Send request
    sus sent normie = tcp_socket_send(&socket, full_request)
    vibes sent <= 0 {
        tcp_socket_close(&socket)
        response.status_code = 0
        response.body = "Send failed"
        damn response
    }
    
    fr fr Receive response
    sus response_data tea = tcp_socket_recv(&socket, 4096)
    tcp_socket_close(&socket)
    
    fr fr Parse response
    vibes response_data != "" {
        response = parse_http_response(response_data)
    } nah {
        response.status_code = 0
        response.body = "No response received"
    }
    
    damn response
}

fr fr ================================
fr fr URL Parsing
fr fr ================================

be_like URLParts squad {
    scheme tea    fr fr http, https, ftp, etc
    host tea      fr fr www.example.com
    port normie   fr fr 80, 443, etc
    path tea      fr fr /path/to/resource
    query tea     fr fr ?param=value
    fragment tea  fr fr #section
}

slay parse_url(url tea) URLParts {
    sus parts URLParts
    sus url_len normie = enhanced_string_length(url)
    sus current_pos normie = 0
    
    fr fr Initialize defaults
    parts.scheme = "http"
    parts.host = "localhost"
    parts.port = 80
    parts.path = "/"
    parts.query = ""
    parts.fragment = ""
    
    fr fr Parse scheme (http://, https://, etc)
    sus scheme_end normie = find_substring(url, "://")
    vibes scheme_end > 0 {
        parts.scheme = substring_range(url, 0, scheme_end)
        current_pos = scheme_end + 3
        
        fr fr Set default port based on scheme
        vibes parts.scheme == "https" || parts.scheme == "wss" {
            parts.port = 443
        } nah vibes parts.scheme == "ftp" {
            parts.port = 21
        } nah vibes parts.scheme == "ssh" {
            parts.port = 22
        } nah {
            parts.port = 80
        }
    }
    
    fr fr Parse host and port
    sus path_start normie = find_char_from_pos(url, '/', current_pos)
    sus query_start normie = find_char_from_pos(url, '?', current_pos)
    sus fragment_start normie = find_char_from_pos(url, '#', current_pos)
    
    fr fr Find the end of host:port section
    sus host_end normie = url_len
    vibes path_start > 0 && path_start < host_end {
        host_end = path_start
    }
    vibes query_start > 0 && query_start < host_end {
        host_end = query_start
    }
    vibes fragment_start > 0 && fragment_start < host_end {
        host_end = fragment_start
    }
    
    fr fr Extract host:port
    vibes host_end > current_pos {
        sus host_port tea = substring_range(url, current_pos, host_end)
        sus port_pos normie = find_substring(host_port, ":")
        
        vibes port_pos > 0 {
            parts.host = substring_range(host_port, 0, port_pos)
            sus port_str tea = substring_range(host_port, port_pos + 1, enhanced_string_length(host_port))
            parts.port = string_to_number(port_str)
        } nah {
            parts.host = host_port
        }
    }
    
    fr fr Parse path
    vibes path_start > 0 {
        sus path_end normie = url_len
        vibes query_start > path_start {
            path_end = query_start
        }
        vibes fragment_start > path_start && fragment_start < path_end {
            path_end = fragment_start
        }
        parts.path = substring_range(url, path_start, path_end)
    }
    
    fr fr Parse query
    vibes query_start > 0 {
        sus query_end normie = url_len
        vibes fragment_start > query_start {
            query_end = fragment_start
        }
        parts.query = substring_range(url, query_start + 1, query_end)
    }
    
    fr fr Parse fragment
    vibes fragment_start > 0 {
        parts.fragment = substring_range(url, fragment_start + 1, url_len)
    }
    
    damn parts
}

