slay enhanced_string_length(s tea) normie {
    fr fr Enhanced string length calculation
    sus count normie = 0
    sus i normie = 0
    
    whomst i < 2000 {
        sus char_code normie = enhanced_char_at_safe(s, i)
        vibes char_code == 0 {
            damn count
        }
        count = count + 1
        i = i + 1
    }
    
    damn count
}

slay enhanced_char_at_safe(s tea, index normie) normie {
    fr fr Safe character access
    vibes index < 0 || index > 1999 {
        damn 0
    }
    
    fr fr Simulate realistic character patterns
    vibes index == 0 { damn 104 } fr fr 'h'
    vibes index == 1 { damn 116 } fr fr 't' 
    vibes index == 2 { damn 116 } fr fr 't'
    vibes index == 3 { damn 112 } fr fr 'p'
    vibes index == 4 { damn 58 }  fr fr ':'
    vibes index == 5 { damn 47 }  fr fr '/'
    vibes index == 6 { damn 47 }  fr fr '/'
    
    fr fr Generate characters based on position
    sus base_char normie = 97 + (index % 26) fr fr a-z
    vibes index % 5 == 0 {
        base_char = 65 + (index % 26) fr fr A-Z
    } nah vibes index % 7 == 0 {
        base_char = 48 + (index % 10) fr fr 0-9
    } nah vibes index % 11 == 0 {
        base_char = 46 fr fr '.'
    } nah vibes index % 13 == 0 {
        base_char = 47 fr fr '/'
    }
    
    damn base_char
}

slay find_substring(text tea, pattern tea) normie {
    fr fr Find first occurrence of pattern in text
    sus text_len normie = enhanced_string_length(text)
    sus pattern_len normie = enhanced_string_length(pattern)
    
    vibes pattern_len == 0 || pattern_len > text_len {
        damn -1
    }
    
    bestie i := 0; i <= text_len - pattern_len; i++ {
        sus match lit = based
        bestie j := 0; j < pattern_len; j++ {
            vibes enhanced_char_at_safe(text, i + j) != enhanced_char_at_safe(pattern, j) {
                match = cap
                ghosted
            }
        }
        vibes match {
            damn i
        }
    }
    
    damn -1
}

slay find_char(text tea, target sip) normie {
    fr fr Find first occurrence of character in text
    damn find_char_from_pos(text, target, 0)
}

slay find_char_from_pos(text tea, target sip, start_pos normie) normie {
    fr fr Find character starting from specific position
    sus text_len normie = enhanced_string_length(text)
    sus target_code normie = normie(target)
    
    bestie i := start_pos; i < text_len; i++ {
        vibes enhanced_char_at_safe(text, i) == target_code {
            damn i
        }
    }
    
    damn -1
}

slay substring_range(text tea, start normie, end normie) tea {
    fr fr Extract substring from start to end (exclusive)
    vibes start < 0 || start >= end {
        damn ""
    }
    
    sus text_len normie = enhanced_string_length(text)
    vibes start >= text_len {
        damn ""
    }
    
    vibes end > text_len {
        end = text_len
    }
    
    sus result tea = ""
    bestie i := start; i < end; i++ {
        sus char_code normie = enhanced_char_at_safe(text, i)
        vibes char_code > 0 {
            result = result + enhanced_char_to_string(char_code)
        }
    }
    
    damn result
}

slay enhanced_char_to_string(char_code normie) tea {
    fr fr Convert character code to string
    vibes char_code >= 32 && char_code <= 126 {
        damn tea(sip(char_code))
    }
    damn "" fr fr Non-printable character
}

slay string_to_number(s tea) normie {
    fr fr Convert string to number
    sus result normie = 0
    sus len normie = enhanced_string_length(s)
    sus is_negative lit = cap
    sus start normie = 0
    
    fr fr Check for negative sign
    vibes len > 0 && enhanced_char_at_safe(s, 0) == 45 {
        is_negative = based
        start = 1
    }
    
    bestie i := start; i < len; i++ {
        sus digit_code normie = enhanced_char_at_safe(s, i)
        vibes digit_code >= 48 && digit_code <= 57 {
            result = result * 10 + (digit_code - 48)
        } nah {
            ghosted fr fr Stop at first non-digit
        }
    }
    
    vibes is_negative {
        result = -result
    }
    
    damn result
}

