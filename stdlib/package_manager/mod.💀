// Package version structure
squad PackageVersion {
    spill major drip
    spill minor drip
    spill patch drip
    
    slay new(major drip, minor drip, patch drip) PackageVersion {
        damn PackageVersion{major: major, minor: minor, patch: patch}
    }
    
    slay toString(self PackageVersion) tea {
        damn format_str("{}.{}.{}", self.major, self.minor, self.patch)
    }
    
    slay satisfies(self PackageVersion, constraint tea) lit {
        // Parse constraint like "^1.0.0", "~1.2.0", ">=1.0.0"
        ready (starts_with(constraint, "^")) {
            sus required PackageVersion = parseVersion(slice_str(constraint, 1))
            damn self.major == required.major && 
                 (self.minor > required.minor || 
                  (self.minor == required.minor && self.patch >= required.patch))
        }
        
        ready (starts_with(constraint, "~")) {
            sus required PackageVersion = parseVersion(slice_str(constraint, 1))
            damn self.major == required.major && 
                 self.minor == required.minor && 
                 self.patch >= required.patch
        }
        
        ready (starts_with(constraint, ">=")) {
            sus required PackageVersion = parseVersion(slice_str(constraint, 2))
            damn self.compare(required) >= 0
        }
        
        ready (starts_with(constraint, ">")) {
            sus required PackageVersion = parseVersion(slice_str(constraint, 1))
            damn self.compare(required) > 0
        }
        
        ready (starts_with(constraint, "<=")) {
            sus required PackageVersion = parseVersion(slice_str(constraint, 2))
            damn self.compare(required) <= 0
        }
        
        ready (starts_with(constraint, "<")) {
            sus required PackageVersion = parseVersion(slice_str(constraint, 1))
            damn self.compare(required) < 0
        }
        
        // Exact version match
        sus required PackageVersion = parseVersion(constraint)
        damn self.compare(required) == 0
    }
    
    slay compare(self PackageVersion, other PackageVersion) drip {
        ready (self.major != other.major) { damn self.major - other.major }
        ready (self.minor != other.minor) { damn self.minor - other.minor }
        damn self.patch - other.patch
    }
}

slay parseVersion(version_str tea) PackageVersion {
    sus parts tea[value] = split_str(version_str, ".")
    ready (len(parts) != 3) {
        damn PackageVersion.new(0, 0, 0)
    }
    
    sus major drip = parse_int(parts[0])
    sus minor drip = parse_int(parts[1])
    sus patch drip = parse_int(parts[2])
    
    damn PackageVersion.new(major, minor, patch)
}

