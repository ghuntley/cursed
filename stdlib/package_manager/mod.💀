slay parseManifest(content tea) PackageManifest {
    // Simple manifest parser - in production would use proper parser
    sus manifest PackageManifest = PackageManifest.new("", "0.1.0")
    
    sus lines tea[value] = split_str(content, "\n")
    sus i drip = 0
    bestie (i < len(lines)) {
        sus line tea = trim_str(lines[i])
        
        ready (starts_with(line, "package ")) {
            sus name_start drip = find_str(line, "\"") + 1
            sus name_end drip = find_str(slice_str(line, name_start), "\"") + name_start
            manifest.name = slice_str(line, name_start, name_end)
        }
        
        ready (contains_str(line, "version = ")) {
            sus value tea = extractQuotedValue(line)
            manifest.version = value
        }
        
        ready (contains_str(line, "description = ")) {
            sus value tea = extractQuotedValue(line)
            manifest.description = value
        }
        
        // Parse dependencies section
        ready (contains_str(line, "dependencies = {")) {
            i = i + 1
            bestie (i < len(lines) && !contains_str(lines[i], "}")) {
                sus dep_line tea = trim_str(lines[i])
                ready (contains_str(dep_line, "=")) {
                    sus dep PackageDependency = parseDependencyLine(dep_line)
                    manifest.dependencies = append_array(manifest.dependencies, dep)
                }
                i = i + 1
            }
        }
        
        // Parse dev_dependencies section
        ready (contains_str(line, "dev_dependencies = {")) {
            i = i + 1
            bestie (i < len(lines) && !contains_str(lines[i], "}")) {
                sus dep_line tea = trim_str(lines[i])
                ready (contains_str(dep_line, "=")) {
                    sus dep PackageDependency = parseDependencyLine(dep_line)
                    dep.is_dev = based
                    manifest.dev_dependencies = append_array(manifest.dev_dependencies, dep)
                }
                i = i + 1
            }
        }
        
        i = i + 1
    }
    
    damn manifest
}

slay extractQuotedValue(line tea) tea {
    sus start drip = find_str(line, "\"") + 1
    sus end drip = find_str(slice_str(line, start), "\"") + start
    damn slice_str(line, start, end)
}

slay parseDependencyLine(line tea) PackageDependency {
    sus parts tea[value] = split_str(line, "=")
    ready (len(parts) != 2) {
        damn PackageDependency.new("", "")
    }
    
    sus name tea = trim_str(replace_str(parts[0], "\"", ""))
    sus version tea = trim_str(replace_str(parts[1], "\"", ""))
    damn PackageDependency.new(name, version)
}

// Package resolution and dependency graph
squad PackageResolver {
    spill cache_dir tea
    spill registry_url tea
    spill installed_packages PackageInfo[value]
    
    slay new(cache_dir tea) PackageResolver {
        damn PackageResolver{
            cache_dir: cache_dir,
            registry_url: "https://packages.cursed.dev/api/v1",
            installed_packages: PackageInfo[value]{}
        }
    }
    
    slay resolvePackage(self PackageResolver, name tea, constraint tea) PackageInfo {
        // Check if already installed and satisfies constraint
        sus i drip = 0
        bestie (i < len(self.installed_packages)) {
            sus pkg PackageInfo = self.installed_packages[i]
            ready (pkg.name == name && pkg.version.satisfies(constraint)) {
                damn pkg
            }
            i = i + 1
        }
        
        // Fetch from registry
        damn self.fetchFromRegistry(name, constraint)
    }
    
    slay fetchFromRegistry(self PackageResolver, name tea, constraint tea) PackageInfo {
        sus url tea = format_str("{}/packages/{}", self.registry_url, name)
        sus response tea = http_get(url)
        sus package_info PackageInfo = parsePackageInfo(response)
        
        // Find version that satisfies constraint
        sus i drip = 0
        bestie (i < len(package_info.versions)) {
            sus version tea = package_info.versions[i]
            sus pkg_version PackageVersion = parseVersion(version)
            ready (pkg_version.satisfies(constraint)) {
                package_info.version = pkg_version
                damn package_info
            }
            i = i + 1
        }
        
        // No suitable version found
        vibez.spill("Error: No version of {} satisfies {}", name, constraint)
        damn PackageInfo.new("", PackageVersion.new(0, 0, 0))
    }
    
    slay resolveDependencies(self PackageResolver, manifest PackageManifest) PackageInfo[value]{
        sus resolved PackageInfo[value] = PackageInfo[value]{}
        sus to_resolve PackageDependency[value] = manifest.dependencies
        
        // Add dev dependencies if in development mode
        sus i drip = 0
        bestie (i < len(manifest.dev_dependencies)) {
            to_resolve = append_array(to_resolve, manifest.dev_dependencies[i])
            i = i + 1
        }
        
        // Resolve each dependency
        i = 0
        bestie (i < len(to_resolve)) {
            sus dep PackageDependency = to_resolve[i]
            sus pkg PackageInfo = self.resolvePackage(dep.name, dep.version_constraint)
            ready (pkg.name != "") {
                resolved = append_array(resolved, pkg)
                
                // Recursively resolve transitive dependencies
                sus dep_manifest PackageManifest = pkg.getManifest()
                sus transitive_deps PackageInfo[value] = self.resolveDependencies(dep_manifest)
                
                sus j drip = 0
                bestie (j < len(transitive_deps)) {
                    resolved = append_array(resolved, transitive_deps[j])
                    j = j + 1
                }
            }
            i = i + 1
        }
        
        damn removeDuplicates(resolved)
    }
    
    slay installPackage(self PackageResolver, pkg PackageInfo) lit {
        sus install_dir tea = format_str("{}/{}", self.cache_dir, pkg.name)
        
        // Create installation directory
        create_dir(install_dir)
        
        // Download package archive
        sus download_url tea = format_str("{}/packages/{}/{}/download", 
                                         self.registry_url, pkg.name, pkg.version.toString())
        sus archive_path tea = format_str("{}/package.tar.gz", install_dir)
        
        ready (!download_file(download_url, archive_path)) {
            vibez.spill("Failed to download package {}", pkg.name)
            damn cringe
        }
        
        // Extract archive
        ready (!extract_archive(archive_path, install_dir)) {
            vibez.spill("Failed to extract package {}", pkg.name)
            damn cringe
        }
        
        // Add to installed packages
        self.installed_packages = append_array(self.installed_packages, pkg)
        
        vibez.spill("Installed {} version {}", pkg.name, pkg.version.toString())
        damn based
    }
}

