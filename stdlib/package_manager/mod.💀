slay parsePackageInfo(json_str tea) PackageInfo {
    // Simple JSON parsing - in production would use proper JSON parser
    sus info PackageInfo = PackageInfo.new("", PackageVersion.new(0, 0, 0))
    
    // Extract name
    sus name_start drip = find_str(json_str, "\"name\":\"") + 8
    sus name_end drip = find_str(slice_str(json_str, name_start), "\"") + name_start
    info.name = slice_str(json_str, name_start, name_end)
    
    // Extract latest version
    sus version_start drip = find_str(json_str, "\"version\":\"") + 11
    sus version_end drip = find_str(slice_str(json_str, version_start), "\"") + version_start
    sus version_str tea = slice_str(json_str, version_start, version_end)
    info.version = parseVersion(version_str)
    
    damn info
}

slay removeDuplicates(packages PackageInfo[value]) PackageInfo[value]{
    sus unique PackageInfo[value] = PackageInfo[value]{}
    
    sus i drip = 0
    bestie (i < len(packages)) {
        sus pkg PackageInfo = packages[i]
        sus found lit = cringe
        
        sus j drip = 0
        bestie (j < len(unique)) {
            ready (unique[j].name == pkg.name) {
                found = based
                break
            }
            j = j + 1
        }
        
        ready (!found) {
            unique = append_array(unique, pkg)
        }
        i = i + 1
    }
    
    damn unique
}

