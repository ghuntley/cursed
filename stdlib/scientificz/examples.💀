# Example 9: Quality control and process analysis
slay demo_quality_control() {
    vibez.spill("\n=== Quality Control Analysis ===")
    
    # Manufacturing process measurements (widget weights in grams)
    sus measurements drip[value] = [50.2, 49.8, 50.1, 50.3, 49.9, 50.0, 50.2, 49.7, 50.4, 50.1,
                              49.8, 50.2, 50.0, 49.9, 50.3, 50.1, 49.8, 50.2, 50.0, 49.9]
    
    sus target_weight drip = 50.0
    sus tolerance drip = 0.5
    
    vibez.spill("Manufacturing Process Control Analysis:")
    vibez.spill("Target weight:", format_number(target_weight), "grams")
    vibez.spill("Tolerance: ±", format_number(tolerance), "grams")
    vibez.spill("Sample size:", len_array(measurements))
    
    # Process capability analysis
    sus process_stats Statistics = calculate_statistics(measurements)
    
    vibez.spill("\nProcess Statistics:")
    vibez.spill("  Process mean:", format_number(process_stats.mean), "grams")
    vibez.spill("  Process std dev:", format_number(process_stats.std_dev), "grams")
    vibez.spill("  Process range:", format_number(process_stats.range), "grams")
    
    # Control limits (3-sigma)
    sus upper_control_limit drip = process_stats.mean + (3 * process_stats.std_dev)
    sus lower_control_limit drip = process_stats.mean - (3 * process_stats.std_dev)
    
    vibez.spill("\nControl Limits (3σ):")
    vibez.spill("  Upper control limit:", format_number(upper_control_limit), "grams")
    vibez.spill("  Lower control limit:", format_number(lower_control_limit), "grams")
    
    # Specification limits
    sus upper_spec_limit drip = target_weight + tolerance
    sus lower_spec_limit drip = target_weight - tolerance
    
    vibez.spill("\nSpecification Limits:")
    vibez.spill("  Upper spec limit:", format_number(upper_spec_limit), "grams")
    vibez.spill("  Lower spec limit:", format_number(lower_spec_limit), "grams")
    
    # Process capability indices
    sus cp drip = (upper_spec_limit - lower_spec_limit) / (6 * process_stats.std_dev)
    sus cpk_upper drip = (upper_spec_limit - process_stats.mean) / (3 * process_stats.std_dev)
    sus cpk_lower drip = (process_stats.mean - lower_spec_limit) / (3 * process_stats.std_dev)
    sus cpk drip = min_value(cpk_upper, cpk_lower)
    
    vibez.spill("\nProcess Capability Indices:")
    vibez.spill("  Cp (potential capability):", format_number(cp))
    vibez.spill("  Cpk (actual capability):", format_number(cpk))
    
    # Interpretation
    ready (cpk > 1.33) {
        vibez.spill("  Process capability: Excellent (Cpk > 1.33)")
    } otherwise ready (cpk > 1.0) {
        vibez.spill("  Process capability: Adequate (1.0 < Cpk < 1.33)")
    } otherwise {
        vibez.spill("  Process capability: Poor (Cpk < 1.0)")
    }
    
    # Out-of-specification count
    sus out_of_spec_count drip = 0
    bestie (sus i drip = 0; i < len_array(measurements); i = i + 1) {
        ready (measurements[i] < lower_spec_limit || measurements[i] > upper_spec_limit) {
            out_of_spec_count = out_of_spec_count + 1
        }
    }
    
    sus out_of_spec_percentage drip = (out_of_spec_count * 100) / len_array(measurements)
    vibez.spill("  Out-of-specification:", out_of_spec_count, "units (", 
                format_number(out_of_spec_percentage), "%)")
}

