    vibez.spill("  50th percentile (median):", format_number(mean))
    vibez.spill("  84th percentile (μ+σ):", format_number(mean + std_dev))
    vibez.spill("  97.5th percentile (μ+2σ):", format_number(mean + 2 * std_dev))
}

# Example 4: Hypothesis testing
slay demo_hypothesis_testing() {
    vibez.spill("\n=== Hypothesis Testing ===")
    
    # One-sample t-test example
    sus sample_data drip[value] = [102, 98, 105, 97, 101, 99, 103, 96, 104, 100, 98, 102, 101, 99, 97]
    sus population_mean drip = 100
    
    vibez.spill("One-Sample t-Test:")
    vibez.spill("Sample data:", array_to_string(sample_data))
    vibez.spill("Null hypothesis: μ = ", population_mean)
    vibez.spill("Alternative hypothesis: μ ≠ ", population_mean)
    
    sus t_result TTestResult = t_test_one_sample(sample_data, population_mean)
    
    vibez.spill("\nTest Results:")
    vibez.spill("  t-statistic:", format_number(t_result.t_statistic))
    vibez.spill("  Degrees of freedom:", t_result.degrees_freedom)
    vibez.spill("  p-value:", format_number(t_result.p_value))
    vibez.spill("  Critical value (α=0.05):", format_number(t_result.critical_value))
    
    # Decision
    ready (t_result.significant) {
        vibez.spill("  Decision: Reject null hypothesis (significant difference)")
    } otherwise {
        vibez.spill("  Decision: Fail to reject null hypothesis (no significant difference)")
    }
    
    vibez.spill("  95% Confidence interval: [", format_number(t_result.confidence_interval[0]), 
                ", ", format_number(t_result.confidence_interval[1]), "]")
}

