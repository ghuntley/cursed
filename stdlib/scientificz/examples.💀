# Utility functions for examples
slay array_to_string(arr drip[value]) tea {
    sus result tea = "["
    sus n drip = min_value(len_array(arr), 10)  # Limit to first 10 elements
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        ready (i > 0) {
            result = result + ", "
        }
        result = result + format_number(arr[i])
    }
    
    ready (len_array(arr) > 10) {
        result = result + ", ..."
    }
    
    result = result + "]"
    damn result
}

slay format_number(value drip) tea {
    # Simplified number formatting to 2 decimal places
    sus integer_part drip = floor_func(value)
    sus decimal_part drip = floor_func((value - integer_part) * 100)
    
    sus result tea = int_to_string(integer_part)
    result = result + "."
    
    ready (decimal_part < 10) {
        result = result + "0"
    }
    result = result + int_to_string(decimal_part)
    
    damn result
}

slay print_matrix(m Matrix) {
    vibez.spill("  [")
    bestie (sus i drip = 0; i < m.rows; i = i + 1) {
        sus row tea = "    "
        bestie (sus j drip = 0; j < m.cols; j = j + 1) {
            ready (j > 0) {
                row = row + "  "
            }
            row = row + format_number(m.data[i * m.cols + j])
        }
        vibez.spill(row)
    }
    vibez.spill("  ]")
}

slay min_value(a drip, b drip) drip {
    ready (a < b) {
        damn a
    }
    damn b
}

