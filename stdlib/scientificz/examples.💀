# Example 1: Basic statistical analysis
slay demo_basic_statistics() {
    vibez.spill("\n=== Basic Statistical Analysis ===")
    
    # Sample dataset: exam scores
    sus exam_scores drip[value] = [78, 85, 92, 67, 88, 91, 76, 82, 95, 89, 84, 77, 90, 86, 93]
    
    vibez.spill("Exam scores dataset:")
    vibez.spill("Data:", array_to_string(exam_scores))
    
    # Calculate comprehensive statistics
    sus stats Statistics = calculate_statistics(exam_scores)
    
    vibez.spill("\nDescriptive Statistics:")
    vibez.spill("  Sample size:", stats.count)
    vibez.spill("  Mean:", format_number(stats.mean), "points")
    vibez.spill("  Median:", format_number(stats.median), "points")
    vibez.spill("  Mode:", format_number(stats.mode), "points")
    vibez.spill("  Standard deviation:", format_number(stats.std_dev), "points")
    vibez.spill("  Variance:", format_number(stats.variance))
    vibez.spill("  Range:", format_number(stats.range), "points")
    vibez.spill("  IQR (Q3-Q1):", format_number(stats.iqr), "points")
    vibez.spill("  Skewness:", format_number(stats.skewness))
    vibez.spill("  Kurtosis:", format_number(stats.kurtosis))
    
    # Interpret results
    ready (stats.skewness > 0.5) {
        vibez.spill("  Distribution: Positively skewed (right tail)")
    } otherwise ready (stats.skewness < -0.5) {
        vibez.spill("  Distribution: Negatively skewed (left tail)")
    } otherwise {
        vibez.spill("  Distribution: Approximately symmetric")
    }
}

# Example 2: Correlation and regression analysis
slay demo_correlation_regression() {
    vibez.spill("\n=== Correlation and Regression Analysis ===")
    
    # Study hours vs exam scores
    sus study_hours drip[value] = [2, 4, 6, 8, 10, 12, 3, 5, 7, 9, 11, 13, 1, 15, 14]
    sus exam_scores drip[value] = [65, 70, 75, 80, 85, 90, 68, 73, 78, 83, 88, 92, 60, 95, 93]
    
    vibez.spill("Study Hours vs Exam Scores Analysis:")
    vibez.spill("Study hours:", array_to_string(study_hours))
    vibez.spill("Exam scores:", array_to_string(exam_scores))
    
    # Calculate correlation
    sus correlation drip = pearson_correlation(study_hours, exam_scores)
    vibez.spill("\nPearson correlation coefficient:", format_number(correlation))
    
    # Interpret correlation strength
    sus abs_corr drip = abs_val(correlation)
    ready (abs_corr > 0.9) {
        vibez.spill("Correlation strength: Very strong")
    } otherwise ready (abs_corr > 0.7) {
        vibez.spill("Correlation strength: Strong")
    } otherwise ready (abs_corr > 0.5) {
        vibez.spill("Correlation strength: Moderate")
    } otherwise ready (abs_corr > 0.3) {
        vibez.spill("Correlation strength: Weak")
    } otherwise {
        vibez.spill("Correlation strength: Very weak")
    }
    
    # Linear regression
    sus regression Regression = linear_regression(study_hours, exam_scores)
    
    vibez.spill("\nLinear Regression Results:")
    vibez.spill("  Equation: Score = ", format_number(regression.slope), " * Hours + ", format_number(regression.intercept))
    vibez.spill("  R-squared:", format_number(regression.r_squared))
    vibez.spill("  Standard error:", format_number(regression.std_error))
    
    # Interpretation
    sus r_squared_percent drip = regression.r_squared * 100
    vibez.spill("  Interpretation:", format_number(r_squared_percent), "% of score variance explained by study hours")
    
    # Predictions
    vibez.spill("\nPredictions:")
    sus prediction_hours drip[value] = [5, 10, 15]
    bestie (sus i drip = 0; i < 3; i = i + 1) {
        sus hours drip = prediction_hours[i]
        sus predicted_score drip = regression.slope * hours + regression.intercept
        vibez.spill("  ", hours, " hours study ->", format_number(predicted_score), "points expected")
    }
}

# Example 3: Probability distributions
slay demo_probability_distributions() {
    vibez.spill("\n=== Probability Distributions ===")
    
    # Normal distribution analysis
    sus mean drip = 100
    sus std_dev drip = 15
    sus normal Distribution = normal_distribution(mean, std_dev)
    
    vibez.spill("Normal Distribution Analysis (μ=100, σ=15):")
    vibez.spill("Distribution type:", normal.distribution_type)
    vibez.spill("Mean:", format_number(normal.mean))
    vibez.spill("Standard deviation:", format_number(normal.std_dev))
    vibez.spill("Variance:", format_number(normal.variance))
    
    # Calculate probabilities for different values
    sus test_values drip[value] = [85, 100, 115, 130]
    vibez.spill("\nProbability Density Function (PDF) values:")
    bestie (sus i drip = 0; i < 4; i = i + 1) {
        sus x drip = test_values[i]
        sus pdf_val drip = normal_pdf(x, mean, std_dev)
        sus cdf_val drip = normal_cdf(x, mean, std_dev)
        vibez.spill("  x =", x, ": PDF =", format_number(pdf_val), ", CDF =", format_number(cdf_val))
    }
    
