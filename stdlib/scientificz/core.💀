# Core statistical functions
slay calculate_statistics(data drip[value]) Statistics {
    sus n drip = len_array(data)
    ready (n == 0) {
        damn create_empty_statistics()
    }
    
    # Sort data for median and quartile calculations
    sus sorted_data drip[value] = sort_array(data)
    
    # Basic statistics
    sus mean drip = calculate_mean(data)
    sus median drip = calculate_median(sorted_data)
    sus mode drip = calculate_mode(data)
    sus variance drip = calculate_variance(data, mean)
    sus std_dev drip = sqrt_newton(variance)
    
    # Min/max/range
    sus min_val drip = sorted_data[0]
    sus max_val drip = sorted_data[n - 1]
    sus range_val drip = max_val - min_val
    
    # Quartiles
    sus q1 drip = calculate_quartile(sorted_data, 0.25)
    sus q3 drip = calculate_quartile(sorted_data, 0.75)
    sus iqr drip = q3 - q1
    
    # Higher-order moments
    sus skewness drip = calculate_skewness(data, mean, std_dev)
    sus kurtosis drip = calculate_kurtosis(data, mean, std_dev)
    
    damn Statistics{
        mean: mean,
        median: median,
        mode: mode,
        variance: variance,
        std_dev: std_dev,
        min_value: min_val,
        max_value: max_val,
        range: range_val,
        q1: q1,
        q3: q3,
        iqr: iqr,
        skewness: skewness,
        kurtosis: kurtosis,
        count: n
    }
}

slay calculate_mean(data drip[value]) drip {
    sus sum drip = 0
    sus n drip = len_array(data)
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sum = sum + data[i]
    }
    
    damn sum / n
}

slay calculate_median(sorted_data drip[value]) drip {
    sus n drip = len_array(sorted_data)
    
    ready (n % 2 == 1) {
        damn sorted_data[n / 2]
    } otherwise {
        sus mid1 drip = sorted_data[(n / 2) - 1]
        sus mid2 drip = sorted_data[n / 2]
        damn (mid1 + mid2) / 2
    }
}

slay calculate_mode(data drip[value]) drip {
    # Simplified mode calculation - finds most frequent value
    sus n drip = len_array(data)
    sus max_count drip = 0
    sus mode_value drip = data[0]
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus count drip = 0
        bestie (sus j drip = 0; j < n; j = j + 1) {
            ready (data[i] == data[j]) {
                count = count + 1
            }
        }
        
        ready (count > max_count) {
            max_count = count
            mode_value = data[i]
        }
    }
    
    damn mode_value
}

slay calculate_variance(data drip[value], mean drip) drip {
    sus sum_sq_diff drip = 0
    sus n drip = len_array(data)
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus diff drip = data[i] - mean
        sum_sq_diff = sum_sq_diff + (diff * diff)
    }
    
    damn sum_sq_diff / (n - 1)  # Sample variance
}

slay calculate_quartile(sorted_data drip[value], percentile drip) drip {
    sus n drip = len_array(sorted_data)
    sus index drip = percentile * (n - 1)
    sus lower_index drip = floor_func(index)
    sus upper_index drip = ceil_func(index)
    
    ready (lower_index == upper_index) {
        damn sorted_data[lower_index]
    } otherwise {
        sus weight drip = index - lower_index
        damn sorted_data[lower_index] * (1 - weight) + sorted_data[upper_index] * weight
    }
}

slay calculate_skewness(data drip[value], mean drip, std_dev drip) drip {
    sus n drip = len_array(data)
    sus sum_cubed drip = 0
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus standardized drip = (data[i] - mean) / std_dev
        sum_cubed = sum_cubed + (standardized * standardized * standardized)
    }
    
    damn sum_cubed / n
}

slay calculate_kurtosis(data drip[value], mean drip, std_dev drip) drip {
    sus n drip = len_array(data)
    sus sum_fourth drip = 0
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus standardized drip = (data[i] - mean) / std_dev
        sus fourth_power drip = standardized * standardized * standardized * standardized
        sum_fourth = sum_fourth + fourth_power
    }
    
    damn (sum_fourth / n) - 3  # Excess kurtosis
}

# Correlation and regression analysis
slay pearson_correlation(x_data drip[value], y_data drip[value]) drip {
    sus n drip = len_array(x_data)
    ready (n != len_array(y_data) || n < 2) {
        damn 0  # Invalid data
    }
    
    sus x_mean drip = calculate_mean(x_data)
    sus y_mean drip = calculate_mean(y_data)
    
    sus numerator drip = 0
    sus x_sq_sum drip = 0
    sus y_sq_sum drip = 0
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus x_diff drip = x_data[i] - x_mean
        sus y_diff drip = y_data[i] - y_mean
        
        numerator = numerator + (x_diff * y_diff)
        x_sq_sum = x_sq_sum + (x_diff * x_diff)
        y_sq_sum = y_sq_sum + (y_diff * y_diff)
    }
    
    sus denominator drip = sqrt_newton(x_sq_sum * y_sq_sum)
    ready (denominator == 0) {
        damn 0
    }
    
    damn numerator / denominator
}

slay linear_regression(x_data drip[value], y_data drip[value]) Regression {
    sus n drip = len_array(x_data)
    sus x_mean drip = calculate_mean(x_data)
    sus y_mean drip = calculate_mean(y_data)
    
    sus numerator drip = 0
    sus denominator drip = 0
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus x_diff drip = x_data[i] - x_mean
        sus y_diff drip = y_data[i] - y_mean
        
        numerator = numerator + (x_diff * y_diff)
        denominator = denominator + (x_diff * x_diff)
    }
    
    sus slope drip = numerator / denominator
    sus intercept drip = y_mean - (slope * x_mean)
    
    # Calculate R-squared
    sus correlation drip = pearson_correlation(x_data, y_data)
    sus r_squared drip = correlation * correlation
    
    # Calculate residuals and standard error
    sus residuals drip[value] = calculate_residuals(x_data, y_data, slope, intercept)
    sus std_error drip = calculate_standard_error(residuals, n)
    
    damn Regression{
        slope: slope,
        intercept: intercept,
        r_squared: r_squared,
        correlation: correlation,
        residuals: residuals,
        std_error: std_error,
        p_value: 0.05  # Simplified
    }
}

slay calculate_residuals(x_data drip[value], y_data drip[value], slope drip, intercept drip) drip[value]{
    sus n drip = len_array(x_data)
    sus residuals drip[value] = create_array(n)
    
    bestie (sus i drip = 0; i < n; i = i + 1) {
        sus predicted drip = slope * x_data[i] + intercept
        residuals[i] = y_data[i] - predicted
    }
    
    damn residuals
}

slay calculate_standard_error(residuals drip[value], n drip) drip {
    sus sum_sq_residuals drip = 0
    
    bestie (sus i drip = 0; i < len_array(residuals); i = i + 1) {
        sum_sq_residuals = sum_sq_residuals + (residuals[i] * residuals[i])
    }
    
    damn sqrt_newton(sum_sq_residuals / (n - 2))
}

