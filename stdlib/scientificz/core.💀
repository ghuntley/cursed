slay matrix_multiply(a Matrix, b Matrix) Matrix {
    ready (a.cols != b.rows) {
        vibez.spill("[Matrix] Error: Invalid dimensions for multiplication")
        damn create_zero_matrix(1, 1)
    }
    
    sus result_rows drip = a.rows
    sus result_cols drip = b.cols
    sus result_data drip[value] = create_array(result_rows * result_cols)
    
    bestie (sus i drip = 0; i < result_rows; i = i + 1) {
        bestie (sus j drip = 0; j < result_cols; j = j + 1) {
            sus sum drip = 0
            
            bestie (sus k drip = 0; k < a.cols; k = k + 1) {
                sus a_val drip = a.data[i * a.cols + k]
                sus b_val drip = b.data[k * b.cols + j]
                sum = sum + (a_val * b_val)
            }
            
            result_data[i * result_cols + j] = sum
        }
    }
    
    damn create_matrix(result_rows, result_cols, result_data)
}

slay calculate_determinant(rows drip, cols drip, data drip[value]) drip {
    ready (rows == 1) {
        damn data[0]
    }
    
    ready (rows == 2) {
        damn (data[0] * data[3]) - (data[1] * data[2])
    }
    
    ready (rows == 3) {
        sus a drip = data[0]
        sus b drip = data[1]
        sus c drip = data[2]
        sus d drip = data[3]
        sus e drip = data[4]
        sus f drip = data[5]
        sus g drip = data[6]
        sus h drip = data[7]
        sus i drip = data[8]
        
        damn a * (e * i - f * h) - b * (d * i - f * g) + c * (d * h - e * g)
    }
    
    damn 0  # For larger matrices, would need more complex algorithm
}

