slay normal_pdf(x drip, mean drip, std_dev drip) drip {
    # Probability density function for normal distribution
    sus z drip = (x - mean) / std_dev
    sus coefficient drip = 1 / (std_dev * sqrt_newton(2 * PI))
    sus exponent drip = -(z * z) / 2
    damn coefficient * exp_taylor(exponent)
}

slay normal_cdf(x drip, mean drip, std_dev drip) drip {
    # Cumulative distribution function (simplified approximation)
    sus z drip = (x - mean) / std_dev
    damn 0.5 * (1 + erf_approx(z / sqrt_newton(2)))
}

slay erf_approx(x drip) drip {
    # Error function approximation
    sus a1 drip = 0.254829592
    sus a2 drip = -0.284496736
    sus a3 drip = 1.421413741
    sus a4 drip = -1.453152027
    sus a5 drip = 1.061405429
    sus p drip = 0.3275911
    
    sus sign drip = 1
    ready (x < 0) {
        sign = -1
        x = -x
    }
    
    sus t drip = 1 / (1 + p * x)
    sus y drip = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * exp_taylor(-x * x)
    
    damn sign * y
}

# Statistical tests
slay t_test_one_sample(sample drip[value], population_mean drip) TTestResult {
    sus n drip = len_array(sample)
    sus sample_mean drip = calculate_mean(sample)
    sus sample_std drip = sqrt_newton(calculate_variance(sample, sample_mean))
    
    sus t_stat drip = (sample_mean - population_mean) / (sample_std / sqrt_newton(n))
    sus df drip = n - 1
    
    # Simplified p-value calculation
    sus p_val drip = 2 * (1 - t_cdf_approx(abs_val(t_stat), df))
    
    damn TTestResult{
        t_statistic: t_stat,
        degrees_freedom: df,
        p_value: p_val,
        critical_value: 2.0,  # Simplified
        significant: p_val < 0.05,
        confidence_interval: [sample_mean - 1.96 * (sample_std / sqrt_newton(n)), 
                            sample_mean + 1.96 * (sample_std / sqrt_newton(n))]
    }
}

slay t_cdf_approx(t drip, df drip) drip {
    # Simplified t-distribution CDF approximation
    ready (df > 30) {
        damn normal_cdf(t, 0, 1)  # Approximate with normal for large df
    }
    
    # Very rough approximation for small df
    damn 0.5 + (t / (2 * sqrt_newton(df + t * t))) * 0.5
}

