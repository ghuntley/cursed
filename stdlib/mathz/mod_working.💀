fr fr Absolute Value Functions - using simple structure without if_merge issues
slay abs_normie(x normie) normie {
    ready x < 0 {
        damn -x
    } otherwise {
        damn x
    }
}

slay abs_meal(x meal) meal {
    ready x < 0.0 {
        damn -x
    } otherwise {
        damn x
    }
}
