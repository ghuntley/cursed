yeet "mathz"

vibez.spill("Testing mathz module...")

# Test constants
vibez.spill("Testing constants:")
vibez.spill("PI =", PI)
vibez.spill("E =", E) 
vibez.spill("TAU =", TAU)

# Test absolute value
vibez.spill("Testing abs functions:")
vibez.spill("abs_normie(-5) =", abs_normie(-5))
vibez.spill("abs_normie(5) =", abs_normie(5))

# Test max/min functions  
vibez.spill("Testing max/min functions:")
vibez.spill("max_normie(5, 3) =", max_normie(5, 3))
vibez.spill("min_normie(5, 3) =", min_normie(5, 3))

# Test power function
vibez.spill("Testing power function:")
sus pow_result meal = pow_meal(2.0, 3)
vibez.spill("pow_meal(2.0, 3) =", pow_result)

# Test square root
vibez.spill("Testing square root:")
sus sqrt_result meal = sqrt_meal(9.0)
vibez.spill("sqrt_meal(9.0) =", sqrt_result)

# Test utility functions
vibez.spill("Testing utility functions:")
vibez.spill("is_positive_meal(5.5) =", is_positive_meal(5.5))
vibez.spill("is_negative_meal(-3.3) =", is_negative_meal(-3.3))
vibez.spill("is_zero_meal(0.0) =", is_zero_meal(0.0))

vibez.spill("mathz module tests complete!")
