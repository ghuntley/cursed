yeet "mathz"

vibez.spill("🧪 Testing mathz module")

// Test mathematical constants
vibez.spill("📐 Testing Constants:")
vibez.spill("Pi: " + Pi.(tea))
vibez.spill("E: " + E.(tea))

// Test basic operations
vibez.spill("🔢 Testing Basic Operations:")
sus abs_test meal = Abs(0.0 - 5.5)
vibez.spill("Abs(-5.5): " + abs_test.(tea))

sus max_test meal = Max(3.0, 7.0)  
vibez.spill("Max(3.0, 7.0): " + max_test.(tea))

sus min_test meal = Min(3.0, 7.0)
vibez.spill("Min(3.0, 7.0): " + min_test.(tea))

// Test square root
vibez.spill("√ Testing Square Root:")
sus sqrt_test meal = Sqrt(16.0)
vibez.spill("Sqrt(16.0): " + sqrt_test.(tea))

sus sqrt_test2 meal = Sqrt(9.0)
vibez.spill("Sqrt(9.0): " + sqrt_test2.(tea))

// Test power function
vibez.spill("💪 Testing Power Function:")
sus pow_test meal = Pow(2.0, 3)
vibez.spill("Pow(2.0, 3): " + pow_test.(tea))

sus pow_test2 meal = Pow(5.0, 2)
vibez.spill("Pow(5.0, 2): " + pow_test2.(tea))

// Test rounding functions
vibez.spill("🎯 Testing Rounding Functions:")
sus ceil_test meal = Ceil(3.2)
vibez.spill("Ceil(3.2): " + ceil_test.(tea))

sus floor_test meal = Floor(3.8)
vibez.spill("Floor(3.8): " + floor_test.(tea))

sus round_test meal = Round(3.6)
vibez.spill("Round(3.6): " + round_test.(tea))

// Test sign function
vibez.spill("📊 Testing Sign Function:")
sus sign_pos normie = Sign(5.5)
vibez.spill("Sign(5.5): " + sign_pos.(tea))

sus sign_neg normie = Sign(0.0 - 3.2)
vibez.spill("Sign(-3.2): " + sign_neg.(tea))

sus sign_zero normie = Sign(0.0)
vibez.spill("Sign(0.0): " + sign_zero.(tea))

// Test utility functions
vibez.spill("🔧 Testing Utility Functions:")
sus clamp_test meal = Clamp(15.0, 1.0, 10.0)
vibez.spill("Clamp(15.0, 1.0, 10.0): " + clamp_test.(tea))

sus lerp_test meal = Lerp(0.0, 10.0, 0.5)
vibez.spill("Lerp(0.0, 10.0, 0.5): " + lerp_test.(tea))

// Test conversion functions
vibez.spill("🔄 Testing Conversion Functions:")
sus rad_test meal = DegToRad(90.0)
vibez.spill("DegToRad(90.0): " + rad_test.(tea))

sus deg_test meal = RadToDeg(Pi)
vibez.spill("RadToDeg(Pi): " + deg_test.(tea))

// Test factorial
vibez.spill("🎲 Testing Factorial:")
sus fact_test normie = Factorial(5)
vibez.spill("Factorial(5): " + fact_test.(tea))

// Test prime checking
vibez.spill("🔍 Testing Prime Numbers:")
sus prime_test1 lit = IsPrime(17)
vibez.spill("IsPrime(17): " + prime_test1.(tea))

sus prime_test2 lit = IsPrime(16)
vibez.spill("IsPrime(16): " + prime_test2.(tea))

// Test distance functions
vibez.spill("📏 Testing Distance Functions:")
sus hypot_test meal = Hypot(3.0, 4.0)
vibez.spill("Hypot(3.0, 4.0): " + hypot_test.(tea))

sus dist_test meal = Distance(0.0, 0.0, 3.0, 4.0)
vibez.spill("Distance(0,0 to 3,4): " + dist_test.(tea))

vibez.spill("🎉 mathz module testing complete!")
