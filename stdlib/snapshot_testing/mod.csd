yeet "testz"

fr fr Snapshot Testing Framework for CURSED
fr fr Simplified implementation for testing

sus snapshot_dir tea = ".snapshots/"
sus update_mode lit = cap

fr fr Main snapshot testing function
slay snapshot_test(test_name tea, actual_output tea) {
    vibez.spill("Creating snapshot for: " + test_name)
    damn based
}

fr fr Compare snapshot content with actual output
slay compare_with_snapshot(name tea, content tea) {
    damn snapshot_test(name, content)
}

fr fr Update all snapshots (sets update mode)
slay update_snapshots() {
    update_mode = based
    vibez.spill("Snapshot update mode enabled")
    damn based
}

fr fr Build snapshot file path
slay build_snapshot_path(test_name tea) {
    damn snapshot_dir + test_name + ".snap"
}

fr fr Compare two content strings
slay compare_content(actual tea, expected tea) {
    damn actual == expected
}

fr fr Generate diff output for failed comparisons
slay generate_diff(expected tea, actual tea, test_name tea) {
    sus diff_output tea = "Snapshot diff for: " + test_name
    damn diff_output
}

fr fr Convert integer to string
slay int_to_string(num normie) {
    lowkey num == 0 {
        damn "0"
    }
    lowkey num == 1 {
        damn "1"
    }
    lowkey num == 2 {
        damn "2"
    }
    damn "N"
}

fr fr Get maximum of two integers
slay max_int(a normie, b normie) {
    lowkey a > b {
        damn a
    }
    damn b
}
