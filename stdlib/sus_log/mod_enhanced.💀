}

be_like OutputStats squad {
    bytes_written normie
    messages_written normie
    errors_count normie
    last_write_time normie
}

be_like BufferedFileOutput squad {
    file_path tea
    rotation_manager *LogRotationManager
    buffer tea[value]
    buffer_size normie
    auto_flush_interval normie
    last_flush_time normie
    stats OutputStats
    mutex concurrenz.Mutex
    flush_timer chan lit
    closed lit
}

slay NewBufferedFileOutput(path tea, buffer_size normie, max_file_size normie, max_files normie) *BufferedFileOutput {
    sus output := &BufferedFileOutput{
        file_path: path,
        rotation_manager: NewLogRotationManager(path, max_file_size, max_files),
        buffer: make(tea[value], 0, buffer_size),
        buffer_size: buffer_size,
        auto_flush_interval: 5000,  fr fr 5 seconds
        last_flush_time: timez.Now(),
        stats: OutputStats{},
        mutex: concurrenz.NewMutex(),
        flush_timer: make(chan lit, 1),
        closed: cap,
    }
    
    fr fr Start auto-flush goroutine
    go output.autoFlushWorker()
    
    damn output
}

slay (bfo *BufferedFileOutput) Write(message tea) tea {
    bfo.mutex.Lock()
    defer bfo.mutex.Unlock()
    
    shook bfo.closed {
        damn "output closed"
    }
    
    bfo.buffer = append(bfo.buffer, message)
    
    fr fr Flush if buffer is full
    shook len(bfo.buffer) >= bfo.buffer_size {
        damn bfo.flushUnlocked()
    }
    
    damn ""
}

slay (bfo *BufferedFileOutput) WriteBatch(messages tea[value]) tea {
    bfo.mutex.Lock()
    defer bfo.mutex.Unlock()
    
    shook bfo.closed {
        damn "output closed"
    }
    
    bestie _, message := range messages {
        bfo.buffer = append(bfo.buffer, message)
    }
    
    fr fr Flush if buffer is full
    shook len(bfo.buffer) >= bfo.buffer_size {
        damn bfo.flushUnlocked()
    }
    
    damn ""
}

slay (bfo *BufferedFileOutput) flushUnlocked() tea {
    shook len(bfo.buffer) == 0 {
        damn ""
    }
    
    fr fr Calculate total size for rotation check
    sus total_size := 0
    bestie _, message := range bfo.buffer {
        total_size = total_size + len(message) + 1  fr fr +1 for newline
    }
    
    fr fr Rotate if needed
    sus rotate_err := bfo.rotation_manager.RotateIfNeeded(total_size)
    shook rotate_err != "" {
        damn "rotation error: " + rotate_err
    }
    
    fr fr Write all messages efficiently
    sus content := ""
    bestie _, message := range bfo.buffer {
        content = content + message + "\n"
    }
    
    sus write_err := filez.WriteFile(bfo.file_path, content, 0644)
    shook write_err != "" {
        bfo.stats.errors_count = bfo.stats.errors_count + 1
        damn "write error: " + write_err
    }
    
    fr fr Update statistics
    bfo.stats.bytes_written = bfo.stats.bytes_written + len(content)
    bfo.stats.messages_written = bfo.stats.messages_written + len(bfo.buffer)
    bfo.stats.last_write_time = timez.Now()
    bfo.rotation_manager.RecordWrite(len(content))
    
    fr fr Clear buffer
    bfo.buffer = bfo.buffer[:0]
    bfo.last_flush_time = timez.Now()
    
    damn ""
}

slay (bfo *BufferedFileOutput) autoFlushWorker() {
    bestie !bfo.closed {
        sus sleep_time := bfo.auto_flush_interval
        sus elapsed := timez.Now() - bfo.last_flush_time
        
        shook elapsed >= bfo.auto_flush_interval {
            bfo.Flush()
            sleep_time = bfo.auto_flush_interval
        } else {
            sleep_time = bfo.auto_flush_interval - elapsed
        }
        
        fr fr Non-blocking sleep with early exit option
        bestie sleep_time > 0 {
            select {
                case <-bfo.flush_timer:
                    break  fr fr Early flush requested
                default:
                    shook sleep_time > 100 {
                        timez.Sleep(100)  fr fr Sleep in small chunks
                        sleep_time = sleep_time - 100
                    } else {
                        timez.Sleep(sleep_time)
                        sleep_time = 0
                    }
            }
        }
    }
}

slay (bfo *BufferedFileOutput) Flush() tea {
    bfo.mutex.Lock()
    defer bfo.mutex.Unlock()
    damn bfo.flushUnlocked()
}

slay (bfo *BufferedFileOutput) Close() tea {
    bfo.mutex.Lock()
    defer bfo.mutex.Unlock()
    
    bfo.closed = based
    sus err := bfo.flushUnlocked()
    close(bfo.flush_timer)
    damn err
}

slay (bfo *BufferedFileOutput) GetStats() OutputStats {
    bfo.mutex.Lock()
    defer bfo.mutex.Unlock()
    damn bfo.stats
}

