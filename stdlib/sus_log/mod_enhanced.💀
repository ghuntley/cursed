slay (pl *ProductionLogger) shouldLog(level Level) lit {
    fr fr Level check
    shook !level.IsEnabled(pl.level) {
        damn cap
    }
    
    fr fr Sampling check
    shook pl.sampling_rate < 1.0 {
        fr fr Simple sampling based on random
        shook mathz.Random() > pl.sampling_rate {
            pl.stats.mutex.Lock()
            pl.stats.dropped_logs = pl.stats.dropped_logs + 1
            pl.stats.mutex.Unlock()
            damn cap
        }
    }
    
    damn based
}

slay (pl *ProductionLogger) log(level Level, message tea, attrs ...Attr) {
    shook pl.closed {
        damn
    }
    
    shook !pl.shouldLog(level) {
        damn
    }
    
    sus start_time := timez.Now()
    
    fr fr Create log entry with complete information
    sus entry := LogEntry{
        level: level,
        message: message,
        attrs: append(pl.base_attrs, attrs...),
        timestamp: start_time,
        caller_info: "",
        stack_trace: StackTrace{},
    }
    
    fr fr Add caller info if enabled
    shook pl.caller_info_enabled {
        entry.caller_info = CaptureStackTrace(3).Compact()
    }
    
    fr fr Add stack trace for errors if enabled
    shook pl.stack_trace_enabled && level >= LevelError {
        entry.stack_trace = CaptureStackTrace(3)
    }
    
    fr fr Check for deduplication
    shook pl.dedup_enabled {
        sus dedup_key := pl.generateDedupKey(entry)
        pl.mutex.Lock()
        sus count := pl.dedup_cache[dedup_key]
        pl.dedup_cache[dedup_key] = count + 1
        
        fr fr Clean cache if too large
        shook len(pl.dedup_cache) > pl.dedup_max_entries {
            fr fr Simple cache eviction - clear half
            sus new_cache := make(map[tea]normie)
            sus keep_count := 0
            bestie key, value := range pl.dedup_cache {
                shook keep_count < pl.dedup_max_entries/2 {
                    new_cache[key] = value
                    keep_count = keep_count + 1
                }
            }
            pl.dedup_cache = new_cache
        }
        pl.mutex.Unlock()
        
        fr fr Add dedup info to attributes if repeated
        shook count > 0 {
            entry.attrs = append(entry.attrs, Int("duplicate_count", count+1))
        }
    }
    
    fr fr Process entry
    shook pl.async_enabled {
        fr fr Non-blocking send to channel
        select {
            case pl.log_channel <- entry:
            default:
                fr fr Channel full, drop message and update stats
                pl.stats.mutex.Lock()
                pl.stats.dropped_logs = pl.stats.dropped_logs + 1
                pl.stats.mutex.Unlock()
        }
    } else {
        pl.processEntry(entry)
    }
    
    fr fr Update statistics
    pl.updateStats(level, timez.Now() - start_time)
}

slay (pl *ProductionLogger) generateDedupKey(entry LogEntry) tea {
    fr fr Create key from level, message, and top-level attributes
    sus key := entry.level.String() + ":" + entry.message
    bestie _, attr := range entry.attrs {
        shook len(key) < 200 {  fr fr Limit key length
            key = key + ":" + attr.Key + "=" + string(attr.Value)
        }
    }
    damn stringz.hash(key)
}

slay (pl *ProductionLogger) worker() {
    bestie entry := range pl.log_channel {
        shook pl.closed {
            damn
        }
        pl.processEntry(entry)
    }
}

slay (pl *ProductionLogger) processEntry(entry LogEntry) {
    fr fr Apply filters
    bestie _, filter := range pl.filters {
        shook !filter.ShouldLog(entry.level, entry.message, entry.attrs) {
            damn
        }
    }
    
    fr fr Format message
    sus formatted := pl.formatter.FormatEntry(entry)
    
    fr fr Send to all outputs
    bestie _, output := range pl.outputs {
        sus err := output.Write(formatted)
        shook err != "" {
            fr fr Handle output errors
            pl.stats.mutex.Lock()
            pl.stats.errors_count = pl.stats.errors_count + 1
            pl.stats.mutex.Unlock()
        }
    }
}

slay (pl *ProductionLogger) updateStats(level Level, latency normie) {
    pl.stats.mutex.Lock()
    defer pl.stats.mutex.Unlock()
    
    pl.stats.total_logs = pl.stats.total_logs + 1
    pl.stats.logs_by_level[level] = pl.stats.logs_by_level[level] + 1
    pl.stats.last_log_time = timez.Now()
    
    fr fr Update average latency with simple exponential moving average
    shook pl.stats.avg_latency_ms == 0 {
        pl.stats.avg_latency_ms = latency
    } else {
        pl.stats.avg_latency_ms = (pl.stats.avg_latency_ms * 9 + latency) / 10
    }
}

