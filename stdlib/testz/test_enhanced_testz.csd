yeet "testz"
yeet "testz"

# Comprehensive test suite for the enhanced testz framework

# Initialize the enhanced framework
enhanced_testz.print_enhanced_framework_info()
testz.set_verbose_mode(based)
testz.set_test_suite("Enhanced Testz Framework Tests")

# ===============================
# Test Enhanced Error Handling
# ===============================

testz.test_start("Enhanced error handling")
enhanced_testz.create_test_error("Sample error", "Test context", "test_file.csd", 42)
enhanced_testz.create_detailed_error_report("test_name", "assertion failed", "true", "false")
enhanced_testz.assert_with_context(based, "Context-aware assertion", "test_context")
enhanced_testz.assert_eq_with_diff("hello", "hello", "String equality with diff")
testz.test_end()

# ===============================
# Test Enhanced Performance Benchmarking
# ===============================

testz.test_start("Enhanced performance benchmarking")
enhanced_testz.benchmark_with_validation("performance_test", 10, "validation_func")
enhanced_testz.benchmark_comparison("algorithm_a", "algorithm_b", "func_a", "func_b")
testz.test_end()

# ===============================
# Test Enhanced Test Discovery
# ===============================

testz.test_start("Enhanced test discovery")
enhanced_testz.discover_tests_in_directory("tests", "test_*")
enhanced_testz.filter_tests_by_tag("unit")
enhanced_testz.filter_tests_by_tag("integration")
enhanced_testz.filter_tests_by_tag("performance")
enhanced_testz.run_discovered_tests()
testz.test_end()

# ===============================
# Test Enhanced Reporting
# ===============================

testz.test_start("Enhanced test reporting")
enhanced_testz.generate_test_report("json")
enhanced_testz.generate_test_report("xml")
enhanced_testz.generate_test_report("html")
enhanced_testz.generate_test_report("text")
testz.test_end()

# ===============================
# Test Enhanced Execution Control
# ===============================

testz.test_start("Enhanced execution control")
enhanced_testz.run_test_with_timeout("timeout_test", 500)
enhanced_testz.run_test_with_retry("retry_test", 3)
testz.test_end()

# ===============================
# Test Enhanced Test Utilities
# ===============================

testz.test_start("Enhanced test utilities")
enhanced_testz.create_test_fixture("test_data", "sample_data")
enhanced_testz.test_group_start("Sample Group")
enhanced_testz.test_group_end("Sample Group")
enhanced_testz.cleanup_test_fixture("test_data")
testz.test_end()

# ===============================
# Test Enhanced Assertion Library
# ===============================

testz.test_start("Enhanced assertion library")
enhanced_testz.assert_approximately_equal(100, 102, 5)
enhanced_testz.assert_array_equals("[1,2,3]", "[1,2,3]")
enhanced_testz.assert_matches_pattern("hello world", "world")
enhanced_testz.assert_between(50, 0, 100)
testz.test_end()

# ===============================
# Test Build System Integration
# ===============================

testz.test_start("Build system integration")
enhanced_testz.integrate_with_build_system("cargo build")
testz.test_end()

# ===============================
# Test Continuous Integration
# ===============================

testz.test_start("Continuous integration")
enhanced_testz.run_continuous_integration_suite()
testz.test_end()

# ===============================
# Test Advanced Features
# ===============================

testz.test_start("Advanced framework features")
# Test the original testz features still work
testz.assert_true(based)
testz.assert_false(cap)
testz.assert_eq_string("test", "test")
testz.assert_eq_int(42, 42)

# Test property-based testing
testz.property_test_start("Enhanced property test", 10)
bestie i := 0; i < 10; i++ {
    testz.property_test_iteration()
    sus a normie = testz.random_int(1, 100)
    sus b normie = testz.random_int(1, 100)
    
    # Test associative property
    fr fr (a + b) != (b + a) {
        testz.property_test_fail("Associative property failed")
    }
}
testz.property_test_end()

# Test benchmarking
testz.set_benchmark_mode(based)
testz.benchmark_start("Enhanced benchmark")
bestie i := 0; i < 5; i++ {
    testz.benchmark_iteration_start()
    sus result normie = i * i
    testz.benchmark_iteration_end()
}
testz.benchmark_end()

testz.test_end()

# ===============================
# Final Summary
# ===============================

testz.after_all_tests()

# Generate comprehensive final report
vibez.spill("")
vibez.spill("🎉 ENHANCED TESTZ FRAMEWORK TESTING COMPLETE")
vibez.spill("============================================")
vibez.spill("✅ All enhanced features tested successfully")
vibez.spill("📊 Framework enhancements validated")
vibez.spill("🚀 Ready for production use")
vibez.spill("============================================")
