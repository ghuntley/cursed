fr fr Real parallel test execution
struct ParallelTestRunner {
    worker_count normie
    test_queue chan<TestTask>
    result_queue chan<TestResult>
    active_workers normie
    completed_tests normie
}

struct TestTask {
    test_function tea
    test_name tea
    file_path tea
    timeout normie
}

slay create_parallel_runner(workers normie) ParallelTestRunner {
    damn ParallelTestRunner{
        worker_count: workers,
        test_queue: make_channel(),
        result_queue: make_channel(),
        active_workers: 0,
        completed_tests: 0
    }
}

slay run_tests_parallel(test_functions [tea]) [TestResult] {
    ready (!__testz_parallel_enabled) {
        damn run_tests_sequential(test_functions)
    }
    
    sus runner ParallelTestRunner = create_parallel_runner(4)
    sus results [TestResult] = []
    
    fr fr Start worker goroutines
    sus worker_id normie = 0
    bestie (worker_id < runner.worker_count) {
        go {
            test_worker(worker_id, runner.test_queue, runner.result_queue)
        }
        worker_id = worker_id + 1
    }
    
    fr fr Queue test tasks
    sus i normie = 0
    bestie (i < len(test_functions)) {
        sus task TestTask = TestTask{
            test_function: test_functions[i],
            test_name: "test_" + int_to_string(i),
            file_path: get_current_file(),
            timeout: 30000  fr fr 30 second timeout
        }
        runner.test_queue <- task
        i = i + 1
    }
    
    fr fr Collect results
    sus completed normie = 0
    bestie (completed < len(test_functions)) {
        sus result TestResult = <-runner.result_queue
        results = append_test_result(results, result)
        completed = completed + 1
        
        ready (__testz_execution_mode == "debug") {
            vibez.spill("📊 [DEBUG] Test", completed, "of", len(test_functions), "completed")
        }
    }
    
    fr fr Close channels
    close_channel(runner.test_queue)
    close_channel(runner.result_queue)
    
    damn results
}

slay test_worker(worker_id normie, task_queue chan<TestTask>, result_queue chan<TestResult>) {
    ready (__testz_execution_mode == "debug") {
        vibez.spill("👷 [DEBUG] Worker", worker_id, "starting")
    }
    
    bestie (based) {
        sick (task_queue) {
            when task TestTask -> {
                ready (__testz_execution_mode == "debug") {
                    vibez.spill("👷 [DEBUG] Worker", worker_id, "executing:", task.test_name)
                }
                
                sus start_time normie = get_real_timestamp()
                sus result TestResult = execute_test_with_timeout(task)
                sus end_time normie = get_real_timestamp()
                
                result_queue <- result
                
                ready (__testz_execution_mode == "debug") {
                    vibez.spill("👷 [DEBUG] Worker", worker_id, "completed:", task.test_name, 
                               "in", end_time - start_time, "ms")
                }
            }
            when _ -> {
                fr fr Channel closed, exit worker
                break
            }
        }
    }
    
    ready (__testz_execution_mode == "debug") {
        vibez.spill("👷 [DEBUG] Worker", worker_id, "shutting down")
    }
}

