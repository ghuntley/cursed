fr fr ================================
fr fr Test Lifecycle Functions
fr fr ================================

slay suite_start(name tea) {
    current_suite_name = name
    vibez.spill("=== Starting Test Suite: " + name + " ===")
}

slay suite_end() {
    vibez.spill("=== Completed Test Suite: " + current_suite_name + " ===")
    vibez.spill("")
    
    fr fr Create suite result
    sus suite_result SuiteResult = SuiteResult{
        suite_name: current_suite_name,
        total_tests: test_count,
        passed_tests: test_passed,
        failed_tests: test_failed,
        skipped_tests: test_skipped,
        error_tests: test_errors,
        execution_time: 0,
        test_results: test_results
    }
    
    suite_results = suite_results + [suite_result]
}

slay test_start(name tea) {
    current_test_name = name
    test_count = test_count + 1
    test_start_time = get_current_time()
    
    lowkey config.verbose {
        vibez.spill("  Running test: " + name)
    }
}

slay test_end() {
    lowkey config.verbose {
        vibez.spill("  Completed test: " + current_test_name)
    }
}

slay test_skip(reason tea) {
    test_skipped = test_skipped + 1
    
    sus result TestResult = TestResult.skip(current_test_name, current_assertion_name, reason)
    test_results = test_results + [result]
    
    vibez.spill("  ⚠ SKIP: " + reason)
}

