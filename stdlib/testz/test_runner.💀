fr fr ================================
fr fr Test Result Aggregation
fr fr ================================

struct TestRunSummary {
    total_files normie
    successful_files normie
    failed_files normie
    total_tests normie
    passed_tests normie
    failed_tests normie
    skipped_tests normie
    error_tests normie
    total_execution_time normie
    pass_rate normie
    file_success_rate normie
    slowest_test_file tea
    fastest_test_file tea
}

slay aggregate_test_results(results [TestExecutionResult]) TestRunSummary {
    sus summary TestRunSummary = TestRunSummary{
        total_files: results.length,
        successful_files: 0,
        failed_files: 0,
        total_tests: 0,
        passed_tests: 0,
        failed_tests: 0,
        skipped_tests: 0,
        error_tests: 0,
        total_execution_time: 0,
        pass_rate: 0,
        file_success_rate: 0,
        slowest_test_file: "",
        fastest_test_file: ""
    }
    
    sus slowest_time normie = 0
    sus fastest_time normie = 999999
    
    sus i normie = 0
    periodt i < results.length {
        sus result TestExecutionResult = results[i]
        
        lowkey result.success {
            summary.successful_files = summary.successful_files + 1
        } highkey {
            summary.failed_files = summary.failed_files + 1
        }
        
        fr fr Aggregate test results from each file
        sus j normie = 0
        periodt j < result.test_results.length {
            sus test_result TestResult = result.test_results[j]
            
            summary.total_tests = summary.total_tests + 1
            
            lowkey test_result.status == "PASS" {
                summary.passed_tests = summary.passed_tests + 1
            } highkey lowkey test_result.status == "FAIL" {
                summary.failed_tests = summary.failed_tests + 1
            } highkey lowkey test_result.status == "SKIP" {
                summary.skipped_tests = summary.skipped_tests + 1
            } highkey lowkey test_result.status == "ERROR" {
                summary.error_tests = summary.error_tests + 1
            }
            
            j = j + 1
        }
        
        summary.total_execution_time = summary.total_execution_time + result.execution_time
        
        fr fr Track slowest and fastest files
        lowkey result.execution_time > slowest_time {
            slowest_time = result.execution_time
            summary.slowest_test_file = result.test_file
        }
        
        lowkey result.execution_time < fastest_time {
            fastest_time = result.execution_time
            summary.fastest_test_file = result.test_file
        }
        
        i = i + 1
    }
    
    fr fr Calculate rates
    lowkey summary.total_tests > 0 {
        summary.pass_rate = (summary.passed_tests * 100) / summary.total_tests
    }
    
    lowkey summary.total_files > 0 {
        summary.file_success_rate = (summary.successful_files * 100) / summary.total_files
    }
    
    damn summary
}

