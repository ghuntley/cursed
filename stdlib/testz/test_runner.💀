slay filter_test_files(files [tea], include_pattern tea, exclude_pattern tea) [tea] {
    sus filtered_files [tea] = []
    
    sus i normie = 0
    periodt i < files.length {
        sus file tea = files[i]
        sus should_include lit = matches_pattern(file, include_pattern)
        sus should_exclude lit = cap
        
        lowkey exclude_pattern != "" {
            should_exclude = matches_pattern(file, exclude_pattern)
        }
        
        lowkey should_include && !should_exclude {
            filtered_files = filtered_files + [file]
        }
        
        i = i + 1
    }
    
    vibez.spill("🔽 Filtered to " + tea(filtered_files.length) + " test files")
    
    damn filtered_files
}

slay matches_pattern(text tea, pattern tea) lit {
    fr fr Simplified pattern matching
    lowkey pattern == "*" {
        damn based
    }
    
    lowkey pattern == "test_*" {
        damn text.contains("test_")
    }
    
    lowkey pattern == "*test*" {
        damn text.contains("test")
    }
    
    lowkey pattern == "*crypto*" {
        damn text.contains("crypto")
    }
    
    lowkey pattern == "*math*" {
        damn text.contains("math")
    }
    
    lowkey pattern == "*string*" {
        damn text.contains("string")
    }
    
    damn text.contains(pattern)
}

