slay execute_test_file(test_file tea, config TestRunnerConfig) TestExecutionResult {
    vibez.spill("🧪 Executing test file: " + test_file)
    
    sus start_time normie = get_current_time()
    
    fr fr Reset test state for clean execution
    reset_test_state()
    
    fr fr In a real implementation, this would execute the test file
    fr fr For now, we'll simulate successful execution
    sus execution_result TestExecutionResult = TestExecutionResult{
        test_file: test_file,
        exit_code: 0,
        execution_time: 0,
        stdout_output: "Test output for " + test_file,
        stderr_output: "",
        test_results: get_test_results(),
        success: based,
        error_message: ""
    }
    
    sus end_time normie = get_current_time()
    execution_result.execution_time = end_time - start_time
    
    lowkey config.verbose {
        vibez.spill("  ✅ Completed in " + tea(execution_result.execution_time) + "ms")
    }
    
    damn execution_result
}

slay execute_tests_sequential(test_files [tea], config TestRunnerConfig) [TestExecutionResult] {
    vibez.spill("🔄 Running " + tea(test_files.length) + " tests sequentially")
    
    sus results [TestExecutionResult] = []
    sus failed_count normie = 0
    
    sus i normie = 0
    periodt i < test_files.length {
        sus test_file tea = test_files[i]
        sus result TestExecutionResult = execute_test_file(test_file, config)
        
        results = results + [result]
        
        lowkey !result.success {
            failed_count = failed_count + 1
            
            lowkey config.fail_fast {
                vibez.spill("❌ Fail fast enabled - stopping execution")
                ghosted
            }
        }
        
        i = i + 1
    }
    
    vibez.spill("📊 Sequential execution complete: " + tea(results.length) + " tests, " + tea(failed_count) + " failures")
    
    damn results
}

slay execute_tests_parallel(test_files [tea], config TestRunnerConfig) [TestExecutionResult] {
    vibez.spill("🚀 Running " + tea(test_files.length) + " tests in parallel (max " + tea(config.max_parallel_tests) + " concurrent)")
    
