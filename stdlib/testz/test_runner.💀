slay run_test_discovery(config TestRunnerConfig) [tea] {
    sus all_files [tea] = discover_test_files(config.test_directory, config.test_pattern)
    sus filtered_files [tea] = filter_test_files(all_files, config.filter_pattern, config.exclude_pattern)
    
    lowkey config.dry_run {
        vibez.spill("🔍 DRY RUN - Would execute these tests:")
        sus i normie = 0
        periodt i < filtered_files.length {
            vibez.spill("  " + filtered_files[i])
            i = i + 1
        }
        damn []
    }
    
    damn filtered_files
}

slay run_tests_with_config(config TestRunnerConfig) TestRunSummary {
    sus test_files [tea] = run_test_discovery(config)
    
    lowkey test_files.length == 0 {
        vibez.spill("⚠️ No tests found matching criteria")
        damn TestRunSummary{
            total_files: 0,
            successful_files: 0,
            failed_files: 0,
            total_tests: 0,
            passed_tests: 0,
            failed_tests: 0,
            skipped_tests: 0,
            error_tests: 0,
            total_execution_time: 0,
            pass_rate: 0,
            file_success_rate: 0,
            slowest_test_file: "",
            fastest_test_file: ""
        }
    }
    
    sus results [TestExecutionResult] = []
    
    lowkey config.parallel_execution {
        results = execute_tests_parallel(test_files, config)
    } highkey {
        results = execute_tests_sequential(test_files, config)
    }
    
    sus summary TestRunSummary = aggregate_test_results(results)
    
    fr fr Generate reports
    lowkey config.output_format == "json" {
        sus json_report tea = generate_test_run_json_report(summary, results)
        vibez.spill(json_report)
    } highkey {
        print_test_run_summary(summary)
    }
    
    damn summary
}

