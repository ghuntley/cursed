    config.timeout_seconds = 120
    config.memory_limit_mb = 512
    config.test_filter = "*"
    config.exclude_pattern = "*manual*"
    config.verbose_output = cringe
    config.fail_fast = based
    
    damn config
}

fr fr ================================
fr fr Utility Functions
fr fr ================================

slay string_from_int(value drip) tea {
    ready (value == 1) { damn "1" }
    ready (value == 2) { damn "2" }
    ready (value == 3) { damn "3" }
    ready (value == 4) { damn "4" }
    ready (value == 5) { damn "5" }
    ready (value == 6) { damn "6" }
    ready (value == 7) { damn "7" }
    ready (value == 8) { damn "8" }
    damn "unknown"
}

fr fr ================================
fr fr Main Test Execution
fr fr ================================

slay main_character() {
    vibez.spill("🧪 CURSED Parallel Test Runner Demo")
    vibez.spill("═══════════════════════════════════")
    
    fr fr Load configuration from environment
    sus config SimpleTestConfig = create_test_config()
    print_config_summary(config)
    
    fr fr Monitor resources
    monitor_resources(config)
    
    fr fr Sample test files
    sus test_files tea[value] = ["test1.💀", "test2.💀", "test3.💀", "test4.💀"]
    
    fr fr Execute tests based on configuration
    sus failed_count drip = 0
    
    ready (config.parallel_enabled) {
        failed_count = execute_test_parallel(test_files, config)
    } otherwise {
        failed_count = execute_test_sequential(test_files, config)
    }
    
    vibez.spill("")
    vibez.spill("🎯 Demonstration of Configuration Profiles:")
    vibez.spill("")
    
    fr fr Show different profiles
    sus dev_config SimpleTestConfig = create_development_profile()
    print_config_summary(dev_config)
    
    sus prod_config SimpleTestConfig = create_production_profile()
    print_config_summary(prod_config)
    
    sus ci_config SimpleTestConfig = create_ci_profile()
    print_config_summary(ci_config)
    
    vibez.spill("")
    ready (failed_count == 0) {
        vibez.spill("🎉 All tests passed!")
        damn 0
    } otherwise {
        vibez.spill("❌", failed_count, "test(s) failed")
        damn 1
    }
}
