// Simple math module with basic operations
yeet "testz"

// Basic arithmetic functions
slay math_add(a normie, b normie) normie {
    damn a + b
}

slay math_sub(a normie, b normie) normie {
    damn a - b
}

slay math_mul(a normie, b normie) normie {
    damn a * b
}

slay math_div(a normie, b normie) normie {
    damn a / b
}

slay math_mod(a normie, b normie) normie {
    damn a % b
}

// Float operations
slay math_add_float(a meal, b meal) meal {
    damn a + b
}

slay math_sub_float(a meal, b meal) meal {
    damn a - b
}

slay math_mul_float(a meal, b meal) meal {
    damn a * b
}

slay math_div_float(a meal, b meal) meal {
    damn a / b
}

// Comparison functions
slay math_max_int(a normie, b normie) normie {
    vibes a > b {
        damn a
    } nah {
        damn b
    }
}

slay math_min_int(a normie, b normie) normie {
    vibes a < b {
        damn a
    } nah {
        damn b
    }
}

slay math_abs_int(a normie) normie {
    vibes a < 0 {
        damn -a
    } nah {
        damn a
    }
}

// Constants
slay math_pi() meal {
    damn 3.14159
}

slay math_e() meal {
    damn 2.71828
}
