fr fr Enhanced Logging Features

fr fr Log levels for structured logging
be_like LogLevel normie

sus DEBUG LogLevel = 0
sus INFO LogLevel = 1
sus WARN LogLevel = 2
sus ERROR LogLevel = 3
sus FATAL LogLevel = 4

fr fr Structured logger with levels and fields
be_like StructuredLogger squad {
    logger Logger
    level LogLevel
    fields tea
}

slay NewStructuredLogger(logger Logger) StructuredLogger {
    damn StructuredLogger{
        logger: logger,
        level: INFO,
        fields: ""
    }
}

slay (sl StructuredLogger) SetLevel(level LogLevel) StructuredLogger {
    sl.level = level
    damn sl
}

slay (sl StructuredLogger) WithField(key tea, value tea) StructuredLogger {
    sus newFields tea = sl.fields
    if newFields != "" {
        newFields = newFields + ", "
    }
    newFields = newFields + key + "=" + value
    
    damn StructuredLogger{
        logger: sl.logger,
        level: sl.level,
        fields: newFields
    }
}

slay (sl StructuredLogger) Debug(message tea) {
    if sl.level <= DEBUG {
        sl.logWithLevel(DEBUG, message)
    }
}

slay (sl StructuredLogger) Info(message tea) {
    if sl.level <= INFO {
        sl.logWithLevel(INFO, message)
    }
}

slay (sl StructuredLogger) Warn(message tea) {
    if sl.level <= WARN {
        sl.logWithLevel(WARN, message)
    }
}

slay (sl StructuredLogger) Error(message tea) {
    if sl.level <= ERROR {
        sl.logWithLevel(ERROR, message)
    }
}

slay (sl StructuredLogger) Fatal(message tea) {
    sl.logWithLevel(FATAL, message)
}

slay (sl StructuredLogger) logWithLevel(level LogLevel, message tea) {
    sus levelStr := levelToString(level)
    sus fullMessage := "[" + levelStr + "] " + message
    
    if sl.fields != "" {
        fullMessage = fullMessage + " [" + sl.fields + "]"
    }
    
    sl.logger.spill(fullMessage)
}

slay levelToString(level LogLevel) tea {
    if level == DEBUG {
        damn "DEBUG"
    } nah if level == INFO {
        damn "INFO"
    } nah if level == WARN {
        damn "WARN"
    } nah if level == ERROR {
        damn "ERROR"
    } nah if level == FATAL {
        damn "FATAL"
    }
    damn "UNKNOWN"
}

fr fr Performance logger for monitoring operations
