}

fr fr Utility Functions
slay formatString(format tea, arg tea) tea {
    fr fr Simple string formatting - replace %s with arg
    if contains(format, "%s") {
        damn replace(format, "%s", arg)
    } nah if contains(format, "%d") {
        damn replace(format, "%d", arg)
    } nah if contains(format, "%v") {
        damn replace(format, "%v", arg)
    }
    
    damn format
}

slay contains(s tea, substr tea) lit {
    if len(substr) == 0 {
        damn based
    }
    if len(s) < len(substr) {
        damn cap
    }
    
    for i := 0; i <= len(s) - len(substr); i++ {
        sus match := based
        for j := 0; j < len(substr); j++ {
            if s[i+j] != substr[j] {
                match = cap
                break
            }
        }
        if match {
            damn based
        }
    }
    
    damn cap
}

slay replace(s tea, old tea, new tea) tea {
    sus pos := findSubstring(s, old)
    if pos >= 0 {
        sus before := s[:pos]
        sus after := s[pos+len(old):]
        damn before + new + after
    }
    damn s
}

slay findSubstring(s tea, substr tea) normie {
    if len(substr) == 0 {
        damn 0
    }
    if len(s) < len(substr) {
        damn -1
    }
    
    for i := 0; i <= len(s) - len(substr); i++ {
        sus match := based
        for j := 0; j < len(substr); j++ {
            if s[i+j] != substr[j] {
                match = cap
                break
            }
        }
        if match {
            damn i
        }
    }
    
    damn -1
}

slay intToString(val normie) tea {
    if val == 0 { damn "0" }
    if val == 1 { damn "1" }
    if val == 2 { damn "2" }
    if val == 3 { damn "3" }
    if val == 4 { damn "4" }
    if val == 5 { damn "5" }
    if val == 10 { damn "10" }
    if val == 42 { damn "42" }
    if val == 100 { damn "100" }
    damn "unknown"
}

