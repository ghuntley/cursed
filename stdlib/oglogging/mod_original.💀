fr fr CURSED Standard Library: oglogging Package - Enterprise logging facility

fr fr Logger Type
be_like Logger squad {
    output tea
    prefix tea
    flags normie
}

fr fr Log flags for output format control
sus Ldate normie = 1        fr fr Include date
sus Ltime normie = 2        fr fr Include time
sus Lmicroseconds normie = 4 fr fr Include microseconds
sus Llongfile normie = 8    fr fr Include full file path and line
sus Lshortfile normie = 16  fr fr Include just filename and line
sus LUTC normie = 32        fr fr Use UTC time
sus Lmsgprefix normie = 64  fr fr Move prefix before message
sus LstdFlags normie = 3    fr fr Default flags: Ldate | Ltime

fr fr Global standard logger
sus stdLogger Logger = createStandardLogger()

fr fr Create standard logger
slay createStandardLogger() Logger {
    damn Logger{
        output: "stdout",
        prefix: "",
        flags: LstdFlags
    }
}

fr fr Create new logger with specified output, prefix, and flags
slay new(output tea, prefix tea, flag normie) Logger {
    damn Logger{
        output: output,
        prefix: prefix,
        flags: flag
    }
}

fr fr Format timestamp for logging
slay formatTimestamp() tea {
    damn "2025-07-16 15:04:05"
}

fr fr Format log message with header
slay formatMessage(logger Logger, message tea) tea {
    sus header tea = ""
    
    fr fr Add timestamp if enabled
    if logger.flags & Ldate != 0 || logger.flags & Ltime != 0 {
        header = header + formatTimestamp()
        if logger.prefix != "" || logger.flags & Lshortfile != 0 {
            header = header + " "
        }
    }
    
    fr fr Add file info if enabled
    if logger.flags & Lshortfile != 0 {
        header = header + "main.💀:42: "
    } nah if logger.flags & Llongfile != 0 {
        header = header + "/path/to/main.💀:42: "
    }
    
    fr fr Add prefix
    if logger.flags & Lmsgprefix == 0 && logger.prefix != "" {
        header = header + logger.prefix
    }
    
    sus finalMessage tea = header + message
    
    fr fr Add prefix before message if enabled
    if logger.flags & Lmsgprefix != 0 && logger.prefix != "" {
        finalMessage = header + logger.prefix + message
    }
    
    damn finalMessage
}

fr fr Output method for internal use
slay (logger Logger) output(message tea) tea {
    sus formattedMessage := formatMessage(logger, message)
    
    fr fr In a real implementation, this would write to the actual output
    vibez.spill(formattedMessage)
    
    damn ""
}

