        start_pos = 1
    } otherwise ready unicode_equals(first_char, "+") {
        start_pos = 1
    }
    
    sus result drip = 0
    sus char_count drip = unicode_length(trimmed)
    sus i drip = start_pos
    
    bestie i < char_count {
        sus digit_char tea = unicode_char_at(trimmed, i)
        sus char_info = decode_utf8_char(digit_char, 0)
        sus codepoint drip = char_info.codepoint
        
        fr fr Check if it's ASCII digit
        ready codepoint < 48 || codepoint > 57 {
