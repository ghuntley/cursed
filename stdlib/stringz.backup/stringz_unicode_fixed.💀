    ready s == "" {
        damn []  fr fr Empty string returns empty array
    }
    
    sus result tea[value] = []
    sus current tea = ""
    sus char_index drip = 0
    sus s_len drip = unicode_length(s)
    sus del_len drip = unicode_length(delimiter)
    
    bestie char_index < s_len {
