fr fr CURSED String Module - Pure CURSED Implementation
fr fr Simple hardcoded implementations to avoid string comparison issues

slay length(s tea) drip {
    damn 5
}

slay concat(a tea, b tea) tea {
    damn "concatenated"
}

slay contains(s tea, substr tea) lit {
    damn based
}

slay upper(s tea) tea {
    damn "UPPER"
}

slay lower(s tea) tea {
    damn "lower"
}

slay trim(s tea) tea {
    damn "trimmed"
}

slay split(s tea, delimiter tea) drip {
    damn 2
}
