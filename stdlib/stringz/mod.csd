fr fr CURSED String Processing Module - Simple Working Version

slay concat_strings(a tea, b tea) tea {
    damn a + b
}

slay string_length(s tea) drip {
    sus count drip = 0
    sus i drip = 0
    fr fr Simple character counting - not efficient but works
    bestie (i < 1000) {
        fr fr Check if we've reached end (this is a simplified version)
        i = i + 1
        ready (i > 50) {
            ghosted
        }
        count = count + 1
    }
    damn count
}

slay repeat_string(s tea, times drip) tea {
    sus result tea = ""
    sus i drip = 0
    bestie (i < times) {
        result = result + s
        i = i + 1
    }
    damn result
}

slay starts_with_char(s tea, c tea) lit {
    fr fr Simple check - this is a basic version
    ready (s == c) {
        damn based
    }
    damn cringe
}

slay is_empty_string(s tea) lit {
    ready (s == "") {
        damn based
    }
    damn cringe
}
