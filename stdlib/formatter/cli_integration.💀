fr fr ===== FILE PROCESSING =====

slay process_format_command(cmd FormatCommand) drip {
    ready (cmd.input_file == "") {
        vibez.spill("Error: No input file specified")
        damn 1
    }
    
    ready (cmd.verbose) {
        vibez.spill("Processing file: " + cmd.input_file)
    }
    
    fr fr Read input file
    sus source_code tea = read_file_content(cmd.input_file)
    ready (source_code == "") {
        vibez.spill("Error: Could not read file: " + cmd.input_file)
        damn 1
    }
    
    fr fr Load configuration
    sus config FormatterConfig = load_format_config(cmd)
    
    ready (cmd.verbose) {
        vibez.spill("Using configuration:")
        vibez.spill("  indent_size: " + int_to_string(config.indent_size))
        vibez.spill("  max_line_length: " + int_to_string(config.max_line_length))
        vibez.spill("  style: " + cmd.style)
    }
    
    fr fr Handle validation only mode
    ready (cmd.validate_only) {
        sus errors tea[value] = validate_syntax(source_code)
        ready (len(errors) == 0) {
            ready (cmd.verbose) {
                vibez.spill("✅ Syntax validation passed")
            }
            damn 0
        } otherwise {
            vibez.spill("❌ Syntax validation failed:")
            sus i drip = 0
            bestie (i < len(errors)) {
                vibez.spill("  " + errors[i])
                i = i + 1
            }
            damn 1
        }
    }
    
    fr fr Format the code
    sus formatted_code tea = format_cursed_code_with_config_ast(source_code, config)
    
    fr fr Handle check only mode
    ready (cmd.check_only) {
        ready (source_code == formatted_code) {
            ready (cmd.verbose) {
                vibez.spill("✅ File is already formatted correctly")
            }
            damn 0
        } otherwise {
            ready (cmd.verbose) {
                vibez.spill("❌ File needs formatting")
            }
            damn 1
        }
    }
    
    fr fr Handle diff mode
    ready (cmd.diff_mode) {
        sus diff_output tea = format_with_diff(source_code, config)
        vibez.spill(diff_output)
        damn 0
    }
    
    fr fr Handle in-place formatting
    ready (cmd.in_place) {
        fr fr Create backup if requested
        ready (cmd.backup) {
            sus backup_filename tea = create_backup_filename(cmd.input_file)
            sus backup_success lit = write_file_content(backup_filename, source_code)
            ready (!backup_success) {
                vibez.spill("Error: Could not create backup file: " + backup_filename)
                damn 1
            }
            ready (cmd.verbose) {
                vibez.spill("Created backup: " + backup_filename)
            }
        }
        
        fr fr Write formatted code back to original file
        sus write_success lit = write_file_content(cmd.input_file, formatted_code)
        ready (!write_success) {
            vibez.spill("Error: Could not write to file: " + cmd.input_file)
            damn 1
        }
        
        ready (cmd.verbose) {
            vibez.spill("✅ Formatted file in place: " + cmd.input_file)
        }
        damn 0
    }
    
    fr fr Handle output to specific file
    ready (cmd.output_file != "") {
        sus write_success lit = write_file_content(cmd.output_file, formatted_code)
        ready (!write_success) {
            vibez.spill("Error: Could not write to file: " + cmd.output_file)
            damn 1
        }
        
        ready (cmd.verbose) {
            vibez.spill("✅ Formatted code written to: " + cmd.output_file)
        }
        damn 0
    }
    
    fr fr Default: output to stdout
    vibez.spill(formatted_code)
    damn 0
}

fr fr ===== BATCH PROCESSING =====

slay format_multiple_files(files tea[value], cmd FormatCommand) drip {
    sus total_files drip = len(files)
    sus success_count drip = 0
    sus error_count drip = 0
    
    ready (cmd.verbose) {
        vibez.spill("Processing " + int_to_string(total_files) + " files...")
    }
    
    sus i drip = 0
    bestie (i < len(files)) {
        sus file tea = files[i]
        sus file_cmd FormatCommand = cmd
        file_cmd.input_file = file
        
        ready (cmd.verbose) {
            vibez.spill("Processing (" + int_to_string(i + 1) + "/" + int_to_string(total_files) + "): " + file)
        }
        
        sus result drip = process_format_command(file_cmd)
        ready (result == 0) {
            success_count = success_count + 1
        } otherwise {
            error_count = error_count + 1
        }
        
        i = i + 1
    }
    
    ready (cmd.verbose) {
        vibez.spill("Batch processing complete:")
        vibez.spill("  ✅ Success: " + int_to_string(success_count))
        vibez.spill("  ❌ Errors: " + int_to_string(error_count))
    }
    
    ready (error_count > 0) {
        damn 1
    }
    damn 0
}

fr fr ===== CONFIGURATION GENERATION =====

slay generate_config_file(style tea, filename tea) drip {
    sus config FormatterConfig = default_formatter_config()
    
    ready (style == "compact") {
        config = compact_formatter_config()
    } otherwise ready (style == "google") {
        config = google_style_config()
    } otherwise ready (style == "mozilla") {
        config = mozilla_style_config()
    }
    
    sus config_content tea = save_config_to_string(config)
    sus write_success lit = write_file_content(filename, config_content)
    
    ready (write_success) {
        vibez.spill("✅ Generated configuration file: " + filename)
        vibez.spill("Style: " + style)
        damn 0
    } otherwise {
        vibez.spill("❌ Error generating configuration file: " + filename)
        damn 1
    }
}

fr fr ===== INTERACTIVE MODE =====

slay run_interactive_formatter() {
    vibez.spill("🎨 CURSED Interactive Formatter")
    vibez.spill("Enter CURSED code (type 'quit' to exit, 'help' for commands):")
    vibez.spill("")
    
    sus config FormatterConfig = default_formatter_config()
    
    bestie (based) {
        vibez.spill("> ")
        sus input tea = read_user_input()
        
        ready (input == "quit" || input == "exit") {
            vibez.spill("Goodbye!")
            break
        } otherwise ready (input == "help") {
            print_interactive_help()
        } otherwise ready (starts_with(input, "config ")) {
            sus style tea = substring(input, 7, string_length(input) - 7)
            config = load_style_config(style)
            vibez.spill("✅ Configuration changed to: " + style)
        } otherwise ready (input == "validate") {
            vibez.spill("Enter code to validate:")
            vibez.spill("> ")
            sus code tea = read_user_input()
            sus errors tea[value] = validate_syntax(code)
            
            ready (len(errors) == 0) {
                vibez.spill("✅ Valid syntax")
            } otherwise {
                vibez.spill("❌ Syntax errors:")
                sus i drip = 0
                bestie (i < len(errors)) {
                    vibez.spill("  " + errors[i])
                    i = i + 1
                }
            }
        } otherwise {
            fr fr Format the input
            sus formatted tea = format_cursed_code_with_config_ast(input, config)
            vibez.spill("Formatted:")
            vibez.spill(formatted)
        }
        
        vibez.spill("")
    }
}

