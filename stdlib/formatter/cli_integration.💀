fr fr ===== CONFIGURATION LOADING =====

slay load_format_config(cmd FormatCommand) FormatterConfig {
    sus config FormatterConfig = default_formatter_config()
    
    fr fr Load predefined style
    ready (cmd.style == "compact") {
        config = compact_formatter_config()
    } otherwise ready (cmd.style == "google") {
        config = google_style_config()
    } otherwise ready (cmd.style == "mozilla") {
        config = mozilla_style_config()
    }
    
    fr fr Load custom config file if specified
    ready (cmd.config_file != "") {
        sus config_content tea = read_file_content(cmd.config_file)
        ready (config_content != "") {
            config = load_config_from_string(config_content)
        } otherwise {
            vibez.spill("Warning: Could not read config file: " + cmd.config_file)
        }
    }
    
    damn config
}

