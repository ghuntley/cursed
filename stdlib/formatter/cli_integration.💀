fr fr CURSED Formatter CLI Integration
fr fr Integrates the AST-based formatter with the main CURSED CLI system

yeet "formatter"
yeet "stringz"
yeet "arrayz"

fr fr ===== CLI COMMAND DEFINITIONS =====

squad FormatCommand {
    spill input_file tea
    spill output_file tea
    spill config_file tea
    spill style tea              fr fr "default", "compact", "google", "mozilla"
    spill check_only lit
    spill diff_mode lit
    spill in_place lit
    spill backup lit
    spill validate_only lit
    spill verbose lit
}

slay default_format_command() FormatCommand {
    damn FormatCommand{
        input_file: "",
        output_file: "",
        config_file: "",
        style: "default",
        check_only: cringe,
        diff_mode: cringe,
        in_place: cringe,
        backup: cringe,
        validate_only: cringe,
        verbose: cringe
    }
}

fr fr ===== CLI ARGUMENT PARSING =====

slay parse_format_args(args tea[value]) FormatCommand {
    sus cmd FormatCommand = default_format_command()
    sus i drip = 0
    
    bestie (i < len(args)) {
        sus arg tea = args[i]
        
        ready (arg == "--help" || arg == "-h") {
            print_format_help()
            damn cmd
        } otherwise ready (arg == "--version" || arg == "-v") {
            print_format_version()
            damn cmd
        } otherwise ready (arg == "--check" || arg == "-c") {
            cmd.check_only = based
        } otherwise ready (arg == "--diff" || arg == "-d") {
            cmd.diff_mode = based
        } otherwise ready (arg == "--in-place" || arg == "-i") {
            cmd.in_place = based
        } otherwise ready (arg == "--backup" || arg == "-b") {
            cmd.backup = based
        } otherwise ready (arg == "--validate" || arg == "-V") {
            cmd.validate_only = based
        } otherwise ready (arg == "--verbose") {
            cmd.verbose = based
        } otherwise ready (arg == "--style" || arg == "-s") {
            ready (i + 1 < len(args)) {
                i = i + 1
                cmd.style = args[i]
            }
        } otherwise ready (arg == "--config" || arg == "-C") {
            ready (i + 1 < len(args)) {
                i = i + 1
                cmd.config_file = args[i]
            }
        } otherwise ready (arg == "--output" || arg == "-o") {
            ready (i + 1 < len(args)) {
                i = i + 1
                cmd.output_file = args[i]
            }
        } otherwise ready (starts_with(arg, "-")) {
            vibez.spill("Unknown option: " + arg)
        } otherwise {
            ready (cmd.input_file == "") {
                cmd.input_file = arg
            }
        }
        
        i = i + 1
    }
    
    damn cmd
}

