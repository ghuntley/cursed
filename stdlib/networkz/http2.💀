// ==== HTTP/2 CONNECTION MANAGEMENT ====

slay create_http2_connection(socket Socket, is_server lit) yikes<Http2Connection> {
    sus default_settings Http2Settings = Http2Settings{
        header_table_size: 4096,
        enable_push: 1,
        max_concurrent_streams: 1000,
        initial_window_size: 65535,
        max_frame_size: 16384,
        max_header_list_size: 8192
    }

    sus conn Http2Connection = Http2Connection{
        socket: socket,
        connection_preface_sent: no_cap,
        connection_preface_received: no_cap,
        settings_sent: no_cap,
        settings_acked: no_cap,
        stream_count: 0,
        next_stream_id: ready (is_server) 2 otherwise 1,  // Server uses even, client uses odd
        is_server: is_server,
        local_settings: default_settings,
        remote_settings: default_settings,
        connection_window: 65535,
        goaway_sent: no_cap,
        goaway_received: no_cap,
        last_stream_id: 0,
        error_code: 0
    }

    // Initialize HPACK dynamic tables
    conn.hpack_encoder = create_hpack_dynamic_table(4096)
    conn.hpack_decoder = create_hpack_dynamic_table(4096)

    damn conn
}

slay send_connection_preface(conn Http2Connection) yikes<lit> {
    ready (conn.connection_preface_sent) {
        yikes create_network_error_advanced("http2_preface", "Connection preface already sent", HTTP2_PROTOCOL_ERROR, "")
    }

    // HTTP/2 connection preface (RFC 7540 Section 3.5)
    sus preface tea = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    
    sus bytes_sent drip = tcp_send(conn.socket, preface) fam {
        when err -> yikes err
    }

    conn.connection_preface_sent = based
    
    // Send initial SETTINGS frame
    sus settings_frame Http2Frame = create_settings_frame(conn.local_settings, no_cap)
    send_frame(conn, settings_frame) fam {
        when err -> yikes err
    }

    conn.settings_sent = based
    damn based
}

slay receive_connection_preface(conn Http2Connection) yikes<lit> {
    ready (conn.connection_preface_received) {
        yikes create_network_error_advanced("http2_preface", "Connection preface already received", HTTP2_PROTOCOL_ERROR, "")
    }

    sus expected_preface tea = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    sus received_preface tea = tcp_receive(conn.socket, stringz.len(expected_preface)) fam {
        when err -> yikes err
    }

    ready (!stringz.equals(received_preface, expected_preface)) {
        yikes create_network_error_advanced("http2_preface", "Invalid connection preface", HTTP2_PROTOCOL_ERROR, received_preface)
    }

    conn.connection_preface_received = based
    damn based
}

// ==== HTTP/2 FRAME PROCESSING ====

slay create_frame_header(frame_type drip, flags drip, stream_id drip, payload_length drip) tea {
    // Frame header is 9 bytes: 3 bytes length + 1 byte type + 1 byte flags + 4 bytes stream ID
    sus header drip[value] = [
        (payload_length >> 16) & 0xFF,    // Length (24-bit, big-endian)
        (payload_length >> 8) & 0xFF,
        payload_length & 0xFF,
        frame_type & 0xFF,                // Type (8-bit)
        flags & 0xFF,                     // Flags (8-bit)
        (stream_id >> 24) & 0x7F,         // Stream ID (31-bit, big-endian, R bit clear)
        (stream_id >> 16) & 0xFF,
        (stream_id >> 8) & 0xFF,
        stream_id & 0xFF
    ]
    
    sus header_bytes tea = ""
    sus i drip = 0
    bestie (i < 9) {
        header_bytes = stringz.concat([header_bytes, stringz.from_byte(header[i])])
        i = i + 1
    }
    
    damn header_bytes
}

slay parse_frame_header(header_bytes tea) yikes<Http2Frame> {
    ready (stringz.len(header_bytes) != 9) {
        yikes create_network_error_advanced("http2_frame", "Invalid frame header length", HTTP2_FRAME_SIZE_ERROR, "")
    }

    sus bytes drip[value] = stringz.to_bytes(header_bytes)
    
    sus payload_length drip = (bytes[0] << 16) | (bytes[1] << 8) | bytes[2]
    sus frame_type drip = bytes[3]
    sus flags drip = bytes[4]
    sus stream_id drip = ((bytes[5] & 0x7F) << 24) | (bytes[6] << 16) | (bytes[7] << 8) | bytes[8]

    ready (payload_length > 16384) {  // Default max frame size
        yikes create_network_error_advanced("http2_frame", "Frame too large", HTTP2_FRAME_SIZE_ERROR, stringz.from_int(payload_length))
    }

    sus frame Http2Frame = Http2Frame{
        frame_type: frame_type,
        flags: flags,
        stream_id: stream_id,
        payload: "",
        payload_length: payload_length
    }

    damn frame
}

slay send_frame(conn Http2Connection, frame Http2Frame) yikes<lit> {
    ready (conn.goaway_sent || conn.goaway_received) {
        yikes create_network_error_advanced("http2_send", "Connection is closing", HTTP2_PROTOCOL_ERROR, "")
    }

    sus header tea = create_frame_header(frame.frame_type, frame.flags, frame.stream_id, frame.payload_length)
    sus frame_data tea = stringz.concat([header, frame.payload])

    sus bytes_sent drip = tcp_send(conn.socket, frame_data) fam {
        when err -> yikes err
    }

    damn based
}

slay receive_frame(conn Http2Connection) yikes<Http2Frame> {
    ready (conn.goaway_received) {
        yikes create_network_error_advanced("http2_receive", "Connection is closing", HTTP2_PROTOCOL_ERROR, "")
    }

    // Read frame header (9 bytes)
    sus header_bytes tea = tcp_receive(conn.socket, 9) fam {
        when err -> yikes err
    }

    sus frame Http2Frame = parse_frame_header(header_bytes) fam {
        when err -> yikes err
    }

    // Read frame payload
    ready (frame.payload_length > 0) {
        frame.payload = tcp_receive(conn.socket, frame.payload_length) fam {
            when err -> yikes err
        }
    }

    damn frame
}

// ==== SETTINGS FRAME IMPLEMENTATION ====

slay create_settings_frame(settings Http2Settings, ack lit) Http2Frame {
    sus flags drip = ready (ack) HTTP2_FLAG_ACK otherwise 0
    sus payload tea = ""

    ready (!ack) {
        // Each setting is 6 bytes: 2 bytes identifier + 4 bytes value
        sus setting_pairs drip[value] = [
            1, settings.header_table_size,      // SETTINGS_HEADER_TABLE_SIZE
            2, settings.enable_push,            // SETTINGS_ENABLE_PUSH  
            3, settings.max_concurrent_streams, // SETTINGS_MAX_CONCURRENT_STREAMS
            4, settings.initial_window_size,    // SETTINGS_INITIAL_WINDOW_SIZE
            5, settings.max_frame_size,         // SETTINGS_MAX_FRAME_SIZE
            6, settings.max_header_list_size    // SETTINGS_MAX_HEADER_LIST_SIZE
        ]

        sus i drip = 0
        bestie (i < arrayz.len(setting_pairs)) {
            sus setting_id drip = setting_pairs[i]
            sus setting_value drip = setting_pairs[i + 1]
            
            // Setting ID (16-bit, big-endian)
            payload = stringz.concat([payload, stringz.from_byte((setting_id >> 8) & 0xFF)])
            payload = stringz.concat([payload, stringz.from_byte(setting_id & 0xFF)])
            
            // Setting value (32-bit, big-endian)
            payload = stringz.concat([payload, stringz.from_byte((setting_value >> 24) & 0xFF)])
            payload = stringz.concat([payload, stringz.from_byte((setting_value >> 16) & 0xFF)])
            payload = stringz.concat([payload, stringz.from_byte((setting_value >> 8) & 0xFF)])
            payload = stringz.concat([payload, stringz.from_byte(setting_value & 0xFF)])
            
            i = i + 2
        }
    }

    damn Http2Frame{
        frame_type: HTTP2_FRAME_SETTINGS,
        flags: flags,
        stream_id: 0,  // Settings frames must use stream ID 0
        payload: payload,
        payload_length: stringz.len(payload)
    }
}

slay process_settings_frame(conn Http2Connection, frame Http2Frame) yikes<lit> {
    ready (frame.stream_id != 0) {
        yikes create_network_error_advanced("http2_settings", "SETTINGS frame with non-zero stream ID", HTTP2_PROTOCOL_ERROR, "")
    }

    ready (frame.flags & HTTP2_FLAG_ACK) {
        // Settings ACK frame - no payload expected
        ready (frame.payload_length != 0) {
            yikes create_network_error_advanced("http2_settings", "SETTINGS ACK frame with payload", HTTP2_FRAME_SIZE_ERROR, "")
        }
        conn.settings_acked = based
        damn based
    }

    // Process settings parameters
    ready (frame.payload_length % 6 != 0) {
        yikes create_network_error_advanced("http2_settings", "Invalid SETTINGS frame payload length", HTTP2_FRAME_SIZE_ERROR, "")
    }

    sus payload_bytes drip[value] = stringz.to_bytes(frame.payload)
    sus i drip = 0
    
    bestie (i < frame.payload_length) {
        sus setting_id drip = (payload_bytes[i] << 8) | payload_bytes[i + 1]
        sus setting_value drip = (payload_bytes[i + 2] << 24) | (payload_bytes[i + 3] << 16) | 
                                (payload_bytes[i + 4] << 8) | payload_bytes[i + 5]

        // Apply setting to remote settings
        sick setting_id {
            when 1 -> conn.remote_settings.header_table_size = setting_value
            when 2 -> conn.remote_settings.enable_push = setting_value
            when 3 -> conn.remote_settings.max_concurrent_streams = setting_value
            when 4 -> conn.remote_settings.initial_window_size = setting_value
            when 5 -> conn.remote_settings.max_frame_size = setting_value
            when 6 -> conn.remote_settings.max_header_list_size = setting_value
            when _ -> {
                // Unknown setting IDs are ignored per RFC 7540
            }
        }
        
        i = i + 6
    }

    // Send SETTINGS ACK
    sus ack_frame Http2Frame = create_settings_frame(conn.local_settings, based)
    send_frame(conn, ack_frame) fam {
        when err -> yikes err
    }

    damn based
}

// ==== STREAM MANAGEMENT ====

slay find_stream(conn Http2Connection, stream_id drip) yikes<Http2StreamState> {
    sus i drip = 0
    bestie (i < conn.stream_count) {
        ready (conn.streams[i].stream_id == stream_id) {
            damn conn.streams[i]
        }
        i = i + 1
    }
    
    yikes create_network_error_advanced("http2_stream", "Stream not found", HTTP2_PROTOCOL_ERROR, stringz.from_int(stream_id))
}

slay create_stream(conn Http2Connection, stream_id drip) yikes<Http2StreamState> {
    ready (conn.stream_count >= 1000) {
        yikes create_network_error_advanced("http2_stream", "Maximum streams exceeded", HTTP2_REFUSED_STREAM, "")
    }

    sus stream Http2StreamState = Http2StreamState{
        stream_id: stream_id,
        state: HTTP2_STREAM_IDLE,
        local_window: conn.local_settings.initial_window_size,
        remote_window: conn.remote_settings.initial_window_size,
        headers: [],
        data_frames: [],
        priority_weight: 16,      // Default weight
        priority_dependency: 0,   // No dependency
        priority_exclusive: no_cap
    }

    conn.streams[conn.stream_count] = stream
    conn.stream_count = conn.stream_count + 1

    damn stream
}

slay transition_stream_state(stream Http2StreamState, event drip) yikes<lit> {
    // Stream state transitions per RFC 7540 Section 5.1
    sus old_state drip = stream.state
    sus new_state drip = old_state
    
    sick old_state {
        when HTTP2_STREAM_IDLE -> {
            ready (event == 1) {  // send/recv HEADERS
                new_state = HTTP2_STREAM_OPEN
            } otherwise ready (event == 2) {  // recv PUSH_PROMISE
                new_state = HTTP2_STREAM_RESERVED_REMOTE
            }
        }
        when HTTP2_STREAM_OPEN -> {
            ready (event == 3) {  // send END_STREAM
                new_state = HTTP2_STREAM_HALF_CLOSED_LOCAL
            } otherwise ready (event == 4) {  // recv END_STREAM
                new_state = HTTP2_STREAM_HALF_CLOSED_REMOTE
            }
        }
        when HTTP2_STREAM_HALF_CLOSED_LOCAL -> {
            ready (event == 4) {  // recv END_STREAM
                new_state = HTTP2_STREAM_CLOSED
            }
        }
        when HTTP2_STREAM_HALF_CLOSED_REMOTE -> {
            ready (event == 3) {  // send END_STREAM
                new_state = HTTP2_STREAM_CLOSED
            }
        }
        when HTTP2_STREAM_RESERVED_LOCAL -> {
            ready (event == 1) {  // send HEADERS
                new_state = HTTP2_STREAM_HALF_CLOSED_REMOTE
            }
        }
        when HTTP2_STREAM_RESERVED_REMOTE -> {
            ready (event == 1) {  // recv HEADERS
                new_state = HTTP2_STREAM_HALF_CLOSED_LOCAL
            }
        }
    }

    ready (new_state != old_state) {
        stream.state = new_state
    }

    damn based
}

// ==== HPACK HEADER COMPRESSION ====

slay create_hpack_dynamic_table(max_size drip) HpackDynamicTable {
    damn HpackDynamicTable{
        size: 0,
        max_size: max_size,
        insertion_count: 0
    }
}

slay hpack_lookup_static(index drip) yikes<HpackEntry> {
    ready (index < 1 || index > arrayz.len(hpack_static_table)) {
        yikes create_network_error_advanced("hpack", "Invalid static table index", HTTP2_COMPRESSION_ERROR, stringz.from_int(index))
    }
    
    damn hpack_static_table[index - 1]
}

slay hpack_lookup_dynamic(table HpackDynamicTable, index drip) yikes<HpackEntry> {
    ready (index < 1 || index > table.insertion_count) {
        yikes create_network_error_advanced("hpack", "Invalid dynamic table index", HTTP2_COMPRESSION_ERROR, stringz.from_int(index))
    }
    
    sus actual_index drip = table.insertion_count - index
    damn table.entries[actual_index]
}

slay hpack_add_to_dynamic_table(table HpackDynamicTable, entry HpackEntry) yikes<lit> {
    // Check if adding this entry would exceed max table size
    ready (entry.size > table.max_size) {
        // Entry is larger than max table size - don't add it
        damn based
    }

    // Evict entries if necessary to make room
    bestie (table.size + entry.size > table.max_size && table.insertion_count > 0) {
        sus oldest_index drip = 0
        sus oldest_entry HpackEntry = table.entries[oldest_index]
        table.size = table.size - oldest_entry.size
        
        // Shift entries down
        sus i drip = 0
        bestie (i < table.insertion_count - 1) {
            table.entries[i] = table.entries[i + 1]
            i = i + 1
        }
        table.insertion_count = table.insertion_count - 1
    }

    // Add new entry
    table.entries[table.insertion_count] = entry
    table.insertion_count = table.insertion_count + 1
    table.size = table.size + entry.size

    damn based
}

slay hpack_encode_integer(value drip, prefix_bits drip, first_byte drip) tea {
    sus max_prefix drip = (1 << prefix_bits) - 1
    sus result tea = ""

    ready (value < max_prefix) {
        result = stringz.from_byte(first_byte | value)
    } otherwise {
        result = stringz.from_byte(first_byte | max_prefix)
        value = value - max_prefix
        
        bestie (value >= 128) {
            result = stringz.concat([result, stringz.from_byte((value & 0x7F) | 0x80)])
            value = value >> 7
        }
        result = stringz.concat([result, stringz.from_byte(value)])
    }

    damn result
}

slay hpack_decode_integer(data tea, offset drip, prefix_bits drip) yikes<drip[2]> {
    ready (offset >= stringz.len(data)) {
        yikes create_network_error_advanced("hpack", "Insufficient data for integer", HTTP2_COMPRESSION_ERROR, "")
    }

    sus bytes drip[value] = stringz.to_bytes(data)
    sus max_prefix drip = (1 << prefix_bits) - 1
    sus value drip = bytes[offset] & max_prefix
    sus consumed drip = 1

    ready (value != max_prefix) {
