// ==== HTTP/2 FRAME TYPES AND STRUCTURES ====

squad Http2Frame {
    sus frame_type drip       // 0=DATA, 1=HEADERS, 2=PRIORITY, 3=RST_STREAM, etc.
    sus flags drip            // Frame-specific flags
    sus stream_id drip        // Stream identifier (31-bit)
    sus payload tea           // Frame payload
    sus payload_length drip   // Length of payload (24-bit)
}

squad Http2StreamState {
    sus stream_id drip
    sus state drip           // 0=idle, 1=open, 2=reserved_local, 3=reserved_remote, 4=half_closed_local, 5=half_closed_remote, 6=closed
    sus local_window drip    // Flow control window size for local
    sus remote_window drip   // Flow control window size for remote
    sus headers tea[value]        // Stream headers
    sus data_frames tea[value]    // Accumulated data frames
    sus priority_weight drip // Stream priority weight (1-256)
    sus priority_dependency drip // Stream dependency (31-bit stream ID)
    sus priority_exclusive lit   // Exclusive priority flag
}

squad Http2Connection {
    sus socket Socket            // Underlying TCP connection
    sus connection_preface_sent lit
    sus connection_preface_received lit
    sus settings_sent lit
    sus settings_acked lit
    sus streams Http2StreamState[1000]  // Active streams (max 1000 concurrent)
    sus stream_count drip
    sus next_stream_id drip     // Next stream ID to use (client uses odd, server uses even)
    sus is_server lit           // Is this a server connection
    sus local_settings Http2Settings
    sus remote_settings Http2Settings
    sus hpack_encoder HpackDynamicTable
    sus hpack_decoder HpackDynamicTable
    sus connection_window drip  // Connection-level flow control
    sus goaway_sent lit
    sus goaway_received lit
    sus last_stream_id drip     // Last processed stream ID
    sus error_code drip         // Connection error code if any
}

squad Http2Settings {
    sus header_table_size drip          // SETTINGS_HEADER_TABLE_SIZE (4096)
    sus enable_push drip                // SETTINGS_ENABLE_PUSH (1)
    sus max_concurrent_streams drip     // SETTINGS_MAX_CONCURRENT_STREAMS (unlimited)
    sus initial_window_size drip        // SETTINGS_INITIAL_WINDOW_SIZE (65535)
    sus max_frame_size drip             // SETTINGS_MAX_FRAME_SIZE (16384)
    sus max_header_list_size drip       // SETTINGS_MAX_HEADER_LIST_SIZE (unlimited)
}

