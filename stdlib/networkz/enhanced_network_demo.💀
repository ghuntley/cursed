// ==== ERROR HANDLING DEMO ====

slay demo_error_handling() {
    vibez.spill("\n⚠️  Error Handling Demo")
    vibez.spill("-" * 25)
    
    vibez.spill("Testing various error conditions:")
    
    // Invalid socket parameters
    vibez.spill("1. Invalid socket family:")
    socket_create(99, 1) fam {
        when err -> {
            vibez.spill("   ✅ Correctly caught error: " + err.message)
        }
        otherwise -> {
            vibez.spill("   ❌ Should have failed with invalid family")
        }
    }
    
    // Connection to unreachable host
    vibez.spill("2. Connection to unreachable host:")
    sus unreachable_socket Socket = socket_create(4, 1) fam { when _ -> {} }
    socket_connect_with_timeout(unreachable_socket, "unreachable.timeout.example", 80, 5) fam {
        when err -> {
            vibez.spill("   ✅ Correctly caught connection error: " + err.message)
            vibez.spill("   Error code: " + stringz.from_int(err.code))
            vibez.spill("   Retryable: " + ready is_retryable_error(err) { "Yes" } otherwise { "No" })
        }
        otherwise -> {
            vibez.spill("   ❌ Should have failed with unreachable host")
        }
    }
    
    // Invalid port binding
    vibez.spill("3. Invalid port binding:")
    sus bind_socket Socket = socket_create(4, 1) fam { when _ -> {} }
    socket_bind(bind_socket, "127.0.0.1", 99999) fam {
        when err -> {
            vibez.spill("   ✅ Correctly caught bind error: " + err.message)
        }
        otherwise -> {
            vibez.spill("   ❌ Should have failed with invalid port")
        }
    }
    
    // DNS resolution failure
    vibez.spill("4. DNS resolution for invalid domain:")
    dns_resolve_hostname("definitely.nonexistent.invalid.domain") fam {
        when err -> {
            vibez.spill("   ✅ Correctly caught DNS error: " + err.message)
        }
        otherwise -> {
            vibez.spill("   ℹ️  DNS resolved (using fallback mechanism)")
        }
    }
    
    // HTTP timeout
    vibez.spill("5. HTTP request timeout:")
    http_get_advanced("http://httpbin.org/delay/60", [], 1) fam {
        when err -> {
            vibez.spill("   ✅ Correctly caught timeout error: " + err.message)
        }
        otherwise -> {
            vibez.spill("   ❌ Should have timed out")
        }
    }
}

