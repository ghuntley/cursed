// ==== SOCKET OPERATIONS DEMO ====

slay demo_socket_operations() {
    vibez.spill("\n🔌 Socket Operations Demo")
    vibez.spill("-" * 30)
    
    // Create TCP socket
    vibez.spill("Creating TCP socket...")
    sus tcp_socket Socket = socket_create(4, 1) fam {
        when err -> {
            vibez.spill("❌ Socket creation failed: " + err.message)
            damn
        }
    }
    vibez.spill("✅ TCP socket created with handle: " + stringz.from_int(tcp_socket.handle))
    
    // Connect to localhost
    vibez.spill("Connecting to localhost:80...")
    socket_connect_with_timeout(tcp_socket, "localhost", 80, 30) fam {
        when err -> {
            vibez.spill("❌ Connection failed: " + err.message)
            damn
        }
    }
    vibez.spill("✅ Connected to localhost:80")
    vibez.spill("   Remote address: " + tcp_socket.remote_addr)
    vibez.spill("   Connection state: " + stringz.from_int(tcp_socket.state))
    
    // Send HTTP request
    vibez.spill("Sending HTTP GET request...")
    sus http_request tea = "GET / HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
    sus bytes_sent drip = socket_send_data(tcp_socket, http_request) fam {
        when err -> {
            vibez.spill("❌ Send failed: " + err.message)
            damn
        }
    }
    vibez.spill("✅ Sent " + stringz.from_int(bytes_sent) + " bytes")
    
    // Receive response
    vibez.spill("Receiving response...")
    sus response tea = socket_receive_data(tcp_socket, 1024) fam {
        when err -> {
            vibez.spill("❌ Receive failed: " + err.message)
            damn
        }
    }
    vibez.spill("✅ Received " + stringz.from_int(stringz.len(response)) + " bytes")
    vibez.spill("   Response preview: " + stringz.substring(response, 0, ready stringz.len(response) > 50 { 50 } otherwise { stringz.len(response) }) + "...")
    
    // Close socket
    socket_close(tcp_socket) fam {
        when err -> {
            vibez.spill("❌ Close failed: " + err.message)
        }
        otherwise -> {
            vibez.spill("✅ Socket closed successfully")
        }
    }
}

// ==== CONNECTION POOLING DEMO ====

slay demo_connection_pooling() {
    vibez.spill("\n🏊 Connection Pooling Demo")
    vibez.spill("-" * 30)
    
    vibez.spill("Creating connection pool for localhost:80...")
    sus pool ConnectionPool = connection_pool_create("localhost", 80, "tcp", 5) fam {
        when err -> {
            vibez.spill("❌ Pool creation failed: " + err.message)
            damn
        }
    }
    vibez.spill("✅ Pool created:")
    vibez.spill("   Host: " + pool.host)
    vibez.spill("   Port: " + stringz.from_int(pool.port))
    vibez.spill("   Max connections: " + stringz.from_int(pool.max_connections))
    vibez.spill("   Protocol: " + pool.protocol)
    
    // Get multiple connections from pool
    vibez.spill("Getting connections from pool...")
    sus connections Socket[value] = []
    
    sus i drip = 0
    bestie (i < 3) {
        sus conn Socket = connection_pool_get_connection(pool) fam {
            when err -> {
                vibez.spill("❌ Failed to get connection " + stringz.from_int(i + 1) + ": " + err.message)
                i = i + 1
                damn
            }
        }
        connections = arrayz.push(connections, conn)
        vibez.spill("✅ Got connection " + stringz.from_int(i + 1) + " with handle: " + stringz.from_int(conn.handle))
        i = i + 1
    }
    
    vibez.spill("Pool stats:")
    vibez.spill("   Active connections: " + stringz.from_int(pool.active_connections))
    vibez.spill("   Total created: " + stringz.from_int(pool.stats.total_connections_created))
    
    // Return connections to pool
    vibez.spill("Returning connections to pool...")
    sus j drip = 0
    bestie (j < arrayz.len(connections)) {
        connection_pool_return_connection(pool, connections[j]) fam {
            when err -> {
                vibez.spill("❌ Failed to return connection: " + err.message)
            }
            otherwise -> {
                vibez.spill("✅ Returned connection " + stringz.from_int(j + 1))
            }
        }
        j = j + 1
    }
    
    // Health check
    vibez.spill("Running pool health check...")
    connection_pool_health_check(pool) fam {
        when err -> {
            vibez.spill("❌ Health check failed: " + err.message)
        }
        otherwise -> {
            vibez.spill("✅ Pool health check completed")
            vibez.spill("   Healthy connections: " + stringz.from_int(pool.stats.current_active_connections))
        }
    }
}

// ==== DNS RESOLUTION DEMO ====

slay demo_dns_resolution() {
    vibez.spill("\n🌍 DNS Resolution Demo")
    vibez.spill("-" * 30)
    
    // Test various hostname resolutions
    sus hostnames tea[value] = ["localhost", "google.com", "github.com", "stackoverflow.com", "nonexistent.example.invalid"]
    
    sus i drip = 0
    bestie (i < arrayz.len(hostnames)) {
        sus hostname tea = hostnames[i]
        vibez.spill("Resolving " + hostname + "...")
        
        sus start_time drip = timez.now()
        sus ip_address tea = dns_resolve_hostname(hostname) fam {
            when err -> {
                vibez.spill("❌ DNS resolution failed: " + err.message)
                i = i + 1
                damn
            }
        }
        sus resolve_time drip = timez.now() - start_time
        
        vibez.spill("✅ " + hostname + " → " + ip_address + " (" + stringz.from_int(resolve_time) + "ms)")
        i = i + 1
    }
    
    // Test DNS record types
    vibez.spill("\nTesting DNS record types for gmail.com:")
    
    // A records
    sus a_records DNSRecord[value] = dns_resolve_hostname_all_types("gmail.com", 1) fam {
        when err -> {
            vibez.spill("❌ A record lookup failed: " + err.message)
        }
        otherwise -> {
            vibez.spill("✅ A records found: " + stringz.from_int(arrayz.len(a_records)))
            sus k drip = 0
            bestie (k < arrayz.len(a_records)) {
                vibez.spill("   " + a_records[k].name + " → " + a_records[k].value)
                k = k + 1
            }
        }
    }
    
    // MX records
    sus mx_records DNSRecord[value] = dns_resolve_hostname_all_types("gmail.com", 15) fam {
        when err -> {
            vibez.spill("❌ MX record lookup failed: " + err.message)
        }
        otherwise -> {
            vibez.spill("✅ MX records found: " + stringz.from_int(arrayz.len(mx_records)))
            sus l drip = 0
            bestie (l < arrayz.len(mx_records)) {
                vibez.spill("   " + stringz.from_int(mx_records[l].priority) + " " + mx_records[l].value)
                l = l + 1
            }
        }
    }
    
    // DNS cache test
    vibez.spill("\nTesting DNS caching:")
    vibez.spill("First lookup of example.com...")
    sus first_start drip = timez.now()
    dns_resolve_hostname("example.com") fam { when _ -> {} }
    sus first_time drip = timez.now() - first_start
    
    vibez.spill("Second lookup of example.com (cached)...")
    sus second_start drip = timez.now()
    dns_resolve_hostname("example.com") fam { when _ -> {} }
    sus second_time drip = timez.now() - second_start
    
    vibez.spill("✅ First lookup: " + stringz.from_int(first_time) + "ms")
    vibez.spill("✅ Cached lookup: " + stringz.from_int(second_time) + "ms")
    ready (second_time <= first_time) {
        vibez.spill("✅ Caching improved performance!")
    } otherwise {
        vibez.spill("ℹ️  Cache performance similar to direct lookup")
    }
}

