slay create_push_promise_frame(stream_id drip, promised_stream_id drip, headers tea[value]) yikes<Http2Frame> {
    ready (stream_id == 0 || promised_stream_id == 0) {
        yikes create_network_error_advanced("http2_push", "Invalid stream IDs for PUSH_PROMISE", HTTP2_PROTOCOL_ERROR, "")
    }

    ready (stream_id == promised_stream_id) {
        yikes create_network_error_advanced("http2_push", "Stream ID cannot equal promised stream ID", HTTP2_PROTOCOL_ERROR, "")
    }

    // PUSH_PROMISE payload: 4 bytes promised stream ID + HPACK-encoded headers
    sus payload tea = ""
    
    // Promised stream ID (31-bit, with reserved bit cleared)
    payload = stringz.concat([payload, stringz.from_byte((promised_stream_id >> 24) & 0x7F)])
    payload = stringz.concat([payload, stringz.from_byte((promised_stream_id >> 16) & 0xFF)])
    payload = stringz.concat([payload, stringz.from_byte((promised_stream_id >> 8) & 0xFF)])
    payload = stringz.concat([payload, stringz.from_byte(promised_stream_id & 0xFF)])

    // Encode headers (simplified - using literal encoding)
    sus i drip = 0
    bestie (i < arrayz.len(headers)) {
        sus header tea = headers[i]
        sus colon_pos drip = stringz.find(header, ": ")
        
        ready (colon_pos == -1) {
            yikes create_network_error_advanced("http2_push", "Invalid header format", HTTP2_PROTOCOL_ERROR, header)
        }

        sus name tea = stringz.substring(header, 0, colon_pos)
        sus value tea = stringz.substring(header, colon_pos + 2, stringz.len(header))

        // Literal header field without indexing
        payload = stringz.concat([payload, stringz.from_byte(0x00)])
        payload = stringz.concat([payload, hpack_encode_string(name, no_cap)])
        payload = stringz.concat([payload, hpack_encode_string(value, no_cap)])
        
        i = i + 1
    }

    damn Http2Frame{
        frame_type: HTTP2_FRAME_PUSH_PROMISE,
        flags: HTTP2_FLAG_END_HEADERS,
        stream_id: stream_id,
        payload: payload,
        payload_length: stringz.len(payload)
    }
}

slay process_push_promise_frame(conn Http2Connection, frame Http2Frame) yikes<Http2PushPromise> {
    ready (frame.stream_id == 0) {
        yikes create_network_error_advanced("http2_push", "PUSH_PROMISE frame with stream ID 0", HTTP2_PROTOCOL_ERROR, "")
    }

    ready (frame.payload_length < 4) {
        yikes create_network_error_advanced("http2_push", "PUSH_PROMISE frame too small", HTTP2_FRAME_SIZE_ERROR, "")
    }

    // Extract promised stream ID
    sus bytes drip[value] = stringz.to_bytes(frame.payload)
    sus promised_stream_id drip = ((bytes[0] & 0x7F) << 24) | (bytes[1] << 16) | (bytes[2] << 8) | bytes[3]

    // Decode headers starting after the promised stream ID
    sus headers tea[value] = []
    sus offset drip = 4
    sus payload tea = frame.payload

    bestie (offset < stringz.len(payload)) {
        sus header_bytes drip[value] = stringz.to_bytes(stringz.substring(payload, offset, stringz.len(payload)))
        sus pattern drip = header_bytes[0] & 0xF0

        sick pattern {
            when 0x00 -> {  // Literal header field without indexing
                offset = offset + 1  // Skip pattern byte
                
                // Decode name
                sus name_result tea[2] = hpack_decode_string(payload, offset) fam {
                    when err -> yikes err
                }
                sus name tea = name_result[0]
                offset = offset + mathz.parse_int(name_result[1])

                // Decode value  
                sus value_result tea[2] = hpack_decode_string(payload, offset) fam {
                    when err -> yikes err
                }
                sus value tea = value_result[0]
                offset = offset + mathz.parse_int(value_result[1])

                sus header tea = stringz.concat([name, ": ", value])
                headers = arrayz.push(headers, header)
            }
            when _ -> {
                yikes create_network_error_advanced("hpack", "Unsupported header pattern in PUSH_PROMISE", HTTP2_COMPRESSION_ERROR, stringz.from_int(pattern))
            }
        }
    }

    // Extract pseudo-headers
    sus authority tea = ""
    sus method tea = ""
    sus path tea = ""
    sus scheme tea = ""

    sus i drip = 0
    bestie (i < arrayz.len(headers)) {
        sus header tea = headers[i]
        ready (stringz.starts_with(header, ":authority: ")) {
            authority = stringz.substring(header, 12, stringz.len(header))
        } otherwise ready (stringz.starts_with(header, ":method: ")) {
            method = stringz.substring(header, 9, stringz.len(header))
        } otherwise ready (stringz.starts_with(header, ":path: ")) {
            path = stringz.substring(header, 7, stringz.len(header))
        } otherwise ready (stringz.starts_with(header, ":scheme: ")) {
            scheme = stringz.substring(header, 9, stringz.len(header))
        }
        i = i + 1
    }

    sus push_promise Http2PushPromise = Http2PushPromise{
        promised_stream_id: promised_stream_id,
        request_headers: headers,
        authority: authority,
        method: method,
        path: path,
        scheme: scheme
    }

    damn push_promise
}

slay http2_server_push_resource(conn Http2Connection, parent_stream_id drip, path tea, content_type tea, body tea) yikes<lit> {
    ready (!conn.is_server) {
        yikes create_network_error_advanced("http2_push", "Server push only available for server connections", HTTP2_PROTOCOL_ERROR, "")
    }

    ready (conn.remote_settings.enable_push == 0) {
        yikes create_network_error_advanced("http2_push", "Client disabled server push", HTTP2_PROTOCOL_ERROR, "")
    }

    // Allocate new stream ID for pushed resource
    sus promised_stream_id drip = conn.next_stream_id
    conn.next_stream_id = conn.next_stream_id + 2

    // Create push promise headers
    sus push_headers tea[value] = [
        ":method: GET",
        stringz.concat([":path: ", path]),
        ":scheme: https",
        stringz.concat([":authority: ", conn.socket.remote_addr])
    ]

    // Send PUSH_PROMISE frame
    sus push_promise_frame Http2Frame = create_push_promise_frame(parent_stream_id, promised_stream_id, push_headers) fam {
        when err -> yikes err
    }

    send_frame(conn, push_promise_frame) fam {
        when err -> yikes err
    }

    // Create stream for pushed resource
    sus pushed_stream Http2StreamState = create_stream(conn, promised_stream_id) fam {
        when err -> yikes err
    }

    transition_stream_state(pushed_stream, 1) fam {  // HEADERS sent
        when err -> yikes err
    }

    // Send response headers for pushed resource
    sus response_headers tea[value] = [
        ":status: 200",
        stringz.concat(["content-type: ", content_type]),
        stringz.concat(["content-length: ", stringz.from_int(stringz.len(body))]),
        "cache-control: max-age=3600"
    ]

    sus response_headers_frame Http2Frame = create_headers_frame(promised_stream_id, response_headers, no_cap, based) fam {
        when err -> yikes err
    }

    send_frame(conn, response_headers_frame) fam {
        when err -> yikes err
    }

    // Send data frame with resource content
    ready (stringz.len(body) > 0) {
        sus data_frame Http2Frame = create_data_frame(promised_stream_id, body, based) fam {
            when err -> yikes err
        }

        send_frame(conn, data_frame) fam {
            when err -> yikes err
        }
    }

    transition_stream_state(pushed_stream, 3) fam {  // END_STREAM sent
        when err -> yikes err
    }

    damn based
}

// ==== ADVANCED FLOW CONTROL ====

squad Http2FlowController {
    sus connection_window drip
    sus default_window_size drip
    sus stream_windows drip[1000]  // Flow control windows for each stream
    sus pending_updates drip[1000] // Pending window updates
    sus update_threshold drip      // Threshold for sending window updates
}

slay create_flow_controller(initial_window_size drip) Http2FlowController {
    sus controller Http2FlowController = Http2FlowController{
        connection_window: initial_window_size,
        default_window_size: initial_window_size,
        update_threshold: initial_window_size / 2
    }

    // Initialize stream windows
    sus i drip = 0
    bestie (i < 1000) {
        controller.stream_windows[i] = initial_window_size
        controller.pending_updates[i] = 0
        i = i + 1
    }

    damn controller
}

slay flow_control_consume(controller Http2FlowController, stream_id drip, bytes drip) yikes<lit> {
    ready (bytes <= 0) {
        damn based
    }

    // Update connection window
    ready (bytes > controller.connection_window) {
        yikes create_network_error_advanced("flow_control", "Data exceeds connection window", HTTP2_FLOW_CONTROL_ERROR, "")
    }
    controller.connection_window = controller.connection_window - bytes

    // Update stream window (if not connection-level)
    ready (stream_id != 0) {
        ready (stream_id > 1000) {
            yikes create_network_error_advanced("flow_control", "Stream ID too large", HTTP2_PROTOCOL_ERROR, "")
        }

        sus stream_index drip = stream_id - 1
        ready (bytes > controller.stream_windows[stream_index]) {
            yikes create_network_error_advanced("flow_control", "Data exceeds stream window", HTTP2_FLOW_CONTROL_ERROR, "")
        }
        
        controller.stream_windows[stream_index] = controller.stream_windows[stream_index] - bytes
        controller.pending_updates[stream_index] = controller.pending_updates[stream_index] + bytes
    }

    damn based
}

slay flow_control_should_update(controller Http2FlowController, stream_id drip) lit {
    ready (stream_id == 0) {
        damn (controller.default_window_size - controller.connection_window) >= controller.update_threshold
    }

    ready (stream_id > 1000) {
        damn no_cap
    }

    sus stream_index drip = stream_id - 1
    damn controller.pending_updates[stream_index] >= controller.update_threshold
}

slay flow_control_send_updates(conn Http2Connection, controller Http2FlowController) yikes<lit> {
    // Send connection-level window update if needed
    ready (flow_control_should_update(controller, 0)) {
        sus increment drip = controller.default_window_size - controller.connection_window
        sus window_update Http2Frame = create_window_update_frame(0, increment) fam {
            when err -> yikes err
        }

        send_frame(conn, window_update) fam {
            when err -> yikes err
        }

        controller.connection_window = controller.default_window_size
    }

    // Send stream-level window updates
    sus i drip = 0
    bestie (i < conn.stream_count) {
        sus stream_id drip = conn.streams[i].stream_id
        ready (flow_control_should_update(controller, stream_id)) {
            sus stream_index drip = stream_id - 1
            sus increment drip = controller.pending_updates[stream_index]
            
            sus window_update Http2Frame = create_window_update_frame(stream_id, increment) fam {
                when err -> yikes err
            }

            send_frame(conn, window_update) fam {
                when err -> yikes err
            }

            controller.stream_windows[stream_index] = controller.stream_windows[stream_index] + increment
            controller.pending_updates[stream_index] = 0
        }
        i = i + 1
    }

    damn based
}

// ==== PRIORITY AND DEPENDENCY MANAGEMENT ====

squad Http2StreamDependency {
    sus stream_id drip
    sus depends_on drip
    sus weight drip
    sus exclusive lit
    sus children drip[value]  // Child stream IDs
}

slay create_priority_frame(stream_id drip, dependency drip, weight drip, exclusive lit) Http2Frame {
    // Priority payload: 4 bytes stream dependency + 1 byte weight
    sus payload tea = ""
    
    // Stream dependency (31-bit) with exclusive flag in first bit
    sus dependency_with_flag drip = ready (exclusive) (dependency | 0x80000000) otherwise dependency
    payload = stringz.concat([payload, stringz.from_byte((dependency_with_flag >> 24) & 0xFF)])
    payload = stringz.concat([payload, stringz.from_byte((dependency_with_flag >> 16) & 0xFF)])
    payload = stringz.concat([payload, stringz.from_byte((dependency_with_flag >> 8) & 0xFF)])
    payload = stringz.concat([payload, stringz.from_byte(dependency_with_flag & 0xFF)])
    
    // Weight (8-bit, value is weight - 1)
    payload = stringz.concat([payload, stringz.from_byte(weight - 1)])

    damn Http2Frame{
        frame_type: HTTP2_FRAME_PRIORITY,
        flags: 0,
        stream_id: stream_id,
        payload: payload,
        payload_length: 5
    }
}

slay process_priority_frame(conn Http2Connection, frame Http2Frame) yikes<Http2StreamDependency> {
    ready (frame.stream_id == 0) {
        yikes create_network_error_advanced("http2_priority", "PRIORITY frame with stream ID 0", HTTP2_PROTOCOL_ERROR, "")
    }

    ready (frame.payload_length != 5) {
        yikes create_network_error_advanced("http2_priority", "Invalid PRIORITY frame size", HTTP2_FRAME_SIZE_ERROR, "")
    }

    sus bytes drip[value] = stringz.to_bytes(frame.payload)
    sus dependency_with_flag drip = (bytes[0] << 24) | (bytes[1] << 16) | (bytes[2] << 8) | bytes[3]
    sus exclusive lit = (dependency_with_flag & 0x80000000) != 0
    sus dependency drip = dependency_with_flag & 0x7FFFFFFF
    sus weight drip = bytes[4] + 1  // Weight is stored as weight - 1

    ready (dependency == frame.stream_id) {
        yikes create_network_error_advanced("http2_priority", "Stream cannot depend on itself", HTTP2_PROTOCOL_ERROR, "")
    }

    sus stream_dep Http2StreamDependency = Http2StreamDependency{
        stream_id: frame.stream_id,
        depends_on: dependency,
        weight: weight,
        exclusive: exclusive,
        children: []
    }

    damn stream_dep
}

