                            }
                        }
                    }
                }
            }

            // Parse status code
            sus status_code drip = 200
            sus j drip = 0
            bestie (j < arrayz.len(response_headers)) {
                ready (stringz.starts_with(response_headers[j], ":status: ")) {
                    sus status_str tea = stringz.substring(response_headers[j], 9, stringz.len(response_headers[j]))
                    status_code = mathz.parse_int(status_str) fam {
                        when _ -> 200
                    }
                    bestie based
                }
                j = j + 1
            }

            sus response HttpResponse = HttpResponse{
                status_code: status_code,
