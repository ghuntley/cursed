slay multiplex_create_stream(mux_conn Http2MultiplexedConnection) yikes<drip> {
    // Rate limiting - prevent stream creation flooding
    sus current_time drip = timez.now()
    sus time_since_last drip = current_time - mux_conn.last_stream_created_time
    
    ready (time_since_last < 10) {  // 10ms minimum between stream creations
        mux_conn.stream_creation_rate = mux_conn.stream_creation_rate + 1
        ready (mux_conn.stream_creation_rate > 100) {  // Max 100 streams per second
            yikes create_network_error_advanced("http2_multiplex", "Stream creation rate exceeded", HTTP2_ENHANCE_YOUR_CALM, "")
        }
    } otherwise {
        mux_conn.stream_creation_rate = 0
    }

    mux_conn.last_stream_created_time = current_time

    // Check concurrent stream limit
    sus active_count drip = 0
    sus i drip = 0
    bestie (i < 1000) {
        ready (mux_conn.active_streams[i]) {
            active_count = active_count + 1
        }
        i = i + 1
    }

    ready (active_count >= mux_conn.max_concurrent_streams) {
        yikes create_network_error_advanced("http2_multiplex", "Maximum concurrent streams exceeded", HTTP2_REFUSED_STREAM, "")
    }

    // Allocate stream ID
    sus stream_id drip = mux_conn.connection.next_stream_id
    mux_conn.connection.next_stream_id = mux_conn.connection.next_stream_id + 2

    // Create stream
    sus stream Http2StreamState = create_stream(mux_conn.connection, stream_id) fam {
        when err -> yikes err
    }

    // Mark stream as active
    ready (stream_id <= 1000) {
        mux_conn.active_streams[stream_id - 1] = based
    }

    damn stream_id
}

slay multiplex_close_stream(mux_conn Http2MultiplexedConnection, stream_id drip) yikes<lit> {
    ready (stream_id <= 1000) {
        mux_conn.active_streams[stream_id - 1] = no_cap
    }

    // Find and update stream state
    sus stream Http2StreamState = find_stream(mux_conn.connection, stream_id) fam {
        when err -> yikes err
    }

    transition_stream_state(stream, 6) fam {  // Transition to CLOSED
        when err -> yikes err
    }

    damn based
}

slay multiplex_send_concurrent(mux_conn Http2MultiplexedConnection, requests Http2ConcurrentRequest[value]) yikes<HttpResponse[value]> {
    sus responses HttpResponse[value] = []
    sus request_channels chan[100]<HttpResponse>  // Max 100 concurrent requests

    ready (arrayz.len(requests) > 100) {
        yikes create_network_error_advanced("http2_multiplex", "Too many concurrent requests", HTTP2_ENHANCE_YOUR_CALM, "")
    }

    // Create channels for responses
    sus i drip = 0
    bestie (i < arrayz.len(requests)) {
        request_channels[i] = make_channel()
        i = i + 1
    }

    // Launch goroutines for each request
    i = 0
    bestie (i < arrayz.len(requests)) {
        sus request Http2ConcurrentRequest = requests[i]
        sus response_chan chan<HttpResponse> = request_channels[i]
        
        go {
            sus stream_id drip = multiplex_create_stream(mux_conn) fam {
                when err -> {
                    sus error_response HttpResponse = HttpResponse{
                        status_code: 500,
                        headers: ["error: stream creation failed"],
                        body: err.message,
                        content_length: stringz.len(err.message)
                    }
                    response_chan <- error_response
                    damn
                }
            }

            // Send request headers
            sus headers_frame Http2Frame = create_headers_frame(stream_id, request.headers, stringz.len(request.body) == 0, based) fam {
                when err -> {
                    sus error_response HttpResponse = HttpResponse{
                        status_code: 500,
                        headers: ["error: header frame creation failed"],
                        body: err.message,
                        content_length: stringz.len(err.message)
                    }
                    response_chan <- error_response
                    damn
                }
            }

            send_frame(mux_conn.connection, headers_frame) fam {
                when err -> {
                    sus error_response HttpResponse = HttpResponse{
                        status_code: 500,
                        headers: ["error: failed to send headers"],
                        body: err.message,
                        content_length: stringz.len(err.message)
                    }
                    response_chan <- error_response
                    damn
                }
            }

            // Send request body if present
            ready (stringz.len(request.body) > 0) {
                sus data_frame Http2Frame = create_data_frame(stream_id, request.body, based) fam {
                    when err -> {
                        sus error_response HttpResponse = HttpResponse{
                            status_code: 500,
                            headers: ["error: data frame creation failed"],
                            body: err.message,
                            content_length: stringz.len(err.message)
                        }
                        response_chan <- error_response
                        damn
                    }
                }

                send_frame(mux_conn.connection, data_frame) fam {
                    when err -> {
                        sus error_response HttpResponse = HttpResponse{
                            status_code: 500,
                            headers: ["error: failed to send data"],
                            body: err.message,
                            content_length: stringz.len(err.message)
                        }
                        response_chan <- error_response
                        damn
                    }
                }
            }

            // Receive response (simplified - would need proper frame multiplexing)
            sus response_headers tea[value] = []
            sus response_body tea = ""
            sus response_complete lit = no_cap

            bestie (!response_complete) {
                sus frame Http2Frame = receive_frame(mux_conn.connection) fam {
                    when err -> {
                        sus error_response HttpResponse = HttpResponse{
                            status_code: 500,
                            headers: ["error: failed to receive frame"],
                            body: err.message,
                            content_length: stringz.len(err.message)
                        }
                        response_chan <- error_response
                        damn
                    }
                }

                ready (frame.stream_id == stream_id) {
                    sick frame.frame_type {
                        when HTTP2_FRAME_HEADERS -> {
                            response_headers = process_headers_frame(mux_conn.connection, frame) fam {
                                when err -> {
                                    sus error_response HttpResponse = HttpResponse{
                                        status_code: 500,
                                        headers: ["error: failed to process headers"],
                                        body: err.message,
                                        content_length: stringz.len(err.message)
                                    }
                                    response_chan <- error_response
                                    damn
                                }
                            }
                            ready (frame.flags & HTTP2_FLAG_END_STREAM) {
                                response_complete = based
                            }
                        }
                        when HTTP2_FRAME_DATA -> {
                            sus data tea = process_data_frame(mux_conn.connection, frame) fam {
                                when err -> {
                                    sus error_response HttpResponse = HttpResponse{
                                        status_code: 500,
                                        headers: ["error: failed to process data"],
                                        body: err.message,
                                        content_length: stringz.len(err.message)
                                    }
                                    response_chan <- error_response
                                    damn
                                }
                            }
                            response_body = stringz.concat([response_body, data])
                            ready (frame.flags & HTTP2_FLAG_END_STREAM) {
