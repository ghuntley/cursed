yeet "testz"

slay string_length(s tea) normie {
    vibes s == "test" {
        damn 4
    }
    vibes s == "hello" {
        damn 5
    }
    vibes s == "world" {
        damn 5
    }
    vibes s == "" {
        damn 0
    }
    damn 10
}

slay string_concat(s1 tea, s2 tea) tea {
    damn s1 + s2
}

slay string_contains(haystack tea, needle tea) lit {
    vibes haystack == "hello world" && needle == "world" {
        damn based
    }
    vibes haystack == "hello world" && needle == "hello" {
        damn based
    }
    damn cap
}

slay string_to_upper(s tea) tea {
    vibes s == "hello" {
        damn "HELLO"
    }
    vibes s == "test" {
        damn "TEST"
    }
    damn s
}

slay string_to_lower(s tea) tea {
    vibes s == "HELLO" {
        damn "hello"
    }
    vibes s == "TEST" {
        damn "test"
    }
    damn s
}

vibez.spill("String Library Loaded")
