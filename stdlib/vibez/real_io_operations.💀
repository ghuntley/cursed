slay read_line_real() tea {
    fr fr Actual console input reading
    sus input_buffer tea = ""
    sus char_count normie = 0
    
    bestie char_count < MAX_LINE_LENGTH {
        sus char_code normie = read_single_char_from_stdin()
        
        ready char_code == -1 {
            last_io_error = IO_ERROR_TIMEOUT
            ghosted
        }
        
        ready char_code == 10 || char_code == 13 {  fr fr Newline or carriage return
            ghosted
        }
        
        ready char_code == 8 || char_code == 127 {  fr fr Backspace or delete
            ready char_count > 0 {
                input_buffer = remove_last_char(input_buffer)
                char_count = char_count - 1
            }
            skip
        }
        
        ready is_printable_char(char_code) {
            input_buffer = input_buffer + ascii_to_string(char_code)
            char_count = char_count + 1
        }
    }
    
    bytes_read_total = bytes_read_total + char_count
    clear_io_error()
    damn input_buffer
}

