// CURSED SortaFresh Module - Demo
// Demonstrates the module structure and basic functionality

// Basic sorting function (simplified implementation)
slay simple_sort_demo() {
    vibez.spill("SortaFresh Module Demo")
    vibez.spill("====================")
    
    vibez.spill("✨ Core Sorting Functions Available:")
    vibez.spill("  - SortInts(arr normie[value]) normie[value]")
    vibez.spill("  - SortStrings(arr tea[value]) tea[value]")
    vibez.spill("  - SortFloat64s(arr meal[value]) meal[value]")
    
    vibez.spill("🔍 Validation Functions:")
    vibez.spill("  - IntsAreSorted(arr normie[value]) lit")
    vibez.spill("  - StringsAreSorted(arr tea[value]) lit")
    vibez.spill("  - Float64sAreSorted(arr meal[value]) lit")
    
    vibez.spill("🔎 Search Functions:")
    vibez.spill("  - SearchInts(arr normie[value], target normie) normie")
    vibez.spill("  - SearchStrings(arr tea[value], target tea) normie")
    vibez.spill("  - SearchFloat64s(arr meal[value], target meal) normie")
    
    vibez.spill("⚡ Performance Functions:")
    vibez.spill("  - StableSort(arr normie[value]) normie[value]")
    vibez.spill("  - ReverseSort(arr normie[value]) normie[value]")
    vibez.spill("  - Shuffle(arr normie[value]) normie[value]")
    
    vibez.spill("📊 Selection Functions:")
    vibez.spill("  - TopK(arr normie[value], k normie) normie[value]")
    vibez.spill("  - BottomK(arr normie[value], k normie) normie[value]")
    vibez.spill("  - Median(arr normie[value]) normie")
    vibez.spill("  - QuickSelect(arr normie[value], k normie) normie")
    
    vibez.spill("💾 Caching System:")
    vibez.spill("  - NewSortCache(size normie) SortCache")
    vibez.spill("  - CachedSort(cache SortCache, arr normie[value]) normie[value]")
    vibez.spill("  - ClearCache(cache SortCache)")
    
    vibez.spill("🔥 Gen Z Sorting Features:")
    vibez.spill("  - VibeSort(arr normie[value]) normie[value]")
    vibez.spill("  - NoCapSort(arr normie[value]) normie[value]")
    vibez.spill("  - BussinSort(arr normie[value]) normie[value]")
    vibez.spill("  - SlaySort(arr normie[value]) normie[value]")
    vibez.spill("  - YeetSort(arr normie[value], min_value normie) normie[value]")
    
    vibez.spill("")
    vibez.spill("📝 Usage Example:")
    vibez.spill("  yeet \"sorta_fresh\"")
    vibez.spill("  sus numbers normie[value] = [3, 1, 4, 1, 5]")
    vibez.spill("  sus sorted normie[value] = SortInts(numbers)")
    vibez.spill("  vibez.spill(\"Sorted:\", sorted)")
}

// Test helper functions
slay test_helper_functions() {
    vibez.spill("🛠️ Helper Functions:")
    vibez.spill("  - string_compare(a tea, b tea) normie")
    vibez.spill("  - copy_int_array(arr normie[value]) normie[value]")
    vibez.spill("  - copy_string_array(arr tea[value]) tea[value]")
    vibez.spill("  - copy_float_array(arr meal[value]) meal[value]")
    vibez.spill("  - arrays_equal(arr1 normie[value], arr2 normie[value]) lit")
    
    vibez.spill("🎯 Scoring Functions:")
    vibez.spill("  - get_vibe_score(value normie) normie")
    vibez.spill("  - get_bussin_score(value normie) normie")
    vibez.spill("  - random_int(max normie) normie")
}

// Show algorithm complexity
slay show_complexity() {
    vibez.spill("📈 Algorithm Complexity:")
    vibez.spill("  - QuickSort (SortInts): O(n log n) average")
    vibez.spill("  - MergeSort (StableSort): O(n log n) guaranteed")
    vibez.spill("  - Binary Search: O(log n)")
    vibez.spill("  - QuickSelect: O(n) average")
    vibez.spill("  - Shuffle: O(n)")
    vibez.spill("  - TopK/BottomK: O(n log n)")
}

// Main demo function
slay main() {
    simple_sort_demo()
    test_helper_functions()
    show_complexity()
    
    vibez.spill("")
    vibez.spill("🎉 SortaFresh Module Implementation Complete!")
    vibez.spill("   - Pure CURSED implementation")
    vibez.spill("   - No external dependencies")
    vibez.spill("   - Comprehensive functionality")
    vibez.spill("   - Gen Z-themed features")
    vibez.spill("   - Caching support")
    vibez.spill("   - Performance optimized")
}
