test_start("test_new_reader")
# Test new_reader function - creates RFC 4180 CSV reader
sus csv_data tea = "Name,Age,City\nJohn,25,NYC\nJane,30,LA"
sus reader CsvReader = new_reader(csv_data)
assert_eq_string(reader.delimiter, ",")
assert_eq_string(reader.quote, "\"")
assert_eq_string(reader.line_ending, "\r\n")
assert_eq_int(reader.position, 0)
assert_eq_int(reader.current_line, 1)
