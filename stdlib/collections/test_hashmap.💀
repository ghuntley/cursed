slay test_hashmap_single_item() {
    test_start("HashMap Single Item")
    
    sus map HashMap = hashmap_new()
    
    map = hashmap_insert(map, "only", "one")
    
    assert_eq_int(hashmap_len(map), 1)
    assert_eq_string(hashmap_get(map, "only"), "one")
