slay test_hashmap_new() {
    test_start("HashMap New")
    
    sus map HashMap = hashmap_new()
    
    assert_eq_int(hashmap_len(map), 0)
    assert_true(hashmap_is_empty(map))
    assert_eq_int(map.capacity, 16)
}

slay test_hashmap_with_capacity() {
    test_start("HashMap With Capacity")
    
    sus map HashMap = hashmap_with_capacity(32)
    
    assert_eq_int(hashmap_len(map), 0)
    assert_true(hashmap_is_empty(map))
    assert_eq_int(map.capacity, 32)
}

slay test_hashmap_insert_and_get() {
    test_start("HashMap Insert and Get")
    
    sus map HashMap = hashmap_new()
    
    map = hashmap_insert(map, "key1", "value1")
    map = hashmap_insert(map, "key2", "value2")
    map = hashmap_insert(map, "key3", "value3")
    
    assert_eq_int(hashmap_len(map), 3)
    assert_false(hashmap_is_empty(map))
    
    assert_eq_string(hashmap_get(map, "key1"), "value1")
    assert_eq_string(hashmap_get(map, "key2"), "value2")
    assert_eq_string(hashmap_get(map, "key3"), "value3")
}

slay test_hashmap_insert_update() {
    test_start("HashMap Insert Update")
    
    sus map HashMap = hashmap_new()
    
    map = hashmap_insert(map, "key1", "value1")
    assert_eq_string(hashmap_get(map, "key1"), "value1")
    assert_eq_int(hashmap_len(map), 1)
    
    fr fr Update existing key
    map = hashmap_insert(map, "key1", "updated_value")
    assert_eq_string(hashmap_get(map, "key1"), "updated_value")
    assert_eq_int(hashmap_len(map), 1)
}

slay test_hashmap_contains_key() {
    test_start("HashMap Contains Key")
    
    sus map HashMap = hashmap_new()
    
    map = hashmap_insert(map, "exists", "value")
    
    assert_true(hashmap_contains_key(map, "exists"))
    assert_false(hashmap_contains_key(map, "not_exists"))
}

slay test_hashmap_remove() {
    test_start("HashMap Remove")
    
    sus map HashMap = hashmap_new()
    
    map = hashmap_insert(map, "key1", "value1")
    map = hashmap_insert(map, "key2", "value2")
    
    assert_eq_int(hashmap_len(map), 2)
    assert_true(hashmap_contains_key(map, "key1"))
    
    map = hashmap_remove(map, "key1")
    
    assert_eq_int(hashmap_len(map), 1)
    assert_false(hashmap_contains_key(map, "key1"))
    assert_true(hashmap_contains_key(map, "key2"))
}

slay test_hashmap_clear() {
    test_start("HashMap Clear")
    
    sus map HashMap = hashmap_new()
    
    map = hashmap_insert(map, "key1", "value1")
    map = hashmap_insert(map, "key2", "value2")
    map = hashmap_insert(map, "key3", "value3")
    
    assert_eq_int(hashmap_len(map), 3)
    
    map = hashmap_clear(map)
    
    assert_eq_int(hashmap_len(map), 0)
    assert_true(hashmap_is_empty(map))
    assert_false(hashmap_contains_key(map, "key1"))
    assert_false(hashmap_contains_key(map, "key2"))
    assert_false(hashmap_contains_key(map, "key3"))
}

