        i = i + 1
    }
    
    fr fr Map should have resized
    assert_true(map.capacity > 8)
    assert_eq_int(hashmap_len(map), 10)
    
    fr fr All items should still be accessible after resize
    i = 0
    bestie i < 10 {
        sus key tea = "key" + tea(i)
        sus expected_value tea = "value" + tea(i)
        assert_true(hashmap_contains_key(map, key))
        assert_eq_string(hashmap_get(map, key), expected_value)
        i = i + 1
    }
}

