slay test_hashmap_collision_handling() {
    test_start("HashMap Collision Handling")
    
    sus map HashMap = hashmap_with_capacity(4)  fr fr Small capacity to force collisions
    
    fr fr Insert items that may collide
    map = hashmap_insert(map, "a", "value_a")
    map = hashmap_insert(map, "b", "value_b")
    map = hashmap_insert(map, "c", "value_c")
    map = hashmap_insert(map, "d", "value_d")
    
    fr fr All items should be retrievable despite collisions
    assert_eq_string(hashmap_get(map, "a"), "value_a")
    assert_eq_string(hashmap_get(map, "b"), "value_b")
    assert_eq_string(hashmap_get(map, "c"), "value_c")
    assert_eq_string(hashmap_get(map, "d"), "value_d")
    
    assert_eq_int(hashmap_len(map), 4)
}

