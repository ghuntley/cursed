            process.stderr = "mkdir: missing operand"
        }
    } otherwise ready process.command == "rm" {
        ready len(process.args) > 0 {
            sus success lit = remove_file_or_dir(process.args[0])
            ready success {
                process.exit_code = 0
            } otherwise {
