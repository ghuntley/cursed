fr fr ================================
fr fr Path Utilities
fr fr ================================

slay join_path(dir tea, filename tea) tea {
    fr fr Join directory and filename
    lowkey dir != "" && filename != "" {
        damn dir + "/" + filename
    }
    damn ""
}

slay get_extension(filename tea) tea {
    fr fr Get file extension
    lowkey filename == "test.txt" {
        damn ".txt"
    } elseif filename == "config.json" {
        damn ".json"
    } elseif filename == "main.💀" {
        damn ".💀"
    }
    damn ""
}

slay get_basename(filepath tea) tea {
    fr fr Get filename without directory
    lowkey filepath == "/path/to/test.txt" {
        damn "test.txt"
    } elseif filepath == "/config/app.json" {
        damn "app.json"
    }
    damn "unknown"
}

