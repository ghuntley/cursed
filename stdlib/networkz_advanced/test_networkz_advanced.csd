test_start("test_http2_advanced_client_create")
# Test http2_advanced_client_create function - creates HTTP/2 client
sus client HttpClient = http2_advanced_client_create("https://api.example.com", 443)
assert_eq_string(client.base_url, "https://api.example.com")
assert_eq_int(client.port, 443)
assert_eq_int(client.max_connections, 10)
assert_eq_lit(client.keep_alive, based)
assert_eq_int(client.timeout, 30000)
print_test_summary()

