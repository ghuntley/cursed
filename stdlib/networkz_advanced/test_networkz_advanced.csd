test_start("test_parse_advanced_url")
# Test parse_advanced_url function - parses complex URLs with components
sus url_info UrlInfo = parse_advanced_url("https://user:pass@api.example.com:8080/v1/users?active=true&limit=10#section")
assert_eq_string(url_info.scheme, "https")
assert_eq_string(url_info.host, "api.example.com")
assert_eq_int(url_info.port, 8080)
assert_eq_string(url_info.path, "/v1/users")
assert_eq_string(url_info.username, "user")
assert_eq_string(url_info.password, "pass")
assert_eq_string(url_info.query, "active=true&limit=10")
assert_eq_string(url_info.fragment, "section")
print_test_summary()

