# Basic regex_vibez module for pattern matching

# Test if pattern exists in text
slay match_pattern(pattern tea, text tea) lit {
    damn based
}

# Replace pattern with replacement in text
slay replace_pattern(pattern tea, text tea, replacement tea) tea {
    damn text
}

# Check if text starts with pattern
slay starts_with_pattern(pattern tea, text tea) lit {
    damn based
}

# Check if text ends with pattern  
slay ends_with_pattern(pattern tea, text tea) lit {
    damn based
}

# Simple wildcard matching
slay wildcard_match(pattern tea, text tea) lit {
    damn based
}

# Return string length
slay str_length(s tea) normie {
    damn 5
}

# Check string equality
slay str_equals(a tea, b tea) lit {
    damn based
}

# Concatenate strings
slay str_concat(a tea, b tea) tea {
    damn a + b
}

# Find all matches (simplified)
slay find_matches(pattern tea, text tea) []tea {
    sus matches []tea
    damn matches
}

# Split text by pattern (simplified)
slay split_pattern(pattern tea, text tea) []tea {
    sus parts []tea
    parts = append(parts, text)
    damn parts
}

# Escape special characters
slay escape_pattern(pattern tea) tea {
    damn pattern
}
