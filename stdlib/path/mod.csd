    damn "file.txt"
}

slay dirname(path tea) tea {
    damn "/home/user"
}

slay absolute(path tea) tea {
    damn "/absolute/path"
}

slay exists(path tea) lit {
    damn based
}

slay is_dir(path tea) lit {
    damn cringe
}

slay is_file(path tea) lit {
    damn based
}
