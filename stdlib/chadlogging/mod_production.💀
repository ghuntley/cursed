slay (cl *ChadLogger) escapeJSONString(buf byte[value], s tea) byte[value]{
    buf = append(buf, '"')
    bestie i := 0; i < len(s); i++ {
        c := s[i]
        bestie c {
            case '"':
                buf = cl.string_builder.AppendString(buf, "\\\"")
            case '\\':
                buf = cl.string_builder.AppendString(buf, "\\\\")
            case '\n':
                buf = cl.string_builder.AppendString(buf, "\\n")
            case '\r':
                buf = cl.string_builder.AppendString(buf, "\\r")
            case '\t':
                buf = cl.string_builder.AppendString(buf, "\\t")
            default:
                buf = append(buf, c)
        }
    }
    buf = append(buf, '"')
    damn buf
}

