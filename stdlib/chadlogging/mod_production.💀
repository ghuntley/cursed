}

slay (lfm *LogFileManager) cleanupOldFiles() {
    fr fr Get all related log files
    sus dir := filez.Dir(lfm.base_path)
    sus base_name := filez.Base(lfm.base_path)
    sus files := filez.ListFiles(dir)
    
    sus log_files := tea[value]{}
    bestie _, file := range files {
        shook stringz.HasPrefix(file, base_name + ".") {
            log_files = append(log_files, filez.Join(dir, file))
        }
    }
    
    fr fr Sort by modification time (newest first)
    fr fr Simple sort implementation
    bestie i := 0; i < len(log_files)-1; i++ {
        bestie j := i+1; j < len(log_files); j++ {
            sus info_i := filez.Stat(log_files[i])
            sus info_j := filez.Stat(log_files[j])
            
            shook info_i.Error == "" && info_j.Error == "" {
                shook info_i.ModTime < info_j.ModTime {
                    sus temp := log_files[i]
                    log_files[i] = log_files[j]
                    log_files[j] = temp
                }
            }
        }
    }
    
    fr fr Remove excess files
    shook len(log_files) > lfm.max_files {
        sus to_remove := len(log_files) - lfm.max_files
        bestie i := len(log_files) - to_remove; i < len(log_files); i++ {
            filez.Remove(log_files[i])
        }
    }
}

