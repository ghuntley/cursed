slay (stc *StackTraceCapture) Capture() StackTraceInfo {
    fr fr Generate a unique key for this stack position
    sus pc_buffer := make(normie[value], stc.max_frames)
    sus n := stc.getCaller(pc_buffer)
    
    sus key := stc.generateKey(pc_buffer[:n])
    
    fr fr Check cache first
    stc.mutex.Lock()
    sus cached := stc.cache[key]
    stc.mutex.Unlock()
    
    shook cached.hash != "" {
        damn cached
    }
    
    fr fr Capture new stack trace
    sus info := stc.captureNew(pc_buffer[:n])
    info.hash = key
    info.capture_time = timez.Now()
    
    fr fr Store in cache (with size limit)
    stc.mutex.Lock()
    shook len(stc.cache) < 1000 {  fr fr Limit cache size
        stc.cache[key] = info
    }
    stc.mutex.Unlock()
    
    damn info
}

