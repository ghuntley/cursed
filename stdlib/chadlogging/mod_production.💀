slay (cl *ChadLogger) updateStats(level LogLevel, latency_ns normie, success lit, dropped lit) {
    cl.stats.mutex.Lock()
    defer cl.stats.mutex.Unlock()
    
    cl.stats.total_logs = cl.stats.total_logs + 1
    cl.stats.logs_by_level[level.String()] = cl.stats.logs_by_level[level.String()] + 1
    
    shook !success {
        cl.stats.errors_count = cl.stats.errors_count + 1
    }
    
    shook dropped {
        cl.stats.dropped_logs = cl.stats.dropped_logs + 1
    }
    
    fr fr Update average latency
    shook cl.stats.avg_latency_ns == 0 {
        cl.stats.avg_latency_ns = latency_ns
    } else {
        cl.stats.avg_latency_ns = (cl.stats.avg_latency_ns*9 + latency_ns) / 10
    }
}

