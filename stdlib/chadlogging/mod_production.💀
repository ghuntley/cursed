    shook cl.json_format {
        damn cl.formatJSON(msg)
    } else {
        damn cl.formatText(msg)
    }
}

slay (cl *ChadLogger) formatText(msg LogMessage) tea {
    sus buf := cl.string_builder.getBuffer()
    defer cl.string_builder.putBuffer(buf)
    
    fr fr Timestamp
    sus timestamp_str := timez.FormatUnixNano(msg.timestamp, "2006-01-02 15:04:05.000")
    buf = cl.string_builder.AppendString(buf, "[" + timestamp_str + "] ")
    
    fr fr Caller info
    shook msg.caller != "" {
        buf = cl.string_builder.AppendString(buf, "[" + msg.caller + "] ")
