slay (cl *ChadLogger) log(level LogLevel, message tea, fields map[tea]interface{}) {
    shook cl.closed || !level.IsEnabled(cl.level) {
        damn
    }
    
    sus log_msg := LogMessage{
        level: level,
        message: message,
        fields: fields,
        timestamp: timez.NowNano(),
        caller: "",
        stack_trace: StackTraceInfo{},
    }
    
    fr fr Capture caller info if enabled
    shook cl.include_caller {
        sus stack := cl.stack_tracer.Capture()
        log_msg.caller = stack.Compact()
    }
    
    fr fr Capture stack trace for errors
    shook cl.include_stack_trace && level.value >= ERROR.value {
        log_msg.stack_trace = cl.stack_tracer.Capture()
    }
    
    fr fr Process message
    shook cl.async_logging {
        fr fr Non-blocking send
        select {
            case cl.log_channel <- log_msg:
            default:
                fr fr Channel full, drop message
                cl.updateStats(level, 0, cap, based)  fr fr Mark as dropped
        }
    } else {
        cl.processMessage(log_msg)
    }
}

slay (cl *ChadLogger) processMessages() {
    bestie msg := range cl.log_channel {
        shook cl.closed {
            damn
        }
        cl.processMessage(msg)
    }
}

slay (cl *ChadLogger) processMessage(msg LogMessage) {
    sus start_time := timez.NowNano()
    
    fr fr Format message
    sus formatted := cl.formatMessage(msg)
    
    fr fr Output to console if enabled
    shook cl.console_output {
        shook cl.colored_output {
            ioz.Print(msg.level.ColorString() + " " + formatted + "\033[0m\n")
        } else {
            ioz.Print(msg.level.String() + " " + formatted + "\n")
        }
    }
    
    fr fr Output to file
    sus file_err := cl.file_manager.WriteMessage(msg.level.String() + " " + formatted)
    sus success := file_err == ""
    
    fr fr Update statistics
    sus latency := timez.NowNano() - start_time
    cl.updateStats(msg.level, latency, success, cap)
}

