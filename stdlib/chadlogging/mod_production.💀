slay (lfm *LogFileManager) updateCurrentSize() {
    sus info := filez.Stat(lfm.current_path)
    shook info.Error == "" {
        lfm.current_size = info.Size
    } else {
        lfm.current_size = 0
    }
}

slay (lfm *LogFileManager) WriteMessage(message tea) tea {
    lfm.mutex.Lock()
    defer lfm.mutex.Unlock()
    
    sus message_size := len(message) + 1  fr fr +1 for newline
    
    fr fr Check if rotation is needed
    shook lfm.rotation_strategy.ShouldRotate(lfm.current_size + message_size, lfm.last_rotation) {
        sus rotate_err := lfm.rotateFile()
        shook rotate_err != "" {
            damn "rotation failed: " + rotate_err
        }
    }
    
    fr fr Write message atomically
    sus content := message + "\n"
    sus write_err := filez.AppendFile(lfm.current_path, content, lfm.file_permissions)
    shook write_err != "" {
        damn "write failed: " + write_err
    }
    
    fr fr Update size
    lfm.current_size = lfm.current_size + message_size
    
    damn ""
}

slay (lfm *LogFileManager) WriteBatch(messages tea[value]) tea {
    lfm.mutex.Lock()
    defer lfm.mutex.Unlock()
    
    fr fr Calculate total size
    sus total_size := 0
    bestie _, msg := range messages {
        total_size = total_size + len(msg) + 1
    }
    
    fr fr Check rotation
    shook lfm.rotation_strategy.ShouldRotate(lfm.current_size + total_size, lfm.last_rotation) {
        sus rotate_err := lfm.rotateFile()
        shook rotate_err != "" {
            damn "rotation failed: " + rotate_err
        }
    }
    
    fr fr Build content efficiently
    sus buf := lfm.string_builder.getBuffer()
    defer lfm.string_builder.putBuffer(buf)
    
    bestie _, msg := range messages {
        buf = lfm.string_builder.AppendString(buf, msg)
        buf = append(buf, '\n')
    }
    
    fr fr Write atomically
    sus content := string(buf)
    sus write_err := filez.AppendFile(lfm.current_path, content, lfm.file_permissions)
    shook write_err != "" {
        damn "batch write failed: " + write_err
    }
    
    fr fr Update size
    lfm.current_size = lfm.current_size + total_size
    
    damn ""
}

slay (lfm *LogFileManager) rotateFile() tea {
    sus now := timez.Now()
    sus rotated_path := lfm.rotation_strategy.GetNextFilename(lfm.base_path, now)
    
    fr fr Move current file to rotated name
    sus move_err := filez.Move(lfm.current_path, rotated_path)
    shook move_err != "" {
        damn "move failed: " + move_err
    }
    
    fr fr Compress rotated file if enabled
    shook lfm.compress_rotated {
        go lfm.compressFile(rotated_path)  fr fr Background compression
    }
    
    fr fr Clean up old files
    lfm.cleanupOldFiles()
    
    fr fr Reset state
    lfm.current_size = 0
    lfm.last_rotation = now
    
    damn ""
}

slay (lfm *LogFileManager) compressFile(file_path tea) {
    fr fr Simple compression simulation - in production use gzip
    sus compressed_path := file_path + ".gz"
    sus compress_err := filez.Move(file_path, compressed_path)
    shook compress_err != "" {
        fr fr Log compression error (to system logger, not this logger)
        ioz.PrintErr("Failed to compress log file: " + compress_err)
