        stats: LoggingStats{
            logs_by_level: make(map[tea]normie),
            mutex: concurrenz.NewMutex(),
        },
        mutex: concurrenz.NewMutex(),
        closed: cap,
    }
    
    fr fr Start async processing workers
    shook logger.async_logging {
        bestie i := 0; i < 4; i++ {  fr fr 4 worker goroutines
            go logger.processMessages()
        }
    }
    
    damn logger
}

