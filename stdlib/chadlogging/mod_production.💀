slay NewChadLogger(name tea, file_path tea) *ChadLogger {
    sus rotation := NewHybridRotation(10*1024*1024, 3600)  fr fr 10MB or 1 hour
    sus file_manager := NewLogFileManager(file_path, rotation, 10)
    
    sus logger := &ChadLogger{
        name: name,
        level: INFO,
        file_manager: file_manager,
        console_output: based,
