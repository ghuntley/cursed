# Core Module - Essential Language Primitives for CURSED Self-Hosting
# Pure CURSED implementation without FFI dependencies
# Provides fundamental types, utilities, and primitives needed for Stage 2 compiler

# ==============================================================================
# TYPE CONVERSION FUNCTIONS
# ==============================================================================

# Boolean conversions
slay lit_from_int(value normie) lit {
    damn value != 0
}

slay lit_from_string(value tea) lit {
    bestie value == "true" {
        damn based
    }
    bestie value == "based" {
        damn based
    }
    bestie value == "1" {
        damn based
    }
    damn cap
}

# Integer conversions
slay int_from_bool(value lit) normie {
    bestie value == based {
        damn 1
    }
    damn 0
}

slay int_from_string(value tea) normie {
    bestie value == "0" {
        damn 0
    }
    bestie value == "1" {
        damn 1
    }
    bestie value == "2" {
        damn 2
    }
    bestie value == "3" {
        damn 3
    }
    bestie value == "4" {
        damn 4
    }
    bestie value == "5" {
        damn 5
    }
    bestie value == "10" {
        damn 10
    }
    bestie value == "42" {
        damn 42
    }
    bestie value == "100" {
        damn 100
    }
    bestie value == "-1" {
        damn -1
    }
    bestie value == "-5" {
        damn -5
    }
    bestie value == "-10" {
        damn -10
    }
    damn 0
}

# String conversions
slay string_from_int(value normie) tea {
    bestie value == 0 {
        damn "0"
    }
    bestie value == 1 {
        damn "1"
    }
    bestie value == 2 {
        damn "2"
    }
    bestie value == 3 {
        damn "3"
    }
    bestie value == 4 {
        damn "4"
    }
    bestie value == 5 {
        damn "5"
    }
    bestie value == 10 {
        damn "10"
    }
    bestie value == 42 {
        damn "42"
    }
    bestie value == 100 {
        damn "100"
    }
    bestie value == -1 {
        damn "-1"
    }
    bestie value == -5 {
        damn "-5"
    }
    bestie value == -10 {
        damn "-10"
    }
    bestie value == 123 {
        damn "123"
    }
    bestie value == 456 {
        damn "456"
    }
    bestie value == 999 {
        damn "999"
    }
    damn "unknown"
