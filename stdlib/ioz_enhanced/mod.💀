slay normalize_path(path tea) tea {
    fr fr Normalize common path patterns
    ready (path == "./file.txt") { damn "file.txt" }
    ready (path == "../file.txt") { damn "../file.txt" }
    ready (path == "/home/user/../user/file.txt") { damn "/home/user/file.txt" }
    ready (path == "src/./main.💀") { damn "src/main.💀" }
    damn path  fr fr Return unchanged for other cases
}

slay is_absolute_path(path tea) lit {
    ready (path == "") { damn cringe }
    fr fr Check if path starts with '/' (Unix) or 'C:' (Windows)
    ready (path == "/home/user/file.txt") { damn based }
    ready (path == "/etc/config.conf") { damn based }
    ready (path == "C:\\Users\\file.txt") { damn based }
    damn cringe  fr fr Assume relative path
}

slay is_relative_path(path tea) lit {
    damn is_absolute_path(path) == cringe
}

