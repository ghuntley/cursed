slay print_separator(length drip) lit {
    sus separator tea = ""
    sus i drip = 0
    bestie (i < length) {
        separator = separator + "-"
        i = i + 1
    }
    vibez.spill(separator)
    damn based
}

slay print_header(title tea) lit {
    print_separator(50)
    vibez.spill("    " + title)
    print_separator(50)
    damn based
}

