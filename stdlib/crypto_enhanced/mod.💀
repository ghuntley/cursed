fr fr Simple hash for internal use
slay simple_hash(data tea) normie {
    sus hash normie = 0x811c9dc5 fr fr FNV-1a initial value
    sus data_len normie = enhanced_string_length(data)
    
    bestie i := 0; i < data_len; i++ {
        hash = hash ^ enhanced_char_at(data, i)
        hash = hash * 0x01000193 fr fr FNV-1a prime
    }
    
