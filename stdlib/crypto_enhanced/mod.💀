slay encrypt_simple(data tea, key tea) tea {
    fr fr Simple XOR-based encryption with key expansion
    sus key_len normie = enhanced_string_length(key)
    sus data_len normie = enhanced_string_length(data)
    sus result tea = ""
    
    fr fr Generate extended key using hash mixing
    sus key_hash1 normie = simple_hash(key)
    sus key_hash2 normie = simple_hash(key + "salt")
    
    bestie i := 0; i < data_len; i++ {
        sus data_byte normie = enhanced_char_at(data, i)
        sus key_byte1 normie = (key_hash1 >> ((i % 4) * 8)) & 0xFF
        sus key_byte2 normie = (key_hash2 >> (((i + 1) % 4) * 8)) & 0xFF
        sus encrypted_byte normie = data_byte ^ key_byte1 ^ key_byte2 ^ (i & 0xFF)
        result = result + enhanced_byte_to_char(encrypted_byte)
    }
    
    damn result
}

slay decrypt_simple(data tea, key tea) tea {
    fr fr Decryption is the same as encryption for XOR cipher
    damn encrypt_simple(data, key)
}

