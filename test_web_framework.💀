    fr fr Test basic variable substitution
    sus template_content tea = "Hello {{name}}! Welcome to {{site}}."
    sus data_json tea = `{"name": "CURSED User", "site": "CURSED Blog"}`
    
    sus result tea = template.render_template_string(template_content, data_json)
    sus expected tea = "Hello CURSED User! Welcome to CURSED Blog."
    
    vibe_if result != expected {
        print("FAIL: Basic template rendering failed")
        print("Expected: " + expected)
        print("Got: " + result)
        damn "Template rendering failed"
    }
    print("PASS: Basic template rendering works")
    
    fr fr Test template compilation
    sus template_id tea = template.compile_template(template_content)
    vibe_if template_id == "" {
        print("FAIL: Template compilation failed")
        damn "Template compilation failed"
    }
    print("PASS: Template compilation works")
    
    fr fr Test loop rendering (simple test)
    sus loop_template tea = "Items: {{#each items}}{{this}} {{/each}}"
    sus loop_data tea = `{"items": ["a", "b", "c"]}`
    sus loop_result tea = template.render_template_string(loop_template, loop_data)
    
    print("Loop template result: " + loop_result)
    print("PASS: Loop template processing works")
    
    print("SUCCESS: Template engine test passed")
    damn nil
}

