yeet "vibez"
yeet "mathz"

slay main_character() {
    sus x drip = 42.5
    sus y drip = 17.2
    
    sus result drip = mathz.add(x, y)
    vibez.spill("Math add result:")
    vibez.spill(result.(tea))
    
    sus abs_result drip = mathz.abs_normie(-25.5)
    vibez.spill("Math abs result:")
    vibez.spill(abs_result.(tea))
    
    sus max_result drip = mathz.max_normie(10.0, 20.0)
    vibez.spill("Math max result:")
    vibez.spill(max_result.(tea))
}
