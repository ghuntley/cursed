fr fr Test file for type assertions

slay main() normie {
    fr fr Basic type assertions
    sus number normie = 42
    sus floatNum meal = 3.14
    sus text tea = "hello"
    sus flag lit = based
    sus character sip = 'A'
    
    fr fr Convert integer to different integer types
    sus smallInt smol = number.(smol)
    sus mediumInt mid = number.(mid)
    sus largeInt thicc = number.(thicc)
    
    fr fr Convert integer to float
    sus numberAsFloat meal = number.(meal)
    
    fr fr Convert float to integer
    sus floatAsInt normie = floatNum.(normie)
    
    fr fr Convert character to integer
    sus charAsInt normie = character.(normie)
    
    fr fr Convert integer to character
    sus intAsChar sip = 65.(sip)
    
    fr fr Convert boolean to integer
    sus boolAsInt normie = flag.(normie)
    
    fr fr Output results
    vibez.spill("Original number: ")
    vibez.spill(number)
    vibez.spill("As smol: ")
    vibez.spill(smallInt)
    vibez.spill("As mid: ")
    vibez.spill(mediumInt)
    vibez.spill("As thicc: ")
    vibez.spill(largeInt)
    
    vibez.spill("Number as float: ")
    vibez.spill(numberAsFloat)
    vibez.spill("Float as int: ")
    vibez.spill(floatAsInt)
    
    vibez.spill("Character as int: ")
    vibez.spill(charAsInt)
    vibez.spill("Int as character: ")
    vibez.spill(intAsChar)
    
    vibez.spill("Boolean as int: ")
    vibez.spill(boolAsInt)
    
    yolo 0
}
