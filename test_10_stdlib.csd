# Test 10: Standard library modules
yeet "mathz"
yeet "stringz"
yeet "arrayz"

sus result drip = mathz.abs(-42)
vibez.spill("Math result: " + result)

sus str tea = "hello world"
sus upper tea = stringz.to_upper(str)
vibez.spill("String result: " + upper)

sus arr = arrayz.create(5)
arrayz.set(arr, 0, 100)
sus val drip = arrayz.get(arr, 0)
vibez.spill("Array result: " + val)
