yeet "mathz"

slay main_character() {
    yap("=== CURSED Complex Math Test ===")
    
    // Test 1: Arithmetic + stdlib combined
    sus base normie = 2
    sus stdlib_result normie = mathz.add_two(4, 5)
    sus combined normie = base + stdlib_result
    yap("2 + mathz.add_two(4, 5) =")
    yap(combined)
    
    // Test 2: Multiple operations
    sus val1 normie = mathz.add_two(3, 2)
    sus val2 normie = mathz.add_two(1, 4)
    sus final_result normie = val1 + val2
    yap("mathz.add_two(3, 2) + mathz.add_two(1, 4) =")
    yap(final_result)
    
    // Test 3: Multiplication with mathz
    sus mathz_val normie = mathz.add_two(2, 3)
    sus multiplied normie = mathz_val * 2
    yap("mathz.add_two(2, 3) * 2 =")
    yap(multiplied)
    
    yap("=== Complex Test Complete ===")
}
