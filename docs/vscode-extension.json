{
  "name": "cursed-language-support",
  "displayName": "CURSED Language Support",
  "description": "Language support for the CURSED programming language",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cursed",
        "aliases": [
          "CURSED",
          "cursed"
        ],
        "extensions": [
          ".csd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cursed",
        "scopeName": "source.cursed",
        "path": "./syntaxes/cursed.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "CURSED Language Server",
      "properties": {
        "cursed.lsp.path": {
          "type": "string",
          "default": "cursed-lsp",
          "description": "Path to the CURSED language server executable"
        },
        "cursed.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the CURSED language server"
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:cursed"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}
