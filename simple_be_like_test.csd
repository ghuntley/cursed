# Simple be_like test
vibez.spill("Testing be_like keyword")

# Define type aliases
be_like MyInteger = normie
be_like MyString = tea

# Use type aliases
sus number MyInteger = 42
sus text MyString = "hello"

vibez.spill("Number:", number)
vibez.spill("Text:", text)

vibez.spill("be_like test complete")
