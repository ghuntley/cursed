fr fr Working Interpreter Test
fr fr Focus on features that work in the current interpreter

vibez.spill("🚀 Testing working interpreter features")

fr fr Basic variable declarations (simplified syntax)
sus x = 10
sus y = 5
sus name = "CURSED"

fr fr Arithmetic expressions
sus sum = x + y
sus diff = x - y

fr fr Multiple argument printing
vibez.spill("Variables:", x, y, name)
vibez.spill("Sum:", sum)
vibez.spill("Difference:", diff)

fr fr String and boolean values
sus greeting = "Hello World"
sus flag = based

vibez.spill("String:", greeting)
vibez.spill("Boolean:", flag)

fr fr Complex expressions
sus complex = x + y + 5

vibez.spill("Complex expression (x + y + 5):", complex)

vibez.spill("🎯 Working interpreter test complete!")
