yeet "stringz"
yeet "mathz"
yeet "vibez"

vibez.spill("=== Testing String Functions ===")

sus test_str tea = "Hello, CURSED!"
sus str_length normie = length(test_str)
vibez.spill("String length:", str_length)

sus sub_str tea = substring(test_str, 0, 5) 
vibez.spill("Substring:", sub_str)

sus contains_result lit = contains(test_str, "CURSED")
vibez.spill("Contains 'CURSED':", contains_result)

sus concat_result tea = concat("Hello", " World")
vibez.spill("Concatenation:", concat_result)

vibez.spill("=== Testing Math Functions ===")

sus sqrt_result meal = sqrt_meal(16.0)
vibez.spill("sqrt(16) =", sqrt_result)

sus power_result meal = pow_meal(2.0, 3.0)
vibez.spill("2^3 =", power_result)

sus abs_result normie = abs_normie(-42)
vibez.spill("abs(-42) =", abs_result)

sus sin_result meal = sin_meal(3.14159 / 2.0)
vibez.spill("sin(π/2) =", sin_result)

vibez.spill("=== All Tests Complete ===")
