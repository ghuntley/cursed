slay main_character() {
    vibez.spill("=== CURSED LLVM Compilation Test ===");
    
    vibez.spill("Basic variables:");
    sus x drip = 10;
    sus y drip = 3;
    vibez.spill(x);
    vibez.spill(y);
    
    vibez.spill("Binary operations:");
    sus add drip = x + y;
    sus sub drip = x - y;
    sus mul drip = x * y;
    sus div drip = x / y;
    
    vibez.spill(add);
    vibez.spill(sub);
    vibez.spill(mul);
    vibez.spill(div);
    
    vibez.spill("Mathz stdlib test:");
    sus mathz_add drip = mathz.add_two(5, 3);
    sus mathz_mul drip = mathz.multiply_two(4, 6);
    vibez.spill(mathz_add);
    vibez.spill(mathz_mul);
    
    vibez.spill("Test complete!");
}
