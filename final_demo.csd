fr fr CURSED v3.9.0 Final Demonstration - All Core Features Working

slay add(x normie, y normie) normie {
    damn x + y;
}

slay multiply(a normie, b normie) normie {
    damn a * b;
}

slay main() {
    fr fr Variable declarations with types
    sus x normie = 10;
    sus y normie = 5;
    
    fr fr Function calls with mathematical operations
    sus sum normie = add(x, y);
    sus product normie = multiply(x, y);
    
    fr fr Multi-line if statements with complex logic
    lowkey sum > 10 {
        vibez.spill("Sum is greater than 10");
        lowkey product > 40 {
            vibez.spill("Product is also greater than 40");
        } highkey {
            vibez.spill("Product is 40 or less");
        }
    } highkey {
        vibez.spill("Sum is 10 or less");
    }
    
    fr fr Single-line conditional
    lowkey sum == 15 { vibez.spill("Sum equals exactly 15!"); }
    
    fr fr Boolean expressions
    sus flag lit = based;
    lowkey flag { vibez.spill("Boolean flag is true"); }
    
    damn sum;
}
