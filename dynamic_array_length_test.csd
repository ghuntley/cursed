yeet "arrayz"

# Test 1: Dynamic length calculation for array literals
sus arr1 []drip = [1, 2, 3]
vibez.spill("Array literal length:", len(arr1))

# Test 2: Empty array length
sus arr2 []drip = []
vibez.spill("Empty array length:", len(arr2))

# Test 3: Longer array
sus arr3 []drip = [10, 20, 30, 40, 50, 60]
vibez.spill("Longer array length:", len(arr3))

# Test 4: Array access with bounds checking
vibez.spill("First element:", arr1[0])
vibez.spill("Second element:", arr1[1])
vibez.spill("Third element:", arr1[2])

# Test 5: Different types
sus strings []tea = ["hello", "world", "test"]
