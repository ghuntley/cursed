yeet "vibez"
yeet "mathz"

slay main_character() {
    vibez.spill("Testing multiple stdlib modules:")
    
    sus x drip = mathz.abs_normie(-42.5)
    vibez.spill("Mathz abs result calculated")
    
    sus max_val drip = mathz.max_normie(10.0, 20.0) 
    vibez.spill("Mathz max result calculated")
    
    vibez.spill("All stdlib tests completed in binary!")
}
