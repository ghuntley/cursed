vibe main
yeet "vibez"

slay main_character() {
    sus simple_slice []normie
    sus double_slice [][]normie
    sus triple_slice [][][]normie
    
    vibez.spill("Successfully parsed multi-dimensional slice types:")
    vibez.spill("- []normie (single slice)")
    vibez.spill("- [][]normie (double slice)")  
    vibez.spill("- [][][]normie (triple slice)")
    vibez.spill("Parser fix working correctly!")
}
