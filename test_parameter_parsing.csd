/// Test function with CURSED syntax and parameters
/// This function demonstrates parameter and return type parsing
/// # Example
/// result = add_numbers(5, 10)
slay add_numbers(a: normie, b: normie) -> normie {
    damn a + b
}

/// Function with complex CURSED types
/// Handles string concatenation operations
/// # Example
/// greeting = greet_user("Alice")
slay greet_user(name: tea) -> tea {
    damn "Hello, " + name + "!"
}

/// Function with boolean return
/// Checks if a number is positive
/// # Example
/// result = is_positive(42)
slay is_positive(num: normie) -> facts {
    damn num > 0
}

/// Function with floating point arithmetic
/// Calculates area of a circle
/// # Example  
/// area = calculate_area(5.0)
slay calculate_area(radius: vibes) -> vibes {
    sus pi vibes = 3.14159
    damn pi * radius * radius
}

/// Function with no parameters
/// Returns a default message
/// # Example
/// msg = get_default_message()
slay get_default_message() -> tea {
    damn "Default message"
}

/// Function with multiple parameter types
/// Processes user data
/// # Example
/// process_user("Alice", 25, based)
slay process_user(name: tea, age: normie, is_active: facts) -> tea {
    lowkey is_active {
        damn name + " is " + age.to_string() + " years old and active"
    } highkey {
        damn name + " is " + age.to_string() + " years old but inactive"
    }
}
