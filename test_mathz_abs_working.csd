vibe main
yeet "vibez"
yeet "mathz"

slay main_character() {
    vibez.spill("Testing mathz.abs_normie function...")
    
    // Test normal case
    sus negative drip = -42
    sus result1 drip = mathz.abs_normie(negative)
    vibez.spill("mathz.abs_normie(-42):")
    vibez.spill(result1)
    
    // Test potentially problematic case
    sus large_negative drip = -999999
    sus result2 drip = mathz.abs_normie(large_negative)
    vibez.spill("mathz.abs_normie(-999999):")
    vibez.spill(result2)
    
    vibez.spill("Test completed successfully!")
}
