{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CURSED Advanced",
  "scopeName": "source.cursed",
  "fileTypes": ["csd", "cursed"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#structs"
    },
    {
      "include": "#interfaces"
    },
    {
      "include": "#generics"
    },
    {
      "include": "#macros"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cursed",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cursed",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        },
        {
          "name": "comment.line.documentation.cursed",
          "match": "///.*$",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "markup.bold.cursed",
                  "match": "\\*\\*[^*]+\\*\\*"
                },
                {
                  "name": "markup.italic.cursed",
                  "match": "\\*[^*]+\\*"
                },
                {
                  "name": "markup.inline.code.cursed",
                  "match": "`[^`]+`"
                }
              ]
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cursed",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\(\\\\|[abfnrtv'\"?]|[0-3]\\d{,2}|[4-7]\\d?|x[0-9a-fA-F]{,2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
            },
            {
              "name": "invalid.illegal.unknown-escape.cursed",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.cursed",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.cursed",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\(\\\\|[abfnrtv'\"?]|[0-3]\\d{,2}|[4-7]\\d?|x[0-9a-fA-F]{,2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
            }
          ]
        },
        {
          "name": "string.quoted.triple.cursed",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "characters": {
      "name": "string.quoted.single.cursed",
      "match": "'([^'\\\\]|\\\\.)'",
      "patterns": [
        {
          "name": "constant.character.escape.cursed",
          "match": "\\\\(\\\\|[abfnrtv'\"?]|[0-3]\\d{,2}|[4-7]\\d?|x[0-9a-fA-F]{,2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cursed",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?[fF]?\\b"
        },
        {
          "name": "constant.numeric.integer.hexadecimal.cursed",
          "match": "\\b0[xX][0-9a-fA-F]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.integer.binary.cursed",
          "match": "\\b0[bB][01]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.integer.octal.cursed",
          "match": "\\b0[oO][0-7]+[uUlL]*\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.cursed",
          "match": "\\b\\d+[uUlL]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cursed",
          "match": "\\b(ready|otherwise|bestie|break|continue|damn|yikes|fam|shook|sick|go)\\b"
        },
        {
          "name": "keyword.declaration.cursed",
          "match": "\\b(sus|slay|squad|collab|yeet|nocap|periodt|vibes)\\b"
        },
        {
          "name": "keyword.modifier.cursed",
          "match": "\\b(static|extern|inline|const|mut|ref|async|await)\\b"
        },
        {
          "name": "keyword.operator.cursed",
          "match": "\\b(and|or|not|in|is|as|typeof|sizeof|alignof)\\b"
        },
        {
          "name": "keyword.other.cursed",
          "match": "\\b(use|mod|pub|priv|unsafe|defer|comptime|@[a-zA-Z_][a-zA-Z0-9_]*)\\b"
        },
        {
          "name": "storage.modifier.cursed",
          "match": "\\b(thread_local|volatile|atomic)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cursed",
          "match": "\\b(drip|tea|lit|cap|vibe|flex|no_cap|periodt)\\b"
        },
        {
          "name": "storage.type.compound.cursed",
          "match": "\\b(Array|Map|Set|Option|Result|Channel|Promise|Future)\\b"
        },
        {
          "name": "storage.type.generic.cursed",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "storage.type.pointer.cursed",
          "match": "\\*|&|\\[\\]"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.cursed",
          "begin": "\\b(slay)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.cursed"
            },
            "2": {
              "name": "entity.name.function.cursed"
            }
          },
          "end": "\\{",
          "patterns": [
            {
              "include": "#function-parameters"
            },
            {
              "include": "#function-return-type"
            },
            {
              "include": "#generics"
            }
          ]
        },
        {
          "name": "meta.function.call.cursed",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.call.cursed"
            }
          }
        }
      ]
    },
    "function-parameters": {
      "name": "meta.function.parameters.cursed",
      "begin": "\\(",
      "end": "\\)",
      "patterns": [
        {
          "include": "#types"
        },
        {
          "include": "#identifiers"
        },
        {
          "include": "#keywords"
        }
      ]
    },
    "function-return-type": {
      "name": "meta.function.return-type.cursed",
      "begin": "->",
      "end": "(?=\\{)",
      "patterns": [
        {
          "include": "#types"
        }
      ]
    },
    "structs": {
      "patterns": [
        {
          "name": "meta.struct.definition.cursed",
          "begin": "\\b(squad)\\s+([A-Z][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.struct.cursed"
            },
            "2": {
              "name": "entity.name.type.struct.cursed"
            }
          },
          "end": "\\}",
          "patterns": [
            {
              "include": "#struct-fields"
            },
            {
              "include": "#generics"
            },
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "struct-fields": {
      "name": "meta.struct.field.cursed",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s+([a-zA-Z_][a-zA-Z0-9_<>\\[\\]]*)",
      "captures": {
        "1": {
          "name": "variable.other.member.cursed"
        },
        "2": {
          "name": "storage.type.cursed"
        }
      }
    },
    "interfaces": {
      "patterns": [
        {
          "name": "meta.interface.definition.cursed",
          "begin": "\\b(collab)\\s+([A-Z][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.interface.cursed"
            },
            "2": {
              "name": "entity.name.type.interface.cursed"
            }
          },
          "end": "\\}",
          "patterns": [
            {
              "include": "#generics"
            },
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "generics": {
      "patterns": [
        {
          "name": "meta.generic.cursed",
          "begin": "<",
          "end": ">",
          "patterns": [
            {
              "include": "#types"
            },
            {
              "include": "#identifiers"
            },
            {
              "name": "punctuation.separator.generic.cursed",
              "match": ","
            }
          ]
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "meta.macro.cursed",
          "begin": "\\b(macro)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.macro.cursed"
            },
            "2": {
              "name": "entity.name.function.macro.cursed"
            }
          },
          "end": "\\}",
          "patterns": [
            {
              "include": "$self"
            }
          ]
        },
        {
          "name": "meta.macro.call.cursed",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)!",
          "captures": {
            "1": {
              "name": "entity.name.function.macro.call.cursed"
            }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.cursed",
          "begin": "#\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "entity.name.function.attribute.cursed",
              "match": "[a-zA-Z_][a-zA-Z0-9_]*"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.cursed",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.cursed",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.cursed",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.cursed",
          "match": "(&|\\||\\^|~|<<|>>)"
        },
        {
          "name": "keyword.operator.assignment.cursed",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.range.cursed",
          "match": "\\.\\.|\\.\\.="
        },
        {
          "name": "keyword.operator.access.cursed",
          "match": "\\.|::|\\->"
        },
        {
          "name": "keyword.operator.channel.cursed",
          "match": "<-"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.cursed",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.cursed",
          "match": ";"
        },
        {
          "name": "punctuation.definition.block.cursed",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.group.cursed",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.array.cursed",
          "match": "[\\[\\]]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.constant.cursed",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.cursed",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
