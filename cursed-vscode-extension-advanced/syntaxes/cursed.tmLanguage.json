{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CURSED",
    "scopeName": "source.cursed",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#structs"
        },
        {
            "include": "#interfaces"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#imports"
        },
        {
            "include": "#pattern-matching"
        },
        {
            "include": "#error-handling"
        },
        {
            "include": "#concurrency"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.cursed",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.cursed",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "name": "comment.block.documentation.cursed",
                            "match": "\\*.*"
                        }
                    ]
                },
                {
                    "name": "comment.block.documentation.cursed",
                    "begin": "/\\*\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "name": "keyword.other.documentation.cursed",
                            "match": "@(param|returns|throws|example|see|since|deprecated)\\b"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cursed",
                    "match": "\\b(ready|otherwise|bestie|sick|when|go|select|defer|damn)\\b"
                },
                {
                    "name": "keyword.declaration.cursed",
                    "match": "\\b(sus|slay|squad|collab|yeet)\\b"
                },
                {
                    "name": "keyword.other.cursed",
                    "match": "\\b(fam|shook|yikes|stan|dm|vibe)\\b"
                },
                {
                    "name": "constant.language.boolean.cursed",
                    "match": "\\b(based|cringe)\\b"
                },
                {
                    "name": "constant.language.null.cursed",
                    "match": "\\b(null|void)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cursed",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        },
                        {
                            "name": "constant.other.placeholder.cursed",
                            "match": "\\{[^}]*\\}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.cursed",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.raw.cursed",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.cursed",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.cursed",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.cursed",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.decimal.cursed",
                    "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.cursed",
                    "match": "(=|\\+=|-=|\\*=|/=|%=|\\|=|&=|\\^=|<<=|>>=)"
                },
                {
                    "name": "keyword.operator.comparison.cursed",
                    "match": "(==|!=|<|<=|>|>=)"
                },
                {
                    "name": "keyword.operator.logical.cursed",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.arithmetic.cursed",
                    "match": "(\\+|-|\\*|/|%)"
                },
                {
                    "name": "keyword.operator.bitwise.cursed",
                    "match": "(&|\\||\\^|<<|>>|~)"
                },
                {
                    "name": "keyword.operator.channel.cursed",
                    "match": "(<-)"
                },
                {
                    "name": "keyword.operator.pointer.cursed",
                    "match": "(\\*|&)"
                },
                {
                    "name": "keyword.operator.range.cursed",
                    "match": "(\\.\\.)"
                },
                {
                    "name": "keyword.operator.access.cursed",
                    "match": "(\\.)"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.cursed",
                    "match": "\\b(drip|tea|lit|smol|thicc|mid)\\b"
                },
                {
                    "name": "storage.type.collection.cursed",
                    "match": "\\b(\\[\\]|chan|map)\\b"
                },
                {
                    "name": "storage.type.user.cursed",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.declaration.cursed",
                    "match": "(?<=slay\\s+)[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                },
                {
                    "name": "entity.name.function.call.cursed",
                    "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                },
                {
                    "name": "entity.name.function.method.cursed",
                    "match": "(?<=\\.)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
                }
            ]
        },
        "structs": {
            "patterns": [
                {
                    "name": "entity.name.type.struct.cursed",
                    "match": "(?<=squad\\s+)[A-Z][a-zA-Z0-9_]*"
                },
                {
                    "name": "storage.type.struct.cursed",
                    "match": "\\bsquad\\b"
                }
            ]
        },
        "interfaces": {
            "patterns": [
                {
                    "name": "entity.name.type.interface.cursed",
                    "match": "(?<=collab\\s+)[A-Z][a-zA-Z0-9_]*"
                },
                {
                    "name": "storage.type.interface.cursed",
                    "match": "\\bcollab\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.declaration.cursed",
                    "match": "(?<=sus\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
                },
                {
                    "name": "variable.other.cursed",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.other.cursed",
                    "match": "\\b[A-Z][A-Z0-9_]*\\b"
                },
                {
                    "name": "constant.language.cursed",
                    "match": "\\b(facts|cap|normie)\\b"
                }
            ]
        },
        "imports": {
            "patterns": [
                {
                    "name": "keyword.control.import.cursed",
                    "match": "\\byeet\\b"
                },
                {
                    "name": "string.quoted.double.import.cursed",
                    "begin": "(?<=yeet\\s+)\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "entity.name.namespace.cursed",
                            "match": "[a-zA-Z_][a-zA-Z0-9_]*"
                        }
                    ]
                }
            ]
        },
        "pattern-matching": {
            "patterns": [
                {
                    "name": "keyword.control.pattern.cursed",
                    "match": "\\b(sick|when)\\b"
                },
                {
                    "name": "keyword.operator.pattern.cursed",
                    "match": "(->) "
                },
                {
                    "name": "constant.other.wildcard.cursed",
                    "match": "\\b_\\b"
                }
            ]
        },
        "error-handling": {
            "patterns": [
                {
                    "name": "keyword.control.error.cursed",
                    "match": "\\b(fam|yikes|shook)\\b"
                },
                {
                    "name": "entity.name.type.error.cursed",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*Error\\b"
                }
            ]
        },
        "concurrency": {
            "patterns": [
                {
                    "name": "keyword.control.concurrency.cursed",
                    "match": "\\b(go|select|chan|timeout)\\b"
                },
                {
                    "name": "storage.type.channel.cursed",
                    "match": "\\bchan<[^>]+>\\b"
                }
            ]
        }
    }
}
