fr fr CURSED Interpreter Validation Test

fr fr Test 1: Basic variable declaration and output
sus x drip = 42
vibez.spill(x)

fr fr Test 2: String variables
sus name tea = "CURSED"
vibez.spill(name)

fr fr Test 3: Boolean variables
sus flag lit = based
vibez.spill(flag)

fr fr Test 4: Arithmetic expressions
sus result drip = (10 + 5) * 2
vibez.spill(result)

fr fr Test 5: Arrays
sus numbers []drip = [1, 2, 3, 4, 5]
vibez.spill(len(numbers))
vibez.spill(numbers[0])
vibez.spill(numbers[4])

fr fr Test 6: Function definition and call
slay multiply(a drip, b drip) drip {
    damn a * b
}
vibez.spill(multiply(6, 7))

fr fr Test 7: Stdlib function (hardcoded)
vibez.spill(abs_normie(-42))

fr fr Test 8: Control flow with if/else
ready (x > 40) {
    vibez.spill("x is greater than 40")
} otherwise {
    vibez.spill("x is not greater than 40")
}

fr fr Test 9: While loop
sus i drip = 0
bestie (i < 3) {
    vibez.spill(i)
    i = i + 1
}

vibez.spill("All validation tests completed!")
