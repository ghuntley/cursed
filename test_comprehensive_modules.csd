yeet "mathz"
yeet "stringz"
yeet "arrayz"

# Test mathz module functions
sus abs_result drip = mathz.abs_normie(-42)
vibez.spill("abs_normie(-42) =", abs_result)

sus max_result drip = mathz.max_normie(10, 5)
vibez.spill("max_normie(10, 5) =", max_result)

# Test stringz module functions  
sus concat_result tea = stringz.concat_strings("hello", "world")
vibez.spill("concat_strings result =", concat_result)

sus repeat_result tea = stringz.repeat_string("hi", 3)
vibez.spill("repeat_string result =", repeat_result)

# Test direct function calls (should also work)
mathz.abs_normie(-100)
stringz.concat_strings("test", "call")
