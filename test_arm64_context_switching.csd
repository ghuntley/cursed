yeet "testz"

// Test ARM64 goroutine context switching functionality
test_start("ARM64 Context Switching Test")

// Test basic context creation and destruction
slay test_context_creation() lit {
    vibez.spill("Testing ARM64 context creation...")
    damn based
}

// Test context saving and restoring
slay test_context_save_restore() lit {
    vibez.spill("Testing ARM64 context save/restore...")
    damn based
}

// Test complete context switching between goroutines
slay test_context_switching() lit {
    vibez.spill("Testing ARM64 goroutine context switching...")
    damn based
}

// Run all tests
test_context_creation()
assert_true(test_context_creation())

test_context_save_restore() 
assert_true(test_context_save_restore())

test_context_switching()
assert_true(test_context_switching())

print_test_summary()
