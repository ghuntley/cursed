{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CURSED",
    "scopeName": "source.cursed",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.cursed",
                    "match": "fr fr.*$"
                },
                {
                    "name": "comment.block.cursed",
                    "begin": "no cap",
                    "end": "on god"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cursed",
                    "match": "\\b(ready|otherwise|vibe_check|mood|basic|bestie|flex|periodt|ghosted|simp|later|stan|dm_send|dm_recv|dm_close)\\b"
                },
                {
                    "name": "keyword.declaration.cursed",
                    "match": "\\b(vibe|yeet|facts|sus|be_like|slay|squad|collab|damn)\\b"
                },
                {
                    "name": "keyword.import.cursed",
                    "match": "\\b(yeet)\\b"
                },
                {
                    "name": "keyword.other.cursed",
                    "match": "\\b(yikes|shook|fam)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.cursed",
                    "match": "\\b(tea|lit|normie|smol|mid|thicc|snack|meal|byte|rune|extra|sip|dm|map|ඞ)\\b"
                },
                {
                    "name": "constant.language.cursed",
                    "match": "\\b(based|cringe|nah)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cursed",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.backtick.cursed",
                    "begin": "`",
                    "end": "`"
                },
                {
                    "name": "string.quoted.single.cursed",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.decimal.cursed",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.hex.cursed",
                    "match": "\\b0x[a-fA-F0-9]+\\b"
                },
                {
                    "name": "constant.numeric.octal.cursed",
                    "match": "\\b0o[0-7]+\\b"
                },
                {
                    "name": "constant.numeric.binary.cursed",
                    "match": "\\b0b[01]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.cursed",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.cursed",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.cursed",
                    "match": "(\\+|\\-|\\*|\\/|\\%|ඞ)"
                },
                {
                    "name": "keyword.operator.comparison.cursed",
                    "match": "(==|!=|<|>|<=|>=)"
                },
                {
                    "name": "keyword.operator.logical.cursed",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.assignment.cursed",
                    "match": "(=|:=|\\+=|\\-=|\\*=|\\/=|%=|&=|\\|=|\\^=|<<=|>>=)"
                },
                {
                    "name": "keyword.operator.increment.cursed",
                    "match": "(\\+\\+|\\-\\-)"
                }
            ]
        }
    }
}
