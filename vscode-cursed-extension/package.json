{
    "name": "cursed-language-support",
    "displayName": "CURSED Language Support",
    "description": "Language support for CURSED programming language",
    "version": "1.0.0",
    "publisher": "cursed-lang",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "cursed",
        "programming",
        "language",
        "gen-z",
        "slang"
    ],
    "activationEvents": [
        "onLanguage:cursed"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [{
            "id": "cursed",
            "aliases": ["CURSED", "cursed"],
            "extensions": [".csd"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "cursed",
            "scopeName": "source.cursed",
            "path": "./syntaxes/cursed.tmLanguage.json"
        }],
        "configuration": {
            "type": "object",
            "title": "CURSED Language Server",
            "properties": {
                "cursed.lsp.path": {
                    "type": "string",
                    "default": "cursed-lsp",
                    "description": "Path to the CURSED language server executable"
                },
                "cursed.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable CURSED language server"
                },
                "cursed.lsp.trace": {
                    "type": "string",
                    "enum": ["off", "messages", "verbose"],
                    "default": "off",
                    "description": "Trace communication between VS Code and the language server"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "@typescript-eslint/eslint-plugin": "^5.45.0",
        "@typescript-eslint/parser": "^5.45.0",
        "eslint": "^8.28.0",
        "typescript": "^4.9.4"
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    }
}
