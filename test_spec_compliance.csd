fr fr Basic language feature test
vibe main

fr fr Variable declarations 
sus name tea = "World"
sus age normie = 25
sus active lit = based

fr fr Function definition
slay greet(n tea) tea {
    damn "Hello, " + n + "!"
}

fr fr Call function
sus greeting tea = greet(name)
sus result lit = (age > 18)

fr fr Basic control flow
ready result {
    damn greeting
} otherwise {
    damn "Not old enough"
}
