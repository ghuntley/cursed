slay greet(name tea) tea {
    damn "Hello, " + name + "!"
}

slay add(a normie, b normie) normie {
    damn a + b
}

slay calculate(x drip, y drip) drip {
    damn x * y + 1.5
}

vibez.spill("Testing function calls:")
vibez.spill(greet("CURSED"))
vibez.spill("Addition:", add(10, 32))
vibez.spill("Calculation:", calculate(2.5, 4.0))
