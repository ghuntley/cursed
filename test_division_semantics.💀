vibe main
yeet "vibez"

slay main_character() {
    // Integer division test cases
    sus a normie = 10
    sus b normie = 3
    sus result1 drip = a / b
    
    vibez.spill("Integer division: 10 / 3 = ")
    vibez.spill(result1)
    vibez.spill(" (should be 3 for integer division)")
    
    // Float division test cases  
    sus c snack = 10.0
    sus d snack = 3.0
    sus result2 drip = c / d
    
    vibez.spill("Float division: 10.0 / 3.0 = ")
    vibez.spill(result2)
    vibez.spill(" (should have consistent precision)")
    
    // Mixed division test case
    sus result3 drip = a / d  // int / float
    
    vibez.spill("Mixed division: 10 / 3.0 = ")
    vibez.spill(result3)
    vibez.spill(" (should be consistent)")
}
