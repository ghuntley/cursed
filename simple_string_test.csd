yeet "stringz"

sus test_str tea = "Hello"
sus len normie = length(test_str)
vibez.spill("Length of 'Hello':", len)

sus contains_hello lit = contains("Hello World", "Hello")
vibez.spill("'Hello World' contains 'Hello':", contains_hello)

sus contains_xyz lit = contains("Hello World", "xyz")
vibez.spill("'Hello World' contains 'xyz':", contains_xyz)
