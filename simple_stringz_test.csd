fr fr Simple test without complex string comparisons
yeet "stringz"

fr fr Test basic functionality
sus len1 drip = stringz.length("hello")
vibez.spill("Length of 'hello': " + len1)

sus concat1 tea = stringz.concat("hello", "world")  
vibez.spill("Concat result: " + concat1)

sus contains1 lit = stringz.contains("hello world", "world")
vibez.spill("Contains test: " + contains1)

vibez.spill("✅ Basic stringz test completed!")
