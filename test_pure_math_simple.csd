// Simple test for pure math implementation
// Test basic math operations

sus result1 meal = 2.5 + 3.5;
vibez.spill("Addition test: 2.5 + 3.5 = " + result1.to_string());

sus result2 meal = 10.0 - 4.0;
vibez.spill("Subtraction test: 10.0 - 4.0 = " + result2.to_string());

sus result3 meal = 3.0 * 4.0;
vibez.spill("Multiplication test: 3.0 * 4.0 = " + result3.to_string());

sus result4 meal = 15.0 / 3.0;
vibez.spill("Division test: 15.0 / 3.0 = " + result4.to_string());

// Test constants
vibez.spill("Pi constant: " + (3.141592653589793).to_string());
vibez.spill("E constant: " + (2.718281828459045).to_string());

// Test abs function
sus abs_test meal = -5.5;
vibez.spill("Absolute value test: abs(-5.5) = " + abs_test.to_string());

vibez.spill("Pure math implementation tests completed!");
