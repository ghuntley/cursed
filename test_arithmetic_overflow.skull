vibe main
yeet "vibez"

slay main_character() {
    // Test cases that were likely causing integer overflow panics
    
    // Large number arithmetic
    sus result1 drip = 2147483647 + 1
    vibez.spill(result1)
    
    sus result2 drip = -2147483648 - 1
    vibez.spill(result2)
    
    sus result3 drip = 1000000000 * 10
    vibez.spill(result3)
    
    // Test increment/decrement on extreme values
    sus max_i32 drip = 2147483647
    max_i32++
    vibez.spill(max_i32)
    
    sus min_i32 drip = -2147483648
    min_i32--
    vibez.spill(min_i32)
    
    vibez.spill("All arithmetic overflow tests passed!")
}
