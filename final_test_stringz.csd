yeet "stringz"
yeet "mathz"

vibez.spill("=== Final Validation Test ===")

fr Test working string functions
sus text tea = "Hello World"
sus length normie = stringz.length(text)
sus contains_result lit = stringz.contains(text, "World")
sus combined tea = stringz.concat("Start: ", text)

vibez.spill("Original text:", text)
vibez.spill("Length =", length)
vibez.spill("Contains 'World':", contains_result)
vibez.spill("Combined:", combined)

fr Test working math functions
sus int_abs normie = mathz.abs_normie(-42)
sus float_abs meal = mathz.abs_meal(-3.14)

vibez.spill("abs_normie(-42) =", int_abs)
vibez.spill("abs_meal(-3.14) =", float_abs)

fr Test with equals sign in strings (the original bug)
sus test_val drip = 100
vibez.spill("Value = ", test_val)
vibez.spill("Equation: 2 + 3 = 5")
vibez.spill("Result =", test_val)

vibez.spill("✅ All stringz module execution issues resolved!")
