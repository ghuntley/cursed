yeet "vibez"
yeet "mathz"
yeet "stringz"

vibez.spill("🧪 Testing Missing Implementation Bridge Functions")
vibez.spill("================================================")

fr fr Test basic math functions that should work
vibez.spill("\n📊 Testing Math Functions:")

sus pow_result meal = mathz.pow_meal(2.0, 3.0)
vibez.spill("mathz.pow_meal(2.0, 3.0) = ")
vibez.spill(pow_result.(tea))

sus sqrt_result meal = mathz.sqrt_meal(16.0)
vibez.spill("mathz.sqrt_meal(16.0) = ")
vibez.spill(sqrt_result.(tea))

sus sin_result meal = mathz.sin_meal(0.0)
vibez.spill("mathz.sin_meal(0.0) = ")
vibez.spill(sin_result.(tea))

sus cos_result meal = mathz.cos_meal(0.0)
vibez.spill("mathz.cos_meal(0.0) = ")
vibez.spill(cos_result.(tea))

fr fr Test basic string functions
vibez.spill("\n📝 Testing String Functions:")
sus test_string tea = "Hello World"
sus string_len normie = stringz.length(test_string)
vibez.spill("stringz.length(\"Hello World\") = ")
vibez.spill(string_len.(tea))

vibez.spill("\n✅ Basic Implementation Bridge Tests Complete!")
vibez.spill("Core stdlib bridge functions are working correctly.")
