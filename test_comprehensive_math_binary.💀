yeet "vibez"
yeet "mathz"

slay main_character() {
    sus a drip = 10.5
    sus b drip = 5.5
    
    sus add_result drip = mathz.add(a, b)
    vibez.spill(add_result)
    
    sus sub_result drip = mathz.sub(a, b)
    vibez.spill(sub_result)
    
    sus mul_result drip = mathz.mul(a, b)
    vibez.spill(mul_result)
    
    sus abs_result drip = mathz.abs_normie(-25.5)
    vibez.spill(abs_result)
    
    sus max_result drip = mathz.max_normie(a, b)
    vibez.spill(max_result)
}
