# Complex CURSED code for formatter testing
yeet "testz"
yeet "math"
yeet "string"

# Function with complex expressions
slay complex_calculation(x normie,y drip,z lit) normie {
    sus result normie=x*2+y/3.14-1
    sus array[5]normie={1,2,3,4,5}
    sus tuple:=(x,y,z)
    nah result>0&&z==based{
        result=result*2
    }
    damn result
}

# Nested structures
slay nested_example()lit{
    sus data:=map[tea]normie{
        "key1":42,
        "key2":84
    }
    sus condition:=data["key1"]>0&&data["key2"]<100
    nah condition{
        vibez.spill("Data is valid")
    }catch{
        vibez.spill("Data is invalid")
    }
    damn based
}

# Channel operations
slay channel_example()lit{
    sus ch:=make(chan normie,10)
    ch<-42
    sus value:=<-ch
    damn value==42
}

# Main function
slay main()lit{
    sus x:=complex_calculation(10,3.14,based)
    sus y:=nested_example()
    sus z:=channel_example()
    damn x>0&&y&&z
}
