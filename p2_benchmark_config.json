{
  "languages": ["cursed", "go", "rust", "cpp"],
  "optimization_levels": ["debug", "release"],
  "benchmark_categories": ["micro", "real_world", "stdlib", "compiler"],
  "memory_leak_detection": true,
  "cross_language_comparison": true,
  "continuous_integration": true,
  "performance_targets": {
    "cursed_vs_go_ratio": 1.2,
    "cursed_vs_rust_ratio": 1.1,
    "cursed_vs_cpp_ratio": 1.5,
    "compilation_time_target_ms": 1000,
    "execution_time_target_ms": 100,
    "memory_usage_target_kb": 10240,
    "zero_memory_leaks": true
  },
  "regression_thresholds": {
    "critical": 25.0,
    "major": 15.0,
    "minor": 5.0
  },
  "benchmark_timeout_seconds": 300,
  "memory_leak_tolerance_bytes": 0,
  "parallel_execution": true,
  "max_workers": 8,
  "database_path": "p2_benchmark_results.db",
  "report_path": "p2_benchmark_reports",
  "valgrind_enabled": true,
  "statistical_analysis": {
    "confidence_threshold": 0.95,
    "min_historical_samples": 10,
    "outlier_detection": true,
    "trend_analysis": true
  },
  "ci_integration": {
    "github_actions": true,
    "pre_commit_hooks": true,
    "performance_budgets": true,
    "auto_bisect_regressions": true
  },
  "notification": {
    "email_alerts": false,
    "webhook_url": null,
    "slack_webhook": null
  },
  "real_world_benchmarks": {
    "web_server": {
      "enabled": true,
      "target_rps": 10000,
      "max_latency_ms": 10
    },
    "cli_tool": {
      "enabled": true,
      "target_files_per_second": 1000,
      "max_memory_mb": 50
    },
    "database_orm": {
      "enabled": true,
      "target_qps": 5000,
      "max_connection_time_ms": 5
    },
    "game_engine": {
      "enabled": true,
      "target_fps": 60,
      "max_frame_time_ms": 16
    },
    "compiler_frontend": {
      "enabled": true,
      "target_lines_per_second": 100000,
      "max_memory_per_line_bytes": 100
    },
    "crypto_service": {
      "enabled": true,
      "target_ops_per_second": 1000,
      "max_key_gen_time_ms": 100
    }
  },
  "benchmark_matrix": {
    "micro_benchmarks": [
      "benchmarks/cursed/fasta.csd",
      "benchmarks/cursed/mandelbrot.csd",
      "benchmarks/cursed/binary_trees.csd",
      "benchmarks/cursed/n_bodies.csd",
      "benchmarks/cursed/fannkuch.csd",
      "benchmarks/cursed/string_processing.csd"
    ],
    "stdlib_benchmarks": [
      "comprehensive_stdlib_test.csd",
      "benchmarks/cursed/comprehensive_stdlib_benchmark.csd",
      "benchmarks/cursed/memory_benchmark.csd",
      "benchmarks/cursed/string_benchmark.csd",
      "benchmarks/cursed/math_benchmark.csd"
    ],
    "language_features": [
      "advanced_features_test.csd",
      "comprehensive_test.csd",
      "benchmarks/cursed/interface_type_assertion_benchmark.csd"
    ]
  }
}
