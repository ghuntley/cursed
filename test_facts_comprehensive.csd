facts PI = 3.14159
facts E = 2.71828

facts (
    MAX_SIZE = 1000
    MIN_SIZE = 1
    DEFAULT_NAME = "cursed"
    MAGIC_NUMBER = 42
)

facts a, b, c = 1, 2, 3

vibez.spill("Testing constants:")
vibez.spill("PI =", PI)
vibez.spill("E =", E)
vibez.spill("MAX_SIZE =", MAX_SIZE)
vibez.spill("DEFAULT_NAME =", DEFAULT_NAME)
vibez.spill("a, b, c =", a, b, c)

sus area drip = PI * 5 * 5
vibez.spill("Area of circle with radius 5 =", area)
