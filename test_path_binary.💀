yeet "vibez"
yeet "path"

slay main_character() {
    sus joined drip = path.join("/home", "user")
    vibez.spill("Path joined")
    
    sus base drip = path.basename("/home/user/file.txt")
    vibez.spill("Basename extracted")
    
    sus dir drip = path.dirname("/home/user/file.txt")
    vibez.spill("Dirname extracted")
    
    sus exists drip = path.exists("/home/user")
    vibez.spill("Path existence checked")
}
