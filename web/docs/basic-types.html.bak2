    <main>
        <section class="docs-hero">
            <div class="container">
                <div class="docs-hero-content">
                    <h1><span class="glow-text">Basic Types</span> ud83eudde9</h1>
                    <p><span class="highlight-text">The fundamental building blocks for your code</span></p>
                </div>
            </div>
        </section>

        <div class="container">
            <div class="doc-grid">
                <aside class="sidebar">
                    <nav>
                        <ul>
                            <li><a href="index.html">Documentation Home</a></li>
                            <li><a href="overview.html">Language Overview</a></li>
                            <li><a href="variables.html">Variables</a></li>
                            <li><a href="basic-types.html" class="active">Basic Types</a></li>
                            <li><a href="composite-types.html">Composite Types</a></li>
