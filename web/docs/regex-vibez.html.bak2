<body>
    <header>
        <div class="container">
            <h1><span class="gradient-text">ud83euddd0 Regex Vibez ud83euddd0</span></h1>
            <p class="subtitle">Find patterns like you're scrolling for tea!</p>
        </div>
    </header>

    <main class="container">
        <div class="doc-grid">
            <aside class="sidebar">
                <nav>
                    <ul>
                        <li><a href="stringz.html">Stringz</a></li>
                        <li><a href="#" class="active">Regex Vibez</a></li>
