fr fr Verify CURSED mathz functions compute correctly

sus a drip = 10
sus b drip = 5

sus sum_result drip = mathz.add_two(a, b)
sus abs_result drip = mathz.abs_normie(-15)
sus factorial_result drip = mathz.factorial(5)
sus power_result drip = mathz.power_int(2, 3)

vibez.spillln("CURSED Math Results:")
