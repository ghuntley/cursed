# Comprehensive array test
vibez.spill("=== Array Creation ===")
sus arr []drip = [1, 2, 3]
vibez.spill("Created array:", arr[0], arr[1], arr[2])

vibez.spill("=== Array Length ===")
vibez.spill("Array length:", len(arr))

vibez.spill("=== Array Indexing ===")
vibez.spill("arr[0] =", arr[0])
vibez.spill("arr[1] =", arr[1])  
vibez.spill("arr[2] =", arr[2])

vibez.spill("=== Array with Variables ===")
sus nums []drip = [10, 20, 30, 40]
sus index drip = 2
vibez.spill("nums[index] where index=2:", nums[index])

vibez.spill("=== Manual Array Iteration ===")
vibez.spill("Element 0:", nums[0])
vibez.spill("Element 1:", nums[1]) 
vibez.spill("Element 2:", nums[2])
vibez.spill("Element 3:", nums[3])

vibez.spill("=== Array Operations Complete ===")
