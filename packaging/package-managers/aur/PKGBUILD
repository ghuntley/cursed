# CURSED Programming Language - AUR Package
# Oracle Week 3 cross-platform packaging preparation for v1.0 launch
# Maintainer: Geoffrey Huntley <ghuntley@ghuntley.com>
# Maintainer: CURSED Development Team <dev@cursedlang.org>

pkgname=cursed
pkgver=1.0.0
pkgrel=1
pkgdesc="CURSED Programming Language: A production-ready systems programming language with ergonomic syntax"
arch=('x86_64' 'aarch64')
url="https://cursedlang.org"
license=('MIT')
depends=('glibc' 'gcc-libs')
makedepends=('zig>=0.12.0' 'llvm' 'clang' 'git')
optdepends=(
    'code: IDE integration with CURSED extension'
    'vim: Text editor support'
    'neovim: Advanced text editor support'  
    'valgrind: Memory safety validation'
    'gdb: Debugging support'
    'perf: Performance profiling'
)
provides=('cursed' 'cursed-lsp' 'cursed-fmt' 'cursed-lint' 'cursed-doc' 'cursed-pkg')
conflicts=('cursed-git' 'cursed-bin')
backup=('etc/cursed/config.toml')
source=(
    "cursed-${pkgver}.tar.gz::https://github.com/ghuntley/cursed/archive/refs/tags/v${pkgver}.tar.gz"
    "cursed.desktop"
    "cursed-config.toml"
)
sha256sums=(
    'SKIP'  # Will be updated by release automation
    'SKIP'  # Desktop file checksum
    'SKIP'  # Config file checksum
)
validpgpkeys=('') # Will be populated with maintainer GPG keys

prepare() {
    cd "${srcdir}/cursed-${pkgver}"
    
    # Verify we have the correct version
    if [ ! -f "VERSION" ] || [ "$(cat VERSION)" != "${pkgver}" ]; then
        echo "Warning: VERSION file missing or incorrect"
    fi
    
    # Patch any Arch-specific configurations if needed
    if [ -f "packaging/arch/config.patch" ]; then
        patch -p1 < "packaging/arch/config.patch"
    fi
}

build() {
    cd "${srcdir}/cursed-${pkgver}"
    
    # Set build environment
    export CC=clang
    export CXX=clang++
    export CURSED_RELEASE_BUILD=1
    export CURSED_ARCH_LINUX=1
    
    # Determine architecture
    case "${CARCH}" in
        'x86_64')
            _target='x86_64-linux-gnu'
            ;;
        'aarch64')
            _target='aarch64-linux-gnu'
            ;;
        *)
            _target='native'
            ;;
    esac
    
    msg2 "Building CURSED for ${_target}..."
    
    # Build with full optimization
    zig build \
        -Doptimize=ReleaseFast \
        -Dtarget=${_target} \
        -Dstrip=true \
        --verbose
    
    # Verify build outputs
    if [ ! -f "zig-out/bin/cursed" ]; then
        error "Main compiler binary not found"
        return 1
    fi
    
    # Test basic functionality
    msg2 "Testing basic functionality..."
    echo 'yeet "vibez"; vibez.spill("Build test");' > test.csd
    ./zig-out/bin/cursed test.csd
    rm test.csd
    
    msg2 "Build completed successfully"
}

check() {
    cd "${srcdir}/cursed-${pkgver}"
    
    msg2 "Running test suite..."
    
    # Run unit tests
    if command -v zig >/dev/null 2>&1; then
        zig build test || true  # Don't fail build on test failures
    fi
    
    # Run integration tests
    if [ -f "packaging/scripts/package-verification.sh" ]; then
        bash packaging/scripts/package-verification.sh --basic || true
    fi
    
    # Memory safety check with valgrind if available
    if command -v valgrind >/dev/null 2>&1; then
        msg2 "Running memory safety checks..."
        echo 'yeet "vibez"; vibez.spill("Memory test");' > memtest.csd
        timeout 30s valgrind --error-exitcode=1 --leak-check=full ./zig-out/bin/cursed memtest.csd || true
        rm memtest.csd
    fi
    
    msg2 "Tests completed"
}

package() {
    cd "${srcdir}/cursed-${pkgver}"
    
    # Install main binaries
    install -Dm755 zig-out/bin/cursed "${pkgdir}/usr/bin/cursed"
    install -Dm755 zig-out/bin/cursed-lsp "${pkgdir}/usr/bin/cursed-lsp"
    install -Dm755 zig-out/bin/cursed-fmt "${pkgdir}/usr/bin/cursed-fmt"
    install -Dm755 zig-out/bin/cursed-lint "${pkgdir}/usr/bin/cursed-lint"
    install -Dm755 zig-out/bin/cursed-doc "${pkgdir}/usr/bin/cursed-doc"
    install -Dm755 zig-out/bin/cursed-pkg "${pkgdir}/usr/bin/cursed-pkg"
    
    # Install legacy compatibility binary
    ln -sf cursed "${pkgdir}/usr/bin/cursed-zig"
    
    # Install standard library
    msg2 "Installing standard library..."
    install -dm755 "${pkgdir}/usr/share/cursed/stdlib"
    if [ -d "stdlib" ]; then
        cp -r stdlib/* "${pkgdir}/usr/share/cursed/stdlib/"
    fi
    
    # Install examples
    if [ -d "examples" ]; then
        msg2 "Installing examples..."
        install -dm755 "${pkgdir}/usr/share/cursed/examples"
        cp -r examples/* "${pkgdir}/usr/share/cursed/examples/"
    fi
    
    # Install documentation
    if [ -d "docs" ]; then
        msg2 "Installing documentation..."
        install -dm755 "${pkgdir}/usr/share/doc/cursed"
        cp -r docs/* "${pkgdir}/usr/share/doc/cursed/"
    fi
    
    # Install man pages
    if [ -d "docs/man" ]; then
        msg2 "Installing man pages..."
        for manpage in docs/man/*.1; do
            if [ -f "$manpage" ]; then
                install -Dm644 "$manpage" "${pkgdir}/usr/share/man/man1/$(basename $manpage)"
            fi
        done
    fi
    
    # Install license
    if [ -f "LICENSE" ]; then
        install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/cursed/LICENSE"
    elif [ -f "LICENSE.txt" ]; then
        install -Dm644 LICENSE.txt "${pkgdir}/usr/share/licenses/cursed/LICENSE"
    fi
    
    # Install desktop entry
    install -Dm644 "${srcdir}/cursed.desktop" "${pkgdir}/usr/share/applications/cursed.desktop"
    
    # Install configuration
    install -Dm644 "${srcdir}/cursed-config.toml" "${pkgdir}/etc/cursed/config.toml"
    
    # Install shell completions if available
    if [ -d "completions" ]; then
        msg2 "Installing shell completions..."
        if [ -f "completions/cursed.bash" ]; then
            install -Dm644 completions/cursed.bash "${pkgdir}/usr/share/bash-completion/completions/cursed"
        fi
        if [ -f "completions/_cursed" ]; then
            install -Dm644 completions/_cursed "${pkgdir}/usr/share/zsh/site-functions/_cursed"
        fi  
        if [ -f "completions/cursed.fish" ]; then
            install -Dm644 completions/cursed.fish "${pkgdir}/usr/share/fish/vendor_completions.d/cursed.fish"
        fi
    fi
    
    # Create wrapper script for environment setup
    install -Dm755 /dev/stdin "${pkgdir}/usr/bin/cursed-env" <<EOF
#!/bin/bash
export CURSED_HOME="/usr/share/cursed"
export CURSED_STDLIB_PATH="/usr/share/cursed/stdlib"
export PATH="/usr/bin:\$PATH"
exec "\$@"
EOF
    
    # Install systemd service for LSP server (optional)
    install -Dm644 /dev/stdin "${pkgdir}/usr/lib/systemd/user/cursed-lsp.service" <<EOF
[Unit]
Description=CURSED Language Server
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/cursed-lsp --stdio
Restart=on-failure
Environment=CURSED_HOME=/usr/share/cursed
Environment=CURSED_STDLIB_PATH=/usr/share/cursed/stdlib

[Install]
WantedBy=default.target
EOF
    
    # Install udev rules for hardware debugging support (if applicable)
    if [ -f "packaging/udev/99-cursed-debugger.rules" ]; then
        install -Dm644 packaging/udev/99-cursed-debugger.rules "${pkgdir}/usr/lib/udev/rules.d/99-cursed-debugger.rules"
    fi
    
    msg2 "Package installation completed"
}

# Custom functions for post-install/upgrade/removal hooks
post_install() {
    echo ""
    echo "🎉 CURSED Programming Language v${pkgver} installed successfully!"
    echo ""
    echo "Quick Start:"
    echo "  1. Create a new file: hello.csd"  
    echo "  2. Add content: yeet \"vibez\"; vibez.spill(\"Hello, Arch!\");"
    echo "  3. Run it: cursed hello.csd"
    echo ""
    echo "Available Commands:"
    echo "  cursed        - CURSED compiler"
    echo "  cursed-lsp    - Language Server Protocol for IDEs"
    echo "  cursed-fmt    - Code formatter"
    echo "  cursed-lint   - Static analyzer and linter"
    echo "  cursed-doc    - Documentation generator"  
    echo "  cursed-pkg    - Package manager"
    echo ""
    echo "IDE Integration:"
    echo "  VS Code: Install 'CURSED Language Support' extension"
    echo "  Vim/Neovim: Use cursed-lsp for LSP support"
    echo ""
    echo "Resources:"
    echo "  Documentation: /usr/share/doc/cursed/"
    echo "  Examples: /usr/share/cursed/examples/"
    echo "  Standard Library: /usr/share/cursed/stdlib/"
    echo "  Config: /etc/cursed/config.toml"
    echo ""
    echo "Online Resources:"
    echo "  Website: https://cursedlang.org"
    echo "  Docs: https://docs.cursedlang.org" 
    echo "  Community: https://discord.gg/cursedlang"
    echo ""
    echo "Happy coding with CURSED! 🚀"
    echo ""
}

post_upgrade() {
    echo ""
    echo "✅ CURSED Programming Language upgraded to v${pkgver}!"
    echo ""
    echo "See release notes at:"
    echo "  https://github.com/ghuntley/cursed/releases/tag/v${pkgver}"
    echo ""
    echo "If you encounter any issues, please check:"
    echo "  /usr/share/doc/cursed/BREAKING_CHANGES.md"
    echo ""
}

pre_remove() {
    echo ""
    echo "Removing CURSED Programming Language..."
    echo ""
    
    # Stop any running LSP services
    if systemctl --user is-active cursed-lsp.service >/dev/null 2>&1; then
        systemctl --user stop cursed-lsp.service
    fi
}

post_remove() {
    echo ""
    echo "✅ CURSED Programming Language removed successfully!"
    echo ""
    echo "Thank you for using CURSED! 👋"
    echo ""
    echo "If you encountered any issues, please report them:"
    echo "  GitHub Issues: https://github.com/ghuntley/cursed/issues"
    echo "  Discord: https://discord.gg/cursedlang"
    echo ""
    
    # Clean up any remaining user data (optional)
    echo "Note: User configuration and cache files remain in:"
    echo "  ~/.config/cursed/"
    echo "  ~/.cache/cursed/"
    echo "  ~/.local/share/cursed/"
    echo ""
    echo "Remove these manually if desired."
    echo ""
}
