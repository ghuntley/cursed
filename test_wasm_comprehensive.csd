// Comprehensive CURSED WebAssembly test
// Tests various language features in WebAssembly compilation

// Test basic output
vibez.spill("=== CURSED WebAssembly Comprehensive Test ===")

// Test integer operations
sus a normie = 10
sus b normie = 20
sus sum normie = a + b
vibez.spill("Integer test: 10 + 20 = ")
vibez.spill(sum)

// Test float operations
sus pi meal = 3.14159
sus radius meal = 5.0
sus area meal = pi * radius * radius
vibez.spill("Float test: Area of circle (r=5) = ")
vibez.spill(area)

// Test string operations
sus greeting tea = "Hello from "
sus target tea = "WebAssembly!"
vibez.spill(greeting)
vibez.spill(target)

// Test boolean operations
sus flag1 lit = based
sus flag2 lit = cap
vibez.spill("Boolean test - true: ")
vibez.spill(flag1)
vibez.spill("Boolean test - false: ")
vibez.spill(flag2)

// Test function call
slay testFunction() lit {
    vibez.spill("Function call successful!")
    damn based
}

sus result lit = testFunction()
vibez.spill("Function returned: ")
vibez.spill(result)

vibez.spill("=== WebAssembly test complete ===")
