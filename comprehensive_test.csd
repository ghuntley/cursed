fr fr CURSED comprehensive test
yeet "mathz"

squad Person { spill name tea; spill age drip }

slay greet(p Person) tea {
    damn "Hello, " + p.name
}

slay factorial(n drip) drip {
    ready (n <= 1) {
        damn 1
    } otherwise {
        damn n * factorial(n - 1)
    }
}

sus person Person = Person{name: "Alice", age: 25}
vibez.spill("Person:", person.name, "is", person.age, "years old")

sus greeting tea = greet(person)
vibez.spill(greeting)

sus fact drip = factorial(5)
vibez.spill("5! =", fact)

sus numbers []drip = [1, 2, 3, 4, 5]
vibez.spill("Array length:", len(numbers))
vibez.spill("First element:", numbers[0])

sus i drip = 0
bestie (i < 3) {
    vibez.spill("Loop iteration:", i)
    i = i + 1
}

ready (person.age > 20) {
    vibez.spill("Alice is an adult")
} otherwise {
    vibez.spill("Alice is young")
}

sus abs_val drip = abs_normie(-99)
vibez.spill("Absolute value:", abs_val)
