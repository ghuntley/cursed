yeet "testz"
yeet "mathz" 
yeet "stringz"
yeet "arrayz"
yeet "timez"
yeet "filez"

test_start("Comprehensive production test")

// Test basic functionality
sus nums []drip = [1, 2, 3, 4, 5]
assert_eq_int(len(nums), 5)

// Test math operations  
assert_eq_int(abs_normie(-42), 42)

// Test string operations
sus greeting tea = "Hello" + " " + "CURSED!"
assert_eq_string(greeting, "Hello CURSED!")

// Test advanced features (previously had memory corruption)
collab Drawable { slay draw() tea; }
squad Circle { 
    slay draw() tea { damn "Drawing circle" }
}
sus c Circle = Circle{}
sus result tea = c.draw()
assert_eq_string(result, "Drawing circle")

print_test_summary()
