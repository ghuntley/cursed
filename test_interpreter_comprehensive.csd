fr fr Comprehensive test of all recent stdlib enhancements in interpreter mode
yeet "mathz"
yeet "stringz" 
yeet "env"
yeet "database_enhanced"
yeet "web_framework"
yeet "template"
yeet "crypto_enhanced"
yeet "network_enhanced"

vibez.spill("🚀 CURSED Comprehensive Stdlib Test")

fr fr Test mathematical operations
sus math_sum drip = mathz.add_two(15, 25)
sus math_abs drip = mathz.abs_normie(-42)
vibez.spill("Math: 15+25=")
vibez.spill(math_sum)
vibez.spill("Abs(-42)=")
vibez.spill(math_abs)

fr fr Test string operations
sus str_len drip = stringz.length("CURSED")
sus str_concat tea = stringz.concat("Hello", "World")
vibez.spill("String length of 'CURSED'=")
vibez.spill(str_len)
vibez.spill("Concat result=")
vibez.spill(str_concat)

fr fr Test environment variables
sus home_path tea = env.get_env("HOME")
sus has_user lit = env.has_env("USER")
vibez.spill("HOME directory=")
vibez.spill(home_path)
vibez.spill("Has USER env var=")
vibez.spill(has_user)

fr fr Test database operations
sus db_conn tea = database_enhanced.create_connection("sqlite://test.db")
sus insert_ok lit = database_enhanced.insert_record("users", "john_doe")
vibez.spill("Database connection=")
vibez.spill(db_conn)
vibez.spill("Insert successful=")
vibez.spill(insert_ok)

fr fr Test web framework
sus server tea = web_framework.create_server(8080)
sus route_added lit = web_framework.add_route("GET", "/api/test", "handler")
vibez.spill("Web server created=")
vibez.spill(server)
vibez.spill("Route added=")
vibez.spill(route_added)

fr fr Test template engine  
sus template tea = template.compile_template("Hello {{name}}!")
sus rendered tea = template.render_template(template, "CURSED")
vibez.spill("Template compiled=")
vibez.spill(template)
vibez.spill("Rendered result=")
vibez.spill(rendered)

fr fr Test crypto operations
sus hash tea = crypto_enhanced.hash_sha256("test_data")
sus encrypted tea = crypto_enhanced.encrypt_simple("secret", "key123")
vibez.spill("SHA256 hash=")
vibez.spill(hash)
vibez.spill("Encrypted data=")
vibez.spill(encrypted)

fr fr Test networking
sus response tea = network_enhanced.http_get("https://api.example.com")
sus domain tea = network_enhanced.get_domain("https://api.example.com/v1")
vibez.spill("HTTP response=")
vibez.spill(response)
vibez.spill("Extracted domain=")
vibez.spill(domain)

fr fr Test assignment operations
sus counter drip = 10
counter = counter + 5
counter = counter * 2
vibez.spill("Final counter value=")
vibez.spill(counter)

vibez.spill("✅ All 8 stdlib modules working!")
vibez.spill("🎯 CURSED interpreter mode: COMPLETE")
vibez.spill("🚀 Ready for production applications!")
