yeet "mathz"
yeet "stringz"

squad Person {
    spill name tea
    spill age drip
}

sus p Person = Person{name: "Alice", age: 25}
vibez.spill("Name:", p.name)
vibez.spill("Age:", p.age)

sus numbers []drip = [1, 2, 3, 4, 5]
sus names []tea = ["Alice", "Bob", "Charlie"]

vibez.spill("Array length:", len(numbers))
vibez.spill("First number:", numbers[0])
vibez.spill("Last number:", numbers[len(numbers)-1])

sus i drip = 0
bestie (i < len(numbers)) {
    vibez.spill("Number at index", i, ":", numbers[i])
    i = i + 1
}

sus abs_val drip = abs_normie(-42)
vibez.spill("Absolute value:", abs_val)
