# Comprehensive feature test
facts PI = 3.14159

# Test struct definition
squad Point {
    spill x normie
    spill y normie
}

# Test interface definition  
collab Drawable {
    slay draw() normie
}

# Test pattern matching
slay classify_number(num normie) normie {
    vibe_check num {
        mood 0:
            damn 10
        mood 1, 2, 3:
            damn 20
        basic:
            damn 30
    }
}

# Test lambda (simplified)
slay test_math(a normie, b normie) normie {
    damn a + b
}

slay main() normie {
    vibez.spill("Comprehensive feature test")
    
    # Test constants
    vibez.spill("PI value processed")
    
    # Test arrays
    sus nums = [1, 2, 3]
    sus first_num = nums[0]
    
    # Test tuples
    sus coords = (5, 10)
    
    # Test pattern matching
    sus class_result = classify_number(2)
    
    # Test map (simplified)
    sus colors = {"red": 1, "blue": 2}
    
    vibez.spill("All features tested successfully")
    damn 0
}
