fr fr Complex CURSED program to test advanced codegen features

sus x drip = 42
sus y drip = 24
sus result drip = x + y

vibez.spill("Testing arithmetic:")
vibez.spill(result)

slay add_numbers(a drip, b drip) drip {
    damn a + b
}

sus sum drip = add_numbers(x, y)
vibez.spill("Function call result:")
vibez.spill(sum)

bestie x < 100 {
    vibez.spill("Loop iteration:")
    vibez.spill(x)
    x = x + 10
}

match result {
    66 => vibez.spill("Correct result!"),
    _ => vibez.spill("Wrong result")
}

vibez.spill("Complex codegen test complete!")
