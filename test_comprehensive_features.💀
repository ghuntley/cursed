#!/usr/bin/env cursed

# Import required modules
import "stdlib/mathz.💀" as mathz
import "stdlib/stringz.💀" as stringz

# Test comprehensive CURSED features across interpreter and compiled modes
func main() {
    print("=== Testing Core CURSED Features ===")
    
    # Test 1: Variable assignments and arithmetic
    print("\n--- Test 1: Variable Assignments and Arithmetic ---")
    x := 10
    y := 5
    result := x + y
    print("x + y = " + result)  # String concatenation with number
    
    # Test assignment operations
    i := 1
    i = i + 1
    print("i after increment: " + i)
    
    # Test 2: String operations
    print("\n--- Test 2: String Operations ---")
    str1 := "Hello"
    str2 := "World"
    concatenated := str1 + " " + str2
    print("Concatenated: " + concatenated)
    
    # Test string module functions
    length := stringz.Length(concatenated)
    print("String length: " + length)
    
    upper := stringz.ToUpper(concatenated)
    print("Uppercase: " + upper)
    
    # Test 3: Math module functions
    print("\n--- Test 3: Math Module Functions ---")
    a := 15
    b := 25
    sum := mathz.add_two(a, b)
    print("mathz.add_two(15, 25) = " + sum)
    
    abs_val := mathz.abs_normie(-42)
    print("mathz.abs_normie(-42) = " + abs_val)
    
    # Test 4: Control flow
    print("\n--- Test 4: Control Flow ---")
    if x > y {
        print("x is greater than y")
    } else {
        print("x is not greater than y") 
    }
    
    # Test 5: Combined operations
    print("\n--- Test 5: Combined Operations ---")
    message := "Result: "
    computation := mathz.add_two(10, 20)
    final_message := message + computation
    print(final_message)
    
    print("\n=== All tests completed successfully! ===")
}

# Call main
main()
