yeet "testz"

# Test edge cases for execution

# Empty variable
sus empty tea = ""
vibez.spill(empty)

# Unicode test  
sus unicode tea = "🚀 CURSED"
vibez.spill(unicode)

# Large number
sus big drip = 999999
vibez.spill(big)

# Multiple function calls
slay double(x drip) drip {
    damn x * 2
}

slay quadruple(x drip) drip {
    damn double(double(x))
}

sus result drip = quadruple(5)
vibez.spill("Nested function result:")
vibez.spill(result)

# Boolean operations
sus truth lit = based
sus lie lit = cringe
vibez.spill(truth)
vibez.spill(lie)

# Array test
sus numbers drip[] = [1, 2, 3, 4, 5]
vibez.spill("Array test:")
vibez.spill(numbers)
