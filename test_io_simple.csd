yeet "testz"

# Simple test to verify basic I/O functionality

test_start("Basic I/O Module Test")

# Test basic string operations
sus message tea = "Hello World from CURSED I/O!"
vibez.spill(message)
assert_eq_string(message, "Hello World from CURSED I/O!")

# Test basic file simulation
sus filename tea = "test.txt"
sus content tea = "File content here"
assert_eq_string(filename, "test.txt")
assert_eq_string(content, "File content here")

# Test basic boolean operations
sus success lit = based
assert_true(success)

sus failure lit = cap
assert_false(failure)

# Test basic integer operations
sus bytes_processed normie = 42
assert_eq_int(bytes_processed, 42)

print_test_summary()

vibez.spill("✅ Basic I/O test completed successfully!")
