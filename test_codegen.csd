# Test basic CURSED code generation

# Variable declarations (sus)
sus x drip = 42
sus y drip = 10
sus name tea = "CURSED"
sus is_active lit = based

# Arithmetic operations
sus sum drip = x + y
sus product drip = x * y

# Function definition (slay)
slay add(a drip, b drip) drip {
    damn a + b
}

# Function call
sus result drip = add(x, y)

# Control flow (ready/otherwise)
ready (x > y) {
    sus bigger tea = "x is bigger"
} otherwise {
    sus bigger tea = "y is bigger"
}

# Loop (bestie)
sus counter drip = 0
bestie (counter < 5) {
    counter = counter + 1
}

# I/O
vibez.spill("Hello, CURSED!")
vibez.spill(result)
