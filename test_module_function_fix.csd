yeet "mathz"

# Test module function calls for integer types
sus result_int drip = mathz.abs_normie(-42)
vibez.spill("abs_normie(-42) =", result_int)

# Test module function calls for float types  
sus result_float normie = mathz.abs_normie(-3.14)
vibez.spill("abs_normie(-3.14) as float =", result_float)

# Test module function calls for string types
yeet "stringz"
sus result_str tea = stringz.concat_strings("hello", "world")
vibez.spill("concat_strings result =", result_str)
