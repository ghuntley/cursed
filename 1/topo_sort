#!/bin/bash
# CURSED Topological Sort Demo - Executable Wrapper
# This script acts as a binary for the topological sort demo

# Colors for output
RESET='\033[0m'
BOLD='\033[1m'
BLUE='\033[34m'
GREEN='\033[32m'

echo -e "${BOLD}CURSED Topological Sort Demo${RESET}"
echo -e "${BLUE}Powered by CURSED Programming Language${RESET}"
echo ""

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if CURSED compiler exists
CURSED_COMPILER="$SCRIPT_DIR/../target/debug/cursed"
if [ ! -f "$CURSED_COMPILER" ]; then
    echo "Error: CURSED compiler not found at $CURSED_COMPILER"
    echo "Please build the CURSED compiler first: make build"
    exit 1
fi

# Run the topological sort demo
exec "$CURSED_COMPILER" "$SCRIPT_DIR/working_topo_sort.csd"
