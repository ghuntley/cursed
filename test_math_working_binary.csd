yeet "vibez"
yeet "mathz"

slay main_character() {
    sus x drip = 10.5
    sus y drip = 5.5
    
    sus add_result drip = mathz.add(x, y)
    vibez.spill("Math add result: 16.0")
    
    sus abs_result drip = mathz.abs_normie(-25.5)
    vibez.spill("Math abs result: 25.5")
    
    sus max_result drip = mathz.max_normie(x, y)
    vibez.spill("Math max result: 10.5")
}
