vibe main
yeet "vibez"

slay main_character() {
    vibez.spill("Testing simple array access")
    
    fr fr Simple array that should work
    sus test_array normie[value] = normie[value]{1, 2, 3}
    
    fr fr Try to access first element - this should trigger the LLVM bug  
    sus first normie = test_array[0]
    
    vibez.spill("First element:")
    vibez.spill(first)
}
