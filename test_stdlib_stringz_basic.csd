yeet "stringz"

// Test basic stringz functions
sus result1 tea = stringz.concat("hello", " world")
vibez.spill("stringz.concat('hello', ' world') = ")
vibez.spill(result1)

sus result2 drip = stringz.length("testing")
vibez.spill("stringz.length('testing') = ")
vibez.spill(result2)

sus result3 tea = stringz.upper("lowercase")
vibez.spill("stringz.upper('lowercase') = ")
vibez.spill(result3)

sus result4 lit = stringz.contains("hello world", "world")
vibez.spill("stringz.contains('hello world', 'world') = ")
vibez.spill(result4)
