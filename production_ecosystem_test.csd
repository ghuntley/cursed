fr CURSED Ecosystem Production Test - Core Features Validation

vibez.spill("🚀 CURSED Language Ecosystem Test")
vibez.spill("==================================")

fr Test 1: Basic Variables
vibez.spill("")
vibez.spill("📦 Testing Variables:")

sus name tea = "CURSED"
sus version drip = 1
sus is_production_ready lit = based
sus pi_value meal = 3.14159

vibez.spill("  Language name:", name)
vibez.spill("  Version:", version)
vibez.spill("  Production ready:", is_production_ready)
vibez.spill("  Pi constant:", pi_value)
vibez.spill("✅ Variables test passed")

fr Test 2: Basic Functions
vibez.spill("")
vibez.spill("⚙️ Testing Functions:")

slay greet(user_name tea) {
    vibez.spill("  Hello,", user_name, "!")
}

slay add_numbers(a drip, b drip) drip {
    damn a + b
}

slay multiply_values(x drip, y drip) drip {
    damn x * y
}

greet("Developer")
sus sum_result drip = add_numbers(10, 5)
sus product_result drip = multiply_values(7, 8)

vibez.spill("  10 + 5 =", sum_result)
vibez.spill("  7 * 8 =", product_result)
vibez.spill("✅ Functions test passed")

fr Test 3: Control Flow
vibez.spill("")
vibez.spill("🔄 Testing Control Flow:")

sus test_score drip = 85

ready (test_score >= 90) {
    vibez.spill("  Grade: A (Excellent)")
} otherwise ready (test_score >= 80) {
    vibez.spill("  Grade: B (Good)")
} otherwise ready (test_score >= 70) {
    vibez.spill("  Grade: C (Average)")
} otherwise {
    vibez.spill("  Grade: F (Needs improvement)")
}

fr Loop test
vibez.spill("  Counting from 1 to 5:")
sus loop_counter drip = 1
bestie (loop_counter <= 5) {
    vibez.spill("    Count:", loop_counter)
    loop_counter = loop_counter + 1
}

vibez.spill("✅ Control flow test passed")

fr Test 4: Arrays
vibez.spill("")
vibez.spill("📋 Testing Arrays:")

sus test_numbers []drip = [10, 20, 30, 40, 50]
sus programming_languages []tea = ["CURSED", "Zig", "Rust", "Go"]

vibez.spill("  Numbers array:", test_numbers)
vibez.spill("  Languages array:", programming_languages)
vibez.spill("  Numbers length:", len(test_numbers))
vibez.spill("  Languages length:", len(programming_languages))
vibez.spill("  First number:", test_numbers[0])
vibez.spill("  Last language:", programming_languages[3])

vibez.spill("✅ Arrays test passed")

fr Test 5: String Operations
vibez.spill("")
vibez.spill("📝 Testing Strings:")

sus welcome_text tea = "Welcome to"
sus language_name tea = "CURSED"
sus full_message tea = welcome_text + " " + language_name + "!"

vibez.spill("  Greeting:", welcome_text)
vibez.spill("  Language:", language_name)
vibez.spill("  Full message:", full_message)
vibez.spill("  Message length:", len(full_message))

vibez.spill("✅ Strings test passed")

fr Test 6: Boolean Logic
vibez.spill("")
vibez.spill("💡 Testing Boolean Logic:")

sus language_is_fast lit = based
sus language_is_safe lit = based
sus language_is_fun lit = based

vibez.spill("  Fast:", language_is_fast)
vibez.spill("  Safe:", language_is_safe)
vibez.spill("  Fun:", language_is_fun)

ready (language_is_fast && language_is_safe && language_is_fun) {
    vibez.spill("  CURSED is fast, safe, AND fun! 🔥")
}

vibez.spill("✅ Boolean logic test passed")

fr Test 7: Arithmetic Operations
vibez.spill("")
vibez.spill("🧮 Testing Arithmetic:")

sus number_a drip = 15
sus number_b drip = 4

vibez.spill("  a =", number_a)
vibez.spill("  b =", number_b)
vibez.spill("  a + b =", number_a + number_b)
vibez.spill("  a - b =", number_a - number_b)
vibez.spill("  a * b =", number_a * number_b)
vibez.spill("  a / b =", number_a / number_b)
vibez.spill("  a % b =", number_a % number_b)

vibez.spill("✅ Arithmetic test passed")

