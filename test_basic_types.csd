fr fr Test file for new basic types

slay main() normie {
    fr fr Basic integer types
    sus small smol = 42
    sus medium mid = 1024
    sus large thicc = 9223372036854775807
    sus normal normie = 12345
    
    fr fr Floating point types
    sus smallFloat snack = 3.14
    sus largeFloat meal = 2.718281828
    
    fr fr Character and byte types
    sus character sip = 'A'
    sus byteVal byte = 255
    sus unicode rune = 65536
    
    fr fr Boolean type
    sus isTrue lit = based
    sus isFalse lit = cap
    
    fr fr Complex number (placeholder for now)
    fr fr sus complexNum extra = 3.0 + 4.0i
    
    vibez.spill("small (smol): ")
