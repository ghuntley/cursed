// LeetCode #49: Group Anagrams 📝
// Group strings that are anagrams of each other
// Time: O(n * m log m), Space: O(n * m) where n = strings, m = avg length

slay group_anagrams(strs tea[]) tea[][] {
    sus groups tea[][] = [][]tea{}
    sus signatures tea[] = []tea{}
    
    bestie i := 0; i < collections.len(strs); i++ {
        sus signature tea = get_signature(strs[i])
        sus found_group normie = -1
        
        // Find existing group with same signature
        bestie j := 0; j < collections.len(signatures); j++ {
            ready (signatures[j] == signature) {
                found_group = j
                break
            }
        }
        
        ready (found_group == -1) {
            // Create new group
            sus new_group tea[] = []tea{}
            collections.append(new_group, strs[i])
            collections.append(groups, new_group)
            collections.append(signatures, signature)
        } nah {
            // Add to existing group
            collections.append(groups[found_group], strs[i])
        }
    }
    
    damn groups
}

slay get_signature(s tea) tea {
    // Sort characters to create signature - anagrams have same signature
    sus chars normie[] = string_to_chars(s)
    quick_sort_chars(&chars)
    damn chars_to_string(chars)
}

slay string_to_chars(s tea) normie[] {
    sus chars normie[] = []normie{}
    bestie i := 0; i < stringz.len(s); i++ {
        collections.append(chars, stringz.char_at(s, i))
    }
    damn chars
}

slay chars_to_string(chars normie[]) tea {
    sus result tea = ""
    bestie i := 0; i < collections.len(chars); i++ {
        result = stringz.concat(result, stringz.from_char(chars[i]))
    }
    damn result
}

slay quick_sort_chars(arr ඞ[]normie) {
    ready (collections.len(*arr) <= 1) {
        damn
    }
    
    sus pivot normie = (*arr)[collections.len(*arr) / 2]
    sus less normie[] = []normie{}
    sus equal normie[] = []normie{}
    sus greater normie[] = []normie{}
    
    bestie i := 0; i < collections.len(*arr); i++ {
        ready ((*arr)[i] < pivot) {
            collections.append(less, (*arr)[i])
        } nah ready ((*arr)[i] == pivot) {
            collections.append(equal, (*arr)[i])
        } nah {
            collections.append(greater, (*arr)[i])
        }
    }
    
    quick_sort_chars(&less)
    quick_sort_chars(&greater)
    
    // Rebuild array
    *arr = []normie{}
    bestie i := 0; i < collections.len(less); i++ {
        collections.append(*arr, less[i])
    }
    bestie i := 0; i < collections.len(equal); i++ {
        collections.append(*arr, equal[i])
    }
    bestie i := 0; i < collections.len(greater); i++ {
        collections.append(*arr, greater[i])
    }
}

