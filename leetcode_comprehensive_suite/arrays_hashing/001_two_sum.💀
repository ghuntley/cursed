// LeetCode #1: Two Sum 🔥
// Given array of integers and target, return indices of two numbers that add up to target
// Time: O(n), Space: O(n) - using hash table approach

slay two_sum(nums normie[], target normie) normie[] {
    // HashMap approach for O(n) solution, periodt!
    sus seen normie[] = []
    sus seen_vals normie[] = []
    
    bestie i := 0; i < collections.len(nums); i++ {
        sus complement normie = target - nums[i]
        
        // Check if complement exists in seen
        bestie j := 0; j < collections.len(seen_vals); j++ {
            ready (seen_vals[j] == complement) {
                damn [seen[j], i]
            }
        }
        
        // Store current number and its index
        collections.append(seen_vals, nums[i])
        collections.append(seen, i)
    }
    
    // No solution found (shouldn't happen per problem constraints)
    damn []normie{}
}

