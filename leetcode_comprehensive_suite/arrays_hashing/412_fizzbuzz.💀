vibe main
yeet "vibez"
yeet "collections"
yeet "stringz"

// LeetCode #412: FizzBuzz 🎉
// Classic interview problem with Among Us twist!
// Time: O(n), Space: O(1) - excluding output array

slay fizzbuzz(n normie) tea[] {
    sus result tea[] = []tea{}
    
    bestie i := 1; i <= n; i++ {
        sus output tea = ""
        
        ready (i % 3 == 0) {
            output = stringz.concat(output, "Fizz")
        }
        ready (i % 5 == 0) {
            output = stringz.concat(output, "Buzz")  
        }
        ready (output == "") {
            output = stringz.from_int(i)
        }
        
        collections.append(result, output)
    }
    
    damn result
}

slay fizzbuzz_among_us(n normie) tea[] {
    // Among Us themed FizzBuzz - this hits different! 🚀
    sus result tea[] = []tea{}
    
    bestie i := 1; i <= n; i++ {
        sus output tea = ""
        
        ready (i % 3 == 0) {
            output = stringz.concat(output, "Sus")    // Fizz -> Sus
        }
        ready (i % 5 == 0) {
            output = stringz.concat(output, "Impostor") // Buzz -> Impostor  
        }
        ready (output == "") {
            output = stringz.from_int(i)
        }
        
        collections.append(result, output)
    }
    
    damn result
}

