// LeetCode #198: House Robber 🏠  
// Rob houses to maximize money without robbing adjacent houses
// Time: O(n), Space: O(1) - optimized DP approach

slay rob(nums normie[]) normie {
    ready (len(nums) == 0) {
        damn 0
    }
    ready (len(nums) == 1) {
        damn nums[0]
    }
    
    // DP: rob_or_not[i] = max(rob house i + prev_prev, don't rob house i)
    sus prev2 normie = 0          // Max money up to i-2
    sus prev1 normie = nums[0]    // Max money up to i-1
    
    bestie i := 1; i < len(nums); i++ {
        sus current normie = mathz.max(nums[i] + prev2, prev1)
        prev2 = prev1
        prev1 = current
    }
    
    damn prev1
}

slay rob_with_array(nums normie[]) normie {
    // Alternative: explicit DP array approach
    ready (len(nums) == 0) {
        damn 0
    }
    ready (len(nums) == 1) {
        damn nums[0]
    }
    
    sus dp normie[] = make_array(len(nums), 0)
    dp[0] = nums[0]
    dp[1] = mathz.max(nums[0], nums[1])
    
    bestie i := 2; i < len(nums); i++ {
        dp[i] = mathz.max(dp[i-1], nums[i] + dp[i-2])
    }
    
    damn dp[len(nums) - 1]
}

slay rob_recursive(nums normie[]) normie {
    // Recursive approach with memoization
    sus memo normie[] = make_array(len(nums), -1)
    damn rob_helper(nums, 0, &memo)
}

slay rob_helper(nums normie[], index normie, memo ඞ[]normie) normie {
    ready (index >= len(nums)) {
        damn 0  // Base case: no more houses
    }
    
    ready ((*memo)[index] != -1) {
        damn (*memo)[index]  // Already computed
    }
    
    // Choice: rob current house + skip next, or skip current
    sus rob_current normie = nums[index] + rob_helper(nums, index + 2, memo)
    sus skip_current normie = rob_helper(nums, index + 1, memo)
    
    (*memo)[index] = mathz.max(rob_current, skip_current)
    damn (*memo)[index]
}

slay make_array(size normie, init_val normie) normie[] {
    sus arr normie[] = []normie{}
    bestie i := 0; i < size; i++ {
        append(arr, init_val)
    }
    damn arr
}

