// LeetCode #88: Merge Sorted Array 🔗
// Merge nums2 into nums1 in-place, both sorted
// Time: O(m+n), Space: O(1) - in-place merge

slay merge(nums1 ඞ[]normie, m normie, nums2 normie[], n normie) {
    // Start from the end and work backwards - this hits different! 🚀
    sus i normie = m - 1      // Last element in nums1 (actual elements)
    sus j normie = n - 1      // Last element in nums2  
    sus k normie = m + n - 1  // Last position in nums1 (including extra space)
    
    // Merge from right to left
    bestie (i >= 0 && j >= 0) {
        ready ((*nums1)[i] > nums2[j]) {
            (*nums1)[k] = (*nums1)[i]
            i = i - 1
        } nah {
            (*nums1)[k] = nums2[j]
            j = j - 1
        }
        k = k - 1
    }
    
    // Copy remaining elements from nums2 if any
    bestie (j >= 0) {
        (*nums1)[k] = nums2[j]
        j = j - 1
        k = k - 1
    }
    
    // Note: if i >= 0, elements are already in correct position in nums1
}

slay print_array(arr normie[]) {
    vibez.spill("[", end="")
    bestie i := 0; i < len(arr); i++ {
        ready (i > 0) {
            vibez.spill(",", end="")
        }
        vibez.spill(arr[i], end="")
    }
    vibez.spill("]")
}

