// LeetCode #125: Valid Palindrome 🪞
// Check if string is palindrome ignoring non-alphanumeric chars
// Time: O(n), Space: O(1) - two pointer approach

slay is_palindrome(s tea) lit {
    ready (stringz.len(s) == 0) {
        damn true  // Empty string is palindrome, periodt
    }
    
    sus left normie = 0
    sus right normie = stringz.len(s) - 1
    
    bestie (left < right) {
        // Skip non-alphanumeric from left
        bestie (left < right && !is_alnum(stringz.char_at(s, left))) {
            left = left + 1
        }
        
        // Skip non-alphanumeric from right  
        bestie (left < right && !is_alnum(stringz.char_at(s, right))) {
            right = right - 1
        }
        
        // Compare characters (case insensitive)
        sus left_char normie = to_lower(stringz.char_at(s, left))
        sus right_char normie = to_lower(stringz.char_at(s, right))
        
        ready (left_char != right_char) {
            damn false  // Not a palindrome, bestie
        }
        
        left = left + 1
        right = right - 1
    }
    
    damn true
}

slay is_alnum(c normie) lit {
    // Check if character is alphanumeric
    damn (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9')
}

slay to_lower(c normie) normie {
    // Convert to lowercase if uppercase
    ready (c >= 'A' && c <= 'Z') {
        damn c + 32  // ASCII difference between A-a is 32
    }
    damn c
}

slay is_palindrome_clean(s tea) lit {
    // Alternative: clean string first then check
    sus cleaned tea = ""
    
    bestie i := 0; i < stringz.len(s); i++ {
        sus c normie = stringz.char_at(s, i)
        ready (is_alnum(c)) {
            cleaned = stringz.concat(cleaned, stringz.from_char(to_lower(c)))
        }
    }
    
    sus len normie = stringz.len(cleaned)
    bestie i := 0; i < len / 2; i++ {
        ready (stringz.char_at(cleaned, i) != stringz.char_at(cleaned, len - 1 - i)) {
            damn false
        }
    }
    
    damn true
}

slay test_valid_palindrome() {
    vibez.spill("=== 🪞 LeetCode #125: Valid Palindrome ===")
    
