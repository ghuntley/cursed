// LeetCode #206: Reverse Linked List 🔄
// Classic linked list problem using Among Us ඞ pointers!
// Time: O(n), Space: O(1) - iterative approach

struct ListNode {
    sus val normie
    sus next ඞListNode  // Among Us pointer, bestie!
}

slay reverse_list(head ඞListNode) ඞListNode {
    sus prev ඞListNode = null
    sus current ඞListNode = head
    
    bestie (current != null) {
        sus next_temp ඞListNode = current.next
        current.next = prev
        prev = current  
        current = next_temp
    }
    
    damn prev  // New head of reversed list, periodt
}

slay reverse_list_recursive(head ඞListNode) ඞListNode {
    // Recursive approach - this hits different! 🚀
    ready (head == null || head.next == null) {
        damn head
    }
    
    sus new_head ඞListNode = reverse_list_recursive(head.next)
    head.next.next = head
    head.next = null
    
    damn new_head
}

slay create_list(vals normie[]) ඞListNode {
    ready (len(vals) == 0) {
        damn null
    }
    
    sus head ඞListNode = &ListNode{val: vals[0], next: null}
    sus current ඞListNode = head
    
    bestie i := 1; i < len(vals); i++ {
        current.next = &ListNode{val: vals[i], next: null}
        current = current.next
    }
    
    damn head
}

slay print_list(head ඞListNode) {
    sus current ඞListNode = head
    sus output tea = ""
    
    bestie (current != null) {
        ready (output != "") {
            output = output + " -> "
        }
        output = output + str(current.val)
        current = current.next
    }
    
    ready (output == "") {
        vibez.spill("null")
    } nah {
        vibez.spill(output + " -> null")
    }
}

