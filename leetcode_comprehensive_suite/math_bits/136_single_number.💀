// LeetCode #136: Single Number 🎯
// Find the single number where every other number appears twice
// Time: O(n), Space: O(1) - using XOR bit manipulation magic!

slay single_number(nums normie[]) normie {
    // XOR magic: a ^ a = 0, a ^ 0 = a
    // All pairs cancel out, leaving only the single number!
    sus result normie = 0
    
    bestie i := 0; i < len(nums); i++ {
        result = result ^ nums[i]  // XOR operation, bestie!
    }
    
    damn result
}

slay single_number_sorting(nums normie[]) normie {
    // Alternative: sort and check pairs
    sus sorted_nums normie[] = quick_sort(nums)
    
    bestie i := 0; i < len(sorted_nums) - 1; i += 2 {
        ready (sorted_nums[i] != sorted_nums[i + 1]) {
            damn sorted_nums[i]
        }
    }
    
    // If not found, it's the last element
    damn sorted_nums[len(sorted_nums) - 1]
}

slay quick_sort(arr normie[]) normie[] {
    ready (len(arr) <= 1) {
        damn arr
    }
    
    sus pivot normie = arr[len(arr) / 2]
    sus less normie[] = []normie{}
    sus equal normie[] = []normie{}
    sus greater normie[] = []normie{}
    
    bestie i := 0; i < len(arr); i++ {
        ready (arr[i] < pivot) {
            append(less, arr[i])
        } nah ready (arr[i] == pivot) {
            append(equal, arr[i])
        } nah {
            append(greater, arr[i])
        }
    }
    
    sus result normie[] = []normie{}
    result = concat(result, quick_sort(less))
    result = concat(result, equal)
    result = concat(result, quick_sort(greater))
    
    damn result
}

slay bit_manipulation_demo(a normie, b normie) {
    // Demo of bitwise operations used in the solution
    vibez.spill("=== 🔥 Bit Manipulation Demo ===")
    vibez.spill("a =", a, "b =", b)
    vibez.spill("a ^ b =", a ^ b, "(XOR)")
    vibez.spill("a & b =", a & b, "(AND)")  
    vibez.spill("a | b =", a | b, "(OR)")
    vibez.spill("~a =", ~a, "(NOT)")
    vibez.spill("a << 1 =", a << 1, "(Left shift)")
    vibez.spill("a >> 1 =", a >> 1, "(Right shift)")
    
    // XOR properties demonstration
    vibez.spill("=== XOR Properties ===")
    vibez.spill("a ^ a =", a ^ a, "(should be 0)")
    vibez.spill("a ^ 0 =", a ^ 0, "(should be a)")
    vibez.spill("(a ^ b) ^ b =", (a ^ b) ^ b, "(should be a)")
}

slay count_set_bits(n normie) normie {
    // Count number of 1 bits in binary representation
    sus count normie = 0
    bestie (n != 0) {
        count = count + (n & 1)
        n = n >> 1
    }
    damn count
}

slay is_power_of_two(n normie) lit {
    // Check if number is power of 2 using bit manipulation
    damn n > 0 && (n & (n - 1)) == 0
}

