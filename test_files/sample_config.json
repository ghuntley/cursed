{
    "application": {
        "name": "CURSED JSON Processor",
        "version": "1.0.0",
        "debug": true,
        "features": [
            "file_io",
            "streaming",
            "validation",
            "cross_platform"
        ]
    },
    "database": {
        "host": "localhost",
        "port": 5432,
        "name": "cursed_db",
        "ssl": true
    },
    "logging": {
        "level": "info",
        "format": "json",
        "outputs": ["console", "file"]
    }
}
