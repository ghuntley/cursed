yeet "vibez"

# Simple test of core functionality without advanced modules
sus test_name tea = "Simple Test"
sus passed lit = based

vibez.spill("Starting simple test framework validation...")

# Test basic assertions
fr fr 2 + 2 == 4 {
    vibez.spill("✅ Basic arithmetic test passed")
} else {
    vibez.spill("❌ Basic arithmetic test failed")
    passed = cap
}

# Test string operations  
fr fr "hello" + "world" == "helloworld" {
    vibez.spill("✅ String concatenation test passed")
} else {
    vibez.spill("❌ String concatenation test failed")
    passed = cap
}

# Test boolean operations
fr fr based == based {
    vibez.spill("✅ Boolean comparison test passed")
} else {
    vibez.spill("❌ Boolean comparison test failed")
    passed = cap
}

# Final result
fr fr passed == based {
    vibez.spill("🎉 All simple tests passed!")
} else {
    vibez.spill("❌ Some tests failed")
}
