yeet "testz"
yeet "vibez"

vibez.spill("🧪 Testing Enhanced Testz Framework")
vibez.spill("===================================")

fr fr Test basic functionality
testz.test_start("basic_math")
testz.assert_eq_int(2 + 2, 4)

testz.test_start("string_equality")
testz.assert_eq_string("hello", "hello")

testz.test_start("boolean_test")
testz.assert_true(based)

fr fr Test benchmarking
vibez.spill("⏱️ Testing benchmark functionality")
sus bench_id drip = testz.benchmark_start("simple_arithmetic")
sus result drip = 10 + 20 + 30
testz.benchmark_end(bench_id)

fr fr Print summary
testz.print_test_summary()

vibez.spill("✅ Testz framework validation complete!")
