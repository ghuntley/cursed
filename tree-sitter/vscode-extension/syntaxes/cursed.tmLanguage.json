{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CURSED",
  "scopeName": "source.cursed",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cursed",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cursed",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cursed",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.cursed",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.backtick.cursed",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cursed",
          "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.float.cursed",
          "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.float.cursed",
          "match": "\\b\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.cursed",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.cursed",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.cursed",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.cursed",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cursed",
          "match": "\\b(lowkey|highkey|vibe_check|mood|basic|bestie|flex|periodt|ready|yolo|ghosted|simp|later|stan)\\b"
        },
        {
          "name": "keyword.declaration.cursed",
          "match": "\\b(vibe|yeet|facts|sus|be_like|slay|squad|vibes|dm|map)\\b"
        },
        {
          "name": "keyword.operator.cursed",
          "match": "\\b(close)\\b"
        },
        {
          "name": "constant.language.boolean.cursed",
          "match": "\\b(based|cap)\\b"
        },
        {
          "name": "constant.language.null.cursed",
          "match": "\\b(cringe)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.cursed",
          "match": "\\b(normie|smol|mid|thicc|drip|snack|meal|byte|rune|extra|tea|lit|sip)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.cursed",
          "match": "(:=|=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
        },
        {
          "name": "keyword.operator.arithmetic.cursed",
          "match": "(\\+|-|\\*|/|%|&|\\||\\^|<<|>>|&\\^)"
        },
        {
          "name": "keyword.operator.comparison.cursed",
          "match": "(==|!=|<|<=|>|>=)"
        },
        {
          "name": "keyword.operator.logical.cursed",
          "match": "(&&|\\||\\!)"
        },
        {
          "name": "keyword.operator.increment.cursed",
          "match": "(\\+\\+|--)"
        },
        {
          "name": "keyword.operator.channel.cursed",
          "match": "(<-)"
        },
        {
          "name": "keyword.operator.address.cursed",
          "match": "(&|\\*)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cursed",
          "match": "\\b(slay)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.cursed"
            },
            "2": {
              "name": "entity.name.function.cursed"
            }
          }
        },
        {
          "name": "entity.name.function.call.cursed",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.call.cursed"
            }
          }
        },
        {
          "name": "entity.name.function.method.cursed",
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.method.cursed"
            }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.declaration.cursed",
          "match": "\\b(sus|facts)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.cursed"
            },
            "2": {
              "name": "variable.name.cursed"
            }
          }
        },
        {
          "name": "variable.other.cursed",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.other.cursed",
          "match": "\\b[A-Z_][A-Z0-9_]*\\b"
        }
      ]
    }
  }
}
