{
  "name": "cursed-language-support",
  "displayName": "CURSED Language Support",
  "description": "Language support for the CURSED programming language",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cursed",
        "aliases": ["CURSED", "cursed"],
        "extensions": [".💀"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cursed",
        "scopeName": "source.cursed",
        "path": "./syntaxes/cursed.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "cursed",
        "path": "./snippets/cursed.json"
      }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.0"
  }
}
