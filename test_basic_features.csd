# CURSED Basic Features Test
# Testing variables, arithmetic, strings, and basic operations

# Variables and types
sus age drip = 25
sus name tea = "CURSED Developer"
sus active lit = based
sus pi drip = 3.14159

# Arithmetic operations
sus sum drip = age + 10
sus product drip = age * 2
sus division drip = age / 5

# String operations
sus greeting tea = "Hello, " + name
sus full_message tea = greeting + "! Welcome to CURSED"

# Boolean operations
sus is_adult lit = age >= 18
sus ready_to_code lit = active && is_adult

# Print results
spill("=== BASIC FEATURES TEST ===")
spill("Name:", name)
spill("Age:", age)
spill("Active:", active)
spill("Sum (age + 10):", sum)
spill("Product (age * 2):", product)
spill("Division (age / 5):", division)
spill("Greeting:", greeting)
spill("Full message:", full_message)
spill("Is adult:", is_adult)
spill("Ready to code:", ready_to_code)
spill("Pi value:", pi)
