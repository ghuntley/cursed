vibe main
yeet "vibez"

slay main_character() {
    vibez.spill("Hello World!")
    bestie i drip = 1; i <= 100; i++ {
        lowkey (i % 15 == 0) {
            vibez.spill("FizzBuzz")
        } highkey lowkey (i % 3 == 0) {
            vibez.spill("Fizz")
        } highkey lowkey (i % 5 == 0) {
            vibez.spill("Buzz")  
        } highkey {
            vibez.spill(i)
        }
    }
}
