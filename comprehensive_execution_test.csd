yeet "testz"

sus x drip = 42
sus name tea = "CURSED"
sus flag lit = based

vibez.spill("Testing variable assignment:")
vibez.spill(x)
vibez.spill(name)
vibez.spill(flag)

slay add(a drip, b drip) drip {
    damn a + b
}

sus result drip = add(10, 20)
vibez.spill("Function result:")
vibez.spill(result)

squad Point {
    spill x drip
    spill y drip
}

sus p Point = Point{x: 5, y: 10}
vibez.spill("Struct test:")
vibez.spill(p.x)
vibez.spill(p.y)
