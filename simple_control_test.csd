sus x drip = 10

lowkey x > 5 {
    vibez.spill("x is greater than 5")
}

lowkey x < 5 {
    vibez.spill("x is less than 5")
} highkey {
    vibez.spill("x is not less than 5") 
}

bestie i := 0; i < 3; i++ {
    vibez.spill("loop iteration")
}

sus counter drip = 0
periodt counter < 3 {
    counter++
    vibez.spill("while loop")
}
