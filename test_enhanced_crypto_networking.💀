fr fr CURSED Enhanced Crypto & Networking Test Suite
fr fr Comprehensive testing of all enhanced crypto and networking functions

yeet "stdlib/crypto_enhanced/mod.💀"
yeet "stdlib/network_enhanced/mod.💀"
yeet "testz"

slay test_crypto_enhanced() {
    vibez.spill("🔐 Testing Enhanced Crypto Functions...")
    
    fr fr Test MD5 hashing
    vibez.spill("Testing MD5 hashing...")
    sus test_data tea = "Hello, World!"
    sus md5_result tea = hash_md5(test_data)
    vibez.spill("MD5 of '" + test_data + "': " + md5_result)
    
    fr fr Test SHA-256 hashing (from base crypto)
    vibez.spill("Testing SHA-256 hashing...")
    sus sha256_result tea = hash_sha256(test_data)
    vibez.spill("SHA-256 of '" + test_data + "': " + sha256_result)
    
    fr fr Test simple encryption/decryption
    vibez.spill("Testing simple encryption/decryption...")
    sus plaintext tea = "Secret message"
    sus key tea = "mykey123"
    sus encrypted tea = encrypt_simple(plaintext, key)
    sus decrypted tea = decrypt_simple(encrypted, key)
    
    vibez.spill("Plaintext: " + plaintext)
    vibez.spill("Key: " + key) 
    vibez.spill("Encrypted: " + encrypted)
    vibez.spill("Decrypted: " + decrypted)
    
    fr fr Test different key for verification
    sus wrong_key tea = "wrongkey"
    sus wrong_decrypt tea = decrypt_simple(encrypted, wrong_key)
    vibez.spill("Wrong key decrypt: " + wrong_decrypt)
    
    fr fr Test random string generation
    vibez.spill("Testing random string generation...")
    bestie i := 1; i <= 5; i++ {
        sus random_str tea = generate_random(10)
        vibez.spill("Random " + tea(i) + " (length 10): " + random_str)
    }
    
    fr fr Test different lengths
    bestie len := 5; len <= 25; len = len + 5 {
        sus random_str tea = generate_random(len)
        vibez.spill("Random length " + tea(len) + ": " + random_str)
    }
    
    vibez.spill("✅ Enhanced crypto functions tested successfully")
}

slay test_networking_enhanced() {
    vibez.spill("🌐 Testing Enhanced Networking Functions...")
    
    fr fr Test URL parsing
    vibez.spill("Testing URL parsing...")
    sus test_urls [tea] = [
        "http://www.example.com/path/to/resource?param=value#section",
        "https://api.github.com:443/repos/user/repo",
        "ftp://files.example.com:21/downloads/file.zip",
        "ws://localhost:8080/websocket",
        "https://subdomain.example.co.uk/api/v1/users?id=123&name=test#results"
    ]
    
    bestie i := 0; i < 5; i++ {
        sus url tea = test_urls[i]
        vibez.spill("Parsing URL: " + url)
        
        sus parts URLParts = parse_url(url)
        vibez.spill("  Scheme: " + parts.scheme)
        vibez.spill("  Host: " + parts.host)
        vibez.spill("  Port: " + tea(parts.port))
        vibez.spill("  Path: " + parts.path)
        vibez.spill("  Query: " + parts.query)
        vibez.spill("  Fragment: " + parts.fragment)
        vibez.spill("")
    }
    
    fr fr Test domain extraction
    vibez.spill("Testing domain extraction...")
    bestie i := 0; i < 5; i++ {
        sus url tea = test_urls[i]
        sus domain tea = get_domain(url)
        vibez.spill("Domain of '" + url + "': " + domain)
    }
    
    fr fr Test email validation
    vibez.spill("Testing email validation...")
    sus test_emails [tea] = [
        "user@example.com",           fr fr Valid
        "test.email@domain.co.uk",    fr fr Valid with dots and subdomain
        "user123@test-domain.org",    fr fr Valid with numbers and hyphens
        "invalid.email",              fr fr Invalid - no @
        "user@",                      fr fr Invalid - no domain
        "@domain.com",                fr fr Invalid - no local part
        "user@domain",                fr fr Invalid - no TLD
        "user@@domain.com",           fr fr Invalid - double @
        "",                           fr fr Invalid - empty
        "a@b.c",                      fr fr Valid minimal
        "very.long.email.address.that.is.over.sixty.four.characters.long@example.com" fr fr Invalid - too long local part
    ]
    
    bestie i := 0; i < 11; i++ {
        sus email tea = test_emails[i]
        sus is_valid lit = validate_email(email)
        sus status tea = "❌ INVALID"
        vibes is_valid {
            status = "✅ VALID"
        }
        vibez.spill("Email: '" + email + "' - " + status)
    }
    
    fr fr Test HTTP functions (these will use simulated responses in interpreter mode)
    vibez.spill("Testing HTTP functions...")
    
    sus get_result tea = http_get("http://httpbin.org/get")
    vibez.spill("HTTP GET result: " + get_result)
    
    sus post_data tea = "name=test&value=123"
    sus post_result tea = http_post("http://httpbin.org/post", post_data)
    vibez.spill("HTTP POST result: " + post_result)
    
    fr fr Test with localhost
    sus local_get tea = http_get("http://localhost:8080/test")
    vibez.spill("Local HTTP GET result: " + local_get)
    
    vibez.spill("✅ Enhanced networking functions tested successfully")
}

slay test_integration() {
    vibez.spill("🔗 Testing Integration Scenarios...")
    
    fr fr Test hashing URL data
    sus url tea = "https://api.example.com/secure/endpoint"
    sus url_hash tea = hash_sha256(url)
    vibez.spill("SHA-256 of URL: " + url_hash)
    
    fr fr Test encrypting HTTP response
    sus response_data tea = "{'status':'success','data':'sensitive info'}"
    sus encryption_key tea = "secure-key-2024"
    sus encrypted_response tea = encrypt_simple(response_data, encryption_key)
    sus decrypted_response tea = decrypt_simple(encrypted_response, encryption_key)
    
    vibez.spill("Original response: " + response_data)
    vibez.spill("Encrypted response: " + encrypted_response)
    vibez.spill("Decrypted response: " + decrypted_response)
    
    fr fr Test generating API keys
    vibez.spill("Generating API keys...")
    bestie i := 1; i <= 3; i++ {
        sus api_key tea = generate_random(32)
        sus api_key_hash tea = hash_md5(api_key)
        vibez.spill("API Key " + tea(i) + ": " + api_key)
        vibez.spill("API Key " + tea(i) + " MD5: " + api_key_hash)
    }
    
    fr fr Test domain validation for secure connections
    sus secure_domains [tea] = [
        "https://secure-api.example.com/v1/auth",
        "https://api.github.com/user/repos",
        "wss://websocket.secure-site.com/realtime"
    ]
    
    bestie i := 0; i < 3; i++ {
        sus domain tea = get_domain(secure_domains[i])
        sus domain_hash tea = hash_sha256(domain)
        vibez.spill("Secure domain: " + domain)
        vibez.spill("Domain fingerprint: " + domain_hash)
    }
    
    vibez.spill("✅ Integration scenarios tested successfully")
}

slay test_security_considerations() {
    vibez.spill("🛡️ Testing Security Considerations...")
    
    fr fr Test hash collision (different inputs should produce different hashes)
    sus data1 tea = "password123"
    sus data2 tea = "password124"
    sus hash1 tea = hash_sha256(data1)
    sus hash2 tea = hash_sha256(data2)
    
    vibez.spill("Hash of '" + data1 + "': " + hash1)
    vibez.spill("Hash of '" + data2 + "': " + hash2)
    vibez.spill("Hashes different: " + tea(hash1 != hash2))
    
    fr fr Test encryption key sensitivity
    sus message tea = "Confidential data"
    sus key1 tea = "key123"
    sus key2 tea = "key124"
    sus encrypted1 tea = encrypt_simple(message, key1)
    sus encrypted2 tea = encrypt_simple(message, key2)
    
    vibez.spill("Same message, different keys produce different ciphertext:")
    vibez.spill("Key1 result: " + encrypted1)
    vibez.spill("Key2 result: " + encrypted2)
    vibez.spill("Ciphertexts different: " + tea(encrypted1 != encrypted2))
    
    fr fr Test random string uniqueness
    vibez.spill("Testing random string uniqueness...")
    sus random_strings [tea] = ["", "", "", "", ""]
    bestie i := 0; i < 5; i++ {
        random_strings[i] = generate_random(16)
    }
    
    vibez.spill("Generated random strings:")
    bestie i := 0; i < 5; i++ {
        vibez.spill("  " + tea(i + 1) + ": " + random_strings[i])
    }
    
    fr fr Check for duplicates
    sus duplicates_found lit = cap
    bestie i := 0; i < 5; i++ {
        bestie j := i + 1; j < 5; j++ {
            vibes random_strings[i] == random_strings[j] {
                duplicates_found = based
                vibez.spill("⚠️ Duplicate found: " + random_strings[i])
            }
        }
    }
    
    vibes duplicates_found == cap {
        vibez.spill("✅ All random strings are unique")
    }
    
    vibez.spill("🛡️ Security considerations tested")
}

