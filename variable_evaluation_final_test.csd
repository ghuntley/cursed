sus count drip = 42
sus price meal = 19.99
sus name tea = "Alice"
sus active lit = based
sus grade sip = 'A'

vibez.spill("=== Variable Evaluation Fix Test ===")
vibez.spill("Integer variable count:", count)
vibez.spill("Float variable price:", price)
vibez.spill("String variable name:", name)
vibez.spill("Boolean variable active:", active)
vibez.spill("Character variable grade:", grade)

vibez.spill("Direct variable access:")
vibez.spill(count)
vibez.spill(price)
vibez.spill(name)
vibez.spill(active)
vibez.spill(grade)

vibez.spill("All variable types now display their actual values!")
