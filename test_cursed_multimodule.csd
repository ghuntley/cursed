yeet "mathz"
yeet "stringz"

slay main_character() {
    yap("=== CURSED Multi-Module Test ===")
    
    // Test 1: mathz functions
    sus math_result normie = mathz.add_two(10, 5)
    yap("mathz.add_two(10, 5) =")
    yap(math_result)
    
    // Test 2: stringz functions
    sus str1 vibes = "Hello "
    sus str2 vibes = "CURSED!"
    sus combined_str vibes = stringz.concat(str1, str2)
    yap("stringz.concat result:")
    yap(combined_str)
    
    // Test 3: Combined operations
    sus final_math normie = mathz.add_two(20, 22)
    sus final_str vibes = stringz.concat("Result: ", "42")
    yap("Final math:")
    yap(final_math)
    yap("Final string:")
    yap(final_str)
    
    yap("=== Multi-Module Test Complete ===")
}
