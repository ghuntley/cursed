vibe main

yeet "vibez"

slay main_character() {
    vibez.spill("=== Comparison Test ===")
    
    sus i normie = 1
    sus limit normie = 3
    
    vibez.spill("i =")
    vibez.spill(i)
    vibez.spill("limit =")
    vibez.spill(limit)
    
    vibez.spill("i <= limit:")
    vibez.spill(i <= limit)
    
    i = 5
    vibez.spill("After i = 5, i <= limit:")
    vibez.spill(i <= limit)
    
    vibez.spill("=== Test Complete ===")
}
