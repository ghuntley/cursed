yeet "stringz"

vibez.spill("=== Additional StringZ Functions ===")

fr Test case conversion
sus upper tea = stringz.to_upper("hello")
sus lower tea = stringz.to_lower("WORLD")
vibez.spill("'hello' to upper:", upper)
vibez.spill("'WORLD' to lower:", lower)

fr Test string equality
sus equal1 lit = stringz.equals("test", "test")
sus equal2 lit = stringz.equals("test", "other")
vibez.spill("'test' equals 'test':", equal1)
vibez.spill("'test' equals 'other':", equal2)

fr Test empty check
sus empty1 lit = stringz.is_empty("")
sus empty2 lit = stringz.is_empty("test")
vibez.spill("'' is empty:", empty1)
vibez.spill("'test' is empty:", empty2)

vibez.spill("=== Extended tests completed ===")
