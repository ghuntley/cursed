# Debug: Arithmetic operations
sus a drip = 10
sus b drip = 5

vibez.spill("Testing arithmetic:")
sus sum drip = a + b
vibez.spill(sum)

sus diff drip = a - b  
vibez.spill(diff)

sus prod drip = a * b
vibez.spill(prod)

vibez.spill("Direct arithmetic:")
vibez.spill(10 + 5)
vibez.spill(10 - 5)
vibez.spill(10 * 5)
