yeet "vibez"

vibe "complex_test"

slay fibonacci(n normie) -> normie {
    bestie (n <= 1) {
        damn n
    }
    damn fibonacci(n - 1) + fibonacci(n - 2)
}

slay main() {
    vibez.spill("=== Complex Test ===")
    
    sus result := fibonacci(8)
    vibez.spill("Fibonacci(8): " + result)
    
    sus i := 0
    periodt (i < 3) {
        vibez.spill("Loop " + i)
        i++
    }
    
    vibez.spill("=== Test Complete ===")
}
