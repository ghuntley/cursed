fr fr Import the vibez module
yeet "vibez";

fr fr  Variable declarations
sus x = 5;
sus y = 10;
sus z = x + y;

fr fr  Print results
vibez.spill(x);

vibez.spill(y);

vibez.spill(z);

fr fr  Function call with addition
vibez.spill(x + y);

fr fr  Print a message
vibez.spill("Test completed successfully!"); 