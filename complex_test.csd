sus numbers []drip = [1, 2, 3, 4, 5]
sus total drip = 0

bestie i := 0; i < numbers.len(); i = i + 1 {
    total = total + numbers[i]
}

slay factorial(n drip) drip {
    ready n <= 1 {
        damn 1
    }
    damn n * factorial(n - 1)
}

vibez.spill("Array sum:", total)
vibez.spill("Factorial of 5:", factorial(5))
