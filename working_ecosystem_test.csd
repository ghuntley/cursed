fr CURSED Ecosystem Working Test - Core Features Validation

vibez.spill("🚀 CURSED Language Ecosystem Test")
vibez.spill("==================================")

fr Test 1: Basic Variables
vibez.spill("")
vibez.spill("📦 Testing Variables:")

sus name tea = "CURSED"
sus version drip = 1
sus ready lit = based
sus pi meal = 3.14159

vibez.spill("  Language name:", name)
vibez.spill("  Version:", version)
vibez.spill("  Production ready:", ready)
vibez.spill("  Pi constant:", pi)
vibez.spill("✅ Variables test passed")

fr Test 2: Basic Functions
vibez.spill("")
vibez.spill("⚙️ Testing Functions:")

slay greet(name tea) {
    vibez.spill("  Hello,", name, "!")
}

slay add(a drip, b drip) drip {
    damn a + b
}

slay multiply(x drip, y drip) drip {
    damn x * y
}

greet("Developer")
sus sum drip = add(10, 5)
sus product drip = multiply(7, 8)

vibez.spill("  10 + 5 =", sum)
vibez.spill("  7 * 8 =", product)
vibez.spill("✅ Functions test passed")

fr Test 3: Control Flow
vibez.spill("")
vibez.spill("🔄 Testing Control Flow:")

sus score drip = 85

ready (score >= 90) {
    vibez.spill("  Grade: A (Excellent)")
} otherwise ready (score >= 80) {
    vibez.spill("  Grade: B (Good)")
} otherwise ready (score >= 70) {
    vibez.spill("  Grade: C (Average)")
} otherwise {
    vibez.spill("  Grade: F (Needs improvement)")
}

fr Loop test
vibez.spill("  Counting from 1 to 5:")
sus counter drip = 1
bestie (counter <= 5) {
    vibez.spill("    Count:", counter)
    counter = counter + 1
}

vibez.spill("✅ Control flow test passed")

fr Test 4: Arrays
vibez.spill("")
vibez.spill("📋 Testing Arrays:")

sus numbers []drip = [10, 20, 30, 40, 50]
sus languages []tea = ["CURSED", "Zig", "Rust", "Go"]

vibez.spill("  Numbers array:", numbers)
vibez.spill("  Languages array:", languages)
vibez.spill("  Numbers length:", len(numbers))
vibez.spill("  Languages length:", len(languages))
vibez.spill("  First number:", numbers[0])
vibez.spill("  Last language:", languages[3])

vibez.spill("✅ Arrays test passed")

fr Test 5: String Operations
vibez.spill("")
vibez.spill("📝 Testing Strings:")

sus greeting tea = "Welcome to"
sus lang tea = "CURSED"
sus message tea = greeting + " " + lang + "!"

vibez.spill("  Greeting:", greeting)
vibez.spill("  Language:", lang)
vibez.spill("  Full message:", message)
vibez.spill("  Message length:", len(message))

vibez.spill("✅ Strings test passed")

fr Test 6: Boolean Logic
vibez.spill("")
vibez.spill("💡 Testing Boolean Logic:")

sus is_fast lit = based
sus is_safe lit = based
sus is_fun lit = based

vibez.spill("  Fast:", is_fast)
vibez.spill("  Safe:", is_safe)
vibez.spill("  Fun:", is_fun)

ready (is_fast && is_safe && is_fun) {
    vibez.spill("  CURSED is fast, safe, AND fun! 🔥")
}

vibez.spill("✅ Boolean logic test passed")

fr Test 7: Arithmetic Operations
vibez.spill("")
vibez.spill("🧮 Testing Arithmetic:")

sus a drip = 15
sus b drip = 4

vibez.spill("  a =", a)
vibez.spill("  b =", b)
vibez.spill("  a + b =", a + b)
vibez.spill("  a - b =", a - b)
vibez.spill("  a * b =", a * b)
vibez.spill("  a / b =", a / b)
vibez.spill("  a % b =", a % b)

vibez.spill("✅ Arithmetic test passed")

