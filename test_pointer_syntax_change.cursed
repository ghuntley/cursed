vibe main
yeet "vibez"

slay test_pointer_syntax() {
    fr fr Testing new pointer syntax with ඞ
    sus x normie = 42
    sus ptr ඞnormie = ඞx
    
    vibez.spill("Value of x:")
    vibez.spill(x)
    vibez.spill("Value pointed to by ptr:")
    vibez.spill(*ptr)
}

slay main_character() {
    test_pointer_syntax()
}
