vibe main
yeet "vibez"
yeet "stringz"

slay main_character() {
    vibez.spill("Testing stringz.concat implementation:")
    
    sus base = "CURSED"
    vibez.spill("Base string length:", stringz.length(base))
    
    sus result1 = stringz.concat(base, base)
    vibez.spill("After 1st concat length:", stringz.length(result1))
    vibez.spill("Result1 content:", result1)
    
    sus result2 = stringz.concat(result1, base)
    vibez.spill("After 2nd concat length:", stringz.length(result2))
    vibez.spill("Result2 content:", result2)
}
