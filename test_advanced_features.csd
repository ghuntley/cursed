facts PI = 3.14159

slay calculateArea(radius normie) normie {
    yolo radius * radius * PI
}

slay main() {
    sus radius normie = 5
    sus area normie = calculateArea(radius)
    
    lowkey area > 70 {
        vibez.spill("Large circle!")
    } highkey {
        vibez.spill("Small circle!")
    }
    
    yolo area
}
