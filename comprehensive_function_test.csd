yeet "mathz"

fr fr Test all mathz functions
vibez.spill("Testing max_normie(10, 5):", max_normie(10, 5))
vibez.spill("Testing min_normie(3, 7):", min_normie(3, 7))
vibez.spill("Testing abs_normie(-5):", abs_normie(-5))
vibez.spill("Testing add_two(3, 4):", add_two(3, 4))

fr fr Test variable assignments
sus max_result drip = max_normie(15, 8)
sus min_result drip = min_normie(12, 6)
sus abs_result drip = abs_normie(-10)
sus add_result drip = add_two(7, 9)

vibez.spill("Variable results:")
vibez.spill("max_result:", max_result)
vibez.spill("min_result:", min_result)
vibez.spill("abs_result:", abs_result)
vibez.spill("add_result:", add_result)
