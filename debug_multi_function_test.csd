slay add(a drip, b drip) drip {
    damn a + b
}

slay multiply(x drip, y drip, z drip) drip {
    damn x * y * z
}

slay main_character() {
    vibez.spill("Step 1: Starting test")
    
    sus result1 drip = add(5, 3)
    vibez.spill("Step 2: add result is", result1)
    
    sus result2 drip = multiply(2, 3, 4)
    vibez.spill("Step 3: multiply result is", result2)
    
    vibez.spill("Step 4: Test complete")
}
