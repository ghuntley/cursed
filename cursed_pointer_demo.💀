fr fr Using the world's first Among Us character pointer syntax!

slay demonstrate_among_us_pointers() {
    vibez.spill("🔥 Among Us Pointers Demo 🔥")
    
    sus x normie = 42
    sus ptr ඞnormie = ඞx    // ඞ = "sus" pointers! 
    
    vibez.spill("Original value:")
    vibez.spill(x)
    
