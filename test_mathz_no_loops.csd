// Test mathz module constants and simple functions without for loops

yeet "testz"

// Mathematical constants
sus Pi drip = 3.14159265358979323846
sus E drip = 2.71828182845904523536

// Absolute value function
slay Abs(x meal) meal {
    bestie x < 0.0 {
        damn 0.0 - x
    }
    damn x
}

// Maximum of two values
slay Max(x meal, y meal) meal {
    bestie x > y {
        damn x
    }
    damn y
}

// Test the functions
vibez.spill("Pi: ", Pi)
vibez.spill("E: ", E)
vibez.spill("Abs(-5.5): ", Abs(0.0 - 5.5))
vibez.spill("Max(3.0, 7.0): ", Max(3.0, 7.0))
