yeet "vibez"
yeet "mathz"

slay test_vibez_spill() {
    vibez.spill("Testing vibez.spill - this works!")
}

slay test_vibez_spillln() {
    vibez.spillln("Testing vibez.spillln - this works!")
}

slay test_vibez_separator() {
    vibez.print_separator()
}

slay test_mathz_abs() {
    sus x drip = -42.5
    sus result drip = mathz.abs_normie(x)
    vibez.spill("Mathz abs test completed")
}

slay test_mathz_max() {
    sus a drip = 10.0
    sus b drip = 20.0  
    sus result drip = mathz.max_normie(a, b)
    vibez.spill("Mathz max test completed")
}

slay test_mathz_min() {
    sus a drip = 10.0
    sus b drip = 20.0
    sus result drip = mathz.min_normie(a, b)
    vibez.spill("Mathz min test completed")
}

slay main_character() {
    test_vibez_spill()
    test_vibez_spillln()
    test_vibez_separator()
    test_mathz_abs()
    test_mathz_max()
    test_mathz_min()
}
