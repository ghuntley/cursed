fr fr Comprehensive test for implemented stdlib functions

yeet "stringz"
yeet "mathz" 
yeet "arrayz"
yeet "vibez"

fr fr Test String Functions
sus text tea = "hello world"
sus len drip = length(text)
vibez.spill("String length:", len)

sus upper tea = to_upper("hello")
vibez.spill("Uppercase:", upper)

sus lower tea = to_lower("HELLO")
vibez.spill("Lowercase:", lower)

sus has_sub lit = contains("hello world", "world")
vibez.spill("Contains world:", has_sub)

sus start_check lit = starts_with("hello", "he")
vibez.spill("Starts with 'he':", start_check)

fr fr Test Math Functions
sus abs_val drip = abs_normie(-42)
vibez.spill("Absolute value:", abs_val)

sus max_val drip = max_normie(10, 5)
vibez.spill("Max value:", max_val)

sus min_val drip = min_normie(10, 5)
vibez.spill("Min value:", min_val)

sus sqrt_val meal = sqrt_meal(16.0)
vibez.spill("Square root of 16:", sqrt_val)

sus power_val meal = pow_meal(2.0, 3)
vibez.spill("2 to power 3:", power_val)

fr fr Test Array Functions
sus arr [tea] = ["hello", "world", "test"]
sus arr_len drip = array_length(arr)
vibez.spill("Array length:", arr_len)

sus first_elem tea = array_get(arr, 0)
vibez.spill("First element:", first_elem)

sus has_hello lit = array_contains(arr, "hello")
vibez.spill("Array contains hello:", has_hello)

sus numbers [normie] = [3, 1, 4, 1, 5]
sus sum drip = array_sum_numbers(numbers)
vibez.spill("Sum of numbers:", sum)

sus avg meal = array_average_numbers(numbers)
vibez.spill("Average of numbers:", avg)

vibez.spill("All stdlib function tests completed!")
