// Test CURSED LSP functionality with comprehensive features
yeet "testz"

squad TestStruct {
    spill name tea
    spill value normie
}

collab TestInterface {
    slay test_method() normie
}

slay main() {
    vibez.spill("Testing CURSED LSP features!")
    
    sus x normie = 42
    sus message tea = "Hello CURSED!"
    sus flag lit = based
    
    bestie (x < 100) {
        vibez.spill("Value is: ")
        vibez.spill(x)
        x = x + 1
    }
    
    match x {
        42 => vibez.spill("Perfect answer!")
        100 => vibez.spill("Century!")
        _ => vibez.spill("Other value")
    }
    
    sus test_struct TestStruct = TestStruct{
        name: "test",
        value: 123
    }
    
    vibez.spill(test_struct.name)
}

slay helper_function(param normie) normie {
    damn param * 2
}
