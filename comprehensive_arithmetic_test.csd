fr fr Comprehensive arithmetic test

sus a drip = 5 + 3
sus b drip = 10 - 4  
sus c drip = 7 * 2
sus d drip = 20 / 4
sus e drip = 17 % 5

vibez.spill("5 + 3 =", a)
