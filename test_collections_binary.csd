fr fr Test collections module in binary compilation mode

yeet "vibez"
yeet "collections"

main_character() {
    vibez.spill("Testing Collections Module - Binary Mode")
    
    fr fr Test basic vector operations
    sus vec = collections.Vec_new()
    vec = collections.Vec_push(vec, 42)
    vec = collections.Vec_push(vec, 99)
    
    sus len = collections.Vec_len(vec)
    vibez.spill("Vector length: " + len.(tea))
    
    sus first = collections.Vec_get(vec, 0)
    vibez.spill("First element: " + first.(tea))
    
    sus second = collections.Vec_get(vec, 1)
    vibez.spill("Second element: " + second.(tea))
    
    vibez.spill("Collections binary test completed!")
    
    no_cap 0
}
