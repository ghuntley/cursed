vibe main

slay main_character() {
    // Test len() with string literal
    sus len_result drip = len("Test")
    println("len(\"Test\") =", len_result)
    
    // Test make() and len() with array
    sus arr drip = make(3)
    sus arr_len drip = len(arr)
    println("make(3) length =", arr_len)
    
    // Test cap()
    sus capacity drip = cap(arr)
    println("cap(arr) =", capacity)
    
    // Test append()
    sus new_arr drip = append(arr, 42)
    sus new_len drip = len(new_arr)
    println("After append, length =", new_len)
    
    println("Simple builtin test complete!")
}
