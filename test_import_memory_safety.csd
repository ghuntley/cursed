// Test import memory safety with complex import patterns
yeet "vibez"
yeet "mathz", "stringz", "arrayz"
yeet "testz", "filez", "networkz"

// Multiple imports on separate lines
yeet "cryptz"
yeet "jsonz"
yeet "xmlz"

// Functions that use imported modules
slay test_memory_management() drip {
    sus x drip = 42
    sus y drip = x + 1
    damn y
}

slay another_test() tea {
    sus msg tea = "Hello, CURSED!"
    damn msg
}

// Test recursive import scenarios
slay complex_function(a drip, b drip) drip {
    ready (a > b) {
        damn a * b
    } otherwise {
        damn a + b  
    }
}

spill("Memory safety test completed successfully!")
