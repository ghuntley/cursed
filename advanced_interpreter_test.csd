fr fr Advanced Interpreter Test
fr fr Test enhanced features in the working interpreter

vibez.spill("🚀 Advanced CURSED Interpreter Test")
vibez.spill("=================================")

fr fr 1. Multiple variable declarations
sus x = 10
sus y = 5
sus z = 3

fr fr 2. Arithmetic expressions with proper evaluation
sus result1 = x + y * 2
sus result2 = x * y + z
sus result3 = x + y + z

vibez.spill("Variables: x =", x, ", y =", y, ", z =", z)
vibez.spill("x + y * 2 =", result1)
vibez.spill("x * y + z =", result2) 
vibez.spill("x + y + z =", result3)

fr fr 3. String operations
sus name = "CURSED"
sus version = "v1.0"
sus message = "Hello from CURSED!"

vibez.spill("Name:", name)
vibez.spill("Version:", version)
vibez.spill("Message:", message)

fr fr 4. Boolean operations
sus flag1 = based
sus flag2 = cringe

vibez.spill("Flag1:", flag1)
vibez.spill("Flag2:", flag2)

fr fr 5. Mixed argument printing
vibez.spill("Mixed:", "Name =", name, "Version =", version, "X =", x)

fr fr 6. Mathematical operations
sus math1 = x + y
sus math2 = x - y
sus math3 = x * y
sus math4 = x / y

vibez.spill("Addition:", math1)
vibez.spill("Subtraction:", math2)
vibez.spill("Multiplication:", math3)
vibez.spill("Division:", math4)

fr fr 7. Complex nested expressions
sus complex = x + y * z - 2
vibez.spill("Complex (x + y * z - 2):", complex)

vibez.spill("")
vibez.spill("🎯 Advanced interpreter test complete!")
vibez.spill("All expression evaluation working correctly!")
