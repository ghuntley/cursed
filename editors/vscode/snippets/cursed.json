{
    "Main Function": {
        "prefix": ["main", "slay main"],
        "body": [
            "slay main() {",
            "\t$0",
            "}"
        ],
        "description": "Main function template"
    },
    "Function Declaration": {
        "prefix": ["func", "slay"],
        "body": [
            "slay ${1:function_name}(${2:params}) -> ${3:return_type} {",
            "\t$0",
            "}"
        ],
        "description": "Function declaration template"
    },
    "Async Function": {
        "prefix": ["async", "yolo"],
        "body": [
            "yolo ${1:async_function}(${2:params}) -> ${3:return_type} {",
            "\t$0",
            "}"
        ],
        "description": "Async function declaration"
    },
    "Variable Declaration": {
        "prefix": ["var", "facts"],
        "body": [
            "facts ${1:variable_name}: ${2:type} = ${3:value}"
        ],
        "description": "Immutable variable declaration"
    },
    "Mutable Variable": {
        "prefix": ["mut", "sus"],
        "body": [
            "sus ${1:variable_name}: ${2:type} = ${3:value}"
        ],
        "description": "Mutable variable declaration"
    },
    "If Statement": {
        "prefix": ["if", "lowkey"],
        "body": [
            "lowkey ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "If statement"
    },
    "If-Else Statement": {
        "prefix": ["ifelse", "lowkey highkey"],
        "body": [
            "lowkey ${1:condition} {",
            "\t${2:// if body}",
            "} highkey {",
            "\t${3:// else body}",
            "\t$0",
            "}"
        ],
        "description": "If-else statement"
    },
    "For Loop": {
        "prefix": ["for", "bestie"],
        "body": [
            "bestie ${1:item} in ${2:collection} {",
            "\t$0",
            "}"
        ],
        "description": "For loop iteration"
    },
    "While Loop": {
        "prefix": ["while", "flex"],
        "body": [
            "flex ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "While loop"
    },
    "Generic Loop": {
        "prefix": ["loop", "periodt"],
        "body": [
            "periodt ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "Generic loop construct"
    },
    "Struct Declaration": {
        "prefix": ["struct", "squad"],
        "body": [
            "squad ${1:StructName} {",
            "\t${2:field_name}: ${3:field_type},",
            "\t$0",
            "}"
        ],
        "description": "Struct declaration"
    },
    "Interface Declaration": {
        "prefix": ["interface", "collab"],
        "body": [
            "collab ${1:InterfaceName} {",
            "\t${2:method_name}(${3:params}) -> ${4:return_type}",
            "\t$0",
            "}"
        ],
        "description": "Interface declaration"
    },
    "Enum Declaration": {
        "prefix": ["enum", "vibes"],
        "body": [
            "vibes ${1:EnumName} {",
            "\t${2:Variant1},",
            "\t${3:Variant2},",
            "\t$0",
            "}"
        ],
        "description": "Enum declaration"
    },
    "Switch Statement": {
        "prefix": ["switch", "vibe_check"],
        "body": [
            "vibe_check ${1:value} {",
            "\tmood ${2:case1}:",
            "\t\t${3:// case body}",
            "\tbasic:",
            "\t\t${4:// default case}",
            "\t\t$0",
            "}"
        ],
        "description": "Switch statement"
    },
    "Return Statement": {
        "prefix": ["return", "bounce"],
        "body": [
            "bounce ${1:value}"
        ],
        "description": "Return statement"
    },
    "Panic Statement": {
        "prefix": ["panic", "yeet"],
        "body": [
            "yeet \"${1:error_message}\""
        ],
        "description": "Panic/throw statement"
    },
    "Channel Declaration": {
        "prefix": ["chan", "channel"],
        "body": [
            "facts ${1:ch}: chan ${2:type} = make(chan ${2:type}${3:, ${4:buffer_size}})"
        ],
        "description": "Channel declaration"
    },
    "Goroutine Spawn": {
        "prefix": ["spawn", "go"],
        "body": [
            "spawn ${1:function_call}(${2:args})"
        ],
        "description": "Spawn goroutine"
    },
    "Print Statement": {
        "prefix": ["print", "p"],
        "body": [
            "print(${1:value})"
        ],
        "description": "Print statement"
    },
    "Println Statement": {
        "prefix": ["println", "pl"],
        "body": [
            "println(${1:value})"
        ],
        "description": "Print line statement"
    },
    "Import Statement": {
        "prefix": ["import", "use"],
        "body": [
            "use \"${1:module_path}\""
        ],
        "description": "Import/use statement"
    },
    "Comment Block": {
        "prefix": ["comment", "/*"],
        "body": [
            "/*",
            " * ${1:Comment description}",
            " */"
        ],
        "description": "Multi-line comment block"
    },
    "TODO Comment": {
        "prefix": ["todo"],
        "body": [
            "// TODO: ${1:Description of what needs to be done}"
        ],
        "description": "TODO comment"
    },
    "FIXME Comment": {
        "prefix": ["fixme"],
        "body": [
            "// FIXME: ${1:Description of what needs to be fixed}"
        ],
        "description": "FIXME comment"
    },
    "Error Handling": {
        "prefix": ["catch", "try"],
        "body": [
            "catch ${1:error} {",
            "\t${2:// error handling}",
            "\t$0",
            "} finally {",
            "\t${3:// cleanup}",
            "}"
        ],
        "description": "Error handling block"
    },
    "Type Assertion": {
        "prefix": ["assert", "as"],
        "body": [
            "${1:value}.(${2:Type})"
        ],
        "description": "Type assertion"
    },
    "Optional Type Assertion": {
        "prefix": ["assert?", "as?"],
        "body": [
            "${1:value}.(${2:Type})?"
        ],
        "description": "Optional type assertion with error propagation"
    }
}
