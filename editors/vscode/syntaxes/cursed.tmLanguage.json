{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CURSED",
    "scopeName": "source.cursed",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#types"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.cursed",
                    "begin": "//",
                    "end": "$"
                },
                {
                    "name": "comment.block.cursed",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cursed",
                    "match": "\\b(lowkey|highkey|periodt|bestie|flex|vibe_check|mood|basic|bounce|yeet|catch|finally)\\b"
                },
                {
                    "name": "keyword.declaration.cursed",
                    "match": "\\b(slay|yolo|facts|sus|squad|collab|vibes|use|from)\\b"
                },
                {
                    "name": "keyword.modifier.cursed",
                    "match": "\\b(public|private|async|await)\\b"
                },
                {
                    "name": "keyword.other.cursed",
                    "match": "\\b(chan|send|recv|select|defer|go|spawn)\\b"
                },
                {
                    "name": "constant.language.cursed",
                    "match": "\\b(true|false|nil)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cursed",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.cursed",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.backtick.cursed",
                    "begin": "`",
                    "end": "`"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.cursed",
                    "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.cursed",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.hex.cursed",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.cursed",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.cursed",
                    "match": "\\b0[oO][0-7]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.cursed",
                    "match": "\\b(slay|yolo)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.cursed"
                        },
                        "2": {
                            "name": "entity.name.function.cursed"
                        }
                    }
                },
                {
                    "name": "support.function.builtin.cursed",
                    "match": "\\b(print|println|len|str|int|float|type|panic|spawn|make|append|copy|delete|close)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.cursed",
                    "match": "\\b(string|int|float|bool|char|byte)\\b"
                },
                {
                    "name": "storage.type.collection.cursed",
                    "match": "\\b(array|slice|map|set|chan)\\b"
                },
                {
                    "name": "storage.type.generic.cursed",
                    "match": "\\b(Vec|HashMap|Option|Result|Any)\\b"
                },
                {
                    "name": "entity.name.type.cursed",
                    "match": "\\b(squad|collab|vibes)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.cursed"
                        },
                        "2": {
                            "name": "entity.name.type.cursed"
                        }
                    }
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.declaration.cursed",
                    "match": "\\b(facts|sus)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.cursed"
                        },
                        "2": {
                            "name": "variable.name.cursed"
                        }
                    }
                },
                {
                    "name": "variable.parameter.cursed",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*:"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.cursed",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.cursed",
                    "match": "\\+|\\-|\\*|\\/|%"
                },
                {
                    "name": "keyword.operator.comparison.cursed",
                    "match": "==|!=|<|>|<=|>="
                },
                {
                    "name": "keyword.operator.logical.cursed",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.bitwise.cursed",
                    "match": "&|\\||\\^|<<|>>"
                },
                {
                    "name": "keyword.operator.channel.cursed",
                    "match": "<-"
                },
                {
                    "name": "keyword.operator.other.cursed",
                    "match": "\\?|:"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.cursed",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.cursed",
                    "match": ","
                },
                {
                    "name": "punctuation.accessor.cursed",
                    "match": "\\."
                },
                {
                    "name": "punctuation.section.brackets.cursed",
                    "match": "\\[|\\]"
                },
                {
                    "name": "punctuation.section.parens.cursed",
                    "match": "\\(|\\)"
                },
                {
                    "name": "punctuation.section.braces.cursed",
                    "match": "\\{|\\}"
                }
            ]
        }
    }
}
