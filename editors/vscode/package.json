{
    "name": "cursed-language-support",
    "displayName": "CURSED Language Support",
    "description": "Comprehensive language support for CURSED programming language - Gen Z meets systems programming",
    "version": "1.0.0",
    "publisher": "cursed-lang",
    "license": "MIT",
    "homepage": "https://github.com/ghuntley/cursed",
    "repository": {
        "type": "git",
        "url": "https://github.com/ghuntley/cursed"
    },
    "bugs": {
        "url": "https://github.com/ghuntley/cursed/issues"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Formatters",
        "Snippets",
        "Debuggers",
        "Testing"
    ],
    "keywords": [
        "cursed",
        "programming language", 
        "gen z",
        "slang",
        "go-like",
        "systems programming",
        "goroutines",
        "channels",
        "garbage collection"
    ],
    "preview": true,
    "activationEvents": [
        "onLanguage:cursed",
        "onCommand:cursed.newProject",
        "workspaceContains:**/*.csd",
        "workspaceContains:**/CursedPackage.toml"
    ],
    "icon": "icons/cursed-icon.png",
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "cursed",
                "aliases": ["CURSED", "cursed"],
                "extensions": [".csd"],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/cursed-light.svg",
                    "dark": "./icons/cursed-dark.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "cursed",
                "scopeName": "source.cursed",
                "path": "./syntaxes/cursed.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "cursed",
                "path": "./snippets/cursed.json"
            }
        ],
        "themes": [
            {
                "label": "CURSED Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/cursed-dark.json"
            },
            {
                "label": "CURSED Light",
                "uiTheme": "vs",
                "path": "./themes/cursed-light.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "CURSED Language Server",
            "properties": {
                "cursed.languageServer.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable CURSED language server"
                },
                "cursed.languageServer.command": {
                    "type": "string",
                    "default": "cursed-lsp",
                    "description": "Command to start the CURSED language server"
                },
                "cursed.languageServer.args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Arguments to pass to the language server"
                },
                "cursed.languageServer.debug": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable debug logging for the language server"
                },
                "cursed.format.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable automatic formatting on save"
                },
                "cursed.format.indentSize": {
                    "type": "number",
                    "default": 4,
                    "description": "Number of spaces per indent level"
                },
                "cursed.format.useTabs": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use tabs instead of spaces for indentation"
                },
                "cursed.format.lineWidth": {
                    "type": "number",
                    "default": 120,
                    "description": "Maximum line width for formatting"
                },
                "cursed.format.braceStyle": {
                    "type": "string",
                    "enum": ["same-line", "next-line", "next-line-unindented"],
                    "default": "same-line",
                    "description": "Brace placement style"
                },
                "cursed.lint.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable linting"
                },
                "cursed.lint.checkStyle": {
                    "type": "boolean",
                    "default": true,
                    "description": "Check for style issues"
                },
                "cursed.lint.checkPerformance": {
                    "type": "boolean",
                    "default": true,
                    "description": "Check for performance issues"
                },
                "cursed.lint.checkSecurity": {
                    "type": "boolean",
                    "default": true,
                    "description": "Check for security issues"
                },
                "cursed.completion.enableSnippets": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable code snippets in completion"
                },
                "cursed.completion.enableCursedSlang": {
                    "type": "boolean",
                    "default": true,
                    "description": "Suggest CURSED slang keywords"
                },
                "cursed.inlayHints.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable inlay hints for type information"
                },
                "cursed.semanticHighlighting.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable semantic syntax highlighting"
                }
            }
        },
        "commands": [
            {
                "command": "cursed.restartLanguageServer",
                "title": "Restart Language Server",
                "category": "CURSED",
                "icon": "$(debug-restart)"
            },
            {
                "command": "cursed.showAstNode",
                "title": "Show AST Node",
                "category": "CURSED",
                "icon": "$(symbol-structure)"
            },
            {
                "command": "cursed.showTypeInfo",
                "title": "Show Type Information",
                "category": "CURSED",
                "icon": "$(info)"
            },
            {
                "command": "cursed.formatDocument",
                "title": "Format Document",
                "category": "CURSED",
                "icon": "$(editor-layout)"
            },
            {
                "command": "cursed.runLinter",
                "title": "Run Linter",
                "category": "CURSED",
                "icon": "$(check)"
            },
            {
                "command": "cursed.showGoroutineInfo",
                "title": "Show Goroutine Information",
                "category": "CURSED",
                "icon": "$(arrow-swap)"
            },
            {
                "command": "cursed.showChannelInfo",
                "title": "Show Channel Information",
                "category": "CURSED",
                "icon": "$(arrow-both)"
            },
            {
                "command": "cursed.newProject",
                "title": "New CURSED Project",
                "category": "CURSED",
                "icon": "$(folder-opened)"
            },
            {
                "command": "cursed.build",
                "title": "Build Project",
                "category": "CURSED",
                "icon": "$(tools)"
            },
            {
                "command": "cursed.run",
                "title": "Run Project",
                "category": "CURSED",
                "icon": "$(play)"
            },
            {
                "command": "cursed.test",
                "title": "Run Tests",
                "category": "CURSED",
                "icon": "$(beaker)"
            },
            {
                "command": "cursed.clean",
                "title": "Clean Build",
                "category": "CURSED",
                "icon": "$(trash)"
            },
            {
                "command": "cursed.openRepl",
                "title": "Open REPL",
                "category": "CURSED",
                "icon": "$(terminal)"
            },
            {
                "command": "cursed.packageInstall",
                "title": "Install Dependencies",
                "category": "CURSED",
                "icon": "$(cloud-download)"
            },
            {
                "command": "cursed.packageUpdate",
                "title": "Update Dependencies",
                "category": "CURSED",
                "icon": "$(sync)"
            },
            {
                "command": "cursed.showProjectStructure",
                "title": "Show Project Structure",
                "category": "CURSED",
                "icon": "$(list-tree)"
            },
            {
                "command": "cursed.showDiagnostics",
                "title": "Show Diagnostics",
                "category": "CURSED",
                "icon": "$(warning)"
            },
            {
                "command": "cursed.generateDocs",
                "title": "Generate Documentation",
                "category": "CURSED",
                "icon": "$(book)"
            },
            {
                "command": "cursed.benchmarks",
                "title": "Run Benchmarks",
                "category": "CURSED",
                "icon": "$(pulse)"
            },
            {
                "command": "cursed.checkLints",
                "title": "Check Lints",
                "category": "CURSED",
                "icon": "$(checklist)"
            },
            {
                "command": "cursed.debugStart",
                "title": "Start Debugging",
                "category": "CURSED",
                "icon": "$(debug-start)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.formatDocument",
                    "group": "1_modification@1"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showTypeInfo",
                    "group": "navigation@1"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showAstNode",
                    "group": "navigation@2"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showGoroutineInfo",
                    "group": "navigation@3"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showChannelInfo",
                    "group": "navigation@4"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.runLinter",
                    "group": "z_commands@1"
                }
            ],
            "editor/title": [
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.build",
                    "group": "navigation@1"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.run",
                    "group": "navigation@2"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.test",
                    "group": "navigation@3"
                }
            ],
            "explorer/context": [
                {
                    "when": "resourceExtname == .csd",
                    "command": "cursed.build",
                    "group": "2_workspace@1"
                },
                {
                    "when": "resourceExtname == .csd",
                    "command": "cursed.run",
                    "group": "2_workspace@2"
                },
                {
                    "when": "resourceFilename == CursedPackage.toml",
                    "command": "cursed.packageInstall",
                    "group": "2_workspace@1"
                }
            ],
            "view/title": [
                {
                    "when": "view == cursedProjectView",
                    "command": "cursed.newProject",
                    "group": "navigation@1"
                },
                {
                    "when": "view == cursedProjectView",
                    "command": "cursed.packageInstall",
                    "group": "navigation@2"
                }
            ],
            "commandPalette": [
                {
                    "command": "cursed.newProject"
                },
                {
                    "command": "cursed.build"
                },
                {
                    "command": "cursed.run"
                },
                {
                    "command": "cursed.test"
                },
                {
                    "command": "cursed.clean"
                },
                {
                    "command": "cursed.openRepl"
                },
                {
                    "command": "cursed.packageInstall"
                },
                {
                    "command": "cursed.packageUpdate"
                },
                {
                    "command": "cursed.showProjectStructure"
                },
                {
                    "command": "cursed.generateDocs"
                },
                {
                    "command": "cursed.benchmarks"
                },
                {
                    "command": "cursed.restartLanguageServer"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showAstNode"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showTypeInfo"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.formatDocument"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.runLinter"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showGoroutineInfo"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.showChannelInfo"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.checkLints"
                },
                {
                    "when": "resourceLangId == cursed",
                    "command": "cursed.debugStart"
                }
            ]
        },
        "keybindings": [
            {
                "command": "cursed.formatDocument",
                "key": "ctrl+shift+f",
                "mac": "cmd+shift+f",
                "when": "resourceLangId == cursed"
            },
            {
                "command": "cursed.showTypeInfo",
                "key": "ctrl+k ctrl+i",
                "mac": "cmd+k cmd+i",
                "when": "resourceLangId == cursed"
            },
            {
                "command": "cursed.build",
                "key": "ctrl+shift+b",
                "mac": "cmd+shift+b",
                "when": "resourceLangId == cursed"
            },
            {
                "command": "cursed.run",
                "key": "ctrl+f5",
                "mac": "cmd+f5",
                "when": "resourceLangId == cursed"
            },
            {
                "command": "cursed.test",
                "key": "ctrl+shift+t",
                "mac": "cmd+shift+t",
                "when": "resourceLangId == cursed"
            },
            {
                "command": "cursed.openRepl",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r",
                "when": "resourceLangId == cursed"
            }
        ],
        "views": {
            "explorer": [
                {
                    "id": "cursedProjectView",
                    "name": "CURSED Project",
                    "when": "workspaceContains:**/*.csd || workspaceContains:**/CursedPackage.toml"
                },
                {
                    "id": "cursedDependencies",
                    "name": "Dependencies",
                    "when": "workspaceContains:**/CursedPackage.toml"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "cursedProjectView",
                "contents": "Welcome to CURSED development! 🔥\n\n[New CURSED Project](command:cursed.newProject)\n\n[Open Folder](command:vscode.openFolder)\n\nTo learn more about CURSED, [visit our documentation](https://github.com/ghuntley/cursed).",
                "when": "workspaceFolderCount == 0"
            },
            {
                "view": "cursedProjectView",
                "contents": "No CURSED files found in workspace.\n\n[New CURSED Project](command:cursed.newProject)\n\n[Create CURSED file](command:workbench.action.files.newUntitledFile)",
                "when": "workspaceFolderCount > 0 && !workspaceContains:**/*.csd"
            }
        ],
        "taskDefinitions": [
            {
                "type": "cursed",
                "required": [
                    "task"
                ],
                "properties": {
                    "task": {
                        "type": "string",
                        "description": "The CURSED task to execute"
                    },
                    "args": {
                        "type": "array",
                        "description": "Additional arguments"
                    },
                    "cwd": {
                        "type": "string",
                        "description": "Working directory"
                    }
                }
            }
        ],
        "problemMatchers": [
            {
                "name": "cursed",
                "owner": "cursed",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": [
                    {
                        "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                ]
            }
        ],
        "debuggers": [
            {
                "type": "cursed",
                "label": "CURSED Debug",
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Path to CURSED program",
                                "default": "${workspaceFolder}/main.csd"
                            },
                            "args": {
                                "type": "array",
                                "description": "Command line arguments",
                                "default": []
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory",
                                "default": "${workspaceFolder}"
                            },
                            "env": {
                                "type": "object",
                                "description": "Environment variables",
                                "default": {}
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "description": "Stop on entry",
                                "default": false
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "cursed",
                        "request": "launch",
                        "name": "Launch CURSED Program",
                        "program": "${workspaceFolder}/main.csd",
                        "cwd": "${workspaceFolder}",
                        "stopOnEntry": false
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "CURSED: Launch",
                        "description": "Launch a CURSED program",
                        "body": {
                            "type": "cursed",
                            "request": "launch",
                            "name": "Launch CURSED Program",
                            "program": "^\"\\${workspaceFolder}/main.csd\"",
                            "cwd": "^\"\\${workspaceFolder}\"",
                            "stopOnEntry": false
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "test": "npm run compile && node ./out/test/runTest.js",
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "devDependencies": {
        "@types/node": "^18.x",
        "@types/vscode": "^1.74.0",
        "@types/mocha": "^10.0.1",
        "@types/glob": "^8.0.0",
        "@typescript-eslint/eslint-plugin": "^5.45.0",
        "@typescript-eslint/parser": "^5.45.0",
        "@vscode/test-electron": "^2.2.0",
        "eslint": "^8.28.0",
        "glob": "^8.0.3",
        "mocha": "^10.1.0",
        "typescript": "^4.9.4",
        "@vscode/vsce": "^2.15.0"
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    },
    "extensionDependencies": [],
    "extensionPack": []
}
