{
    "typescript.tsc.autoDetect": "off",
    "typescript.validate.enable": true,
    "eslint.validate": [
        "typescript"
    ],
    "files.exclude": {
        "out": false,
        "node_modules": true,
        "**/*.js": {
            "when": "$(basename).ts"
        },
        "**/*.js.map": {
            "when": "$(basename)"
        }
    },
    "search.exclude": {
        "out": true,
        "node_modules": true
    },
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false
}
