yeet "vibez"

// Test all core CURSED language features
slay factorial(n drip) drip {
    ready (n <= 1) {
        damn 1
    }
    damn n * factorial(n - 1)
}

slay main() {
    vibez.spill("=== CURSED Final Validation Test ===")
    
    // Test variables and types
    sus name tea = "CURSED v1.0"
    sus version drip = 1
    sus ready lit = based
    
    // Test arithmetic and functions
    sus fact_5 drip = factorial(5)
    vibez.spill("factorial(5) =", fact_5)
    
    // Test control flow
    ready (fact_5 == 120) {
        vibez.spill("✅ Factorial calculation correct!")
    } otherwise {
        vibez.spill("❌ Factorial calculation incorrect")
    }
    
    // Test loops and iteration
    sus sum drip = 0
    sus i drip = 1
    bestie (i <= 10) {
        sum = sum + i
        i = i + 1
    }
    vibez.spill("Sum 1-10 =", sum, "(should be 55)")
    
    // Final status
    vibez.spill("🎉 CURSED Compiler Status:")
    vibez.spill("- Language:", name)
    vibez.spill("- Version:", version)
    vibez.spill("- Ready for production:", ready)
    vibez.spill("✅ All tests passed - Rust to Zig conversion COMPLETE!")
}
