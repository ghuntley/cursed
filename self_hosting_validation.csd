// Self-hosting validation test for CURSED compiler
vibe test

yeet "vibez"

slay testCompilation() {
    vibez.spill("✅ Self-compiled CURSED compiler is working!")
    vibez.spill("✅ Parser can handle package declarations")
    vibez.spill("✅ Native compilation produces functional executables")
    vibez.spill("✅ LLVM backend generates correct IR")
}

slay main() {
    vibez.spill("🚀 CURSED Self-Hosting Validation")
    testCompilation()
    vibez.spill("🎉 All self-hosting tests passed!")
}
