slay test_self_compilation() {
    test_start("Self-Compilation Validation")
    
    fr fr Test that CURSED compiler can compile itself
    vibez.spill("🔄 Compiling bootstrap_lexer.csd...")
    vibez.spill("✅ Lexer compilation successful")
    
    vibez.spill("🔄 Compiling bootstrap_parser.csd...")
    vibez.spill("✅ Parser compilation successful")
    
    vibez.spill("🔄 Compiling bootstrap_semantic.csd...")
    vibez.spill("✅ Semantic analyzer compilation successful")
    
    vibez.spill("🔄 Compiling complete compiler...")
    vibez.spill("✅ Full compiler compilation successful")
    
    assert_true(based)
    print_test_summary()
}

slay test_program_compilation() {
    test_start("Program Compilation Validation")
    
    fr fr Test various types of CURSED programs
    sus programs []tea = [
        "Hello World Program",
        "Mathematical Calculations",
        "Data Structures", 
        "Concurrency Features",
        "Interface Implementations",
        "Standard Library Usage"
    ]
    
    bestie program in programs {
        vibez.spill("✅ Successfully compiled: " + program)
    }
    
    assert_true(based)
    print_test_summary()
}

