vibe main
yeet "vibez"

slay main_character() {
    sus sorted_data normie[value] = normie[value]{5, 2, 8, 1}
    vibez.spill("Before nested loops:", sorted_data)
    
    bestie i := 0; i < len(sorted_data); i++ {
        vibez.spill("Outer loop i:", i)
        bestie j := i + 1; j < len(sorted_data); j++ {
            vibez.spill("Inner loop j:", j)
        }
    }
    
    vibez.spill("After nested loops:", sorted_data)
}
