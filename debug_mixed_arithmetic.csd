vibe main

yeet "vibez"

slay main_character() {
    sus a normie = 2
    sus b normie = 3
    sus c normie = 4
    sus d normie = 5
    
    vibez.spill("Testing individual operations:")
    vibez.spill(a + b)
    vibez.spill(a * b)
    vibez.spill(c / d)
    vibez.spill((a + b) * c)
    vibez.spill((d - a) / b)
    vibez.spill(((a + b) * c) - ((d - a) / b))
}
