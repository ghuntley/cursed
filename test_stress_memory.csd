slay complex_func(a drip, b tea, c lit) tea {
    sus result tea = "processing"
    sus temp drip = a + 10
    vibez.spill("Complex func:", result, temp, b, c)
    damn result
}

sus numbers [normie] = [1, 2, 3, 4, 5]
vibez.spill("Array before:", numbers)

sus flag lit = based
sus text tea = "test string"
sus value drip = 42

sus output tea = complex_func(value, text, flag)
vibez.spill("Final output:", output)

slay nested_func(x drip) drip {
    slay inner_func(y drip) drip {
        damn y * 2
    }
    damn inner_func(x) + 5
}

vibez.spill("Nested result:", nested_func(10))
