fr fr Test all major stdlib modules to ensure module loading works correctly

yeet "mathz"
yeet "stringz"
yeet "arrayz"

vibez.spill("=== Testing mathz module ===")
vibez.spill("abs_normie(-42):", abs_normie(-42))
vibez.spill("max_normie(10, 20):", max_normie(10, 20))
vibez.spill("factorial(5):", factorial(5))

vibez.spill("=== Testing arrayz module ===")
sus numbers []drip = [1, 2, 3, 4, 5]
vibez.spill("Array length:", len(numbers))
vibez.spill("First element:", numbers[0])

vibez.spill("=== Testing stringz module ===")
vibez.spill("String operations loaded successfully")

vibez.spill("=== All modules loaded and working! ===")
