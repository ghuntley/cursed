vibe main
yeet "vibez"

slay main_character() {
    sus a lit = based
    sus b lit = cringe
    
    vibez.spill("Testing unary NOT operator")
    
    ready (!a) {
        vibez.spill("!a is true (should not print)")
    } otherwise {
        vibez.spill("!a is false (should print)")
    }
    
    ready (!b) {
        vibez.spill("!b is true (should print)")
    } otherwise {
        vibez.spill("!b is false (should not print)")
    }
}
