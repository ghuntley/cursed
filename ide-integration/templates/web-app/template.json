{
  "name": "Web Application",
  "description": "Modern web application with HTTP server, database, authentication, and API endpoints",
  "version": "1.0.0",
  "cursed_version": ">=1.0.0",
  "category": "web",
  "tags": ["web", "api", "server", "database", "auth"],
  
  "variables": {
    "project_name": {
      "type": "string",
      "prompt": "Project name",
      "required": true,
      "validation": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "author_name": {
      "type": "string",
      "prompt": "Author name",
      "default": ""
    },
    "author_email": {
      "type": "email",
      "prompt": "Author email",
      "default": ""
    },
    "github_username": {
      "type": "string",
      "prompt": "GitHub username",
      "default": ""
    },
    "description": {
      "type": "string",
      "prompt": "Project description",
      "default": "A modern web application built with CURSED"
    },
    "license": {
      "type": "choice",
      "prompt": "License",
      "choices": ["MIT", "Apache-2.0", "MIT OR Apache-2.0", "GPL-3.0", "BSD-3-Clause"],
      "default": "MIT OR Apache-2.0"
    },
    "database_type": {
      "type": "choice",
      "prompt": "Database type",
      "choices": ["postgresql", "mysql", "sqlite"],
      "default": "postgresql"
    },
    "enable_redis": {
      "type": "boolean",
      "prompt": "Enable Redis for caching",
      "default": true
    },
    "enable_websockets": {
      "type": "boolean",
      "prompt": "Enable WebSocket support",
      "default": false
    },
    "api_version": {
      "type": "string",
      "prompt": "Initial API version",
      "default": "v1",
      "validation": "^v\\d+$"
    }
  },
  
  "required_variables": [
    "project_name",
    "author_name",
    "author_email"
  ],
  
  "optional_variables": [
    "github_username",
    "description",
    "license",
    "database_type",
    "enable_redis",
    "enable_websockets",
    "api_version"
  ],
  
  "post_creation_hooks": [
    "zig build",
    "cursed-fmt src/",
    "git init",
    "git add .",
    "git commit -m 'Initial commit: {{project_name}} web application'"
  ],
  
  "next_steps": [
    "Review and update CursedPackage.toml with your specific dependencies",
    "Set up your database and update the DATABASE_URL in .env",
    "Configure Redis connection if enabled",
    "Run 'zig build' to compile the project",
    "Run 'cursed-zig src/main.csd' to start the development server",
    "Visit http://localhost:8080/health to verify the server is running",
    "Read the README.md for detailed setup and usage instructions"
  ],
  
  "features": [
    "HTTP server with routing",
    "Database integration (PostgreSQL/MySQL/SQLite)",
    "Redis caching support",
    "JWT authentication",
    "Rate limiting",
    "CORS support",
    "Request/response logging",
    "Health check endpoints",
    "Graceful shutdown",
    "Environment-based configuration",
    "Database migrations",
    "Error handling and validation",
    "API documentation structure"
  ]
}
