yeet "testz"

# Simple interface test
collab Writer {
    slay write(data tea) normie
}

collab SimpleWriter : Writer {
    slay simple_write(data tea) normie
}

slay test_simple_interface() lit {
    vibez.spill("Simple interface inheritance test")
    damn based
}

test_start("Simple interface test")
assert_true(test_simple_interface())
print_test_summary()
