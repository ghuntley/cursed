    fr fr Tuple short declaration
    (a, b, c) := (1, 2, 3)
    vibez.spill("a = ")
    vibez.spill(a)
    vibez.spill("b = ")
    vibez.spill(b)
    vibez.spill("c = ")
    vibez.spill(c)
    
    yolo 0
}
