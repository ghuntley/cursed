        // Check if complement exists in seen
        bestie j := 0; j < len(seen_vals); j++ {
            ready (seen_vals[j] == complement) {
                sus result normie[] = [seen[j], i]
                damn result
            }
        }

        // Store current number and its index (FIXED: assign return value)
        seen_vals = append(seen_vals, nums[i])
        seen = append(seen, i)
