slay main_character() {
    sus value drip = 2
    
    vibe_check value {
        case 1:
            vibez.spill("Value is one")
        case 2:
            vibez.spill("Value is two")
        case 3:
            vibez.spill("Value is three")
        default:
            vibez.spill("Value is something else")
    }
    
