{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CURSED",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.cursed",
                    "begin": "//",
                    "end": "$"
                },
                {
                    "name": "comment.block.cursed",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cursed",
                    "match": "\\b(slay|sus|facts|lowkey|highkey|periodt|stan|bestie|flex|ghosted|simp|squad|collab|yeet|vibes|mood|basic|match|ready|later|dm|select)\\b"
                },
                {
                    "name": "keyword.control.traditional.cursed",
                    "match": "\\b(fn|let|mut|if|else|while|for|return|struct|interface|import|package|switch|case|default)\\b"
                },
                {
                    "name": "constant.language.boolean.cursed",
                    "match": "\\b(based|cringe|true|false)\\b"
                },
                {
                    "name": "constant.language.null.cursed",
                    "match": "\\b(nil)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cursed",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.cursed",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.decimal.cursed",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.cursed",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.hex.cursed",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.cursed",
                    "match": "\\b0[bB][01]+\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.cursed",
                    "match": "\\b(normie|tea|lit|drip|thicc|smol|meal|byte|rune)\\b"
                },
                {
                    "name": "storage.type.complex.cursed",
                    "match": "\\b(\\[\\]\\w+|dm\\s+\\w+|map\\[\\w+\\]\\w+|interface\\{\\})\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.cursed",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                },
                {
                    "name": "support.function.builtin.cursed",
                    "match": "\\b(spill|spillf|read_line|len|append|make|hash|encrypt|spawn|send|receive)\\b"
                },
                {
                    "name": "support.function.module.cursed",
                    "match": "\\b(vibez|cryptz|concurrenz|testz|stringz|mathz|arrayz|hashz)\\."
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.cursed",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.cursed",
                    "match": "(:=|=)"
                },
                {
                    "name": "keyword.operator.arithmetic.cursed",
                    "match": "(\\+|\\-|\\*|\\/|%)"
                },
                {
                    "name": "keyword.operator.comparison.cursed",
                    "match": "(==|!=|<|>|<=|>=)"
                },
                {
                    "name": "keyword.operator.logical.cursed",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.bitwise.cursed",
                    "match": "(&|\\||\\^|<<|>>)"
                },
                {
                    "name": "keyword.operator.damn.cursed",
                    "match": "\\b(damn)\\b"
                }
            ]
        }
    },
    "scopeName": "source.cursed"
}
