{
    "scopeName": "source.cursed",
    "name": "CURSED",
    "fileTypes": ["csd", "cursed"],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.cursed",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.cursed",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cursed",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.cursed",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cursed",
                    "match": "\\b(slay|sus|damn|facts|lowkey|bestie|stan|ready|later|dm|select|match|yeet|vibes|mood|basic|ghosted|simp|squad|collab|periodt|flex|spill)\\b"
                },
                {
                    "name": "constant.language.boolean.cursed",
                    "match": "\\b(based|cringe)\\b"
                },
                {
                    "name": "constant.language.null.cursed",
                    "match": "\\b(void|nil)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.cursed",
                    "match": "\\b(normie|tea|lit|drip|thicc|smol|meal|vibe)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.cursed",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                },
                {
                    "name": "support.function.builtin.cursed",
                    "match": "\\b(vibez\\.spill|vibez\\.readline|math\\.[a-zA-Z_][a-zA-Z0-9_]*|string\\.[a-zA-Z_][a-zA-Z0-9_]*|crypto\\.[a-zA-Z_][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.cursed",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.cursed",
                    "match": "(\\+|\\-|\\*|\\/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|=|\\+=|\\-=|\\*=|\\/=)"
                }
            ]
        }
    }
}
