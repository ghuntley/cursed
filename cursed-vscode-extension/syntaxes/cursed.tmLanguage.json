{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CURSED",
  "scopeName": "source.cursed",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#stdlib"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.cursed",
          "match": "fr fr.*$"
        },
        {
          "name": "comment.block.cursed",
          "begin": "no cap",
          "end": "on god"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cursed",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.cursed",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cursed",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.backtick.cursed",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cursed",
          "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.cursed",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.cursed",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.cursed",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.cursed",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cursed",
          "match": "\\b(ready|otherwise|vibe_check|mood|basic|bestie|flex|periodt|damn|ghosted|simp|later|stan|dm_send|dm_recv|dm_close|yikes|fam|shook)\\b"
        },
        {
          "name": "keyword.declaration.cursed",
          "match": "\\b(vibe|yeet|facts|sus|be_like|slay|squad|collab|map|dm|ඞ)\\b"
        },
        {
          "name": "constant.language.boolean.cursed",
          "match": "\\b(based|cringe)\\b"
        },
        {
          "name": "constant.language.nil.cursed",
          "match": "\\b(nah)\\b"
        }
      ]
    },
        {
          "name": "keyword.declaration.cursed",
          "match": "\\b(vibe|yeet|facts|sus|be_like|slay|squad|collab)\\b"
        },
        {
          "name": "constant.language.boolean.cursed",
          "match": "\\b(based|cringe)\\b"
        },
        {
          "name": "constant.language.nil.cursed",
          "match": "\\b(nah)\\b"
        },
        {
          "name": "keyword.other.cursed",
          "match": "\\b(fr\\ fr|no\\ cap|on\\ god)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.cursed",
          "match": "\\b(normie|smol|mid|thicc|snack|meal|byte|rune|extra|tea|lit|sip|channel|dm)\\b"
        }
      ]
    },
        {
          "name": "storage.type.complex.cursed",
          "match": "\\b(map|dm)\\b"
        },
        {
          "name": "entity.name.type.cursed",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cursed",
          "match": "\\b(slay)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "keyword.declaration.cursed"
            },
            "2": {
              "name": "entity.name.function.cursed"
            }
          }
        },
        {
          "name": "support.function.builtin.cursed",
          "match": "\\b(len|cap|make|append|copy|delete|panic|recover|print|println)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.declaration.cursed",
          "match": "\\b(sus)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.cursed"
            },
            "2": {
              "name": "variable.name.cursed"
            }
          }
        },
        {
          "name": "variable.other.cursed",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.cursed",
          "match": "(=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|:=)"
        },
        {
          "name": "keyword.operator.arithmetic.cursed",
          "match": "(\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.cursed",
          "match": "(==|!=|<|<=|>|>=)"
        },
        {
          "name": "keyword.operator.logical.cursed",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.cursed",
          "match": "(&|\\||\\^|<<|>>|&\\^)"
        },
        {
          "name": "keyword.operator.address.cursed",
          "match": "(&|\\*|ඞ)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.cursed",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.brackets.cursed",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.parameters.cursed",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.cursed",
          "match": "[,;]"
        },
        {
          "name": "punctuation.accessor.cursed",
          "match": "\\."
        }
      ]
    },
    "stdlib": {
      "patterns": [
        {
          "name": "support.module.stdlib.cursed",
          "match": "\\b(mathz|stringz|arrayz|testz|cryptz|filez|httpz|timez|jsonz|vibez|concurrenz)\\b"
        },
        {
          "name": "support.function.stdlib.cursed",
          "match": "\\b(vibez\\.spill|abs_normie|slice_tea|len|sha256_hash|read_file|write_file|sleep|timestamp)\\b"
        }
      ]
    }
  }
}
