{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CURSED",
    "scopeName": "source.cursed",
    "fileTypes": ["csd"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#functions" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.cursed",
                    "match": "(fr fr|#).*$"
                },
                {
                    "name": "comment.block.cursed",
                    "begin": "fr fr",
                    "end": "end comment"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cursed",
                    "match": "\\b(lowkey|highkey|bestie|periodt|stan|ready|select|match|case|basic|ghosted|simp|later)\\b"
                },
                {
                    "name": "keyword.declaration.cursed",
                    "match": "\\b(slay|sus|facts|squad|collab|yeet|vibe)\\b"
                },
                {
                    "name": "keyword.other.cursed",
                    "match": "\\b(damn|in|as|where|impl|extends|with|except|rename)\\b"
                },
                {
                    "name": "keyword.control.traditional",
                    "match": "\\b(fn|let|mut|if|else|while|for|return|struct|interface|import|package|switch|default|break|continue|defer)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.cursed",
                    "match": "\\b(based|cringe|lit|cap|nocap|truth|lies)\\b"
                },
                {
                    "name": "constant.language.traditional",
                    "match": "\\b(true|false|nil|null)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.cursed",
                    "match": "\\b(normie|thicc|smol|mid|meal|snack|tea|txt|sip|byte|rune|extra|drip|lit|dm)\\b"
                },
                {
                    "name": "storage.type.traditional", 
                    "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|string|char|bool|int|uint|float)\\b"
                },
                {
                    "name": "storage.modifier.cursed",
                    "match": "\\b(spill|priv|crew)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.cursed",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        },
                        {
                            "name": "constant.other.placeholder.cursed",
                            "match": "\\{[^}]*\\}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.cursed",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.cursed",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.cursed",
                    "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.cursed",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.hex.cursed",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.cursed",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.cursed",
                    "match": "\\b0[oO][0-7]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.cursed",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                },
                {
                    "name": "support.function.stdlib.cursed",
                    "match": "\\b(vibez\\.(spill|spillf|read_line)|len|append|make|cryptz\\.(hash|encrypt)|concurrenz\\.(spawn|send|receive))\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.cursed",
                    "match": "(=|\\+=|-=|\\*=|/=|%=|:=)"
                },
                {
                    "name": "keyword.operator.comparison.cursed",
                    "match": "(==|!=|<|<=|>|>=)"
                },
                {
                    "name": "keyword.operator.logical.cursed",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.arithmetic.cursed",
                    "match": "(\\+|-|\\*|/|%|\\+\\+|--)"
                },
                {
                    "name": "keyword.operator.bitwise.cursed",
                    "match": "(&|\\||\\^|<<|>>)"
                },
                {
                    "name": "keyword.operator.channel.cursed",
                    "match": "(<-|->)"
                },
                {
                    "name": "keyword.operator.range.cursed",
                    "match": "\\.\\."
                },
                {
                    "name": "keyword.operator.type.cursed",
                    "match": "\\?"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator.cursed",
                    "match": "[,;]"
                },
                {
                    "name": "punctuation.section.cursed",
                    "match": "[{}\\[\\]()]"
                },
                {
                    "name": "punctuation.accessor.cursed",
                    "match": "\\."
                },
                {
                    "name": "punctuation.definition.type.cursed",
                    "match": ":"
                }
            ]
        }
    }
}
