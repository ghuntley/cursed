{
    "Function Definition": {
        "prefix": "slay",
        "body": [
            "slay ${1:function_name}(${2:params}) {",
            "\t$0",
            "}"
        ],
        "description": "Create a function definition"
    },
    "Variable Declaration": {
        "prefix": "sus",
        "body": [
            "sus ${1:name} ${2:type} = ${3:value}"
        ],
        "description": "Declare a variable"
    },
    "Print Statement": {
        "prefix": "spill",
        "body": [
            "vibez.spill(${1:\"message\"})"
        ],
        "description": "Print output"
    },
    "If Statement": {
        "prefix": "facts",
        "body": [
            "facts ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "If condition"
    },
    "Else Statement": {
        "prefix": "lowkey",
        "body": [
            "lowkey {",
            "\t$0",
            "}"
        ],
        "description": "Else clause"
    },
    "For Loop": {
        "prefix": "bestie",
        "body": [
            "bestie ${1:i} ${2:range} {",
            "\t$0",
            "}"
        ],
        "description": "For loop"
    },
    "While Loop": {
        "prefix": "stan",
        "body": [
            "stan ${1:condition} {",
            "\t$0",
            "}"
        ],
        "description": "While loop"
    },
    "Struct Definition": {
        "prefix": "squad",
        "body": [
            "squad ${1:Name} {",
            "\tspill ${2:field} ${3:type}",
            "\t$0",
            "}"
        ],
        "description": "Define a struct"
    },
    "Interface Definition": {
        "prefix": "collab",
        "body": [
            "collab ${1:Name} {",
            "\tslay ${2:method}(${3:params}) ${4:return_type}",
            "\t$0",
            "}"
        ],
        "description": "Define an interface"
    },
    "Return Statement": {
        "prefix": "damn",
        "body": [
            "damn ${1:value}"
        ],
        "description": "Return statement"
    },
    "Import Statement": {
        "prefix": "yeet",
        "body": [
            "yeet \"${1:module}\""
        ],
        "description": "Import a module"
    },
    "Main Function": {
        "prefix": "main",
        "body": [
            "slay main() {",
            "\t$0",
            "}"
        ],
        "description": "Main function entry point"
    }
}
