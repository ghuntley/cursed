{
    "name": "cursed-language-support",
    "displayName": "CURSED Language Support",
    "description": "Language support for CURSED programming language with Gen Z syntax",
    "version": "1.0.0",
    "publisher": "cursed-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/ghuntley/cursed"
    },
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets",
        "Formatters",
        "Linters"
    ],
    "keywords": [
        "cursed",
        "programming language",
        "gen z",
        "syntax highlighting",
        "language server"
    ],
    "activationEvents": [
        "onLanguage:cursed"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "cursed",
                "aliases": ["CURSED", "cursed"],
                "extensions": [".csd", ".cursed"],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/cursed-light.svg",
                    "dark": "./icons/cursed-dark.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "cursed",
                "scopeName": "source.cursed",
                "path": "./syntaxes/cursed.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "CURSED Language Configuration",
            "properties": {
                "cursed.lsp.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable CURSED Language Server Protocol support"
                },
                "cursed.lsp.serverPath": {
                    "type": "string",
                    "default": "cursed-lsp",
                    "description": "Path to the CURSED Language Server executable"
                },
                "cursed.formatting.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable automatic code formatting"
                },
                "cursed.diagnostics.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable real-time error checking and diagnostics"
                },
                "cursed.completion.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable intelligent code completion"
                },
                "cursed.hover.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable hover information and documentation"
                }
            }
        },
        "commands": [
            {
                "command": "cursed.compile",
                "title": "Compile CURSED File",
                "category": "CURSED"
            },
            {
                "command": "cursed.format",
                "title": "Format CURSED Code",
                "category": "CURSED"
            },
            {
                "command": "cursed.lint",
                "title": "Lint CURSED Code",
                "category": "CURSED"
            },
            {
                "command": "cursed.restart-lsp",
                "title": "Restart Language Server",
                "category": "CURSED"
            }
        ],
        "keybindings": [
            {
                "command": "cursed.compile",
                "key": "ctrl+shift+b",
                "when": "editorLangId == cursed"
            },
            {
                "command": "cursed.format",
                "key": "shift+alt+f",
                "when": "editorLangId == cursed"
            }
        ],
        "snippets": [
            {
                "language": "cursed",
                "path": "./snippets/cursed.json"
            }
        ],
        "themes": [
            {
                "label": "CURSED Gen Z Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/cursed-dark-theme.json"
            },
            {
                "label": "CURSED Gen Z Light",
                "uiTheme": "vs",
                "path": "./themes/cursed-light-theme.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.60.0",
        "@types/node": "14.x",
        "@typescript-eslint/eslint-plugin": "^4.26.0",
        "@typescript-eslint/parser": "^4.26.0",
        "eslint": "^7.27.0",
        "typescript": "^4.3.2",
        "vscode-test": "^1.5.2"
    },
    "dependencies": {
        "vscode-languageclient": "^7.0.0"
    }
}
