sus x drip = 10
lowkey x > 5 {
    vibez.spill("x is greater than 5")
}

sus y drip = 3
lowkey y > 5 {
    vibez.spill("y is greater than 5")
} highkey {
    vibez.spill("y is not greater than 5")
}

bestie i := 0; i < 3; i++ {
    vibez.spill("iteration")
}

sus counter drip = 0
periodt counter < 3 {
    vibez.spill("while loop")
    counter++
}
