yeet "regex"
yeet "vibez"

slay main_character() {
    vibez.spillln("=== Debug Regex Patterns ===")
    
    fr fr Test literal pattern
    sus result1 tea = regex.find("123", "abc123def")
    vibez.spillln("Literal '123' in 'abc123def':")
    vibez.spillln(result1)
    
    fr fr Test escaped digits pattern  
    sus result2 tea = regex.find("\\\\d+", "abc123def")
    vibez.spillln("Pattern '\\\\d+' in 'abc123def':")
    vibez.spillln(result2)
    
    fr fr Test backslash pattern
    sus result3 tea = regex.find("\\d+", "abc123def")
    vibez.spillln("Pattern '\\d+' in 'abc123def':")
    vibez.spillln(result3)
    
    vibez.spillln("=== Debug Complete ===")
}
