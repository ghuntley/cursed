// Test CURSED struct and interface parsing

// Define a struct (squad keyword)
squad Person {
    name: tea,
    age: normie,
    email: tea
}

// Define an interface (collab keyword)
collab Drawable {
    draw(): tea
    getArea(): normie
}

// Basic function using the struct
slay createPerson() {
    sus p = "Alice"
    yolo p
}

// Test basic functionality
slay main() {
    vibez.spill("Testing structs and interfaces")
    sus result = createPerson()
    vibez.spill(result)
}
