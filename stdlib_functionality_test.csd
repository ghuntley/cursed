yeet "mathz"
yeet "stringz"
yeet "vibez"

fr fr Test actual function functionality, not just module loading

vibez.spill("Testing actual mathz functions:")
sus abs_result drip = abs_normie(-42)
vibez.spill("abs_normie(-42) =", abs_result)

sus max_result drip = max_normie(5, 8)
vibez.spill("max_normie(5, 8) =", max_result)

vibez.spill("\nTesting actual stringz functions:")
sus test_str tea = "hello world"
sus str_len drip = len_str(test_str)
vibez.spill("len_str('hello world') =", str_len)

sus upper_str tea = to_upper(test_str)
vibez.spill("to_upper('hello world') =", upper_str)

vibez.spill("\nTesting direct stringz module functions:")
sus stringz_len drip = stringz.length(test_str)
vibez.spill("stringz.length('hello world') =", stringz_len)

sus stringz_upper tea = stringz.to_upper(test_str)
vibez.spill("stringz.to_upper('hello world') =", stringz_upper)

vibez.spill("\nFunctionality test complete")
