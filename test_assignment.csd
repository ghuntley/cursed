fr fr Test assignment statements
yeet "mathz"

sus x drip = 5
sus y drip = 10

fr fr Test simple assignment
x = 7
y = x + 3

vibez.spill("x is now:")
vibez.spill(x)
vibez.spill("y is now:")
vibez.spill(y)

fr fr Test increment-like assignment
sus i drip = 0
i = i + 1
vibez.spill("i after increment:")
vibez.spill(i)
