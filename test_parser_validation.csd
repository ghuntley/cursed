// Test CURSED grammar validation
vibe main

yeet (
    "fmt"
    tea "strings"
)

// Constants declaration
facts (
    PI = 3.14159
    MAX_SIZE = 100
)

// Variable declarations  
sus name tea = "World"
sus age, height = 25, 180.5

// Type alias
be_like Person squad {
    name tea
    age normie
}

// Function with return
slay add(x, y normie) normie {
    yolo x + y
}

// If statement with lowkey/highkey
slay main() {
    lowkey age > 18 {
        print("Adult")
    } highkey lowkey age < 13 {
        print("Child")
    } highkey {
        print("Teen")
    }
    
    // Switch statement with vibe_check/mood/basic
    vibe_check name {
        mood "Alice", "Bob":
            print("Known person")
        mood "Charlie":
            print("Another person")
        basic:
            print("Unknown person")
    }
    
    // For loop with bestie
    bestie i := 0; i < 10; i++ {
        print(i)
        lowkey i == 5 {
            ghosted  // break
        }
        lowkey i == 3 {
            simp     // continue
        }
    }
    
    // Range-based for with flex
    bestie _, val := flex [1, 2, 3, 4, 5] {
        print(val)
    }
    
    // While loop with periodt
    sus x = 10
    periodt x > 0 {
        x--
    }
    
    // Goroutine with stan
    stan doAsync()
    
    // Channel operations
    sus ch dm normie = make(dm normie)
    ch <- 42
    sus value = <-ch
    
    yolo 0
}

slay doAsync() {
    print("Async execution")
}
