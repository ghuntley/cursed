yeet "vibez"

slay risky_function() {
    yikes "Something went wrong!"
}

fam {
    risky_function()
    vibez.spill("This should not print")
} shook error {
    vibez.spill("Caught error:", error)
}

slay divide(a drip, b drip) drip {
    ready (b == 0) {
        yikes "Division by zero"
    }
    damn a / b
}

fam {
    sus result drip = divide(10, 0)
    vibez.spill("Result:", result)
} shook error {
    vibez.spill("Division error:", error)
}

vibez.spill("Error handling test completed")
