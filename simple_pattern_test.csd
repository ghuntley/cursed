// Simple pattern matching test
yeet "vibez"

slay test_basic_patterns() {
    sus x normie = 42
    
    // Basic switch without patterns first
    lowkey x == 42 {
        vibez.spill("x is 42")
    }
    
    // Test boolean switching
    sus flag lit = based
    
    lowkey flag == based {
        vibez.spill("flag is true")
    }
}

slay main() {
    test_basic_patterns()
}
