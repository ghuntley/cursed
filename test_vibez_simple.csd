fr fr Simple vibez test without references

vibe main

yeet "vibez"

slay test_basic_spill() lit {
    vibez.spill("Hello, World!")
    yolo based
}

slay test_basic_spillf() lit {
    vibez.spillf("Number: %d", 42)
    yolo based
}

slay main() {
    vibez.spill("Testing vibez.spill() functionality...")
    
    lowkey test_basic_spill() {
        vibez.spill("✅ Basic spill test passed")
    } highkey {
        vibez.spill("❌ Basic spill test failed")
    }
    
    lowkey test_basic_spillf() {
        vibez.spill("✅ Basic spillf test passed")
    } highkey {
        vibez.spill("❌ Basic spillf test failed")
    }
    
    vibez.spill("Vibez test complete!")
}
