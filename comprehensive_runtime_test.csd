// Comprehensive CURSED runtime test
// Testing basic language features that should work

// Variable declarations (sus)
sus x = 10;
sus y = 20;
sus z = x + y;

print("Variable assignment test:");
print("x =", x);
print("y =", y);  
print("z = x + y =", z);

// Function with parameters
slay add(a, b) {
    damn a + b;
}

sus result = add(15, 25);
print("Function call test:");
print("add(15, 25) =", result);

// String operations
sus name = "CURSED";
print("String test:");
print("Language name:", name);

// Boolean and comparison
sus flag = 5 > 3;
print("Boolean test:");
print("5 > 3 =", flag);
