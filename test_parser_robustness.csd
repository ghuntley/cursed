vibe main
yeet "vibez"

slay test_function() {
    // Test 1: Valid for loop
    bestie i := 0; i < 10; i++ {
        vibez.spill("valid")
    }
    
    // Test 2: Invalid for loop that previously caused infinite loop
    bestie x drip = 10 y := flex range {
        vibez.spill("invalid")
    }
    
    // Test 3: Another problematic pattern
    bestie a := b := c := d := e := f := g := h := i := j := k := l
    
    vibez.spill("done")
}

slay main_character() {
    test_function()
}
