fr fr Advanced AST features test

sus numbers []drip = [1, 2, 3, 4, 5]
sus text tea = "Hello, AST world!"
sus is_working lit = based

slay add_numbers(a drip, b drip) drip {
    damn a + b
}

vibez.spill("Testing advanced AST:")
