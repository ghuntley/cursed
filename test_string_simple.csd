yeet "string"

vibez.spill("Testing string operations:")
vibez.spill(string_length("hello"))
vibez.spill(string_concat("hello", " world"))
vibez.spill(string_to_upper("hello"))
vibez.spill(string_to_lower("HELLO"))
vibez.spill(string_contains("hello world", "world"))
vibez.spill("String library test complete!")
