yeet "mathz"
yeet "stringz"

# Test complex nested parentheses expressions that trigger the memory leak path
sus complex drip = ((5 + 3) * (2 + 1)) + ((10 - 2) / (4 - 2))
vibez.spill("Complex expression result:", complex)

# Test string operations that may cause leaks
sus str1 tea = "Hello " + "World"
sus str2 tea = str1 + " from CURSED"
vibez.spill("String result:", str2)

# Test function calls with complex expressions as arguments
slay add_all(a drip, b drip, c drip) drip {
    damn a + b + c
}

sus func_result drip = add_all((1 + 2), (3 * 4), (5 - 1))
vibez.spill("Function with complex args:", func_result)

# Test array operations
sus arr []drip = [1, 2, 3]
sus arr_sum drip = arr[0] + arr[1] + arr[2]
vibez.spill("Array sum:", arr_sum)
