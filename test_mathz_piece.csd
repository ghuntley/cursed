slay abs_normie(x drip) drip {
    ready (x < 0) {
        damn -x
    }
    damn x
}

slay power_int(base drip, exponent drip) drip {
    ready (exponent == 0) {
        damn 1
    }
    ready (exponent == 1) {
        damn base
    }
    sus result drip = base
    sus i drip = 1
    bestie (i < exponent) {
        result = result * base
        i = i + 1
    }
    damn result
}
