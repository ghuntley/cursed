vibe main
yeet "vibez"

slay main_character() {
    // Test integer division  
    sus result1 drip = 10 / 3
    vibez.spill("10 / 3 = ")
    vibez.spill(result1)
    
    sus result2 drip = 15 / 4  
    vibez.spill("15 / 4 = ")
    vibez.spill(result2)
    
    sus result3 drip = 7 / 2
    vibez.spill("7 / 2 = ")
    vibez.spill(result3)
    
    // Test float division
    sus result4 drip = 10.0 / 3.0
    vibez.spill("10.0 / 3.0 = ")
    vibez.spill(result4)
    
    sus result5 drip = 15.0 / 4.0
    vibez.spill("15.0 / 4.0 = ")
    vibez.spill(result5)
    
    // Test mixed division
    sus result6 drip = 10 / 3.0
    vibez.spill("10 / 3.0 = ")
    vibez.spill(result6)
    
    sus result7 drip = 10.0 / 3
    vibez.spill("10.0 / 3 = ")
    vibez.spill(result7)
}
