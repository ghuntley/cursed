yeet "memory"

vibez.spill("Testing bootstrap allocator via memory module...")

// Test basic allocation using the exported functions
sus ptr *byte = cursed_malloc(64)
if ptr != cringe {
    vibez.spill("Bootstrap allocation via memory module successful")
    cursed_free(ptr)
    vibez.spill("Bootstrap deallocation via memory module successful")
} else {
    vibez.spill("Bootstrap allocation failed")
}

vibez.spill("Bootstrap test via memory module completed")
