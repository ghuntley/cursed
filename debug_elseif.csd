vibe main
yeet "vibez"

slay main_character() {
    sus grade normie = 85
    
    ready (grade >= 90) {
        vibez.spill("Grade A")
    } otherwise ready (grade >= 80) {
        vibez.spill("Grade B")
    } otherwise ready (grade >= 70) {
        vibez.spill("Grade C")
    } otherwise {
        vibez.spill("Grade F")
    }
}
