vibe main
yeet "vibez"

slay factorial(n normie) normie {
    vibez.spill("factorial called with:", n)
    ready (n <= 1) {
        vibez.spill("base case reached")
        damn 1
    }
    vibez.spill("recursive case")
    damn n * factorial(n - 1)
}

slay main_character() {
    vibez.spill("Testing factorial with small number")
    sus result normie = factorial(3)
    vibez.spill("Result:", result)
}
