slay IsPrime(n normie) lit {
    lowkey n <= 1 {
        damn cap
    }
    lowkey n <= 3 {
        damn based
    }
    lowkey n % 2 == 0 || n % 3 == 0 {
        damn cap
    }
    
    bestie i := 5; (i * i) <= n; i = i + 6 {
        lowkey n % i == 0 || n % (i + 2) == 0 {
            damn cap
        }
    }
    
    damn based
}

vibez.spill("Prime function test:")
vibez.spill(IsPrime(7))
