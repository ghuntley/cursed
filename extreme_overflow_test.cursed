vibe main
yeet "vibez"

slay main_character() {
    vibez.spill("Testing extreme integer overflow...")
    
    // Test max i64 + 1 - should promote to float
    sus max_int drip = 9223372036854775807;  // Max i64
    sus one drip = 1;
    sus overflow_result drip = max_int + one;
    vibez.spill("Max i64 + 1 handled safely")
    
    // Test max i64 * 2 - should promote to float
    sus two drip = 2;
    sus mult_overflow drip = max_int * two;
    vibez.spill("Max i64 * 2 handled safely")
    
    // Test minimum i64 negation - should promote to float
    sus min_int drip = -9223372036854775808;  // Min i64
    sus negated drip = -min_int;
    vibez.spill("Min i64 negation handled safely")
    
    vibez.spill("Extreme overflow tests passed!")
}
