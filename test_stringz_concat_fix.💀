vibe main
yeet "vibez"
yeet "stringz"

slay main_character() {
    vibez.spill("Testing stringz.concat implementation:")
    
    sus base = "CURSED"
    vibez.spill("Base string:", base)
    vibez.spill("Base length:", stringz.length(base))
    
    sus concat1 = stringz.concat(base, base)
    vibez.spill("After 1st concat:", concat1)  
    vibez.spill("Length after 1st:", stringz.length(concat1))
    
    sus concat2 = stringz.concat(concat1, base)
    vibez.spill("After 2nd concat:", concat2)
    vibez.spill("Length after 2nd:", stringz.length(concat2))
    
    sus concat3 = stringz.concat(concat2, base) 
    vibez.spill("Final concat:", concat3)
    vibez.spill("Final length:", stringz.length(concat3))
    
    vibez.spill("Expected: CURSEDCURSEDCURSEDCURSED (24 chars)")
}
