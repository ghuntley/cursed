yeet "vibez"

slay add_numbers(a drip, b drip) drip {
    sus result drip = a + b
    damn result
}

slay main() {
    vibez.spill("Testing full parser integration...")
    
    sus x drip = 10
    sus y drip = 20
    sus sum drip = add_numbers(x, y)
    
    vibez.spill("x =", x, "y =", y, "sum =", sum)
    
    ready (sum > 25) {
        vibez.spill("Sum is greater than 25!")
    } otherwise {
        vibez.spill("Sum is not greater than 25")
    }
    
    sus i drip = 0
    bestie (i < 3) {
        vibez.spill("Loop iteration:", i)
        i = i + 1
    }
    
    vibez.spill("Full parser test completed successfully!")
}
