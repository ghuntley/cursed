yeet "vibez"

# Test basic vibez.spill functionality
vibez.spill("Hello from CURSED vibez module!")

# Test formatted output
vibez.spillf("Testing formatted output: %s %d", "number", 42)

# Test newline functions
vibez.spillln("This should end with a newline")

# Test error output
vibez.spill_error("This is a test error message")

# Test colored output
vibez.spill_colored("This should be red text", "red")
