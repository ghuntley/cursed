vibe main
yeet "vibez"

slay main_character() {
    sus a drip = 2
    sus b drip = 3
    sus c drip = 4
    sus d drip = 5
    
    vibez.spill("Debug expressions:")
    vibez.spill("a * b + c / d - (a - b) * (c + d)")
    vibez.spill(a * b + c / d - (a - b) * (c + d))
    
    vibez.spill("(a + b * c) / (d - a) + b * (c - d)")
    vibez.spill((a + b * c) / (d - a) + b * (c - d))
}
