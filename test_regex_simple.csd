yeet "regex"
yeet "vibez"

slay main_character() {
    vibez.spillln("=== Regex Module Test ===")
    
    sus pattern tea = "hello"
    sus text tea = "hello world"
    
    fr fr Test basic match
    sus match_result lit = regex.match(pattern, text)
    vibez.spillln("Match result:")
    vibez.spillln(match_result)
    
    fr fr Test find
    sus find_result tea = regex.find(pattern, text)
    vibez.spillln("Find result:")
    vibez.spillln(find_result)
    
    vibez.spillln("=== Regex Test Complete ===")
}
