sus test_char sip = runtime_string_char_at("hello", 0)
sus test_str tea = runtime_char_to_string(test_char)
vibez.spill("✅ runtime_string_char_at: " + runtime_char_to_string(test_char))
vibez.spill("✅ runtime_char_to_string: " + test_str)
