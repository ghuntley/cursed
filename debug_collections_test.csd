vibe main
yeet "collections"
yeet "vibez"

slay main_character() {
    vibez.spill("Testing collections.length function")
    sus test_arr normie[value] = {1, 2, 3, 4, 5}
    sus result normie = collections.length(test_arr)
    vibez.spill("Length result:")
    vibez.spill(result)
    
    vibez.spill("Testing collections.new_array function")
    sus new_arr normie[value] = collections.new_array()
    vibez.spill("New array created")
}
