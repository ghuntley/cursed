fr fr Advanced compilation test with functions
yeet "testz"

slay add_numbers(a drip, b drip) drip {
    damn a + b
}

slay main() {
    vibez.spill("Testing advanced compilation features")
    
    sus result drip = add_numbers(10, 32)
    vibez.spill("10 + 32 =")
    vibez.spill(result)
    
    sus flag lit = based
    sus name tea = "CURSED compiler"
    
    vibez.spill("Compiler name:")
    vibez.spill(name)
    
    vibez.spill("Flag value:")
    vibez.spill(flag)
}
