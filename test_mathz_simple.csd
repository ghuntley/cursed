fr fr Simple test to check mathz module loading

yeet "vibez"

slay main() {
    vibez.spill("Testing mathz module dependency...")
    
    fr fr Try to import mathz
    fr fr yeet "mathz"
    
    vibez.spill("Mathz import skipped - checking if testz works without it")
    
    fr fr Try to import testz directly  
    fr fr yeet "testz"
    
    vibez.spill("All imports skipped for now")
    vibez.spill("Basic array test without stdlib dependencies:")
    
    sus test_array [normie] = [1, 2, 3]
    vibez.spill("Array element 0:")
    vibez.spill(test_array[0])
    vibez.spill("Array element 1:")
    vibez.spill(test_array[1])
    vibez.spill("Array element 2:")
    vibez.spill(test_array[2])
}
