yeet "mathz"

vibez.spill("Testing basic mathz module functionality...")

# Test constants
vibez.spill("PI =", PI)
vibez.spill("E =", E)

# Test basic functions
sus abs_result meal = abs_meal(-5.5)
vibez.spill("abs_meal(-5.5) =", abs_result)

sus max_result meal = max_meal(3.0, 7.0)
vibez.spill("max_meal(3.0, 7.0) =", max_result)

sus sqrt_result meal = sqrt_meal(16.0)
vibez.spill("sqrt_meal(16.0) =", sqrt_result)

sus sin_result meal = sin_meal(0.0)
vibez.spill("sin_meal(0.0) =", sin_result)

sus power_result meal = pow_meal(2.0, 3)
vibez.spill("pow_meal(2.0, 3) =", power_result)

vibez.spill("✅ Basic mathz functionality test complete!")
