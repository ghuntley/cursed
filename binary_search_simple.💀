// Simple binary search that avoids parser issues
slay search(nums normie[], target normie) normie {
    sus low normie = 0
    sus high normie = len(nums) - 1

    bestie (low <= high) {
        sus mid normie = low + high / 2  // Simplified calculation

        ready (nums[mid] == target) {
            damn mid
        } nah ready (nums[mid] < target) {
            low = mid + 1
        } nah {
            high = mid - 1
        }
    }

    damn -1
}

