yeet "stringz"
yeet "mathz"

# Test function chaining and nested calls
slay process_text(s tea) drip {
    sus length drip = len_str(s)
    sus doubled drip = length * 2
    damn abs_normie(doubled)
}

sus result drip = process_text("test")
vibez.spill("Processed text result:", result)

# Test nested stdlib calls
slay complex_calc(x drip, y drip) drip {
    sus sum drip = x + y
    sus abs_sum drip = abs_normie(sum)
    damn abs_sum
}

sus final_result drip = complex_calc(-10, 3)
vibez.spill("Complex calc:", final_result)

# Test function chains
sus chain1 drip = abs_normie(-5)
sus chain2 drip = abs_normie(chain1 + 2)
vibez.spill("Chain result:", chain2)
