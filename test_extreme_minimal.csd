vibe main
yeet "vibez"
yeet "mathz"

slay test_simple() {
    vibez.spill("=== Simple Test ===")
    
    sus large1 = 999999
    sus large2 = 888888
    
    vibez.spill("Large1:", large1)
    vibez.spill("Large2:", large2)
    vibez.spill("Sum:", large1 + large2)
    
    sus temp_val = mathz.abs_normie(-25)
    sus squared = temp_val * temp_val
    vibez.spill("Squared:", squared)
}

slay main() {
    vibez.spill("=== Minimal Extreme Test ===")
    test_simple()
    vibez.spill("Test completed")
    damn
}
